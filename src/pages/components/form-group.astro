---
import DocsLayout from '../../layouts/DocsLayout.astro';
import FormGroup from '../../components/FormGroup.astro';

const usageSnippet = `---
import { FormGroup, Input } from 'comet-astro';

---
<FormGroup
  label="Email"
  description="We'll never share your address."
  helpText="Use a work account for faster verification."
  error="Please enter a valid email."
  required
  labelFor="email"
>
  <input id="email" type="email" class="input" placeholder="name@company.com" />
</FormGroup>`;
---

<DocsLayout
  seoTitle="FormGroup"
  seoDescription="WCAG AAA form wrapper with consistent spacing, labels, descriptions, help text, and error handling."
>
  <section class="space-y-4">
    <p class="text-base text-slate-100">
      FormGroup standardizes field spacing, label placement, help text, and error
      messaging across complex forms. It supports horizontal or vertical layouts,
      wraps inputs in a <code>fieldset</code> when needed, and retains WCAG AAA contrast.
    </p>
  </section>

  <section class="mt-8 space-y-6">
    <div class="rounded-2xl border border-slate-800/70 bg-slate-900/40 p-6 shadow-lg">
      <FormGroup
        label="Email"
        description="We'll never share your address."
        helpText="Use a work account for faster verification."
        error="Please enter a valid email."
        required
        labelFor="email"
      >
        <input
          id="email"
          type="email"
          class="w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-slate-100"
          placeholder="name@company.com"
        />
      </FormGroup>
    </div>
    <pre class="overflow-auto rounded-xl border border-slate-800/70 bg-slate-950/60 p-4 text-sm text-slate-200">
      <code>{usageSnippet}</code>
    </pre>
  </section>

  <section class="mt-8 space-y-4">
    <h2 class="text-xl font-semibold text-slate-100">Props</h2>
    <dl class="grid gap-4 sm:grid-cols-2">
      <div class="space-y-1 rounded-lg border border-slate-800/60 bg-slate-900/40 p-4">
        <dt class="text-sm font-semibold uppercase tracking-wide text-slate-300">label?</dt>
        <dd class="text-sm text-slate-200">Primary label text for the field.</dd>
      </div>
      <div class="space-y-1 rounded-lg border border-slate-800/60 bg-slate-900/40 p-4">
        <dt class="text-sm font-semibold uppercase tracking-wide text-slate-300">description?</dt>
        <dd class="text-sm text-slate-200">Optional helper text displayed under the label.</dd>
      </div>
      <div class="space-y-1 rounded-lg border border-slate-800/60 bg-slate-900/40 p-4">
        <dt class="text-sm font-semibold uppercase tracking-wide text-slate-300">error?</dt>
        <dd class="text-sm text-slate-200">Error message displayed with an alert role.</dd>
      </div>
      <div class="space-y-1 rounded-lg border border-slate-800/60 bg-slate-900/40 p-4">
        <dt class="text-sm font-semibold uppercase tracking-wide text-slate-300">layout?</dt>
        <dd class="text-sm text-slate-200">Choose <code>"vertical"</code> or <code>"horizontal"</code>.</dd>
      </div>
    </dl>
  </section>
</DocsLayout>
