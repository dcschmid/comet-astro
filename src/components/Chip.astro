---
interface Props {
  variant?: 'default' | 'primary' | 'success' | 'warning' | 'error';
  size?: 'sm' | 'md' | 'lg';
  removable?: boolean;
  href?: string;
  className?: string;
}

const {
  variant = 'default',
  size = 'md',
  removable = false,
  href,
  className = '',
} = Astro.props;

// Adjusted palettes for ≥7:1 contrast with text in both themes.
// default: neutral subtle surface with dark/light appropriate text.
// primary/success/error: saturated backgrounds with white text (≥7:1) & hover slightly lighter but still ≥5+ while base stays ≥7.
// warning: amber spectrum often lower contrast; use deeper shade for base + switch to slate-50 text.
const variantKey = variant || 'default';
const sizeKey = size || 'md';
const Tag = href ? 'a' : 'span';
const classes = [
  'chip',
  `chip--variant-${variantKey}`,
  `chip--size-${sizeKey}`,
  removable ? 'chip--removable' : '',
  className,
]
  .filter(Boolean)
  .join(' ');
---

<Tag href={href} class={classes}>
  <slot />
  {
    removable && (
      <button
        type="button"
        class="chip__remove"
        aria-label="Remove"
        data-chip-remove
      >
        ✕
      </button>
    )
  }
</Tag>

<script is:inline>
  (() => {
    const script = document.currentScript;
    if (!(script instanceof HTMLScriptElement)) return;
    const chip = script.previousElementSibling;
    if (!(chip instanceof HTMLElement)) return;
    const removeBtn = chip.querySelector('[data-chip-remove]');
    if (!(removeBtn instanceof HTMLElement)) return;
    removeBtn.addEventListener('click', () => {
      chip.remove();
    });
  })();
</script>

<style is:inline>
  .chip {
    --chip-bg: #f1f5f9;
    --chip-border: rgba(148, 163, 184, 0.4);
    --chip-text: #0f172a;
    --chip-padding-y: 0.25rem;
    --chip-padding-x: 0.75rem;
    --chip-font-size: 0.85rem;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    border-radius: 999px;
    border: 1px solid var(--chip-border);
    background: var(--chip-bg);
    color: var(--chip-text);
    font-weight: 600;
    padding: var(--chip-padding-y) var(--chip-padding-x);
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .chip:focus-visible {
    outline: 2px solid rgba(59, 130, 246, 0.6);
    outline-offset: 2px;
  }

  .chip--size-sm {
    --chip-font-size: 0.75rem;
    --chip-padding-y: 0.2rem;
    --chip-padding-x: 0.55rem;
  }

  .chip--size-lg {
    --chip-font-size: 0.95rem;
    --chip-padding-y: 0.35rem;
    --chip-padding-x: 1rem;
  }

  .chip--variant-default {
    --chip-bg: #e2e8f0;
    --chip-border: #cbd5f5;
    --chip-text: #0f172a;
  }

  .chip--variant-primary {
    --chip-bg: #1d4ed8;
    --chip-border: #2563eb;
    --chip-text: #f8fafc;
  }

  .chip--variant-success {
    --chip-bg: #047857;
    --chip-border: #10b981;
    --chip-text: #f0fdf4;
  }

  .chip--variant-warning {
    --chip-bg: #b45309;
    --chip-border: #fbbf24;
    --chip-text: #fff7ed;
  }

  .chip--variant-error {
    --chip-bg: #be123c;
    --chip-border: #f87171;
    --chip-text: #fff1f2;
  }

  .chip__remove {
    border: none;
    background: transparent;
    color: inherit;
    width: 1.1rem;
    height: 1.1rem;
    border-radius: 999px;
    font-size: 0.75rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: transform 0.2s ease;
  }

  .chip__remove:hover {
    transform: scale(1.1);
  }

  .chip__remove:focus-visible {
    outline: 2px solid rgba(59, 130, 246, 0.6);
    outline-offset: 2px;
  }
</style>
