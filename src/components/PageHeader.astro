---
interface Props {
  // Content props
  title: string;
  subtitle?: string;
  eyebrow?: string;

  // Visual variants
  variant?: 'default' | 'centered' | 'minimal' | 'hero';
  size?: 'sm' | 'md' | 'lg' | 'xl';

  // Layout props
  alignment?: 'left' | 'center' | 'right';
  background?: 'none' | 'subtle' | 'pattern';

  // Accessibility props
  titleLevel?: 1 | 2 | 3 | 4 | 5 | 6;
  role?: string;
  ariaLabel?: string;
  ariaDescribedBy?: string;

  // Styling
  class?: string;
}

const {
  title,
  subtitle,
  eyebrow,
  variant = 'default',
  size = 'md',
  alignment = 'left',
  background = 'none',
  titleLevel = 1,
  role,
  ariaLabel,
  ariaDescribedBy,
  class: className,
} = Astro.props as Props;

// Generate unique IDs for ARIA relationships
const headerId = `page-header-${Math.random().toString(36).substr(2, 9)}`;
const subtitleId = subtitle
  ? `subtitle-${Math.random().toString(36).substr(2, 9)}`
  : undefined;

// Dynamic title tag
const rootClasses = [
  'page-header',
  `page-header--variant-${variant}`,
  `page-header--size-${size}`,
  `page-header--alignment-${alignment}`,
  `page-header--background-${background}`,
  className,
]
  .filter(Boolean)
  .join(' ');

const WrapperTag = (`h${titleLevel}`) as keyof HTMLElementTagNameMap;

const contentClasses = [
  'page-header__content',
  variant === 'centered' || variant === 'hero' || alignment === 'center'
    ? 'page-header__content--narrow'
    : '',
]
  .filter(Boolean)
  .join(' ');
---

<header
  class={rootClasses}
  role={role}
  aria-label={ariaLabel}
  aria-describedby={ariaDescribedBy || subtitleId}
>
  <div class={contentClasses}>
    {eyebrow && <div class="page-header__eyebrow">{eyebrow}</div>}

    {
      title && (
        <WrapperTag id={headerId} class="page-header__title">
          {title}
        </WrapperTag>
      )
    }

    {
      subtitle && (
        <p id={subtitleId} class="page-header__subtitle">
          {subtitle}
        </p>
      )
    }

    {
      Astro.slots.has('default') && (
        <div class="page-header__actions">
          <slot />
        </div>
      )
    }
  </div>
</header>

<style>
  .page-header {
    width: 100%;
    padding: 2rem 1rem;
  }

  .page-header--variant-centered,
  .page-header--variant-hero {
    text-align: center;
  }

  .page-header--variant-hero {
    padding-block: 4rem;
  }

  .page-header--variant-minimal {
    padding-block: 1.5rem;
  }

  .page-header--alignment-center {
    text-align: center;
  }

  .page-header--alignment-right {
    text-align: right;
  }

  .page-header--background-subtle {
    background-color: rgba(248, 250, 252, 0.6);
  }

  .page-header--background-pattern {
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, #f8fafc 0%, #ffffff 100%);
  }

  .page-header--background-pattern::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(
      rgba(148, 163, 184, 0.25) 1px,
      transparent 0
    );
    background-size: 20px 20px;
    opacity: 0.4;
    pointer-events: none;
  }

  .page-header__content {
    max-width: 80rem;
    margin: 0 auto;
    padding-inline: 1rem;
  }

  .page-header__content--narrow {
    max-width: 48rem;
  }

  .page-header__eyebrow {
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #2563eb;
    margin-bottom: 0.75rem;
  }

  .page-header__title {
    margin: 0;
    font-weight: 700;
    color: #0f172a;
    line-height: 1.1;
  }

  .page-header--size-sm .page-header__title {
    font-size: clamp(1.75rem, 3vw, 2.25rem);
  }

  .page-header--size-md .page-header__title {
    font-size: clamp(2.25rem, 4vw, 3rem);
  }

  .page-header--size-lg .page-header__title {
    font-size: clamp(2.75rem, 5vw, 4rem);
  }

  .page-header--size-xl .page-header__title {
    font-size: clamp(3.25rem, 6vw, 4.5rem);
  }

  .page-header__subtitle {
    margin-top: 1rem;
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: #475569;
    line-height: 1.6;
  }

  .page-header__actions {
    margin-top: 1.5rem;
    display: flex;
    gap: 0.75rem;
  }

  .page-header--alignment-center .page-header__actions {
    justify-content: center;
  }

  .page-header--alignment-right .page-header__actions {
    justify-content: flex-end;
  }

  :where(.dark) .page-header {
    color: #f8fafc;
  }

  :where(.dark) .page-header__title {
    color: #f8fafc;
  }

  :where(.dark) .page-header__subtitle {
    color: #cbd5f5;
  }
</style>
