---
/**
 * InfiniteScroll - WCAG AAA compliant utility wrapper for progressively loading content
 */
interface Props {
  eventName?: string;
  threshold?: number;
  rootMargin?: string;
  disabled?: boolean;
  loading?: boolean;
  loaderText?: string;
  loadingVariant?: 'pulse' | 'spinner' | 'dots';
  size?: 'sm' | 'md' | 'lg';
  announceContent?: boolean;
  announceText?: string;
  errorText?: string;
  retryText?: string;
  className?: string;
}

const {
  eventName = 'infinite-scroll:load',
  threshold = 0.25,
  rootMargin = '0px 0px 120px 0px',
  disabled = false,
  loading = false,
  loaderText = 'Loading more content…',
  loadingVariant = 'pulse',
  size = 'md',
  announceContent = true,
  announceText = 'New content loaded',
  errorText = 'Failed to load content',
  retryText = 'Retry',
  className = '',
} = Astro.props as Props;

// Enhanced size classes with responsive design
const sizeClasses = {
  sm: 'infinite-scroll--size-sm',
  md: 'infinite-scroll--size-md',
  lg: 'infinite-scroll--size-lg',
} as const;

const rootClasses = ['infinite-scroll', sizeClasses[size], className]
  .filter(Boolean)
  .join(' ');

const id = `infinite-scroll-${Math.random().toString(36).slice(2, 10)}`;
---

<div
  id={id}
  data-infinite-scroll
  data-event={eventName}
  data-threshold={threshold}
  data-margin={rootMargin}
  data-disabled={disabled}
  data-announce-content={announceContent}
  data-announce-text={announceText}
  data-error-text={errorText}
  data-retry-text={retryText}
  class={rootClasses}
  role="feed"
  aria-label="Content feed with infinite scroll"
>
  <div data-infinite-content>
    <slot />
  </div>

  <!-- Loading State -->
  <div
    class="infinite-scroll__loader"
    data-infinite-loader
    hidden={!loading}
    role="status"
    aria-live="polite"
    aria-label="Loading more content"
  >
    <span class="infinite-scroll__loader-content">
      {
        loadingVariant === 'spinner' ? (
          <svg
            class="infinite-scroll__spinner"
            viewBox="0 0 24 24"
            fill="none"
            aria-hidden="true"
          >
            <circle
              cx="12"
              cy="12"
              r="10"
              stroke="currentColor"
              stroke-width="4"
              stroke-dasharray="31.416"
              stroke-dashoffset="31.416"
              class="opacity-25"
            />
            <path
              fill="currentColor"
              d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
            />
          </svg>
        ) : loadingVariant === 'dots' ? (
          <div class="infinite-scroll__dots" aria-hidden="true">
            <span
              class="infinite-scroll__dot"
              style="animation-delay: 0ms"
            />
            <span
              class="infinite-scroll__dot"
              style="animation-delay: 150ms"
            />
            <span
              class="infinite-scroll__dot"
              style="animation-delay: 300ms"
            />
          </div>
        ) : (
          <span class="infinite-scroll__pulse" aria-hidden="true" />
        )
      }
      <span>{loaderText}</span>
    </span>
  </div>

  <!-- Error State -->
  <div
    class="infinite-scroll__error"
    data-infinite-error
    hidden
    role="alert"
    aria-live="assertive"
  >
    <div class="infinite-scroll__error-text">
      {errorText}
    </div>
    <button
      type="button"
      data-infinite-retry
      class="infinite-scroll__retry"
      aria-label="Retry loading content"
    >
      {retryText}
    </button>
  </div>

  <!-- Announcement region for screen readers -->
  {
    announceContent && (
      <div
        class="sr-only"
        data-infinite-announcer
        aria-live="polite"
        aria-atomic="true"
      />
    )
  }

  <!-- Intersection sentinel -->
  <div
    aria-hidden="true"
    data-infinite-sentinel
    class="infinite-scroll__sentinel"
  >
  </div>
</div>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    // Setup für alle InfiniteScroll-Komponenten auf der Seite
    const allRoots = document.querySelectorAll('[data-infinite-scroll]');

    allRoots.forEach(function (root) {
      if (!(root instanceof HTMLElement)) return;

      // Verhindere mehrfache Initialisierung
      if (root.dataset.infiniteInitialized === 'true') return;
      root.dataset.infiniteInitialized = 'true';

      const sentinel = root.querySelector('[data-infinite-sentinel]');
      if (!(sentinel instanceof HTMLElement)) return;

      const loader = root.querySelector('[data-infinite-loader]');
      const errorElement = root.querySelector('[data-infinite-error]');
      const retryButton = root.querySelector('[data-infinite-retry]');
      const announcer = root.querySelector('[data-infinite-announcer]');

      const eventName = root.dataset.event || 'infinite-scroll:load';
      const announceContent = root.dataset.announceContent === 'true';
      const announceText = root.dataset.announceText || 'New content loaded';
      const errorText = root.dataset.errorText || 'Failed to load content';

      let disabled = root.dataset.disabled === 'true';
      let isLoading = false;
      let hasError = false;

      const threshold =
        Number.parseFloat(root.dataset.threshold || '0.25') || 0.25;
      const rootMargin = root.dataset.margin || '0px';

      console.log(
        '🔧 InfiniteScroll setup for:',
        root.id,
        'threshold:',
        threshold,
        'margin:',
        rootMargin
      );

      // Enhanced state management
      const setState = function (state) {
        isLoading = state.loading || false;
        hasError = state.error || false;

        // Update loader
        if (loader instanceof HTMLElement) {
          loader.hidden = !isLoading;
          loader.setAttribute('aria-hidden', isLoading ? 'false' : 'true');
        }

        // Update error state
        if (errorElement instanceof HTMLElement) {
          errorElement.hidden = !hasError;
          errorElement.setAttribute('aria-hidden', hasError ? 'false' : 'true');
        }

        // Update busy state
        root.setAttribute('aria-busy', isLoading ? 'true' : 'false');

        // Announce content loading
        if (
          announceContent &&
          announcer instanceof HTMLElement &&
          state.announce
        ) {
          announcer.textContent = state.announce;
          // Clear after announcement
          setTimeout(function () {
            if (announcer instanceof HTMLElement) {
              announcer.textContent = '';
            }
          }, 1000);
        }
      };

      const observer = new IntersectionObserver(
        function (entries) {
          if (disabled || isLoading || hasError) return;
          const entry = entries.find(function (item) {
            return item.isIntersecting;
          });
          if (!entry) return;

          console.log('🚀 InfiniteScroll intersection detected for:', root.id);

          const detail = {
            pause: function () {
              disabled = true;
            },
            resume: function () {
              disabled = false;
              hasError = false;
              setState({ loading: false, error: false });
            },
            loading: function (state) {
              setState({
                loading: state,
                error: false,
                announce: state ? 'Loading more content' : announceText,
              });
            },
            error: function (message) {
              setState({
                loading: false,
                error: true,
                announce: message || errorText,
              });
            },
            done: function () {
              disabled = true;
              observer.disconnect();
              setState({
                loading: false,
                error: false,
                announce: 'All content loaded',
              });
            },
          };

          const customEvent = new CustomEvent(eventName, {
            bubbles: true,
            detail: detail,
          });
          console.log('📤 Dispatching event:', eventName, 'on:', root.id);
          root.dispatchEvent(customEvent);
        },
        { threshold: threshold, rootMargin: rootMargin }
      );

      observer.observe(sentinel);

      // Retry functionality
      if (retryButton instanceof HTMLElement) {
        retryButton.addEventListener('click', function () {
          hasError = false;
          disabled = false;
          setState({ loading: false, error: false });
          // Re-trigger intersection if still visible
          observer.unobserve(sentinel);
          observer.observe(sentinel);
        });
      }

      // External event listeners
      root.addEventListener('infinite-scroll:disable', function () {
        disabled = true;
        setState({ loading: false, error: false });
      });

      root.addEventListener('infinite-scroll:enable', function () {
        disabled = false;
        hasError = false;
        setState({ loading: false, error: false });
      });

      root.addEventListener('infinite-scroll:destroy', function () {
        observer.disconnect();
        setState({ loading: false, error: false });
      });

      // Initialize state
      if (loader instanceof HTMLElement && !loader.hidden) {
        setState({ loading: true, error: false });
      } else {
        setState({ loading: false, error: false });
      }

      console.log('✅ InfiniteScroll initialized for:', root.id);
    });
  });
</script>

<style is:inline>
  .infinite-scroll {
    position: relative;
    display: block;
    width: 100%;
    color: #1f2937;
  }

  .infinite-scroll__loader,
  .infinite-scroll__error {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.5rem 1rem;
    font-size: 0.95rem;
    color: #475569;
  }

  .infinite-scroll--size-sm .infinite-scroll__loader,
  .infinite-scroll--size-sm .infinite-scroll__error {
    padding: 0.75rem 1rem;
    font-size: 0.85rem;
  }

  .infinite-scroll--size-lg .infinite-scroll__loader,
  .infinite-scroll--size-lg .infinite-scroll__error {
    padding: 2rem 1rem;
    font-size: 1rem;
  }

  .infinite-scroll__loader-content {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-weight: 600;
    color: inherit;
  }

  .infinite-scroll--size-sm .infinite-scroll__loader-content {
    gap: 0.5rem;
  }

  .infinite-scroll--size-lg .infinite-scroll__loader-content {
    gap: 1rem;
  }

  .infinite-scroll__spinner {
    width: 1rem;
    height: 1rem;
    color: #1d4ed8;
    animation: infinite-scroll-spin 1s linear infinite;
  }

  .infinite-scroll--size-sm .infinite-scroll__spinner {
    width: 0.75rem;
    height: 0.75rem;
  }

  .infinite-scroll--size-lg .infinite-scroll__spinner {
    width: 1.25rem;
    height: 1.25rem;
  }

  .infinite-scroll__dots {
    display: flex;
    gap: 0.4rem;
  }

  .infinite-scroll--size-sm .infinite-scroll__dots {
    gap: 0.3rem;
  }

  .infinite-scroll--size-lg .infinite-scroll__dots {
    gap: 0.5rem;
  }

  .infinite-scroll__dot,
  .infinite-scroll__pulse {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 999px;
    background-color: #1d4ed8;
    animation: infinite-scroll-pulse 1s ease-in-out infinite;
    opacity: 0.75;
  }

  .infinite-scroll__dot:nth-child(2) {
    animation-delay: 0.15s;
  }

  .infinite-scroll__dot:nth-child(3) {
    animation-delay: 0.3s;
  }

  .infinite-scroll--size-sm .infinite-scroll__dot,
  .infinite-scroll--size-sm .infinite-scroll__pulse {
    width: 0.35rem;
    height: 0.35rem;
  }

  .infinite-scroll--size-lg .infinite-scroll__dot,
  .infinite-scroll--size-lg .infinite-scroll__pulse {
    width: 0.65rem;
    height: 0.65rem;
  }

  .infinite-scroll__pulse {
    animation-duration: 0.9s;
  }

  .infinite-scroll__error-text {
    color: #b91c1c;
    font-weight: 600;
  }

  .infinite-scroll__retry {
    color: #1d4ed8;
    font-weight: 600;
    border: none;
    background: transparent;
    cursor: pointer;
    padding: 0.25rem 0.75rem;
    border-radius: 0.25rem;
    transition: color 0.2s ease;
  }

  .infinite-scroll__retry:hover {
    color: #1e40af;
    text-decoration: underline;
  }

  .infinite-scroll__retry:focus-visible {
    outline: 2px solid #2563eb;
    outline-offset: 2px;
  }

  .infinite-scroll__sentinel {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 0.25rem;
  }

  @keyframes infinite-scroll-spin {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  @keyframes infinite-scroll-pulse {
    0%,
    100% {
      opacity: 0.3;
      transform: scale(0.8);
    }
    50% {
      opacity: 0.8;
      transform: scale(1);
    }
  }

  :where(.dark) .infinite-scroll__loader,
  :where(.dark) .infinite-scroll__error {
    color: #cbd5f5;
  }

  :where(.dark) .infinite-scroll__dot,
  :where(.dark) .infinite-scroll__pulse,
  :where(.dark) .infinite-scroll__spinner {
    color: #60a5fa;
    background-color: #60a5fa;
  }

  :where(.dark) .infinite-scroll__error-text {
    color: #f87171;
  }

  :where(.dark) .infinite-scroll__retry {
    color: #93c5fd;
  }

  :where(.dark) .infinite-scroll__retry:hover {
    color: #bfdbfe;
  }

  :where(.dark) .infinite-scroll__retry:focus-visible {
    outline-color: #93c5fd;
  }
</style>
