---
interface Props {
  variant?: 'default' | 'minimal' | 'bordered' | 'filled';
  size?: 'sm' | 'md' | 'lg';
  orientation?: 'horizontal' | 'vertical';
  showLabels?: boolean;
  className?: string;
  ariaLabel?: string;
}

const {
  variant = 'default',
  size = 'md',
  orientation = 'horizontal',
  showLabels = true,
  className = '',
  ariaLabel = 'Theme selection',
} = Astro.props as Props;

const modes = [
  { value: 'light', label: 'Light', icon: '☀️', description: 'Use light theme' },
  { value: 'dark', label: 'Dark', icon: '🌙', description: 'Use dark theme' },
  { value: 'system', label: 'Auto', icon: '🖥️', description: 'Use system theme preference' },
];

const toggleId = `theme-toggle-${Math.random().toString(36).slice(2, 9)}`;

const rootClasses = [
  'theme-toggle',
  `theme-toggle--variant-${variant}`,
  `theme-toggle--size-${size}`,
  `theme-toggle--orientation-${orientation}`,
  showLabels ? 'theme-toggle--with-labels' : 'theme-toggle--icon-only',
  className,
]
  .filter(Boolean)
  .join(' ');
---

<div
  id={toggleId}
  class={rootClasses}
  role="radiogroup"
  aria-label={ariaLabel}
  aria-orientation={orientation}
  data-theme-toggle
>
  {modes.map((mode, index) => (
    <button
      type="button"
      class={[
        'theme-toggle__option',
        showLabels ? 'theme-toggle__option--labeled' : '',
      ]
        .filter(Boolean)
        .join(' ')}
      data-theme-option={mode.value}
      role="radio"
      aria-checked="false"
      aria-describedby={showLabels ? undefined : `${toggleId}-desc-${index}`}
      tabindex="-1"
      title={mode.description}
    >
      <span
        class={[
          'theme-toggle__icon',
          !showLabels ? 'theme-toggle__icon--sr-only' : '',
        ]
          .filter(Boolean)
          .join(' ')}
        aria-hidden={showLabels ? 'true' : 'false'}
        role={showLabels ? undefined : 'img'}
        aria-label={showLabels ? undefined : mode.label}
      >
        {mode.icon}
      </span>
      {showLabels && <span class="theme-toggle__label">{mode.label}</span>}
    </button>
  ))}
</div>

{!showLabels &&
  modes.map((mode, index) => (
    <span id={`${toggleId}-desc-${index}`} class="sr-only">
      {mode.description}
    </span>
  ))}

<div
  id={`${toggleId}-status`}
  class="theme-toggle__status sr-only"
  aria-live="polite"
  aria-atomic="true"
>
  Theme changed
</div>

<script is:inline define:vars={{ toggleId }}>
  (function () {
    const root = document.getElementById(toggleId);
    if (!root) return;

    const buttons = Array.from(
      root.querySelectorAll('.theme-toggle__option')
    ).filter((el) => el instanceof HTMLElement);
    if (!buttons.length) return;

    const statusEl = document.querySelector(`#${toggleId}-status`);
    const controller = window.__cometTheme;
    const media = window.matchMedia('(prefers-color-scheme: dark)');

    const applyState = (mode) => {
      buttons.forEach((button) => {
        const isActive = button.dataset.themeOption === mode;
        button.setAttribute('aria-checked', String(isActive));
        button.tabIndex = isActive ? 0 : -1;
        button.classList.toggle('theme-toggle__option--active', isActive);
      });

      if (statusEl) {
        const label =
          buttons.find((btn) => btn.dataset.themeOption === mode)?.textContent?.trim() ||
          mode;
        statusEl.textContent = `Theme changed to ${label}`;
      }
    };

    const resolveMode = () => {
      if (controller && typeof controller.getMode === 'function') {
        return controller.getMode();
      }
      try {
        const stored = localStorage.getItem('comet-theme');
        if (stored === 'light' || stored === 'dark' || stored === 'system') {
          return stored;
        }
      } catch {
        /* ignore */
      }
      return 'system';
    };

    let currentMode = resolveMode();
    applyState(currentMode);

    const setMode = (mode) => {
      if (controller && typeof controller.setMode === 'function') {
        controller.setMode(mode);
      } else {
        try {
          if (mode === 'system') {
            localStorage.removeItem('comet-theme');
          } else {
            localStorage.setItem('comet-theme', mode);
          }
        } catch {
          /* ignore persistence errors */
        }
        const resolved =
          mode === 'system' ? (media.matches ? 'dark' : 'light') : mode;
        document.documentElement.classList.toggle('dark', resolved === 'dark');
        document.documentElement.dataset.themeMode = mode;
        document.documentElement.dataset.themeResolved = resolved;
      }
      currentMode = mode;
      applyState(mode);
    };

    const handleKeyDown = (event) => {
      const enabled = buttons.filter((btn) => !btn.disabled);
      const currentIndex = enabled.findIndex((btn) => document.activeElement === btn);
      if (currentIndex === -1) return;
      let nextIndex = currentIndex;

      switch (event.key) {
        case 'ArrowRight':
        case 'ArrowDown':
          event.preventDefault();
          nextIndex = (currentIndex + 1) % enabled.length;
          break;
        case 'ArrowLeft':
        case 'ArrowUp':
          event.preventDefault();
          nextIndex = (currentIndex - 1 + enabled.length) % enabled.length;
          break;
        case 'Home':
          event.preventDefault();
          nextIndex = 0;
          break;
        case 'End':
          event.preventDefault();
          nextIndex = enabled.length - 1;
          break;
        case 'Enter':
        case ' ':
          event.preventDefault();
          if (enabled[currentIndex]?.dataset.themeOption) {
            const option = enabled[currentIndex].dataset.themeOption;
            if (option && option !== currentMode) setMode(option);
          }
          return;
        default:
          return;
      }

      enabled[nextIndex]?.focus();
    };

    root.addEventListener('click', (event) => {
      const target =
        event.target instanceof HTMLElement
          ? event.target.closest('.theme-toggle__option')
          : null;
      if (!(target instanceof HTMLElement)) return;
      const option = target.dataset.themeOption;
      if (!option || option === currentMode) return;
      event.preventDefault();
      setMode(option);
    });

    root.addEventListener('keydown', handleKeyDown);

    const mediaListener = () => {
      if (currentMode === 'system') {
        applyState('system');
      }
    };
    media.addEventListener('change', mediaListener);

    let unsubscribe = null;
    if (controller && typeof controller.subscribe === 'function') {
      const result = controller.subscribe((mode) => {
        currentMode = mode;
        applyState(mode);
      });
      if (typeof result === 'function') {
        unsubscribe = result;
      } else if (result && typeof result.unsubscribe === 'function') {
        unsubscribe = () => result.unsubscribe();
      }
    }

    const activeButton = buttons.find(
      (btn) => btn.dataset.themeOption === currentMode
    );
    if (activeButton) {
      activeButton.tabIndex = 0;
    } else if (buttons[0]) {
      buttons[0].tabIndex = 0;
    }

    window.addEventListener('beforeunload', () => {
      media.removeEventListener('change', mediaListener);
      if (typeof unsubscribe === 'function') {
        unsubscribe();
      }
    });
  })();
</script>

<style>
  .theme-toggle {
    --toggle-gap: 0.4rem;
    --toggle-padding: 0.4rem;
    --toggle-font-size: 0.95rem;
    --toggle-icon-size: 1rem;
    --toggle-option-padding: 0.5rem 0.75rem;
    --toggle-border: rgba(148, 163, 184, 0.8);
    --toggle-bg: rgba(255, 255, 255, 0.9);
    --toggle-text: #0f172a;
    --toggle-muted: #64748b;
    display: inline-flex;
    gap: var(--toggle-gap);
    padding: var(--toggle-padding);
    border-radius: 999px;
    border: 1px solid var(--toggle-border);
    background: var(--toggle-bg);
    color: var(--toggle-text);
    font-size: var(--toggle-font-size);
    box-shadow: 0 10px 25px rgba(15, 23, 42, 0.08);
  }

  :where(.dark) .theme-toggle {
    --toggle-border: rgba(71, 85, 105, 0.8);
    --toggle-bg: rgba(2, 6, 23, 0.9);
    --toggle-text: #f8fafc;
    --toggle-muted: #94a3b8;
  }

  .theme-toggle--orientation-horizontal {
    flex-direction: row;
  }

  .theme-toggle--orientation-vertical {
    flex-direction: column;
  }

  .theme-toggle--size-sm {
    --toggle-gap: 0.25rem;
    --toggle-padding: 0.3rem;
    --toggle-font-size: 0.8rem;
    --toggle-icon-size: 0.8rem;
    --toggle-option-padding: 0.4rem 0.5rem;
  }

  .theme-toggle--size-lg {
    --toggle-gap: 0.5rem;
    --toggle-padding: 0.5rem;
    --toggle-font-size: 1rem;
    --toggle-icon-size: 1.25rem;
    --toggle-option-padding: 0.6rem 1rem;
  }

  .theme-toggle--variant-minimal {
    border-color: transparent;
    background: transparent;
    box-shadow: none;
  }

  .theme-toggle--variant-bordered {
    border-width: 2px;
  }

  .theme-toggle--variant-filled {
    background: rgba(226, 232, 240, 0.6);
  }

  :where(.dark) .theme-toggle--variant-filled {
    background: rgba(30, 41, 59, 0.8);
  }

  .theme-toggle__option {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    padding: var(--toggle-option-padding);
    border-radius: 999px;
    border: none;
    background: transparent;
    color: inherit;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease, box-shadow 0.2s ease;
    min-width: 3rem;
  }

  .theme-toggle__option:hover {
    background: rgba(59, 130, 246, 0.08);
  }

  .theme-toggle__option:focus-visible {
    outline: 2px solid rgba(59, 130, 246, 0.4);
    outline-offset: 2px;
  }

  .theme-toggle__option--active {
    background: rgba(59, 130, 246, 0.9);
    color: #fff;
    box-shadow: 0 8px 20px rgba(37, 99, 235, 0.35);
  }

  :where(.dark) .theme-toggle__option--active {
    color: #0f172a;
  }

  .theme-toggle--variant-minimal .theme-toggle__option {
    border-radius: 0.9rem;
  }

  .theme-toggle--variant-minimal .theme-toggle__option--active {
    background: rgba(37, 99, 235, 0.15);
    color: var(--toggle-text);
  }

  .theme-toggle--variant-bordered .theme-toggle__option {
    border: 1px solid var(--toggle-border);
    background: rgba(255, 255, 255, 0.95);
  }

  :where(.dark) .theme-toggle--variant-bordered .theme-toggle__option {
    background: rgba(2, 6, 23, 0.95);
  }

  .theme-toggle__icon {
    font-size: var(--toggle-icon-size);
    line-height: 1;
  }

  .theme-toggle__icon--sr-only {
    font-size: inherit;
  }

  .theme-toggle__label {
    font-weight: 600;
  }

  .theme-toggle__status {
    font-size: 0;
    height: 0;
  }

  @media (prefers-contrast: high) {
    .theme-toggle {
      border-color: currentColor;
    }
    .theme-toggle__option {
      border: 1px solid currentColor;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .theme-toggle * {
      transition: none !important;
    }
  }
</style>
