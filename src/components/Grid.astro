---
/**
 * Grid - WCAG AAA compliant responsive grid layout component
 * Enhanced with semantic HTML options, accessibility features, and comprehensive responsive design
 */
interface Props {
  /** Number of columns or auto-fit behavior */
  cols?: 1 | 2 | 3 | 4 | 5 | 6 | 'auto';
  /** Spacing between grid items */
  gap?: 'none' | 'xs' | 'sm' | 'md' | 'lg' | 'xl' | '2xl';
  /** Additional CSS classes */
  className?: string;
  /** Semantic HTML element to render as */
  as?: 'div' | 'section' | 'main' | 'article' | 'aside' | 'nav' | 'ul' | 'ol';
  /** Alignment of grid items */
  align?: 'start' | 'center' | 'end' | 'stretch';
  /** Justification of grid items */
  justify?: 'start' | 'center' | 'end' | 'between' | 'around' | 'evenly';
  /** Whether to apply auto-fit behavior with minimum item width */
  autoFit?: boolean;
  /** ARIA label for the grid */
  ariaLabel?: string;
}

const {
  cols = 3,
  gap = 'md',
  className = '',
  as = 'div',
  align = 'stretch',
  justify = 'start',
  autoFit = false,
  ariaLabel,
} = Astro.props as Props;

// BEM-based class maps for responsive behavior
const columnClassMap = {
  1: 'comet-grid--cols-1',
  2: 'comet-grid--cols-2',
  3: 'comet-grid--cols-3',
  4: 'comet-grid--cols-4',
  5: 'comet-grid--cols-5',
  6: 'comet-grid--cols-6',
  auto: 'comet-grid--cols-auto',
} as const;

const gapClassMap = {
  none: 'comet-grid--gap-none',
  xs: 'comet-grid--gap-xs',
  sm: 'comet-grid--gap-sm',
  md: 'comet-grid--gap-md',
  lg: 'comet-grid--gap-lg',
  xl: 'comet-grid--gap-xl',
  '2xl': 'comet-grid--gap-2xl',
} as const;

const alignClassMap = {
  start: 'comet-grid--align-start',
  center: 'comet-grid--align-center',
  end: 'comet-grid--align-end',
  stretch: 'comet-grid--align-stretch',
} as const;

const justifyClassMap = {
  start: 'comet-grid--justify-items-start',
  center: 'comet-grid--justify-items-center',
  end: 'comet-grid--justify-items-end',
  between: 'comet-grid--justify-between',
  around: 'comet-grid--justify-around',
  evenly: 'comet-grid--justify-evenly',
} as const;

// Use auto-fit if cols is 'auto' or autoFit is explicitly true
const effectiveCols = (cols === 'auto' || autoFit ? 'auto' : cols) as keyof typeof columnClassMap;

// Build comprehensive class string
const gridClasses = [
  'comet-grid',
  columnClassMap[effectiveCols],
  gapClassMap[gap],
  alignClassMap[align],
  justifyClassMap[justify],
  className,
]
  .filter(Boolean)
  .join(' ');
---

{
  as === 'section' ? (
    <section class={gridClasses} aria-label={ariaLabel}>
      <slot />
    </section>
  ) : as === 'main' ? (
    <main class={gridClasses} aria-label={ariaLabel}>
      <slot />
    </main>
  ) : as === 'article' ? (
    <article class={gridClasses} aria-label={ariaLabel}>
      <slot />
    </article>
  ) : as === 'aside' ? (
    <aside class={gridClasses} aria-label={ariaLabel}>
      <slot />
    </aside>
  ) : as === 'nav' ? (
    <nav class={gridClasses} aria-label={ariaLabel}>
      <slot />
    </nav>
  ) : as === 'ul' ? (
    <ul class={gridClasses} aria-label={ariaLabel} role="list">
      <slot />
    </ul>
  ) : as === 'ol' ? (
    <ol class={gridClasses} aria-label={ariaLabel} role="list">
      <slot />
    </ol>
  ) : (
    <div class={gridClasses} aria-label={ariaLabel}>
      <slot />
    </div>
  )
}

<style is:inline>
  .comet-grid {
    display: grid;
    width: 100%;
    min-width: 0;
  }

  .comet-grid--cols-1 {
    grid-template-columns: repeat(1, minmax(0, 1fr));
  }

  .comet-grid--cols-2 {
    grid-template-columns: repeat(1, minmax(0, 1fr));
  }

  .comet-grid--cols-3 {
    grid-template-columns: repeat(1, minmax(0, 1fr));
  }

  .comet-grid--cols-4 {
    grid-template-columns: repeat(1, minmax(0, 1fr));
  }

  .comet-grid--cols-5 {
    grid-template-columns: repeat(1, minmax(0, 1fr));
  }

  .comet-grid--cols-6 {
    grid-template-columns: repeat(1, minmax(0, 1fr));
  }

  .comet-grid--cols-auto {
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
  }

  @media (min-width: 640px) {
    .comet-grid--cols-2,
    .comet-grid--cols-3,
    .comet-grid--cols-4,
    .comet-grid--cols-5,
    .comet-grid--cols-6 {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 768px) {
    .comet-grid--cols-4,
    .comet-grid--cols-5,
    .comet-grid--cols-6 {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (min-width: 1024px) {
    .comet-grid--cols-3 {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .comet-grid--cols-4,
    .comet-grid--cols-5,
    .comet-grid--cols-6 {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  @media (min-width: 1280px) {
    .comet-grid--cols-5,
    .comet-grid--cols-6 {
      grid-template-columns: repeat(5, minmax(0, 1fr));
    }
  }

  @media (min-width: 1536px) {
    .comet-grid--cols-6 {
      grid-template-columns: repeat(6, minmax(0, 1fr));
    }
  }

  .comet-grid--gap-none {
    gap: 0;
  }

  .comet-grid--gap-xs {
    gap: 0.25rem;
  }

  .comet-grid--gap-sm {
    gap: 0.5rem;
  }

  .comet-grid--gap-md {
    gap: 0.75rem;
  }

  .comet-grid--gap-lg {
    gap: 1rem;
  }

  .comet-grid--gap-xl {
    gap: 1.5rem;
  }

  .comet-grid--gap-2xl {
    gap: 2rem;
  }

  @media (min-width: 640px) {
    .comet-grid--gap-sm {
      gap: 0.75rem;
    }

    .comet-grid--gap-md {
      gap: 1rem;
    }

    .comet-grid--gap-lg {
      gap: 1.5rem;
    }

    .comet-grid--gap-xl {
      gap: 2rem;
    }

    .comet-grid--gap-2xl {
      gap: 2.5rem;
    }
  }

  @media (min-width: 1024px) {
    .comet-grid--gap-md {
      gap: 1.5rem;
    }

    .comet-grid--gap-lg {
      gap: 2rem;
    }

    .comet-grid--gap-xl {
      gap: 2.5rem;
    }

    .comet-grid--gap-2xl {
      gap: 3rem;
    }
  }

  .comet-grid--align-start {
    align-items: start;
  }

  .comet-grid--align-center {
    align-items: center;
  }

  .comet-grid--align-end {
    align-items: end;
  }

  .comet-grid--align-stretch {
    align-items: stretch;
  }

  .comet-grid--justify-items-start {
    justify-items: start;
  }

  .comet-grid--justify-items-center {
    justify-items: center;
  }

  .comet-grid--justify-items-end {
    justify-items: end;
  }

  .comet-grid--justify-between {
    justify-content: space-between;
  }

  .comet-grid--justify-around {
    justify-content: space-around;
  }

  .comet-grid--justify-evenly {
    justify-content: space-evenly;
  }
</style>
