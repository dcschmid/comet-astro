---
export interface ToastProps {
  variant?: 'default' | 'success' | 'warning' | 'error' | 'info';
  size?: 'sm' | 'md' | 'lg';
  position?:
    | 'top-right'
    | 'top-left'
    | 'bottom-right'
    | 'bottom-left'
    | 'top-center'
    | 'bottom-center'
    | 'static';
  title?: string;
  description?: string;
  duration?: number;
  dismissible?: boolean;
  persistent?: boolean;
  showIcon?: boolean;
  showProgress?: boolean;
  className?: string;
}

const {
  variant = 'default',
  size = 'md',
  position = 'bottom-right',
  title,
  description,
  duration = 5000,
  dismissible = true,
  persistent = false,
  showIcon = true,
  showProgress = false,
  className = '',
} = Astro.props as ToastProps;

const icons = {
  default: `<svg class="toast__icon-svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
  </svg>`,
  success: `<svg class="toast__icon-svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
  </svg>`,
  warning: `<svg class="toast__icon-svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.262 16.5c-.77.833.192 2.5 1.732 2.5z" />
  </svg>`,
  error: `<svg class="toast__icon-svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
  </svg>`,
  info: `<svg class="toast__icon-svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
  </svg>`,
};

const closeIcon = `<svg class="toast__close-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
</svg>`;

const toastId = `toast-${Math.random().toString(36).slice(2, 9)}`;
const rootClasses = [
  'toast',
  `toast--variant-${variant}`,
  `toast--size-${size}`,
  `toast--position-${position}`,
  showIcon ? 'toast--with-icon' : 'toast--no-icon',
  className,
]
  .filter(Boolean)
  .join(' ');
---

<div
  id={toastId}
  class={rootClasses}
  role="alert"
  aria-live={variant === 'error' ? 'assertive' : 'polite'}
  aria-atomic="true"
  aria-labelledby={title ? `${toastId}-title` : undefined}
  aria-describedby={`${toastId}-description`}
  data-toast
  data-duration={persistent ? '0' : duration.toString()}
  data-variant={variant}
>
  {showProgress && !persistent && (
    <div class="toast__progress" data-toast-progress aria-hidden="true" />
  )}

  <div class="toast__accent" aria-hidden="true" />

  <div class="toast__body">
    {showIcon && (
      <div class="toast__icon" aria-hidden="true">
        <Fragment set:html={icons[variant]} />
      </div>
    )}

    <div class="toast__content">
      {title && (
        <h3 id={`${toastId}-title`} class="toast__title">
          {title}
        </h3>
      )}

      <div id={`${toastId}-description`} class="toast__description">
        {description && <p>{description}</p>}
        <slot />
      </div>
    </div>

    {dismissible && (
      <button
        type="button"
        class="toast__close"
        aria-label={`Close ${variant} notification`}
        data-toast-close
      >
        <Fragment set:html={closeIcon} />
      </button>
    )}
  </div>
</div>

<script is:inline>
  (function () {
    const toasts = Array.from(document.querySelectorAll('[data-toast]'));
    if (!toasts.length) return;

    let toastContainer = document.querySelector('[data-toast-container]');
    if (!toastContainer) {
      toastContainer = document.createElement('div');
      toastContainer.setAttribute('data-toast-container', '');
      toastContainer.className = 'toast-container';
      toastContainer.setAttribute('aria-live', 'polite');
      toastContainer.setAttribute('aria-label', 'Notifications');
      document.body.appendChild(toastContainer);
    }

    toasts.forEach((toast) => {
      if (!(toast instanceof HTMLElement)) return;

      const duration = Number.parseInt(
        toast.getAttribute('data-duration') || '5000',
        10
      );
      const variant = toast.getAttribute('data-variant') || 'default';
      const closeBtn = toast.querySelector('[data-toast-close]');
      const progressBar = toast.querySelector('[data-toast-progress]');

      let progressInterval;
      let startTime;

      const dismiss = () => {
        if (progressInterval) clearInterval(progressInterval);
        const announcement = document.createElement('div');
        announcement.setAttribute('aria-live', 'polite');
        announcement.setAttribute('aria-atomic', 'true');
        announcement.className = 'sr-only';
        announcement.textContent = `${variant} notification dismissed`;
        document.body.appendChild(announcement);

        toast.style.opacity = '0';
        toast.style.transform = 'translateY(-8px) scale(0.95)';
        toast.setAttribute('aria-hidden', 'true');

        setTimeout(() => {
          toast.remove();
          announcement.remove();
          updateToastPositions();
        }, 300);
      };

      const updateProgress = () => {
        if (!progressBar || duration <= 0) return;
        const elapsed = Date.now() - startTime;
        const remaining = Math.max(0, duration - elapsed);
        const progress = (remaining / duration) * 100;
        progressBar.style.width = `${progress}%`;
        if (remaining <= 0) clearInterval(progressInterval);
      };

      const handleKeyDown = (event) => {
        if (event.key === 'Escape') {
          event.preventDefault();
          dismiss();
        }
      };

      let isPaused = false;
      let remainingTime = duration;
      let pauseTime;

      const pauseTimer = () => {
        if (isPaused || duration <= 0) return;
        isPaused = true;
        pauseTime = Date.now();
        if (progressInterval) clearInterval(progressInterval);
      };

      const resumeTimer = () => {
        if (!isPaused || duration <= 0) return;
        isPaused = false;
        const pausedDuration = Date.now() - pauseTime;
        remainingTime = Math.max(0, remainingTime - pausedDuration);
        startTime = Date.now() - (duration - remainingTime);

        if (remainingTime > 0) {
          progressInterval = setInterval(updateProgress, 16);
          setTimeout(dismiss, remainingTime);
        } else {
          dismiss();
        }
      };

      if (closeBtn instanceof HTMLElement) {
        closeBtn.addEventListener('click', (event) => {
          event.preventDefault();
          dismiss();
        });
      }

      toast.addEventListener('keydown', handleKeyDown);
      toast.addEventListener('mouseenter', pauseTimer);
      toast.addEventListener('mouseleave', resumeTimer);
      toast.addEventListener('focusin', pauseTimer);
      toast.addEventListener('focusout', resumeTimer);

      if (duration > 0) {
        startTime = Date.now();
        progressInterval = setInterval(updateProgress, 16);
        setTimeout(dismiss, duration);
      }

      if (!toast.hasAttribute('tabindex')) {
        toast.setAttribute('tabindex', '-1');
      }

      setTimeout(() => {
        toast.focus();
      }, 100);
    });

    function updateToastPositions() {
      const activeToasts = Array.from(
        document.querySelectorAll('[data-toast]:not([aria-hidden="true"])')
      );
      activeToasts.forEach((toast, index) => {
        if (!(toast instanceof HTMLElement)) return;
        const offset = index * 8;
        toast.style.transform = `translateY(-${offset}px)`;
        toast.style.zIndex = String(50 + activeToasts.length - index);
      });
    }

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      const style = document.createElement('style');
      style.textContent = `
        [data-toast] {
          transition: none !important;
        }
      `;
      document.head.appendChild(style);
    }

    updateToastPositions();
  })();
</script>

<style>
  .toast {
    position: fixed;
    border-radius: 1rem;
    border: 1px solid rgba(148, 163, 184, 0.6);
    padding: 1rem 1.25rem;
    max-width: 24rem;
    min-width: 14rem;
    box-shadow: 0 15px 35px rgba(15, 23, 42, 0.15);
    background: rgba(255, 255, 255, 0.95);
    color: #0f172a;
    backdrop-filter: blur(8px);
    display: flex;
    flex-direction: column;
  }

  :where(.dark) .toast {
    background: rgba(2, 6, 23, 0.95);
    color: #f8fafc;
    border-color: rgba(71, 85, 105, 0.6);
  }

  .toast--position-static {
    position: relative;
  }

  .toast--position-top-right {
    top: 1rem;
    right: 1rem;
  }

  .toast--position-top-left {
    top: 1rem;
    left: 1rem;
  }

  .toast--position-bottom-right {
    bottom: 1rem;
    right: 1rem;
  }

  .toast--position-bottom-left {
    bottom: 1rem;
    left: 1rem;
  }

  .toast--position-top-center {
    top: 1rem;
    left: 50%;
    transform: translateX(-50%);
  }

  .toast--position-bottom-center {
    bottom: 1rem;
    left: 50%;
    transform: translateX(-50%);
  }

  .toast__body {
    display: flex;
    gap: 0.75rem;
    alignItems: flex-start;
  }

  .toast__icon {
    flex-shrink: 0;
    display: inline-flex;
    padding-top: 0.15rem;
    color: inherit;
  }

  .toast__icon-svg {
    width: 1.25rem;
    height: 1.25rem;
  }

  .toast__content {
    flex: 1;
    min-width: 0;
  }

  .toast__title {
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
  }

  .toast--size-sm .toast__title {
    font-size: 0.85rem;
  }

  .toast--size-lg .toast__title {
    font-size: 1.1rem;
  }

  .toast__description {
    margin-top: 0.35rem;
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .toast--size-sm .toast__description {
    font-size: 0.8rem;
  }

  .toast--size-lg .toast__description {
    font-size: 1rem;
  }

  .toast__close {
    border: none;
    background: transparent;
    border-radius: 0.6rem;
    padding: 0.2rem;
    color: inherit;
    cursor: pointer;
  }

  .toast__close:hover {
    background: rgba(148, 163, 184, 0.15);
  }

  .toast__close:focus-visible {
    outline: 2px solid rgba(59, 130, 246, 0.4);
    outline-offset: 2px;
  }

  .toast__close-icon {
    width: 1rem;
    height: 1rem;
  }

  .toast__accent {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 0.35rem;
    border-radius: 0.5rem 0 0 0.5rem;
    background: rgba(100, 116, 139, 0.9);
  }

  .toast__progress {
    position: absolute;
    left: 0;
    top: 0;
    height: 0.25rem;
    width: 100%;
    border-radius: 1rem 1rem 0 0;
    background: rgba(37, 99, 235, 0.85);
  }

  .toast--variant-success .toast__accent,
  .toast--variant-success .toast__progress,
  .toast--variant-success .toast__icon {
    color: #059669;
    background: #059669;
  }

  .toast--variant-warning .toast__accent,
  .toast--variant-warning .toast__progress,
  .toast--variant-warning .toast__icon {
    color: #d97706;
    background: #d97706;
  }

  .toast--variant-error .toast__accent,
  .toast--variant-error .toast__progress,
  .toast--variant-error .toast__icon {
    color: #dc2626;
    background: #dc2626;
  }

  .toast--variant-info .toast__accent,
  .toast--variant-info .toast__progress,
  .toast--variant-info .toast__icon {
    color: #2563eb;
    background: #2563eb;
  }

  .toast--variant-default .toast__accent,
  .toast--variant-default .toast__progress,
  .toast--variant-default .toast__icon {
    color: #475569;
    background: #475569;
  }

  .toast--variant-minimal {
    border-color: rgba(148, 163, 184, 0.3);
    box-shadow: none;
  }

  .toast--variant-bordered {
    border-width: 2px;
  }

  .toast--variant-filled {
    background: rgba(248, 250, 252, 0.95);
  }

  :where(.dark) .toast--variant-filled {
    background: rgba(15, 23, 42, 0.9);
  }

  .toast--size-sm {
    padding: 0.75rem 1rem;
    max-width: 18rem;
  }

  .toast--size-lg {
    padding: 1.25rem 1.5rem;
    max-width: 28rem;
  }

  .toast-container {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 50;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (prefers-contrast: high) {
    .toast {
      border-width: 2px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .toast,
    .toast__progress {
      transition: none !important;
    }
  }
</style>
