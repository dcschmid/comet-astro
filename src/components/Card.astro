---
interface Props {
  as?: 'article' | 'section' | 'div' | 'li';
  href?: string;
  ariaLabel?: string;
  class?: string;
  flat?: boolean;
  elevation?: 0 | 1 | 2 | 3;
  tabIndex?: number;
}

const {
  as = 'article',
  href,
  ariaLabel,
  class: className,
  flat = false,
  elevation = 1,
  tabIndex,
} = Astro.props as Props;

const Tag = href ? 'a' : as;
const ariaAttrs: Record<string, string> = {};
if (ariaLabel) ariaAttrs['aria-label'] = ariaLabel;

const classes = [
  'card',
  flat ? 'card--flat' : '',
  `card--elevation-${elevation}`,
  href ? 'card--interactive' : '',
  className,
]
  .filter(Boolean)
  .join(' ');
---

<Tag class={classes} href={href} tabindex={tabIndex} {...ariaAttrs}>
  <slot />
</Tag>

<style is:inline>
  .card {
    --card-bg: #ffffff;
    --card-bg-dark: #0f172a;
    --card-text: #0f172a;
    --card-text-dark: #f8fafc;
    --card-border: rgba(148, 163, 184, 0.45);
    --card-border-dark: rgba(148, 163, 184, 0.45);
    --card-radius: 1.1rem;
    --card-shadow: 0 15px 35px rgba(15, 23, 42, 0.15);
    --card-shadow-dark: 0 15px 35px rgba(0, 0, 0, 0.35);
    --card-hover-bg: #f8fafc;
    --card-hover-bg-dark: #1e293b;
    --card-focus: rgba(59, 130, 246, 0.65);
    position: relative;
    display: block;
    border-radius: var(--card-radius);
    border: 1px solid var(--card-border);
    background: var(--card-bg);
    color: var(--card-text);
    box-shadow: var(--card-shadow);
    transition:
      background-color 0.2s ease,
      border-color 0.2s ease,
      box-shadow 0.2s ease,
      transform 0.2s ease;
  }

  :where(.dark) .card {
    border-color: var(--card-border-dark);
    background: var(--card-bg-dark);
    color: var(--card-text-dark);
    box-shadow: var(--card-shadow-dark);
  }

  .card:focus-visible {
    outline: 3px solid var(--card-focus);
    outline-offset: 3px;
  }

  .card--flat {
    box-shadow: none;
  }

  .card--elevation-0 {
    box-shadow: none;
  }

  .card--elevation-1 {
    box-shadow: 0 12px 25px rgba(15, 23, 42, 0.12);
  }

  .card--elevation-2 {
    box-shadow: 0 18px 40px rgba(15, 23, 42, 0.16);
  }

  .card--elevation-3 {
    box-shadow: 0 25px 60px rgba(15, 23, 42, 0.18);
  }

  :where(.dark) .card--elevation-1 {
    box-shadow: 0 12px 30px rgba(2, 6, 23, 0.7);
  }

  :where(.dark) .card--elevation-2 {
    box-shadow: 0 18px 40px rgba(2, 6, 23, 0.8);
  }

  :where(.dark) .card--elevation-3 {
    box-shadow: 0 25px 65px rgba(2, 6, 23, 0.85);
  }

  .card--interactive {
    cursor: pointer;
  }

  .card--interactive:hover {
    background: var(--card-hover-bg);
    transform: translateY(-1px);
  }

  :where(.dark) .card--interactive:hover {
    background: var(--card-hover-bg-dark);
  }
</style>
