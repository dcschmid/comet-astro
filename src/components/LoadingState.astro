---
/**
 * LoadingState - Accessible loading states with spinner and optional skeleton content
 * WCAG AAA compliant with proper contrast ratios and semantic markup
 */
import LoadingSpinner from './LoadingSpinner.astro';
import Skeleton from './Skeleton.astro';

interface Props {
  /** Loading message displayed to users */
  label?: string;
  /** Visual style variant */
  variant?: 'default' | 'minimal' | 'card' | 'fullscreen';
  /** Size of the loading state */
  size?: 'sm' | 'md' | 'lg';
  /** Number of skeleton rows to show */
  skeletonRows?: number;
  /** Animation type for the spinner */
  animation?: 'spin' | 'pulse' | 'bounce' | 'dots' | 'bars' | 'orbit';
  /** Custom CSS classes */
  className?: string;
}

const {
  label = 'Loading…',
  variant = 'default',
  size = 'md',
  skeletonRows = 0,
  animation = 'spin',
  className = '',
} = Astro.props as Props;

// Spinner sizes
const spinnerSizes = {
  sm: 'xs',
  md: 'sm',
  lg: 'md',
};

const baseClasses = [
  'loading-state',
  `loading-state--${variant}`,
  `loading-state--size-${size}`,
  className,
]
  .filter(Boolean)
  .join(' ');

const labelClasses = [
  'loading-state__label',
  `loading-state__label--${size}`,
  variant === 'minimal'
    ? 'loading-state__label--inline'
    : 'loading-state__label--block',
]
  .filter(Boolean)
  .join(' ');
---

<div
  class={baseClasses}
  role="status"
  aria-live="polite"
  aria-label={label}
>
  {
    variant === 'minimal' ? (
      <>
        <LoadingSpinner
          className="loading-state__spinner"
          size={spinnerSizes[size] as 'xs' | 'sm' | 'md'}
          animation={animation}
          variant="default"
          aria-hidden="true"
        />
        <span class={labelClasses}>{label}</span>
      </>
    ) : (
      <>
        <LoadingSpinner
          className="loading-state__spinner"
          size={spinnerSizes[size] as 'xs' | 'sm' | 'md'}
          animation={animation}
          variant="default"
          aria-hidden="true"
        />
        {label && <div class={labelClasses}>{label}</div>}

        {skeletonRows > 0 && (
          <div class="loading-state__skeletons">
            {skeletonRows >= 1 && (
              <Skeleton
                width="100%"
                height={
                  size === 'sm' ? '12px' : size === 'md' ? '16px' : '20px'
                }
              />
            )}
            {skeletonRows >= 2 && (
              <Skeleton
                width="85%"
                height={
                  size === 'sm' ? '12px' : size === 'md' ? '16px' : '20px'
                }
              />
            )}
            {skeletonRows >= 3 && (
              <Skeleton
                width="92%"
                height={
                  size === 'sm' ? '12px' : size === 'md' ? '16px' : '20px'
                }
              />
            )}
            {skeletonRows >= 4 && (
              <Skeleton
                width="78%"
                height={
                  size === 'sm' ? '12px' : size === 'md' ? '16px' : '20px'
                }
              />
            )}
            {skeletonRows >= 5 && (
              <Skeleton
                width="88%"
                height={
                  size === 'sm' ? '12px' : size === 'md' ? '16px' : '20px'
                }
              />
            )}
            {skeletonRows >= 6 && (
              <Skeleton
                width="82%"
                height={
                  size === 'sm' ? '12px' : size === 'md' ? '16px' : '20px'
                }
              />
            )}
          </div>
        )}
      </>
    )
  }
</div>

<style>
  .loading-state {
    --loading-state-gap: 1rem;
    --loading-state-padding-block: 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: var(--loading-state-gap);
    padding-block: var(--loading-state-padding-block);
    width: 100%;
    color: #334155;
  }

  .loading-state--size-sm {
    --loading-state-gap: 0.5rem;
    --loading-state-padding-block: 1.5rem;
  }

  .loading-state--size-md {
    --loading-state-gap: 1rem;
    --loading-state-padding-block: 2rem;
  }

  .loading-state--size-lg {
    --loading-state-gap: 1.5rem;
    --loading-state-padding-block: 3rem;
  }

  .loading-state__spinner {
    color: inherit;
  }

  .loading-state__label {
    font-weight: 600;
    color: inherit;
  }

  .loading-state__label--sm {
    font-size: 0.75rem;
    line-height: 1rem;
  }

  .loading-state__label--md {
    font-size: 0.875rem;
    line-height: 1.25rem;
  }

  .loading-state__label--lg {
    font-size: 1rem;
    line-height: 1.5rem;
  }

  .loading-state__label--inline {
    display: inline-flex;
    align-items: center;
    text-align: left;
  }

  .loading-state__label--block {
    display: block;
    text-align: center;
  }

  .loading-state__skeletons {
    width: 100%;
    max-width: 42rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  .loading-state--default {
    color: #334155;
  }

  .loading-state--minimal {
    color: #475569;
    flex-direction: row;
    justify-content: flex-start;
    text-align: left;
  }

  .loading-state--card {
    border-radius: 0.75rem;
    border: 1px solid #e2e8f0;
    background-color: #f8fafc;
    padding-inline: 2rem;
  }

  .loading-state--fullscreen {
    position: fixed;
    inset: 0;
    z-index: 50;
    background-color: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(4px);
  }

  :where(.dark) .loading-state--default,
  :where(.dark) .loading-state--card,
  :where(.dark) .loading-state--fullscreen {
    color: #e2e8f0;
  }

  :where(.dark) .loading-state--minimal {
    color: #cbd5f5;
  }

  :where(.dark) .loading-state--card {
    border-color: #334155;
    background-color: rgba(30, 41, 59, 0.5);
  }

  :where(.dark) .loading-state--fullscreen {
    background-color: rgba(15, 23, 42, 0.8);
  }
</style>
