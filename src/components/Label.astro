---
/**
 * Label - WCAG AAA compliant form label component
 * Provides accessible form labeling with enhanced visual hierarchy and state indicators
 */
interface Props {
  for?: string;
  required?: boolean;
  optional?: boolean;
  disabled?: boolean;
  size?: 'xs' | 'sm' | 'md' | 'lg' | 'xl';
  weight?: 'normal' | 'medium' | 'semibold' | 'bold';
  variant?: 'default' | 'floating' | 'inline' | 'stacked';
  status?: 'default' | 'error' | 'warning' | 'success';
  className?: string;
  description?: string;
  requiredText?: string;
  optionalText?: string;
  hideRequiredIndicator?: boolean;
  hideOptionalIndicator?: boolean;
}

const {
  for: htmlFor,
  required = false,
  optional = false,
  disabled = false,
  size = 'md',
  weight = 'medium',
  variant = 'default',
  status = 'default',
  className = '',
  description,
  requiredText = 'Required',
  optionalText = 'Optional',
  hideRequiredIndicator = false,
  hideOptionalIndicator = false,
} = Astro.props;

const sizeClasses = {
  xs: 'label--size-xs',
  sm: 'label--size-sm',
  md: 'label--size-md',
  lg: 'label--size-lg',
  xl: 'label--size-xl',
} as const;

const weightClasses = {
  normal: 'label__text--weight-normal',
  medium: 'label__text--weight-medium',
  semibold: 'label__text--weight-semibold',
  bold: 'label__text--weight-bold',
} as const;

const variantClasses = {
  default: 'label--variant-default',
  floating: 'label--variant-floating',
  inline: 'label--variant-inline',
  stacked: 'label--variant-stacked',
} as const;

const statusClasses = {
  default: 'label--status-default',
  error: 'label--status-error',
  warning: 'label--status-warning',
  success: 'label--status-success',
} as const;

const wrapperClasses = [
  'label',
  sizeClasses[size],
  variantClasses[variant],
  statusClasses[status],
  className,
]
  .filter(Boolean)
  .join(' ');
const textClasses = ['label__text', weightClasses[weight]]
  .filter(Boolean)
  .join(' ');
const indicatorRequiredClasses = [
  'label__indicator',
  'label__indicator--required',
  disabled ? 'label__indicator--disabled' : '',
]
  .filter(Boolean)
  .join(' ');
const indicatorOptionalClasses = [
  'label__indicator',
  'label__indicator--optional',
  disabled ? 'label__indicator--disabled' : '',
]
  .filter(Boolean)
  .join(' ');
const descriptionClasses = [
  'label__description',
  status === 'error' ? 'label__description--error' : '',
  disabled ? 'label__description--disabled' : '',
]
  .filter(Boolean)
  .join(' ');

// Generate unique IDs for accessibility
const labelId = htmlFor
  ? `label-${htmlFor}`
  : `label-${Math.random().toString(36).slice(2, 8)}`;
const descriptionId = description ? `${labelId}-description` : undefined;

// Required/Optional indicator logic
const showRequired = required && !hideRequiredIndicator;
const showOptional = optional && !hideOptionalIndicator && !required;
---

<div class={wrapperClasses}>
  <label
    for={htmlFor}
    id={labelId}
    class={textClasses}
    aria-describedby={descriptionId}
    aria-disabled={disabled ? 'true' : undefined}
  >
    <!-- Label Text -->
    <span class="label__slot">
      <slot />

      <!-- Required Indicator -->
      {
        showRequired && (
          <span
            class={indicatorRequiredClasses}
            aria-label={requiredText}
            title={requiredText}
          >
            *
          </span>
        )
      }

      <!-- Optional Indicator -->
      {
        showOptional && (
          <span
            class={indicatorOptionalClasses}
            aria-label={optionalText}
          >
            ({optionalText.toLowerCase()})
          </span>
        )
      }
    </span>

    <!-- Status Icon for Error/Warning/Success -->
    {
      status !== 'default' && (
        <span class="label__status-icon" aria-hidden="true">
          {status === 'error' && (
            <svg
              class="label__status-icon-graphic label__status-icon-graphic--error"
              fill="currentColor"
              viewBox="0 0 20 20"
            >
              <path
                fill-rule="evenodd"
                d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-8-3a1 1 0 00-.867.5 1 1 0 11-1.731-1A3 3 0 0113 8a3.001 3.001 0 01-2 2.83V11a1 1 0 11-2 0v-1a1 1 0 011-1 1 1 0 100-2zm0 8a1 1 0 100-2 1 1 0 000 2z"
                clip-rule="evenodd"
              />
            </svg>
          )}
          {status === 'warning' && (
            <svg
              class="label__status-icon-graphic label__status-icon-graphic--warning"
              fill="currentColor"
              viewBox="0 0 20 20"
            >
              <path
                fill-rule="evenodd"
                d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z"
                clip-rule="evenodd"
              />
            </svg>
          )}
          {status === 'success' && (
            <svg
              class="label__status-icon-graphic label__status-icon-graphic--success"
              fill="currentColor"
              viewBox="0 0 20 20"
            >
              <path
                fill-rule="evenodd"
                d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                clip-rule="evenodd"
              />
            </svg>
          )}
        </span>
      )
    }
  </label>

  <!-- Description -->
  {
    description && (
      <p
        id={descriptionId}
        class={descriptionClasses}
        role={status === 'error' ? 'alert' : undefined}
        aria-live={status === 'error' ? 'polite' : undefined}
      >
        {description}
      </p>
    )
  }
</div>

<style is:inline>
  .label {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .label--variant-inline .label__text {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .label--variant-stacked .label__text,
  .label--variant-floating .label__text,
  .label--variant-default .label__text {
    display: block;
  }

  .label__text {
    color: #0f172a;
    font-size: 0.95rem;
    line-height: 1.5;
    cursor: pointer;
    transition: color 0.15s ease;
  }

  .label__text:focus-within {
    outline: 2px solid #2563eb;
    outline-offset: 2px;
    border-radius: 0.35rem;
  }

  .label--status-error .label__text {
    color: #b91c1c;
  }

  .label--status-warning .label__text {
    color: #b45309;
  }

  .label--status-success .label__text {
    color: #15803d;
  }

  .label--size-xs .label__text {
    font-size: 0.75rem;
    line-height: 1.35;
  }

  .label--size-sm .label__text {
    font-size: 0.85rem;
  }

  .label--size-lg .label__text {
    font-size: 1rem;
  }

  .label--size-xl .label__text {
    font-size: 1.1rem;
  }

  .label__text--weight-normal {
    font-weight: 400;
  }

  .label__text--weight-medium {
    font-weight: 500;
  }

  .label__text--weight-semibold {
    font-weight: 600;
  }

  .label__text--weight-bold {
    font-weight: 700;
  }

  .label__slot {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .label--size-xs .label__slot {
    gap: 0.25rem;
  }

  .label--size-lg .label__slot,
  .label--size-xl .label__slot {
    gap: 0.65rem;
  }

  .label__indicator {
    font-size: 0.75rem;
  }

  .label__indicator--required {
    color: #b91c1c;
    font-weight: 600;
  }

  .label__indicator--optional {
    color: #64748b;
    font-weight: 500;
  }

  .label__indicator--disabled {
    color: #94a3b8;
  }

  .label__status-icon {
    display: inline-flex;
    align-items: center;
    margin-left: 0.35rem;
  }

  .label__status-icon-graphic {
    width: 1rem;
    height: 1rem;
  }

  .label__status-icon-graphic--error {
    color: #b91c1c;
  }

  .label__status-icon-graphic--warning {
    color: #b45309;
  }

  .label__status-icon-graphic--success {
    color: #15803d;
  }

  .label__description {
    font-size: 0.8rem;
    color: #475569;
    line-height: 1.5;
  }

  .label--size-xs .label__description {
    font-size: 0.75rem;
  }

  .label--size-xl .label__description {
    font-size: 0.9rem;
  }

  .label__description--disabled {
    color: #94a3b8;
  }

  .label__description--error {
    color: #b91c1c;
  }

  .label[aria-disabled='true'] .label__text {
    color: #94a3b8;
    cursor: not-allowed;
  }

  .label__text:hover:not([aria-disabled='true']) {
    opacity: 0.9;
  }

  @media (prefers-contrast: high) {
    .label__text {
      font-weight: 600;
    }

    .label__indicator {
      font-weight: 700;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .label__text {
      transition: none;
    }
  }

  :where(.dark) .label__text {
    color: #f8fafc;
  }

  :where(.dark) .label__indicator--optional {
    color: #cbd5f5;
  }

  :where(.dark) .label__description {
    color: #cbd5f5;
  }

  :where(.dark) .label__description--disabled {
    color: #94a3b8;
  }

  :where(.dark) .label__description--error,
  :where(.dark) .label__indicator--required,
  :where(.dark) .label__status-icon-graphic--error {
    color: #f87171;
  }

  :where(.dark) .label__status-icon-graphic--warning {
    color: #fbbf24;
  }

  :where(.dark) .label__status-icon-graphic--success {
    color: #4ade80;
  }
</style>
