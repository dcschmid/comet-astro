---
/**
 * Masonry - Accessible responsive masonry layout using CSS columns
 * WCAG AAA compliant with proper focus management and semantic structure
 */
interface Breakpoints {
  base?: number;
  sm?: number;
  md?: number;
  lg?: number;
  xl?: number;
}

const clampColumns = (value: number) => Math.max(1, Math.round(value));

interface Props {
  /** Number of columns or responsive breakpoint object */
  columns?: number | Breakpoints;
  /** Gap between columns and items */
  gap?: 'xs' | 'sm' | 'md' | 'lg' | 'xl' | string;
  /** Visual variant */
  variant?: 'default' | 'card' | 'gallery' | 'minimal';
  /** Size preset for consistent spacing */
  size?: 'sm' | 'md' | 'lg';
  /** Accessible title for the masonry grid */
  title?: string;
  /** Role for semantic structure */
  role?: 'list' | 'grid' | 'region';
  /** Custom CSS classes */
  className?: string;
  /** Enable focus management for keyboard navigation */
  focusManagement?: boolean;
}

const {
  columns = { base: 1, sm: 2, md: 2, lg: 3, xl: 4 },
  gap = 'md',
  variant = 'default',
  size = 'md',
  title,
  role = 'grid',
  className = '',
  focusManagement = true,
} = Astro.props as Props;

// Gap size mappings
const gapSizes = {
  xs: '0.5rem',
  sm: '0.75rem',
  md: '1rem',
  lg: '1.5rem',
  xl: '2rem',
};

// Size variants for consistent spacing
const sizeVariants = {
  sm: { gap: gapSizes.sm, minHeight: '200px' },
  md: { gap: gapSizes.md, minHeight: '300px' },
  lg: { gap: gapSizes.lg, minHeight: '400px' },
};

// Resolve gap value
const gapValue =
  typeof gap === 'string' && gap in gapSizes
    ? gapSizes[gap as keyof typeof gapSizes]
    : typeof gap === 'string'
      ? gap
      : sizeVariants[size].gap;

// Column configuration with proper fallbacks
const columnConfig: Required<Breakpoints> = {
  base: clampColumns(
    typeof columns === 'number' ? columns : (columns.base ?? 1)
  ),
  sm: clampColumns(
    typeof columns === 'number' ? columns : (columns.sm ?? columns.base ?? 2)
  ),
  md: clampColumns(
    typeof columns === 'number'
      ? columns
      : (columns.md ?? columns.sm ?? columns.base ?? 2)
  ),
  lg: clampColumns(
    typeof columns === 'number'
      ? columns
      : (columns.lg ?? columns.md ?? columns.sm ?? columns.base ?? 3)
  ),
  xl: clampColumns(
    typeof columns === 'number'
      ? columns
      : (columns.xl ??
          columns.lg ??
          columns.md ??
          columns.sm ??
          columns.base ??
          4)
  ),
};

// Variant styles with WCAG AAA compliant colors
const variantModifiers = {
  default: '',
  card: 'masonry--card',
  gallery: 'masonry--gallery',
  minimal: 'masonry--minimal',
} as const;

// Generate unique ID for this masonry instance
const id = `masonry-${Math.random().toString(36).slice(2, 9)}`;

// Instance-specific CSS variables for responsive columns and gaps
const instanceStyles = `
  #${id} {
    --masonry-gap: ${gapValue};
    --masonry-columns-base: ${columnConfig.base};
    --masonry-columns-sm: ${columnConfig.sm};
    --masonry-columns-md: ${columnConfig.md};
    --masonry-columns-lg: ${columnConfig.lg};
    --masonry-columns-xl: ${columnConfig.xl};
    --masonry-columns-print: ${Math.min(columnConfig.lg, 2)};
  }
`;

// Container classes
const containerClasses = [
  'masonry',
  variantModifiers[variant],
  focusManagement ? 'masonry--focusable' : '',
  className,
]
  .filter(Boolean)
  .join(' ');

// ARIA attributes
const ariaAttributes = {
  role,
  ...(title && { 'aria-label': title }),
  ...(role === 'grid' && { 'aria-readonly': 'true' }),
  ...(focusManagement && { tabindex: '0' }),
};
---

<style is:inline set:html={instanceStyles}></style>

{
  title && (
    <div class="masonry__sr-only" id={`${id}-title`}>
      {title}
    </div>
  )
}

<div
  id={id}
  class={containerClasses}
  {...ariaAttributes}
  aria-describedby={title ? `${id}-title` : undefined}
>
  <slot />
</div>

<!-- Screen reader instructions for complex layouts -->
{
  role === 'grid' && (
    <div class="masonry__sr-only">
      Navigate this grid using arrow keys. Items are arranged in{' '}
      {columnConfig.base} column{columnConfig.base > 1 ? 's' : ''} on mobile,
      increasing to {columnConfig.xl} column{columnConfig.xl > 1 ? 's' : ''} on
      larger screens.
    </div>
  )
}

<style>
  .masonry {
    column-count: var(--masonry-columns-base, 1);
    column-gap: var(--masonry-gap, 1rem);
    column-fill: balance;
    width: 100%;
  }

  .masonry > * {
    break-inside: avoid;
    page-break-inside: avoid;
    margin-bottom: var(--masonry-gap, 1rem);
  }

  .masonry > *:last-child {
    margin-bottom: 0;
  }

  .masonry--focusable:focus-within {
    outline: 2px solid rgb(59 130 246);
    outline-offset: 2px;
    border-radius: 0.5rem;
  }

  .masonry--focusable > *:focus {
    outline: 2px solid rgb(59 130 246);
    outline-offset: 2px;
    border-radius: 0.25rem;
    position: relative;
    z-index: 5;
  }

  .masonry--card {
    padding: 1.5rem;
    border-radius: 0.75rem;
    border: 1px solid #e2e8f0;
    background-color: #ffffff;
    box-shadow: 0 5px 20px rgba(15, 23, 42, 0.08);
  }

  .masonry--gallery {
    border-radius: 1rem;
    border: 1px solid #f1f5f9;
    background-color: #ffffff;
    box-shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
    overflow: hidden;
  }

  .masonry--minimal > * {
    margin-bottom: calc(var(--masonry-gap, 1rem) * 0.75);
  }

  .masonry__sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (min-width: 640px) {
    .masonry {
      column-count: var(--masonry-columns-sm, var(--masonry-columns-base, 1));
    }
  }

  @media (min-width: 768px) {
    .masonry {
      column-count: var(--masonry-columns-md, var(--masonry-columns-sm, 1));
    }
  }

  @media (min-width: 1024px) {
    .masonry {
      column-count: var(--masonry-columns-lg, var(--masonry-columns-md, 1));
    }
  }

  @media (min-width: 1280px) {
    .masonry {
      column-count: var(--masonry-columns-xl, var(--masonry-columns-lg, 1));
    }
  }

  @media (prefers-contrast: high) {
    .masonry > * {
      border: 1px solid currentColor;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .masonry,
    .masonry > * {
      transition: none;
    }
  }

  @media print {
    .masonry {
      column-count: var(--masonry-columns-print, 2);
    }

    .masonry > * {
      break-inside: avoid;
      page-break-inside: avoid;
    }
  }

  :where(.dark) .masonry--card {
    border-color: #334155;
    background-color: #0f172a;
    box-shadow: 0 5px 20px rgba(0, 0, 0, 0.35);
  }

  :where(.dark) .masonry--gallery {
    border-color: #1e293b;
    background-color: #0f172a;
  }
</style>
