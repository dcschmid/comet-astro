---
interface Props {
  // Content props
  text?: string;

  // HTML element options
  as?: 'p' | 'span' | 'div' | 'blockquote' | 'figcaption';

  // Typography options
  size?: 'xs' | 'sm' | 'md' | 'lg' | 'xl' | '2xl';
  weight?: 'light' | 'normal' | 'medium' | 'semibold' | 'bold';
  lineHeight?: 'tight' | 'normal' | 'relaxed' | 'loose';

  // Visual variants
  variant?:
    | 'default'
    | 'muted'
    | 'subtle'
    | 'accent'
    | 'error'
    | 'success'
    | 'warning';

  // Layout options
  align?: 'left' | 'center' | 'right' | 'justify';
  maxWidth?: 'none' | 'prose' | 'sm' | 'md' | 'lg' | 'xl' | '2xl';

  // Accessibility props
  role?: string;
  ariaLabel?: string;
  ariaDescribedBy?: string;
  id?: string;

  // Deprecated props (for backward compatibility)
  muted?: boolean;

  // Styling
  class?: string;
}

const {
  text,
  as = 'p',
  size = 'md',
  weight = 'normal',
  lineHeight = 'relaxed',
  variant = 'default',
  align = 'left',
  maxWidth = 'none',
  role,
  ariaLabel,
  ariaDescribedBy,
  id,
  muted = false,
  class: className,
} = Astro.props as Props;

// Generate unique ID if needed
const elementId =
  id ||
  (ariaDescribedBy
    ? `paragraph-${Math.random().toString(36).substr(2, 9)}`
    : undefined);

// Handle backward compatibility
const finalVariant = muted ? 'muted' : variant;

// Build classes
const classes = [
  'paragraph',
  `paragraph--size-${size}`,
  `paragraph--weight-${weight}`,
  `paragraph--line-${lineHeight}`,
  `paragraph--variant-${finalVariant}`,
  `paragraph--align-${align}`,
  `paragraph--width-${maxWidth}`,
  className,
]
  .filter(Boolean)
  .join(' ');

// Dynamic tag
const Tag = as;
---

<Tag
  id={elementId}
  class={classes}
  role={role}
  aria-label={ariaLabel}
  aria-describedby={ariaDescribedBy}
>
  {text ? text : <slot />}
</Tag>

<style>
  .paragraph {
    margin-bottom: 0;
    color: #0f172a;
  }

  .paragraph--size-xs {
    font-size: clamp(0.85rem, 1.5vw, 0.95rem);
  }

  .paragraph--size-sm {
    font-size: clamp(0.95rem, 1.7vw, 1.05rem);
  }

  .paragraph--size-md {
    font-size: clamp(1rem, 2vw, 1.15rem);
  }

  .paragraph--size-lg {
    font-size: clamp(1.1rem, 2.2vw, 1.25rem);
  }

  .paragraph--size-xl {
    font-size: clamp(1.2rem, 2.6vw, 1.4rem);
  }

  .paragraph--size-2xl {
    font-size: clamp(1.4rem, 3vw, 1.6rem);
  }

  .paragraph--weight-light {
    font-weight: 300;
  }

  .paragraph--weight-normal {
    font-weight: 400;
  }

  .paragraph--weight-medium {
    font-weight: 500;
  }

  .paragraph--weight-semibold {
    font-weight: 600;
  }

  .paragraph--weight-bold {
    font-weight: 700;
  }

  .paragraph--line-tight {
    line-height: 1.35;
  }

  .paragraph--line-normal {
    line-height: 1.5;
  }

  .paragraph--line-relaxed {
    line-height: 1.7;
  }

  .paragraph--line-loose {
    line-height: 1.85;
  }

  .paragraph--variant-default {
    color: #0f172a;
  }

  .paragraph--variant-muted {
    color: #475569;
  }

  .paragraph--variant-subtle {
    color: #334155;
  }

  .paragraph--variant-accent {
    color: #1d4ed8;
  }

  .paragraph--variant-error {
    color: #b91c1c;
  }

  .paragraph--variant-success {
    color: #15803d;
  }

  .paragraph--variant-warning {
    color: #b45309;
  }

  .paragraph--align-left {
    text-align: left;
  }

  .paragraph--align-center {
    text-align: center;
  }

  .paragraph--align-right {
    text-align: right;
  }

  .paragraph--align-justify {
    text-align: justify;
  }

  .paragraph--width-prose {
    max-width: 60ch;
  }

  .paragraph--width-sm {
    max-width: 40ch;
  }

  .paragraph--width-md {
    max-width: 50ch;
  }

  .paragraph--width-lg {
    max-width: 65ch;
  }

  .paragraph--width-xl {
    max-width: 72ch;
  }

  .paragraph--width-2xl {
    max-width: 80ch;
  }

  :where(.dark) .paragraph {
    color: #f8fafc;
  }
</style>
