---
/**
 * WCAG-compliant Table of Contents with BEM styling
 */
interface TocItem {
  id: string;
  label: string;
  level?: 1 | 2 | 3 | 4 | 5 | 6;
  description?: string;
}

type TocSize = 'sm' | 'md' | 'lg';
type TocVariant = 'default' | 'compact' | 'minimal' | 'elevated';

interface Props {
  title?: string;
  items: TocItem[];
  activeId?: string;
  className?: string;
  size?: TocSize;
  variant?: TocVariant;
  sticky?: boolean;
  collapsible?: boolean;
  defaultCollapsed?: boolean;
  showNumbers?: boolean;
  maxLevel?: 1 | 2 | 3 | 4 | 5 | 6;
  ariaLabel?: string;
}

const {
  title = 'Table of Contents',
  items = [],
  activeId,
  className = '',
  size = 'md',
  variant = 'default',
  sticky = false,
  collapsible = false,
  defaultCollapsed = false,
  showNumbers = false,
  maxLevel = 6,
  ariaLabel,
} = Astro.props as Props;

const filteredItems = items.filter((item) => (item.level || 1) <= maxLevel);

const tocId = `toc-${Math.random().toString(36).slice(2, 9)}`;
const listId = `${tocId}-list`;
const toggleId = `${tocId}-toggle`;

const rootClasses = [
  'toc',
  `toc--size-${size}`,
  `toc--variant-${variant}`,
  sticky ? 'toc--sticky' : '',
  collapsible ? 'toc--collapsible' : '',
  defaultCollapsed ? 'toc--collapsed' : '',
  className,
]
  .filter(Boolean)
  .join(' ');

const getIndentation = (level: number, currentSize: TocSize) => {
  const base = { sm: 0.75, md: 1, lg: 1.25 }[currentSize];
  return `${(level - 1) * base}rem`;
};
---

<nav
  id={tocId}
  aria-label={ariaLabel || `${title} navigation`}
  class={rootClasses}
  data-collapsible={collapsible ? 'true' : 'false'}
  data-default-collapsed={defaultCollapsed ? 'true' : 'false'}
>
  <div class="toc__header">
    <h2 class="toc__title" id={`${tocId}-title`}>
      {title}
    </h2>

    {collapsible && (
      <button
        type="button"
        id={toggleId}
        aria-expanded={!defaultCollapsed}
        aria-controls={listId}
        aria-describedby={`${tocId}-title`}
        class="toc__toggle"
      >
        <svg class="toc__toggle-icon" viewBox="0 0 20 20" aria-hidden="true">
          <path
            fill-rule="evenodd"
            d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
            clip-rule="evenodd"
          />
        </svg>
        <span class="sr-only">
          {defaultCollapsed ? 'Expand table of contents' : 'Collapse table of contents'}
        </span>
      </button>
    )}
  </div>

  <div
    id={listId}
    class={[
      'toc__list',
      collapsible && defaultCollapsed ? 'toc__list--collapsed' : '',
    ]
      .filter(Boolean)
      .join(' ')}
    aria-labelledby={`${tocId}-title`}
  >
    {filteredItems.length === 0 ? (
      <div class="toc__message" role="status" aria-live="polite">
        No sections available
      </div>
    ) : (
      <ul class="toc__items" role="list">
        {filteredItems.map((item, index) => {
          const level = item.level || 1;
          const isActive = activeId === item.id;
          const numberLabel = showNumbers ? `${index + 1}.` : undefined;

          return (
            <li
              class="toc__item"
              style={level > 1 ? `--toc-indent: ${getIndentation(level, size)}` : undefined}
            >
              <a
                href={`#${item.id}`}
                class={[
                  'toc__link',
                  isActive ? 'toc__link--active' : '',
                  showNumbers ? 'toc__link--numbered' : '',
                ]
                  .filter(Boolean)
                  .join(' ')}
                aria-current={isActive ? 'location' : undefined}
                title={item.description || item.label}
              >
                {numberLabel && (
                  <span class="toc__number" aria-hidden="true">
                    {numberLabel}
                  </span>
                )}
                <span class="toc__label">{item.label}</span>
                <span class="sr-only">, heading level {level}</span>
              </a>
            </li>
          );
        })}
      </ul>
    )}
  </div>
</nav>

<script
  is:inline
  define:vars={{ tocId, toggleId, listId, defaultCollapsed, collapsible }}
>
  (function () {
    const nav = document.getElementById(tocId);
    if (!nav) return;

    if (collapsible) {
      const toggle = document.getElementById(toggleId);
      const list = document.getElementById(listId);
      if (toggle && list) {
        if (defaultCollapsed) {
          list.classList.add('toc__list--collapsed');
          toggle.setAttribute('aria-expanded', 'false');
          const icon = toggle.querySelector('svg');
          if (icon) icon.style.transform = 'rotate(-90deg)';
        }

        toggle.addEventListener('click', () => {
          const expanded = toggle.getAttribute('aria-expanded') === 'true';
          const nextState = !expanded;
          toggle.setAttribute('aria-expanded', String(nextState));
          list.classList.toggle('toc__list--collapsed', !nextState);
          nav.classList.toggle('toc--collapsed', !nextState);
          const icon = toggle.querySelector('svg');
          if (icon) icon.style.transform = nextState ? 'rotate(0deg)' : 'rotate(-90deg)';
          const srText = toggle.querySelector('.sr-only');
          if (srText) {
            srText.textContent = nextState
              ? 'Collapse table of contents'
              : 'Expand table of contents';
          }
        });
      }
    }

    const links = Array.from(nav.querySelectorAll('.toc__link'));
    if (!links.length) return;

    const linkMap = new Map();
    links.forEach((link) => {
      const href = link.getAttribute('href');
      if (href && href.startsWith('#')) {
        linkMap.set(href.slice(1), link);
      }
    });

    const observer = new IntersectionObserver(
      (entries) => {
        let maxRatio = 0;
        let activeEntry;
        entries.forEach((entry) => {
          if (entry.isIntersecting && entry.intersectionRatio > maxRatio) {
            maxRatio = entry.intersectionRatio;
            activeEntry = entry;
          }
        });

        if (activeEntry) {
          const activeHeadingId = activeEntry.target.id;
          links.forEach((link) => {
            link.classList.remove('toc__link--active');
            link.removeAttribute('aria-current');
          });
          const activeLink = linkMap.get(activeHeadingId);
          if (activeLink) {
            activeLink.classList.add('toc__link--active');
            activeLink.setAttribute('aria-current', 'location');
            const announcement = document.createElement('div');
            announcement.setAttribute('aria-live', 'polite');
            announcement.setAttribute('aria-atomic', 'true');
            announcement.className = 'sr-only';
            announcement.textContent = `Current section: ${activeLink.textContent?.trim()}`;
            document.body.appendChild(announcement);
            setTimeout(() => {
              document.body.removeChild(announcement);
            }, 1000);
          }
        }
      },
      {
        rootMargin: '-20% 0px -70% 0px',
        threshold: [0, 0.25, 0.5, 0.75, 1],
      }
    );

    linkMap.forEach((_, id) => {
      const element = document.getElementById(id);
      if (element) observer.observe(element);
    });

    const prefersReducedMotion = window.matchMedia(
      '(prefers-reduced-motion: reduce)'
    ).matches;

    links.forEach((link) => {
      link.addEventListener('click', (event) => {
        const href = link.getAttribute('href');
        if (href && href.startsWith('#')) {
          const target = document.getElementById(href.slice(1));
          if (target) {
            event.preventDefault();
            target.focus({ preventScroll: true });
            target.scrollIntoView({
              behavior: prefersReducedMotion ? 'auto' : 'smooth',
              block: 'start',
            });
          }
        }
      });
    });

    window.addEventListener('beforeunload', () => observer.disconnect());
  })();
</script>

<style>
  .toc {
    --toc-padding: 1rem;
    --toc-font-size: 0.95rem;
    --toc-title-size: 0.85rem;
    --toc-link-padding: 0.6rem 0.65rem;
    --toc-number-width: 2rem;
    --toc-border: rgba(148, 163, 184, 0.7);
    --toc-bg: #fff;
    --toc-color: #1f2937;
    --toc-hover-bg: rgba(59, 130, 246, 0.08);
    --toc-active-bg: rgba(59, 130, 246, 0.12);
    --toc-active-color: #1d4ed8;
    border-radius: 1rem;
    border: 1px solid var(--toc-border);
    background: var(--toc-bg);
    padding: var(--toc-padding);
    width: 100%;
    color: var(--toc-color);
    font-size: var(--toc-font-size);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: box-shadow 0.2s ease, border-color 0.2s ease;
  }

  :where(.dark) .toc {
    --toc-border: rgba(71, 85, 105, 0.7);
    --toc-bg: #0f172a;
    --toc-color: #e2e8f0;
    --toc-hover-bg: rgba(148, 163, 184, 0.15);
    --toc-active-bg: rgba(59, 130, 246, 0.2);
    --toc-active-color: #93c5fd;
  }

  .toc--variant-compact {
    background: rgba(241, 245, 249, 0.7);
  }

  :where(.dark) .toc--variant-compact {
    background: rgba(15, 23, 42, 0.7);
  }

  .toc--variant-minimal {
    border-color: transparent;
    background: transparent;
    box-shadow: none;
  }

  .toc--variant-elevated {
    box-shadow: 0 15px 40px rgba(15, 23, 42, 0.18);
  }

  .toc--size-sm {
    --toc-padding: 0.75rem;
    --toc-font-size: 0.85rem;
    --toc-title-size: 0.75rem;
    --toc-link-padding: 0.4rem 0.5rem;
  }

  .toc--size-lg {
    --toc-padding: 1.25rem;
    --toc-font-size: 1rem;
    --toc-title-size: 0.95rem;
    --toc-link-padding: 0.75rem 0.9rem;
  }

  .toc--sticky {
    position: sticky;
    top: 1rem;
    max-height: calc(100vh - 2rem);
    overflow-y: auto;
  }

  .toc__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .toc__title {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: var(--toc-title-size);
    font-weight: 700;
    color: inherit;
  }

  .toc__toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border: none;
    border-radius: 0.5rem;
    background: transparent;
    color: inherit;
    cursor: pointer;
    transition: background 0.2s ease;
  }

  .toc__toggle:hover {
    background: var(--toc-hover-bg);
  }

  .toc__toggle:focus-visible {
    outline: 2px solid rgba(59, 130, 246, 0.4);
    outline-offset: 2px;
  }

  .toc__toggle-icon {
    width: 1rem;
    height: 1rem;
    transition: transform 0.2s ease;
  }

  .toc__list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .toc__list--collapsed {
    display: none;
  }

  .toc__items {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .toc__item {
    margin-left: var(--toc-indent, 0);
  }

  .toc__link {
    display: inline-flex;
    align-items: flex-start;
    gap: 0.5rem;
    width: 100%;
    padding: var(--toc-link-padding);
    border-radius: 0.65rem;
    text-decoration: none;
    color: inherit;
    background: transparent;
    border-left: 2px solid transparent;
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }

  .toc__link:hover {
    background: var(--toc-hover-bg);
  }

  .toc__link--active {
    background: var(--toc-active-bg);
    color: var(--toc-active-color);
    border-left-color: var(--toc-active-color);
    font-weight: 600;
  }

  .toc__number {
    width: var(--toc-number-width);
    flex-shrink: 0;
    color: rgba(100, 116, 139, 0.9);
    font-weight: 600;
  }

  .toc__label {
    flex: 1;
    line-height: 1.4;
  }

  .toc__message {
    font-style: italic;
    color: rgba(100, 116, 139, 0.9);
    padding: 0.5rem 0;
  }

  :where(.dark) .toc__message,
  :where(.dark) .toc__number {
    color: rgba(148, 163, 184, 0.85);
  }

  .toc--collapsible.toc--collapsed .toc__toggle-icon {
    transform: rotate(-90deg);
  }

  .toc:focus-within {
    box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.25);
  }

  @media (prefers-contrast: high) {
    .toc {
      border-color: currentColor;
    }

    .toc__link {
      border-left-width: 2px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .toc *,
    .toc__toggle-icon {
      transition: none !important;
    }
  }
</style>
