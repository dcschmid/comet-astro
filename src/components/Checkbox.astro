---
interface Props {
  name: string;
  label?: string;
  value?: string;
  checked?: boolean;
  indeterminate?: boolean;
  disabled?: boolean;
  required?: boolean;
  helperText?: string;
  error?: string;
  size?: 'sm' | 'md' | 'lg';
  ariaLabel?: string; // for icon-only / no visible label use
  className?: string;
  id?: string;
}

const {
  name,
  label,
  value,
  checked = false,
  indeterminate = false,
  disabled = false,
  required = false,
  helperText,
  error,
  size = 'md',
  ariaLabel,
  className = '',
  id = name + (value ? `-${value}` : ''),
} = Astro.props as Props;

// Size map (box + label spacing)
const sizeKey = size ?? 'md';
const classes = [
  'checkbox',
  `checkbox--size-${sizeKey}`,
  indeterminate ? 'checkbox--indeterminate' : '',
  error ? 'checkbox--error' : '',
  disabled ? 'checkbox--disabled' : '',
  className,
]
  .filter(Boolean)
  .join(' ');

const inputClasses = [
  'checkbox__input',
  indeterminate ? 'checkbox__input--indeterminate' : '',
  error ? 'checkbox__input--error' : '',
  disabled ? 'checkbox__input--disabled' : '',
].join(' ');

// Helper/error description id
const descriptionId = error || helperText ? `${id}-desc` : undefined;

// We render native checkbox for a11y. Indeterminate set via script once (progressive enhancement)
const script = indeterminate
  ? `<script>document.getElementById('${id}')?.indeterminate = true;</script>`
  : '';
---

<div class={classes}>
  <input
    type="checkbox"
    id={id}
    name={name}
    value={value}
    checked={checked}
    disabled={disabled}
    required={required}
    aria-invalid={error ? 'true' : undefined}
    aria-describedby={descriptionId}
    aria-label={!label && ariaLabel ? ariaLabel : undefined}
    class={inputClasses}
  />
  {
    label && (
      <label for={id} class="checkbox__label">
        {label}
        {required && <span class="ml-1 text-rose-500">*</span>}
      </label>
    )
  }
  <div class="checkbox__messages">
    {
      error && (
        <p id={descriptionId} class="checkbox__error">
          {error}
        </p>
      )
    }
    {
      !error && helperText && (
        <p id={descriptionId} class="checkbox__helper">
          {helperText}
        </p>
      )
    }
  </div>
  {indeterminate && <Fragment set:html={script} />}
</div>

<style is:inline>
  .checkbox {
    display: flex;
    gap: 0.5rem;
    align-items: flex-start;
    color: #0f172a;
  }

  :where(.dark) .checkbox {
    color: #f8fafc;
  }

  .checkbox--size-sm {
    gap: 0.35rem;
  }

  .checkbox--size-md {
    gap: 0.45rem;
  }

  .checkbox--size-lg {
    gap: 0.5rem;
  }

  .checkbox__input {
    appearance: none;
    border-radius: 0.2rem;
    border: 1px solid rgba(71, 85, 105, 0.9);
    background: #ffffff;
    width: 1.1rem;
    height: 1.1rem;
    margin-top: 0.2rem;
    cursor: pointer;
    transition: background-color 0.2s ease, border-color 0.2s ease;
  }

  .checkbox--size-sm .checkbox__input {
    width: 1rem;
    height: 1rem;
  }

  .checkbox--size-lg .checkbox__input {
    width: 1.3rem;
    height: 1.3rem;
  }

  :where(.dark) .checkbox__input {
    background: #0f172a;
    border-color: rgba(148, 163, 184, 0.7);
  }

  .checkbox__input:checked {
    background: #2563eb;
    border-color: #2563eb;
    box-shadow: inset 0 0 0 2px #ffffff;
  }

  :where(.dark) .checkbox__input:checked {
    border-color: #60a5fa;
    background: #60a5fa;
    box-shadow: inset 0 0 0 2px #0f172a;
  }

  .checkbox__input:focus-visible {
    outline: 2px solid rgba(59, 130, 246, 0.65);
    outline-offset: 2px;
  }

  .checkbox__input--indeterminate {
    background: #2563eb;
    border-color: #2563eb;
    box-shadow: inset 0 0 0 2px #ffffff;
  }

  :where(.dark) .checkbox__input--indeterminate {
    background: #60a5fa;
    border-color: #60a5fa;
    box-shadow: inset 0 0 0 2px #0f172a;
  }

  .checkbox__input--error {
    border-color: #dc2626;
  }

  :where(.dark) .checkbox__input--error {
    border-color: #fb7185;
  }

  .checkbox__input--disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .checkbox__label {
    font-size: 0.9rem;
    line-height: 1.4;
    cursor: pointer;
  }

  .checkbox--size-sm .checkbox__label {
    font-size: 0.8rem;
  }

  .checkbox--size-lg .checkbox__label {
    font-size: 1rem;
  }

  .checkbox--disabled .checkbox__label {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .checkbox__messages {
    display: flex;
    flex-direction: column;
  }

  .checkbox__error {
    margin-top: 0.2rem;
    font-size: 0.75rem;
    color: #dc2626;
  }

  :where(.dark) .checkbox__error {
    color: #fb7185;
  }

  .checkbox__helper {
    margin-top: 0.2rem;
    font-size: 0.75rem;
    color: rgba(15, 23, 42, 0.75);
  }

  :where(.dark) .checkbox__helper {
    color: rgba(248, 250, 252, 0.7);
  }
</style>
