---
import { cn } from '../utils/cn';

interface Props {
  /** Custom CSS classes */
  class?: string;
  /** Apply container styling to main content */
  container?: boolean;
  /** Layout variant - controls spacing and structure */
  variant?: 'default' | 'wide' | 'narrow' | 'sidebar';
  /** Background theme */
  background?: 'default' | 'muted' | 'accent' | 'gradient';
  /** Content spacing size */
  spacing?: 'tight' | 'normal' | 'loose';
  /** Enable sticky header */
  stickyHeader?: boolean;
  /** Enable sticky footer */
  stickyFooter?: boolean;
  /** Sidebar position for sidebar variant */
  sidebarPosition?: 'left' | 'right';
  /** Maximum content width */
  maxWidth?: 'sm' | 'md' | 'lg' | 'xl' | '2xl' | 'full';
  /** Skip to main content label for accessibility */
  skipToMainLabel?: string;
  /** Aria label for main content area */
  mainAriaLabel?: string;
  /** Header aria label */
  headerAriaLabel?: string;
  /** Footer aria label */
  footerAriaLabel?: string;
}

const {
  class: className,
  container = true,
  variant = 'default',
  background = 'default',
  spacing = 'normal',
  stickyHeader = false,
  stickyFooter = false,
  sidebarPosition = 'left',
  maxWidth = 'lg',
  skipToMainLabel = 'Skip to main content',
  mainAriaLabel = 'Main content',
  headerAriaLabel = 'Site header',
  footerAriaLabel = 'Site footer',
} = Astro.props as Props;

const rootClasses = cn(
  'layout',
  `layout--variant-${variant}`,
  `layout--background-${background}`,
  `layout--spacing-${spacing}`,
  `layout--max-${maxWidth}`,
  stickyHeader ? 'layout--sticky-header' : '',
  stickyFooter ? 'layout--sticky-footer' : '',
  variant === 'sidebar' ? `layout--sidebar-${sidebarPosition}` : '',
  container ? 'layout--container' : 'layout--fluid',
  'text-slate-900 dark:text-slate-100',
  className
);
const headerClasses = cn('layout__header', stickyHeader && 'layout__header--sticky');
const footerClasses = cn('layout__footer', stickyFooter && 'layout__footer--sticky');
const mainClasses = cn(
  'layout__main',
  container ? 'layout__main--container' : 'layout__main--fluid',
  stickyHeader && 'layout__main--with-sticky-header',
  stickyFooter && 'layout__main--with-sticky-footer'
);
const sidebarClasses = [
  'layout__sidebar',
  sidebarPosition === 'right' ? 'layout__sidebar--right' : 'layout__sidebar--left',
].join(' ');

// Generate unique IDs for skip links
const skipLinkId = `main-content-${Math.random().toString(36).substr(2, 9)}`;
---

<!-- Skip to main content link for accessibility -->
<a
  href={`#${skipLinkId}`}
  class={cn(
    'sr-only focus:not-sr-only',
    'absolute top-4 left-4 z-50',
    'px-4 py-2 rounded-md',
    'bg-blue-600 text-white',
    'hover:bg-blue-700 focus:bg-blue-700',
    'transition-colors duration-200',
    'text-sm font-medium',
    'focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2'
  )}
>
  {skipToMainLabel}
</a>

<div class={rootClasses}>
  <header class={headerClasses} aria-label={headerAriaLabel} role="banner">
    <slot name="header" />
  </header>

  {
    variant === 'sidebar' && (
      <aside class={sidebarClasses} aria-label="Sidebar navigation" role="complementary">
        <slot name="sidebar" />
      </aside>
    )
  }

  <main
    id={skipLinkId}
    class={mainClasses}
    aria-label={mainAriaLabel}
    role="main"
    tabindex="-1"
  >
    <slot />
  </main>

  <footer class={footerClasses} aria-label={footerAriaLabel} role="contentinfo">
    <slot name="footer" />
  </footer>
</div>

<style is:inline>
  .layout {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    color: #0f172a;
    background-color: #ffffff;
  }

  .layout--spacing-tight {
    gap: 1rem;
  }

  .layout--spacing-loose {
    gap: 2rem;
  }

  .layout--variant-sidebar {
    flex-direction: column;
  }

  .layout--variant-sidebar.layout--sidebar-left {
    flex-direction: column;
  }

  @media (min-width: 1024px) {
    .layout--variant-sidebar.layout--sidebar-left {
      flex-direction: row;
    }

    .layout--variant-sidebar.layout--sidebar-right {
      flex-direction: row-reverse;
    }
  }

  .layout__header,
  .layout__footer {
    width: 100%;
  }

  .layout__header--sticky {
    position: sticky;
    top: 0;
    z-index: 40;
    background-color: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid rgba(226, 232, 240, 0.8);
  }

  .layout__footer--sticky {
    position: sticky;
    bottom: 0;
    z-index: 40;
    background-color: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(8px);
    border-top: 1px solid rgba(226, 232, 240, 0.8);
  }

  .layout__main {
    flex: 1;
    outline: none;
    width: 100%;
  }

  .layout__main--container {
    max-width: 72rem;
    margin: 0 auto;
    padding: 1rem 1.5rem;
  }

  .layout__main--fluid {
    padding: 1rem 1.5rem;
  }

  .layout__main--with-sticky-header {
    padding-top: 1.25rem;
  }

  .layout__main--with-sticky-footer {
    padding-bottom: 1.25rem;
  }

  .layout--variant-sidebar {
    display: flex;
    gap: 1.5rem;
  }

  .layout__sidebar {
    width: 100%;
    max-width: 20rem;
    background-color: #f1f5f9;
    padding: 1rem;
  }

  .layout--variant-sidebar.layout--sidebar-left .layout__sidebar {
    border-right: 1px solid #e2e8f0;
  }

  .layout--variant-sidebar.layout--sidebar-right .layout__sidebar {
    border-left: 1px solid #e2e8f0;
  }

  .layout--background-muted {
    background-color: #f8fafc;
  }

  .layout--background-accent {
    background-color: #eff6ff;
  }

  .layout--background-gradient {
    background-image: linear-gradient(135deg, #f8fafc, #dbeafe);
  }

  .layout--max-sm .layout__main--container {
    max-width: 48rem;
  }

  .layout--max-md .layout__main--container {
    max-width: 60rem;
  }

  .layout--max-xl .layout__main--container {
    max-width: 80rem;
  }

  .layout--max-2xl .layout__main--container {
    max-width: 90rem;
  }

  .layout--max-full .layout__main--container {
    max-width: none;
  }

  .layout--variant-wide .layout__main--container {
    max-width: 90rem;
  }

  .layout--variant-narrow .layout__main--container {
    max-width: 50rem;
  }

  :where(.dark) .layout {
    color: #f8fafc;
    background-color: #020617;
  }

  :where(.dark) .layout--background-muted {
    background-color: #0f172a;
  }

  :where(.dark) .layout--background-accent {
    background-color: rgba(59, 130, 246, 0.1);
  }

  :where(.dark) .layout--background-gradient {
    background-image: linear-gradient(135deg, #020617, #1e3a8a);
  }

  :where(.dark) .layout__header--sticky,
  :where(.dark) .layout__footer--sticky {
    background-color: rgba(2, 6, 23, 0.9);
    border-color: rgba(51, 65, 85, 0.8);
  }
</style>
