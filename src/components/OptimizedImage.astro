---
/**
 * OptimizedImage - Enhanced responsive image with WCAG AAA compliance
 */

interface Props {
  // Required
  src: string;
  alt: string;
  
  // Dimensions
  width?: number | string;
  height?: number | string;
  
  // Responsive
  sizes?: string;
  srcset?: string;
  
  // Performance
  loading?: 'eager' | 'lazy';
  decoding?: 'async' | 'sync' | 'auto';
  fetchPriority?: 'high' | 'low' | 'auto';
  
  // Styling
  variant?: 'default' | 'rounded' | 'circle' | 'bordered';
  aspectRatio?: '1/1' | '4/3' | '3/2' | '16/9' | '21/9' | 'auto';
  objectFit?: 'contain' | 'cover' | 'fill' | 'none' | 'scale-down';
  
  // Layout
  figure?: boolean;
  caption?: string;
  captionPosition?: 'bottom' | 'top' | 'overlay';
  
  // Accessibility
  role?: string;
  ariaDescribedBy?: string;
  
  // Error handling
  errorFallback?: string;
  placeholder?: boolean;
  
  // Classes
  class?: string;
  className?: string;
}

const {
  src,
  alt,
  width,
  height,
  sizes = '100vw',
  srcset,
  loading = 'lazy',
  decoding = 'async',
  fetchPriority = 'auto',
  variant = 'default',
  aspectRatio = 'auto',
  objectFit = 'cover',
  figure = false,
  caption,
  captionPosition = 'bottom',
  role,
  ariaDescribedBy,
  errorFallback,
  placeholder = true,
  class: className,
  className: legacyClassName
} = Astro.props;

const userClasses = [className, legacyClassName].filter(Boolean).join(' ');

const imageId = `comet-img-${Math.random().toString(36).slice(2, 9)}`;
const captionId = caption ? `${imageId}-caption` : undefined;
const widthAttr =
  typeof width === 'number' || typeof width === 'string' ? width : undefined;
const heightAttr =
  typeof height === 'number' || typeof height === 'string' ? height : undefined;

const rootClasses = [
  'optimized-image',
  `optimized-image--variant-${variant}`,
  `optimized-image--aspect-${aspectRatio.replace('/', '-')}`,
  `optimized-image--object-${objectFit}`,
  caption ? `optimized-image--caption-${captionPosition}` : '',
  figure ? 'optimized-image--figure' : '',
  userClasses,
]
  .filter(Boolean)
  .join(' ');

// Error handling script
const errorScript = errorFallback ? `
  document.addEventListener('DOMContentLoaded', () => {
    const img = document.getElementById('${imageId}');
    if (img) {
      img.addEventListener('error', () => {
        img.src = '${errorFallback}';
        img.alt = '${alt} (fallback image)';
      });
    }
  });
` : '';
---

{figure ? (
  <figure class={rootClasses}>
    {caption && captionPosition === 'top' && (
      <figcaption 
        id={captionId}
        class="optimized-image__caption"
      >
        {caption}
      </figcaption>
    )}
    
    <img
      id={imageId}
      src={src}
      alt={alt}
      width={widthAttr}
      height={heightAttr}
      loading={loading}
      decoding={decoding}
      fetchpriority={fetchPriority}
      sizes={sizes}
      srcset={srcset}
      class="optimized-image__media"
      role={role}
      aria-describedby={ariaDescribedBy || captionId}
    />
    
    {caption && (captionPosition === 'bottom' || captionPosition === 'overlay') && (
      <figcaption 
        id={captionId}
        class="optimized-image__caption"
      >
        {caption}
      </figcaption>
    )}
  </figure>
) : (
  <img
    id={imageId}
    src={src}
    alt={alt}
    width={widthAttr}
    height={heightAttr}
    loading={loading}
    decoding={decoding}
    fetchpriority={fetchPriority}
    sizes={sizes}
    srcset={srcset}
    class="optimized-image__media optimized-image__media--standalone"
    role={role}
    aria-describedby={ariaDescribedBy}
  />
)}

{errorFallback && (
  <script is:inline set:html={errorScript} />
)}

<style>
  .optimized-image {
    display: inline-flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .optimized-image--caption-overlay {
    position: relative;
    display: inline-block;
  }

  .optimized-image__media {
    display: block;
    max-width: 100%;
    height: auto;
    border-radius: 1rem;
    transition: transform 0.3s ease;
  }

  .optimized-image--variant-circle .optimized-image__media {
    border-radius: 999px;
  }

  .optimized-image--variant-bordered .optimized-image__media {
    border: 2px solid rgba(148, 163, 184, 0.5);
  }

  .optimized-image--aspect-1-1 .optimized-image__media {
    aspect-ratio: 1 / 1;
  }

  .optimized-image--aspect-4-3 .optimized-image__media {
    aspect-ratio: 4 / 3;
  }

  .optimized-image--aspect-3-2 .optimized-image__media {
    aspect-ratio: 3 / 2;
  }

  .optimized-image--aspect-16-9 .optimized-image__media {
    aspect-ratio: 16 / 9;
  }

  .optimized-image--aspect-21-9 .optimized-image__media {
    aspect-ratio: 21 / 9;
  }

  .optimized-image--object-contain .optimized-image__media {
    object-fit: contain;
  }

  .optimized-image--object-cover .optimized-image__media {
    object-fit: cover;
  }

  .optimized-image--object-fill .optimized-image__media {
    object-fit: fill;
  }

  .optimized-image--object-none .optimized-image__media {
    object-fit: none;
  }

  .optimized-image--object-scale-down .optimized-image__media {
    object-fit: scale-down;
  }

  .optimized-image__caption {
    font-size: 0.9rem;
    color: #475569;
  }

  .optimized-image--caption-overlay .optimized-image__caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    margin: 0;
    padding: 0.75rem;
    background: rgba(15, 23, 42, 0.75);
    color: #f8fafc;
    backdrop-filter: blur(6px);
  }

  :where(.dark) .optimized-image__caption {
    color: #cbd5f5;
  }
</style>

{placeholder && (
  <style set:html={`
    #${imageId} {
      background-color: #f3f4f6;
      background-image: 
        linear-gradient(45deg, #e5e7eb 25%, transparent 25%),
        linear-gradient(-45deg, #e5e7eb 25%, transparent 25%),
        linear-gradient(45deg, transparent 75%, #e5e7eb 75%),
        linear-gradient(-45deg, transparent 75%, #e5e7eb 75%);
      background-size: 20px 20px;
      background-position: 0 0, 0 10px, 10px -10px, -10px 0px;
    }
    
    .dark #${imageId} {
      background-color: #374151;
      background-image: 
        linear-gradient(45deg, #4b5563 25%, transparent 25%),
        linear-gradient(-45deg, #4b5563 25%, transparent 25%),
        linear-gradient(45deg, transparent 75%, #4b5563 75%),
        linear-gradient(-45deg, transparent 75%, #4b5563 75%);
    }
    
    #${imageId}.loaded {
      background-image: none;
      background-color: transparent;
    }
  `} />
)}

{placeholder && (
  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const img = document.getElementById('{imageId}');
      if (img) {
        if (img.complete) {
          img.classList.add('loaded');
        } else {
          img.addEventListener('load', () => {
            img.classList.add('loaded');
          });
        }
      }
    });
  </script>
)}
