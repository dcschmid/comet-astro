---
/**
 * Breadcrumbs - navigation trail
 */
interface Crumb {
  href?: string;
  label: string;
  current?: boolean;
}

interface Props {
  items: Crumb[];
  ariaLabel?: string;
  className?: string;
}

const {
  items = [],
  ariaLabel = 'Breadcrumb',
  className = '',
} = Astro.props as Props;

const rootClasses = ['breadcrumbs', className].filter(Boolean).join(' ');
---

<nav
  aria-label={ariaLabel}
  class={rootClasses}
>
  <ol class="breadcrumbs__list">
    {
      items.map((c, i) => (
        <li class="breadcrumbs__item">
          {i > 0 && (
            <span aria-hidden="true" class="breadcrumbs__separator">
              /
            </span>
          )}
          {c.current || !c.href ? (
            <span
              aria-current={c.current ? 'page' : undefined}
              class="breadcrumbs__current"
            >
              {c.label}
            </span>
          ) : (
            <a href={c.href} class="breadcrumbs__link">
              {c.label}
            </a>
          )}
        </li>
      ))
    }
  </ol>
</nav>

<style is:inline>
  .breadcrumbs {
    --breadcrumbs-text: #0f172a;
    --breadcrumbs-muted: #475569;
    --breadcrumbs-link: #0f172a;
    --breadcrumbs-link-hover: #1d4ed8;
    --breadcrumbs-current: #020617;
    --breadcrumbs-focus-ring: rgba(59, 130, 246, 0.45);
    max-width: 100%;
    overflow-x: auto;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--breadcrumbs-text);
  }

  :where(.dark) .breadcrumbs {
    --breadcrumbs-text: #e2e8f0;
    --breadcrumbs-muted: #cbd5f5;
    --breadcrumbs-link: #e2e8f0;
    --breadcrumbs-link-hover: #93c5fd;
    --breadcrumbs-current: #ffffff;
    --breadcrumbs-focus-ring: rgba(147, 197, 253, 0.45);
  }

  .breadcrumbs__list {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    gap: 0.5rem;
    white-space: nowrap;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .breadcrumbs__item {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: inherit;
  }

  .breadcrumbs__separator {
    color: var(--breadcrumbs-muted);
    font-size: 0.85em;
  }

  .breadcrumbs__link {
    color: var(--breadcrumbs-link);
    padding: 0.2rem 0.45rem;
    border-radius: 0.45rem;
    text-decoration: none;
    transition:
      color 0.15s ease,
      background-color 0.15s ease;
  }

  .breadcrumbs__link:hover {
    color: var(--breadcrumbs-link-hover);
    background: rgba(59, 130, 246, 0.08);
  }

  .breadcrumbs__link:focus-visible {
    outline: 2px solid var(--breadcrumbs-focus-ring);
    outline-offset: 2px;
  }

  .breadcrumbs__current {
    font-weight: 600;
    color: var(--breadcrumbs-current);
  }
</style>
