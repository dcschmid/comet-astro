---
/**
 * Skeleton - Accessible animated placeholder with WCAG AAA compliance
 * Provides visual feedback during content loading with proper contrast ratios
*/

interface Props {
  /** Width of the skeleton */
  width?: string;
  /** Height of the skeleton */
  height?: string;
  /** Visual variant of the skeleton */
  variant?: 'default' | 'circle' | 'rectangle' | 'text' | 'card';
  /** Size preset for common use cases */
  size?: 'sm' | 'md' | 'lg' | 'xl';
  /** Animation type */
  animation?: 'pulse' | 'wave' | 'none';
  /** Custom border radius */
  rounded?: 'none' | 'sm' | 'md' | 'lg' | 'full';
  /** Loading text for screen readers */
  loadingText?: string;
  /** Number of lines for text variant */
  lines?: number;
  /** Additional CSS classes */
  class?: string;
}

const {
  width,
  height,
  variant = 'default',
  size = 'md',
  animation = 'pulse',
  rounded = 'md',
  loadingText = 'Loading content',
  lines = 3,
  class: className = '',
} = Astro.props;

const rootClass = [
  'skeleton',
  `skeleton--variant-${variant}`,
  `skeleton--size-${size}`,
  `skeleton--rounded-${rounded}`,
  `skeleton--animation-${animation}`,
  className,
]
  .filter(Boolean)
  .join(' ');

// Custom styles for width/height overrides
const customStyles = {
  ...(width && { width }),
  ...(height && { height }),
};

// Generate unique ID for accessibility
const skeletonId = `skeleton-${Math.random().toString(36).slice(2, 9)}`;
---

{
  variant === 'text' && lines > 1 ? (
    <div
      role="status"
      aria-live="polite"
      aria-label={loadingText}
      class="skeleton-group"
    >
      {Array.from({ length: lines }, (_, index) => (
        <div
          key={index}
          id={`${skeletonId}-line-${index}`}
          class={`${rootClass} ${index === lines - 1 ? 'skeleton--short-line' : ''}`.trim()}
          style={customStyles}
          aria-hidden="true"
        />
      ))}
      <span class="sr-only">{loadingText}</span>
    </div>
  ) : (
    <div
      role="status"
      aria-live="polite"
      aria-label={loadingText}
      id={skeletonId}
      class={rootClass}
      style={customStyles}
      aria-hidden="false"
    >
      <span class="sr-only">{loadingText}</span>
    </div>
  )
}

<style>
  .skeleton {
    display: block;
    width: 100%;
    margin: 0;
    border-radius: 0.75rem;
    border: 1px solid rgba(148, 163, 184, 0.6);
    background-color: #e2e8f0;
    position: relative;
    overflow: hidden;
    transition: background-color 0.2s ease;
  }

  .skeleton--variant-circle {
    border-radius: 999px;
    aspect-ratio: 1 / 1;
  }

  .skeleton--variant-card {
    height: 12rem;
    border-radius: 1rem;
  }

  .skeleton--variant-text {
    height: 0.9rem;
    border-radius: 0.4rem;
  }

  .skeleton--variant-rectangle {
    border-radius: 0.75rem;
  }

  .skeleton--size-sm {
    height: 1rem;
  }

  .skeleton--size-md {
    height: 1.5rem;
  }

  .skeleton--size-lg {
    height: 2rem;
  }

  .skeleton--size-xl {
    height: 3rem;
  }

  .skeleton--variant-circle.skeleton--size-sm {
    width: 2rem;
    height: 2rem;
  }

  .skeleton--variant-circle.skeleton--size-md {
    width: 3rem;
    height: 3rem;
  }

  .skeleton--variant-circle.skeleton--size-lg {
    width: 4rem;
    height: 4rem;
  }

  .skeleton--variant-circle.skeleton--size-xl {
    width: 6rem;
    height: 6rem;
  }

  .skeleton--variant-text.skeleton--size-sm {
    height: 0.75rem;
  }

  .skeleton--variant-text.skeleton--size-md {
    height: 0.95rem;
  }

  .skeleton--variant-text.skeleton--size-lg {
    height: 1.1rem;
  }

  .skeleton--variant-text.skeleton--size-xl {
    height: 1.35rem;
  }

  .skeleton--variant-card.skeleton--size-sm {
    height: 8rem;
  }

  .skeleton--variant-card.skeleton--size-md {
    height: 12rem;
  }

  .skeleton--variant-card.skeleton--size-lg {
    height: 16rem;
  }

  .skeleton--variant-card.skeleton--size-xl {
    height: 20rem;
  }

  .skeleton--rounded-none {
    border-radius: 0;
  }

  .skeleton--rounded-sm {
    border-radius: 0.25rem;
  }

  .skeleton--rounded-md {
    border-radius: 0.5rem;
  }

  .skeleton--rounded-lg {
    border-radius: 0.75rem;
  }

  .skeleton--rounded-full {
    border-radius: 999px;
  }

  .skeleton--animation-pulse {
    animation: skeletonPulse 1.5s ease-in-out infinite;
  }

  .skeleton--animation-wave::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      rgba(255, 255, 255, 0),
      rgba(255, 255, 255, 0.4),
      rgba(255, 255, 255, 0)
    );
    background-size: 200px 100%;
    animation: shimmer 1.5s infinite;
  }

  .skeleton--animation-none,
  .skeleton--animation-none::after {
    animation: none;
  }

  .skeleton-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .skeleton--short-line {
    width: 70%;
  }

  @keyframes skeletonPulse {
    0% {
      opacity: 1;
    }
    50% {
      opacity: 0.45;
    }
    100% {
      opacity: 1;
    }
  }

  @keyframes shimmer {
    0% {
      background-position: -200px 0;
    }
    100% {
      background-position: calc(200px + 100%) 0;
    }
  }

  :where(.dark) .skeleton {
    background-color: #1f2937;
    border-color: rgba(148, 163, 184, 0.4);
  }

  :where(.dark) .skeleton--animation-wave::after {
    background: linear-gradient(
      90deg,
      rgba(255, 255, 255, 0),
      rgba(255, 255, 255, 0.15),
      rgba(255, 255, 255, 0)
    );
  }

  @media (prefers-reduced-motion: reduce) {
    .skeleton,
    .skeleton::after {
      animation: none;
    }
  }

  @media (prefers-contrast: high) {
    .skeleton {
      background-color: #d1d5db;
      border-color: #6b7280;
    }

    :where(.dark) .skeleton {
      background-color: #374151;
      border-color: #9ca3af;
    }
  }
</style>
