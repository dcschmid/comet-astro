---
/**
 * CurrentWeather – Minimal Astro component with dedicated BEM CSS.
 * Focus: WCAG AAA contrast, semantic structure, no overengineering.
 * Optional client fetch if latitude & longitude provided.
 */
interface Props {
  latitude?: number;
  longitude?: number;
  location?: string;
  unit?: 'c' | 'f';
  showDetails?: boolean; // humidity & wind
  refreshInterval?: number; // minutes (0 = no auto refresh)
  disableFetch?: boolean; // Force static mode even if coordinates provided
  class?: string;
  ariaLabel?: string;
}

const {
  latitude,
  longitude,
  location = 'Demo Location',
  unit = 'c',
  showDetails = true,
  refreshInterval = 0,
  disableFetch = false,
  class: className = '',
  ariaLabel,
  ...rest
} = Astro.props as Props;

// Fallback demo values (will be replaced if fetch succeeds)
const fallback = {
  temperatureC: 18.4,
  temperatureF: 65.1,
  humidity: 62,
  windKph: 14,
  windDir: 'NW',
  condition: 'Partly cloudy',
  isDay: true,
};

const label = ariaLabel || `Current weather for ${location}`;
const baseClasses = [
  'current-weather',
  showDetails ? 'current-weather--has-details' : 'current-weather--compact',
  latitude && longitude && !disableFetch
    ? 'current-weather--interactive'
    : 'current-weather--static',
  className,
]
  .filter(Boolean)
  .join(' ');
const tempUnitSymbol = unit === 'c' ? '°C' : '°F';
const tempValue =
  unit === 'c'
    ? Math.round(fallback.temperatureC)
    : Math.round(fallback.temperatureF);
const windDisplay = `${fallback.windKph} km/h ${fallback.windDir}`;
const iconMap: Record<string, string> = {
  Clear: '☀️',
  'Mainly clear': '🌤️',
  'Partly cloudy': '⛅',
  Overcast: '☁️',
  Rain: '🌧️',
  Snow: '❄️',
};
const emoji = iconMap[fallback.condition] || '⛅';
---

<div
  class={baseClasses}
  role="region"
  aria-label={label}
  aria-busy={latitude && longitude && !disableFetch ? 'true' : 'false'}
  data-current-weather
  data-unit={unit}
  data-refresh={refreshInterval}
  data-lat={latitude}
  data-lon={longitude}
  data-disable-fetch={disableFetch}
  data-state={latitude && longitude && !disableFetch ? 'loading' : 'static'}
  {...rest}
>
  <header class="current-weather__header">
    <h2 class="current-weather__title">
      <span aria-hidden="true" class="current-weather__title-icon">📍</span>
      <span class="current-weather__location" data-location>{location}</span>
    </h2>
    <p class="current-weather__meta" aria-live="polite" data-updated>
      {
        latitude && longitude && !disableFetch
          ? 'Loading live data…'
          : 'Demo data (static)'
      }
    </p>
  </header>

  <div class="current-weather__body">
    <div class="current-weather__summary">
      <div
        class="current-weather__emoji"
        role="img"
        aria-label={fallback.condition}
        data-icon
      >
        {emoji}
      </div>
      <div class="current-weather__reading">
        <span class="current-weather__temperature" data-temp
          >{tempValue}{tempUnitSymbol}</span
        >
        <span class="current-weather__condition" data-condition
          >{fallback.condition}</span
        >
      </div>
      <span class="current-weather__badge" data-daynight
        >{fallback.isDay ? 'Daytime' : 'Night'}</span
      >
      <div
        class="current-weather__indicator current-weather__indicator--loading"
        data-loading-indicator
      >
        Loading…
      </div>
      <div
        class="current-weather__indicator current-weather__indicator--error"
        data-error-indicator
      >
        Error loading data (showing fallback)
      </div>
    </div>

    <div class="current-weather__details">
      {
        showDetails && (
          <div class="current-weather__details-grid" data-details>
            <div class="current-weather__metric" role="group" aria-label="Humidity">
              <span class="current-weather__metric-label">Humidity</span>
              <span class="current-weather__metric-value" data-humidity>
                {fallback.humidity}%
              </span>
            </div>
            <div class="current-weather__metric" role="group" aria-label="Wind">
              <span class="current-weather__metric-label">Wind</span>
              <span class="current-weather__metric-value" data-wind>
                {windDisplay}
              </span>
            </div>
            <div
              class="current-weather__metric"
              role="group"
              aria-label="Feels like"
            >
              <span class="current-weather__metric-label">Feels Like</span>
              <span class="current-weather__metric-value" data-feels>
                {tempValue}
                {tempUnitSymbol}
              </span>
            </div>
          </div>
        )
      }
    </div>
  </div>

  <footer class="current-weather__footer">
    <span class="current-weather__source"
      >Data source:
      <a
        href="https://open-meteo.com"
        class="current-weather__link"
        >Open‑Meteo</a
      ></span
    >
    <span class="current-weather__refresh" data-refresh-indicator
      >{
        refreshInterval > 0
          ? `Auto refresh ${refreshInterval}m`
          : 'Manual refresh'
      }</span
    >
  </footer>
</div>
<script>
  const codeToCondition = (code) => {
    // Simplified mapping for Open-Meteo weather codes
    const map = {
      0: 'Clear',
      1: 'Mainly clear',
      2: 'Partly cloudy',
      3: 'Overcast',
      45: 'Fog',
      48: 'Depositing rime fog',
      51: 'Drizzle',
      53: 'Drizzle',
      55: 'Drizzle',
      61: 'Rain',
      63: 'Rain',
      65: 'Rain',
      71: 'Snow',
      73: 'Snow',
      75: 'Snow',
      77: 'Snow grains',
      80: 'Rain showers',
      81: 'Rain showers',
      82: 'Rain showers',
      95: 'Thunderstorm',
      96: 'Thunderstorm',
      99: 'Thunderstorm',
    };
    return map[code] || 'Unknown';
  };

  const conditionToEmoji = (condition) => {
    const m = {
      Clear: '☀️',
      'Mainly clear': '🌤️',
      'Partly cloudy': '⛅',
      Overcast: '☁️',
      Rain: '🌧️',
      'Rain showers': '🌦️',
      Snow: '❄️',
      Thunderstorm: '⛈️',
      Fog: '🌫️',
    };
    return m[condition] || '⛅';
  };

  function initCurrentWeather(el) {
    const lat = parseFloat(el.dataset.lat);
    const lon = parseFloat(el.dataset.lon);
    const unit = el.dataset.unit || 'c';
    const refresh = parseInt(el.dataset.refresh || '0');
    const disableFetch = el.dataset.disableFetch === 'true';
    const tempEl = el.querySelector('[data-temp]');
    const condEl = el.querySelector('[data-condition]');
    const iconEl = el.querySelector('[data-icon]');
    const humidEl = el.querySelector('[data-humidity]');
    const windEl = el.querySelector('[data-wind]');
    const feelsEl = el.querySelector('[data-feels]');
    const dayNightEl = el.querySelector('[data-daynight]');
    const updatedEl = el.querySelector('[data-updated]');
    const loadingEl = el.querySelector('[data-loading-indicator]');
    const errorEl = el.querySelector('[data-error-indicator]');

    const LOADING_CLASS = 'current-weather--loading';
    const INDICATOR_VISIBLE_CLASS = 'current-weather__indicator--visible';

    const setIndicatorVisibility = (node, visible) => {
      if (!node) return;
      node.classList.toggle(INDICATOR_VISIBLE_CLASS, visible);
    };

    const setState = (state) => {
      const isLoading = state === 'loading';
      el.dataset.state = state;
      el.setAttribute('aria-busy', isLoading ? 'true' : 'false');
      el.classList.toggle(LOADING_CLASS, isLoading);
      setIndicatorVisibility(loadingEl, isLoading);
      setIndicatorVisibility(errorEl, state === 'error');
    };

    const canFetch = !!lat && !!lon && !disableFetch;
    if (!canFetch) return; // static demo mode

    const doFetch = async () => {
      setState('loading');
      try {
        const url = `https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}&current=temperature_2m,relative_humidity_2m,wind_speed_10m,wind_direction_10m,weather_code,is_day&timezone=auto`;
        const res = await fetch(url);
        if (!res.ok) throw new Error('bad response');
        const data = await res.json();
        const c = data.current;
        if (!c) throw new Error('no current');
        const condition = codeToCondition(c.weather_code);
        const emoji = conditionToEmoji(condition);
        const tempC = Math.round(c.temperature_2m);
        const tempF = Math.round((tempC * 9) / 5 + 32);
        const tempDisplay = unit === 'f' ? `${tempF}°F` : `${tempC}°C`;
        if (tempEl) tempEl.textContent = tempDisplay;
        if (feelsEl) feelsEl.textContent = tempDisplay;
        if (condEl) condEl.textContent = condition;
        if (iconEl) {
          iconEl.textContent = emoji;
          iconEl.setAttribute('aria-label', condition);
        }
        if (humidEl) humidEl.textContent = `${c.relative_humidity_2m}%`;
        if (windEl) {
          const dirs = [
            'N',
            'NNE',
            'NE',
            'ENE',
            'E',
            'ESE',
            'SE',
            'SSE',
            'S',
            'SSW',
            'SW',
            'WSW',
            'W',
            'WNW',
            'NW',
            'NNW',
          ];
          const dirTxt = dirs[Math.round(c.wind_direction_10m / 22.5) % 16];
          windEl.textContent = `${Math.round(c.wind_speed_10m)} km/h ${dirTxt}`;
        }
        if (dayNightEl) dayNightEl.textContent = c.is_day ? 'Daytime' : 'Night';
        if (updatedEl) {
          const now = new Date();
          updatedEl.textContent = `Updated ${now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}`;
        }
        setState('ready');
      } catch {
        if (updatedEl)
          updatedEl.textContent = 'Live update failed (showing fallback)';
        setState('error');
      }
    };

    doFetch();
    if (refresh > 0) setInterval(doFetch, refresh * 60 * 1000);
  }

  document.addEventListener('DOMContentLoaded', () => {
    document
      .querySelectorAll('[data-current-weather]')
      .forEach(initCurrentWeather);
  });
</script>

<style is:inline>
  .current-weather {
    --cw-bg: var(--cw-bg-light, #ffffff);
    --cw-border: var(--cw-border-light, #d1d5db);
    --cw-border-strong: var(--cw-border-strong-light, #e2e8f0);
    --cw-text: var(--cw-text-light, #0f172a);
    --cw-subtext: var(--cw-subtext-light, #475569);
    --cw-muted: var(--cw-muted-light, #64748b);
    --cw-badge-bg: var(--cw-badge-bg-light, #f1f5f9);
    --cw-badge-text: var(--cw-badge-text-light, #475569);
    --cw-link: var(--cw-link-light, #1d4ed8);
    --cw-link-hover: var(--cw-link-hover-light, #1e40af);
    --cw-error: var(--cw-error-light, #b91c1c);
    --cw-shadow: var(--cw-shadow-light, 0 12px 28px rgba(15, 23, 42, 0.08));
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    width: 100%;
    min-width: 0;
    padding: 1.5rem;
    border-radius: 1.25rem;
    border: 1px solid var(--cw-border);
    background: var(--cw-bg);
    color: var(--cw-text);
    box-shadow: var(--cw-shadow);
    transition:
      background-color 0.2s ease,
      border-color 0.2s ease,
      box-shadow 0.2s ease,
      color 0.2s ease;
  }
  @media (min-width: 48rem) {
    .current-weather {
      padding: 2rem;
      gap: 2rem;
    }
  }
  :where(.dark) .current-weather {
    --cw-bg: var(--cw-bg-dark, #0f172a);
    --cw-border: var(--cw-border-dark, #475569);
    --cw-border-strong: var(--cw-border-strong-dark, #1e293b);
    --cw-text: var(--cw-text-dark, #f8fafc);
    --cw-subtext: var(--cw-subtext-dark, #cbd5f5);
    --cw-muted: var(--cw-muted-dark, #94a3b8);
    --cw-badge-bg: var(--cw-badge-bg-dark, rgba(148, 163, 184, 0.18));
    --cw-badge-text: var(--cw-badge-text-dark, #e2e8f0);
    --cw-link: var(--cw-link-dark, #93c5fd);
    --cw-link-hover: var(--cw-link-hover-dark, #bfdbfe);
    --cw-error: var(--cw-error-dark, #fecdd3);
    --cw-shadow: var(--cw-shadow-dark, 0 18px 40px rgba(2, 6, 23, 0.5));
  }
  .current-weather__header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  @media (min-width: 48rem) {
    .current-weather__header {
      flex-direction: row;
      align-items: flex-start;
      justify-content: space-between;
      gap: 1rem;
    }
  }
  .current-weather__title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: clamp(1.25rem, 2vw, 1.5rem);
    font-weight: 700;
    margin: 0;
    color: var(--cw-text);
  }
  .current-weather__title-icon {
    font-size: 1.75rem;
    line-height: 1;
  }
  .current-weather__location {
    display: inline-flex;
    min-width: 0;
    max-width: 100%;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .current-weather__meta {
    margin: 0;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--cw-muted);
  }
  .current-weather__body {
    display: grid;
    gap: clamp(1.25rem, 4vw, 2rem);
    align-items: start;
  }
  @media (min-width: 48rem) {
    .current-weather__body {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
  .current-weather__summary {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    text-align: center;
  }
  .current-weather__emoji {
    font-size: clamp(3rem, 6vw, 3.75rem);
    transition: opacity 0.2s ease;
  }
  .current-weather__reading {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }
  .current-weather__temperature {
    font-size: clamp(2.5rem, 7vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--cw-text);
    transition: color 0.2s ease, opacity 0.2s ease;
  }
  .current-weather__condition {
    font-size: 0.95rem;
    color: var(--cw-subtext);
    text-transform: capitalize;
  }
  .current-weather__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.1rem 0.75rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    background: var(--cw-badge-bg);
    color: var(--cw-badge-text);
  }
  .current-weather__indicator {
    font-size: 0.75rem;
    color: var(--cw-muted);
    display: none;
  }
  .current-weather__indicator--visible {
    display: inline-flex;
  }
  .current-weather__indicator--error {
    color: var(--cw-error);
  }
  .current-weather__details {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    width: 100%;
  }
  @media (min-width: 48rem) {
    .current-weather__details {
      grid-column: span 2;
    }
  }
  .current-weather__details-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }
  @media (min-width: 40rem) {
    .current-weather__details-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
  .current-weather__metric {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    border-radius: 0.75rem;
    padding: 0.75rem;
    background: rgba(15, 23, 42, 0.03);
    border: 1px solid var(--cw-border-strong);
  }
  :where(.dark) .current-weather__metric {
    background: rgba(15, 23, 42, 0.35);
  }
  .current-weather__metric-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--cw-muted);
  }
  .current-weather__metric-value {
    font-size: 1rem;
    font-weight: 600;
    color: var(--cw-text);
  }
  .current-weather__footer {
    margin-top: auto;
    padding-top: 1rem;
    border-top: 1px solid var(--cw-border-strong);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.8rem;
    color: var(--cw-muted);
  }
  .current-weather__source {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
  }
  .current-weather__link {
    color: var(--cw-link);
    text-decoration: underline;
    text-underline-offset: 2px;
    font-weight: 600;
  }
  .current-weather__link:hover {
    color: var(--cw-link-hover);
  }
  .current-weather__link:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 2px;
  }
  .current-weather__refresh {
    margin-left: auto;
    font-weight: 600;
  }
  @media (max-width: 30rem) {
    .current-weather__refresh {
      margin-left: 0;
      width: 100%;
    }
  }
  .current-weather--loading .current-weather__emoji,
  .current-weather--loading .current-weather__temperature {
    opacity: 0.7;
  }
  .current-weather[data-state='loading'] .current-weather__emoji,
  .current-weather[data-state='loading'] .current-weather__temperature,
  .current-weather[data-state='loading'] .current-weather__condition {
    animation: current-weather-pulse 1.4s ease-in-out infinite;
  }
  @media (prefers-reduced-motion: reduce) {
    .current-weather * {
      transition: none !important;
      animation: none !important;
    }
  }
  @media (prefers-contrast: high) {
    .current-weather {
      outline: 2px solid currentColor;
      outline-offset: 2px;
    }
  }
  @keyframes current-weather-pulse {
    0%,
    100% {
      opacity: 0.55;
    }
    50% {
      opacity: 1;
    }
  }
</style>
