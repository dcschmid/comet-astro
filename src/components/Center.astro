---
interface Props {
  axis?: 'horizontal' | 'vertical' | 'both';
  inline?: boolean;
  /** Optional max width preset */
  maxWidth?: 'sm' | 'md' | 'lg' | 'xl' | '2xl' | 'full';
  /** Apply internal padding (gutter). */
  padded?: boolean;
  /** Background contrast variant ensuring text readability. */
  background?: 'none' | 'subtle' | 'soft' | 'solid';
  /** Additional classes */
  className?: string;
  /** Semantic wrapper element */
  as?: 'div' | 'section' | 'article' | 'main' | 'aside';
  /** Accessible label when region semantics need description */
  ariaLabel?: string;
}

const {
  axis = 'both',
  inline = false,
  maxWidth = 'full',
  padded = false,
  background = 'none',
  className = '',
  as = 'div',
  ariaLabel,
} = Astro.props as Props;

const axisClass =
  axis === 'both'
    ? 'center--axis-both'
    : axis === 'horizontal'
      ? 'center--axis-horizontal'
      : axis === 'vertical'
        ? 'center--axis-vertical'
        : 'center--axis-both';

const displayClass = inline ? 'center--inline' : 'center--block';

const widthKey = maxWidth || 'full';
const bgKey = background || 'none';
const classes = [
  'center',
  displayClass,
  axisClass,
  `center--width-${widthKey}`,
  padded ? 'center--padded' : '',
  `center--background-${bgKey}`,
  className,
]
  .filter(Boolean)
  .join(' ');

const Tag = as;
---

<Tag class={classes} aria-label={ariaLabel}>
  <slot />
</Tag>

<style is:inline>
  .center {
    display: flex;
    width: 100%;
    margin-left: auto;
    margin-right: auto;
    align-items: center;
    justify-content: center;
    gap: 0;
  }

  .center--inline {
    display: inline-flex;
  }

  .center--axis-horizontal {
    align-items: stretch;
    justify-content: center;
  }

  .center--axis-vertical {
    align-items: center;
    justify-content: flex-start;
  }

  .center--axis-both {
    align-items: center;
    justify-content: center;
  }

  .center--width-sm {
    max-width: 24rem;
  }

  .center--width-md {
    max-width: 28rem;
  }

  .center--width-lg {
    max-width: 32rem;
  }

  .center--width-xl {
    max-width: 36rem;
  }

  .center--width-2xl {
    max-width: 42rem;
  }

  .center--width-full {
    max-width: 100%;
  }

  .center--padded {
    padding: 1rem;
  }

  @media (min-width: 768px) {
    .center--padded {
      padding: 1.5rem;
    }
  }

  .center--background-none {
    background: transparent;
  }

  .center--background-subtle {
    background: rgba(15, 23, 42, 0.08);
    backdrop-filter: blur(4px);
  }

  .center--background-soft {
    background: rgba(15, 23, 42, 0.18);
    backdrop-filter: blur(8px);
  }

  .center--background-solid {
    background: #0f172a;
    color: #f8fafc;
  }

  :where(.dark) .center--background-subtle {
    background: rgba(226, 232, 240, 0.1);
  }

  :where(.dark) .center--background-soft {
    background: rgba(226, 232, 240, 0.2);
  }

  :where(.dark) .center--background-solid {
    background: #f8fafc;
    color: #0f172a;
  }
</style>
