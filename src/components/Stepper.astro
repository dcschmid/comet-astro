---
export interface Step {
  label: string;
  description?: string;
  icon?: string;
  disabled?: boolean;
}

interface Props {
  steps: Step[];
  currentStep: number;
  orientation?: 'horizontal' | 'vertical';
  size?: 'sm' | 'md' | 'lg';
  variant?: 'default' | 'minimal' | 'outlined' | 'filled';
  as?: 'nav' | 'ol' | 'div';
  ariaLabel?: string;
  interactive?: boolean;
  debug?: boolean;
  class?: string;
}

const {
  steps,
  currentStep = 1,
  orientation = 'horizontal',
  size = 'md',
  variant = 'default',
  as: Element = 'nav',
  ariaLabel = 'Progress steps',
  interactive = false,
  debug = false,
  class: className = '',
} = Astro.props as Props;

const getStepStatus = (index: number) => {
  const stepNumber = index + 1;
  const step = steps[index];

  if (step?.disabled) return 'disabled';
  if (stepNumber < currentStep) return 'completed';
  if (stepNumber === currentStep) return 'active';
  return 'upcoming';
};

const rootClasses = [
  'stepper',
  `stepper--orientation-${orientation}`,
  `stepper--variant-${variant}`,
  `stepper--size-${size}`,
  interactive ? 'stepper--interactive' : '',
  debug ? 'stepper--debug' : '',
  className,
]
  .filter(Boolean)
  .join(' ');

const stepperId = `stepper-${Math.random().toString(36).slice(2, 9)}`;
const debugInfo = debug
  ? `${orientation} ${size} ${variant}${interactive ? ' interactive' : ''}`
  : undefined;
---

<Element
  class={rootClasses}
  aria-label={ariaLabel}
  role={Element === 'ol' ? undefined : 'progressbar'}
  aria-valuenow={currentStep}
  aria-valuemin={1}
  aria-valuemax={steps.length}
  data-debug-info={debugInfo}
>
  {
    steps.map((step, index) => {
      const status = getStepStatus(index);
      const stepNumber = index + 1;
      const isLast = index === steps.length - 1;
      const stepId = `${stepperId}-step-${stepNumber}`;
      const isDisabled = status === 'disabled';
      const isActive = status === 'active';
      const connectorStatus = status === 'completed' ? 'completed' : 'upcoming';

      const stepClasses = [
        'stepper__step',
        `stepper__step--${orientation}`,
        isDisabled ? 'stepper__step--disabled' : '',
      ]
        .filter(Boolean)
        .join(' ');

      const circleClasses = [
        'stepper__circle',
        `stepper__circle--${status}`,
        step.icon ? 'stepper__circle--icon' : '',
      ]
        .filter(Boolean)
        .join(' ');

      const labelClasses = [
        'stepper__label',
        `stepper__label--${status}`,
      ].join(' ');

      const descriptionClasses = [
        'stepper__description',
        `stepper__description--${status}`,
      ].join(' ');

      const connectorClasses = [
        'stepper__connector',
        `stepper__connector--${orientation}`,
        `stepper__connector--${connectorStatus}`,
      ].join(' ');

      return (
        <div
          class={stepClasses}
          role={Element === 'ol' ? 'listitem' : undefined}
        >
          <div class="stepper__content">
            <div
              class={circleClasses}
              aria-current={isActive ? 'step' : undefined}
              aria-describedby={
                step.description ? `${stepId}-description` : undefined
              }
              tabindex={
                interactive && !isDisabled ? 0 : interactive ? -1 : undefined
              }
              role={interactive && !isDisabled ? 'button' : undefined}
              aria-label={
                interactive && !isDisabled
                  ? `Go to step ${stepNumber}: ${step.label}`
                  : undefined
              }
              id={stepId}
            >
              {step.icon ? (
                <span aria-hidden="true">{step.icon}</span>
              ) : status === 'completed' ? (
                <span aria-hidden="true">✓</span>
              ) : (
                <span>{stepNumber}</span>
              )}
            </div>

            <div class="stepper__text">
              <p class={labelClasses} id={`${stepId}-label`}>
                {step.label}
              </p>
              {step.description && (
                <p class={descriptionClasses} id={`${stepId}-description`}>
                  {step.description}
                </p>
              )}
            </div>
          </div>

          {!isLast && (
            <div class={connectorClasses} aria-hidden="true" />
          )}
        </div>
      );
    })
  }
</Element>

<style>
  .stepper {
    --stepper-gap: 1.25rem;
    --stepper-circle-size: 2.5rem;
    --stepper-circle-font: 1rem;
    --stepper-label-size: 0.95rem;
    --stepper-description-size: 0.85rem;
    --stepper-vertical-spacing: 2rem;
    --stepper-connector-thickness: 3px;
    --stepper-connector-gap: 1rem;
    display: flex;
    flex-direction: column;
    gap: var(--stepper-gap);
    width: 100%;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .stepper--orientation-horizontal {
    flex-direction: column;
  }

  @media (min-width: 640px) {
    .stepper--orientation-horizontal {
      flex-direction: row;
      align-items: flex-start;
    }
  }

  .stepper--orientation-vertical {
    flex-direction: column;
  }

  .stepper__step {
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .stepper__step--horizontal {
    flex: 1;
  }

  .stepper--orientation-horizontal .stepper__step {
    flex-direction: column;
  }

  @media (min-width: 640px) {
    .stepper--orientation-horizontal .stepper__step {
      flex-direction: row;
      align-items: flex-start;
    }
  }

  .stepper__step--vertical:not(:last-child) {
    padding-bottom: var(--stepper-vertical-spacing);
  }

  .stepper__content {
    display: flex;
    align-items: flex-start;
    gap: var(--stepper-gap);
  }

  .stepper--orientation-horizontal .stepper__content {
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  @media (min-width: 640px) {
    .stepper--orientation-horizontal .stepper__content {
      flex-direction: row;
      align-items: flex-start;
      text-align: left;
    }
  }

  .stepper__circle {
    width: var(--stepper-circle-size);
    height: var(--stepper-circle-size);
    border-radius: 999px;
    border: 2px solid #94a3b8;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: var(--stepper-circle-font);
    font-weight: 600;
    color: #1f2937;
    background: #fff;
    box-shadow: 0 4px 10px rgba(15, 23, 42, 0.08);
    transition: transform 0.2s ease, background 0.2s ease,
      color 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .stepper__circle span {
    line-height: 1;
  }

  .stepper__circle--completed {
    background: #2563eb;
    border-color: #2563eb;
    color: #fff;
  }

  :where(.dark) .stepper__circle--completed {
    background: #38bdf8;
    border-color: #38bdf8;
    color: #0f172a;
  }

  .stepper__circle--active {
    background: #dbeafe;
    border-color: #2563eb;
    color: #1e3a8a;
    box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.15);
  }

  :where(.dark) .stepper__circle--active {
    background: rgba(37, 99, 235, 0.25);
    border-color: #3b82f6;
    color: #bfdbfe;
    box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.25);
  }

  .stepper__circle--upcoming {
    background: #fff;
    color: #334155;
  }

  :where(.dark) .stepper__circle--upcoming {
    background: #0f172a;
    color: #cbd5f5;
    border-color: #475569;
  }

  .stepper__circle--disabled {
    background: #e2e8f0;
    border-color: #cbd5f5;
    color: #94a3b8;
  }

  :where(.dark) .stepper__circle--disabled {
    background: #1e293b;
    border-color: #475569;
    color: #64748b;
  }

  .stepper__text {
    text-align: left;
  }

  .stepper--orientation-horizontal .stepper__text {
    text-align: center;
  }

  @media (min-width: 640px) {
    .stepper--orientation-horizontal .stepper__text {
      text-align: left;
    }
  }

  .stepper__label {
    margin: 0;
    font-size: var(--stepper-label-size);
    font-weight: 600;
    letter-spacing: 0.01em;
  }

  .stepper__label--completed {
    color: #0f172a;
  }
  .stepper__label--active {
    color: #0f172a;
  }
  .stepper__label--upcoming {
    color: #475569;
  }
  .stepper__label--disabled {
    color: #94a3b8;
  }

  :where(.dark) .stepper__label--completed,
  :where(.dark) .stepper__label--active {
    color: #f8fafc;
  }

  :where(.dark) .stepper__label--upcoming {
    color: #cbd5f5;
  }

  :where(.dark) .stepper__label--disabled {
    color: #94a3b8;
  }

  .stepper__description {
    margin: 0.35rem 0 0;
    font-size: var(--stepper-description-size);
    color: #64748b;
    max-width: 18rem;
    line-height: 1.4;
  }

  .stepper__description--completed {
    color: #475569;
  }
  .stepper__description--active {
    color: #1f2937;
  }
  .stepper__description--upcoming {
    color: #94a3b8;
  }
  .stepper__description--disabled {
    color: #cbd5f5;
  }

  :where(.dark) .stepper__description--completed {
    color: #cbd5f5;
  }
  :where(.dark) .stepper__description--active {
    color: #f8fafc;
  }
  :where(.dark) .stepper__description--upcoming,
  :where(.dark) .stepper__description--disabled {
    color: #94a3b8;
  }

  .stepper__connector {
    background: #cbd5f5;
    flex: 1;
    margin-top: var(--stepper-connector-gap);
    transition: background 0.2s ease;
  }

  .stepper__connector--horizontal {
    display: none;
  }

  @media (min-width: 640px) {
    .stepper__connector--horizontal {
      display: block;
      height: var(--stepper-connector-thickness);
      align-self: center;
      margin: 0 1rem;
    }
  }

  .stepper__connector--vertical {
    position: absolute;
    top: calc(var(--stepper-circle-size) + 0.5rem);
    bottom: 0;
    left: calc(
      (var(--stepper-circle-size) / 2) -
        (var(--stepper-connector-thickness) / 2)
    );
    width: var(--stepper-connector-thickness);
  }

  .stepper__connector--completed {
    background: #2563eb;
  }

  :where(.dark) .stepper__connector--completed {
    background: #38bdf8;
  }

  .stepper__connector--upcoming {
    background: #cbd5f5;
  }

  :where(.dark) .stepper__connector--upcoming {
    background: #475569;
  }

  .stepper__step--disabled {
    cursor: not-allowed;
  }

  .stepper--interactive .stepper__step:not(.stepper__step--disabled) {
    cursor: pointer;
  }

  .stepper--interactive
    .stepper__step:not(.stepper__step--disabled)
    .stepper__circle {
    transform: translateZ(0);
  }

  .stepper--interactive
    .stepper__step:not(.stepper__step--disabled)
    .stepper__circle:focus-visible {
    outline: 3px solid rgba(59, 130, 246, 0.4);
    outline-offset: 2px;
  }

  .stepper--interactive
    .stepper__step:not(.stepper__step--disabled)
    .stepper__circle:hover {
    transform: scale(1.05);
  }

  .stepper--variant-minimal .stepper__circle {
    border-width: 0;
    box-shadow: none;
  }

  .stepper--variant-minimal .stepper__circle--active {
    background: rgba(37, 99, 235, 0.15);
    box-shadow: none;
  }

  .stepper--variant-minimal .stepper__circle--upcoming {
    background: transparent;
  }

  .stepper--variant-outlined .stepper__circle--completed,
  .stepper--variant-outlined .stepper__circle--active {
    background: transparent;
    color: #1e3a8a;
  }

  :where(.dark) .stepper--variant-outlined .stepper__circle--completed,
  :where(.dark) .stepper--variant-outlined .stepper__circle--active {
    color: #bfdbfe;
  }

  .stepper--variant-filled .stepper__circle--upcoming {
    background: #e2e8f0;
  }

  :where(.dark) .stepper--variant-filled .stepper__circle--upcoming {
    background: #1e293b;
  }

  .stepper--size-sm {
    --stepper-circle-size: 2rem;
    --stepper-circle-font: 0.85rem;
    --stepper-label-size: 0.85rem;
    --stepper-description-size: 0.75rem;
    --stepper-gap: 0.75rem;
    --stepper-vertical-spacing: 1.5rem;
    --stepper-connector-thickness: 2px;
  }

  .stepper--size-lg {
    --stepper-circle-size: 3rem;
    --stepper-circle-font: 1.1rem;
    --stepper-label-size: 1rem;
    --stepper-description-size: 0.95rem;
    --stepper-gap: 1.5rem;
    --stepper-vertical-spacing: 2.5rem;
    --stepper-connector-thickness: 4px;
  }

  .stepper--debug {
    outline: 2px dashed rgba(255, 165, 0, 0.7);
    outline-offset: 2px;
    position: relative;
  }

  .stepper--debug::after {
    content: attr(data-debug-info);
    position: absolute;
    top: -1.5rem;
    left: 0;
    font-size: 0.75rem;
    color: #f97316;
    background: rgba(255, 255, 255, 0.95);
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
    font-family: monospace;
  }

  :where(.dark) .stepper--debug::after {
    background: rgba(15, 23, 42, 0.95);
    color: #fdba74;
  }

  @media (prefers-reduced-motion: reduce) {
    .stepper * {
      transition: none !important;
    }
  }

  @media (prefers-contrast: high) {
    .stepper__circle {
      border-color: currentColor;
      color: currentColor;
      box-shadow: none;
    }

    .stepper__connector {
      background: currentColor;
    }

    .stepper__label,
    .stepper__description {
      color: currentColor;
    }
  }
</style>
