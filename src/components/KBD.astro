---
/**
 * KBD - WCAG AAA compliant keyboard key display component
 * Displays keyboard shortcuts and key combinations with optimal accessibility
 */
interface Props {
  keys?: string[];
  size?: 'xs' | 'sm' | 'md' | 'lg' | 'xl';
  variant?: 'default' | 'outlined' | 'minimal' | 'filled';
  separator?: 'plus' | 'then' | 'or' | 'space';
  className?: string;
  ariaLabel?: string;
  description?: string;
  platform?: 'auto' | 'mac' | 'windows' | 'linux';
}

const {
  keys = [],
  size = 'md',
  variant = 'default',
  separator = 'plus',
  className = '',
  ariaLabel,
  description,
  platform = 'auto',
} = Astro.props;

const sizeClasses = {
  xs: {
    root: 'kbd--size-xs',
    key: 'kbd__key--size-xs',
    separator: 'kbd__separator--size-xs',
  },
  sm: {
    root: 'kbd--size-sm',
    key: 'kbd__key--size-sm',
    separator: 'kbd__separator--size-sm',
  },
  md: {
    root: 'kbd--size-md',
    key: 'kbd__key--size-md',
    separator: 'kbd__separator--size-md',
  },
  lg: {
    root: 'kbd--size-lg',
    key: 'kbd__key--size-lg',
    separator: 'kbd__separator--size-lg',
  },
  xl: {
    root: 'kbd--size-xl',
    key: 'kbd__key--size-xl',
    separator: 'kbd__separator--size-xl',
  },
} as const;

const variantClasses = {
  default: 'kbd--variant-default',
  outlined: 'kbd--variant-outlined',
  minimal: 'kbd--variant-minimal',
  filled: 'kbd--variant-filled',
} as const;

// Separator symbols and labels
const separatorConfig = {
  plus: { symbol: '+', label: 'plus' },
  then: { symbol: '→', label: 'then' },
  or: { symbol: '/', label: 'or' },
  space: { symbol: ' ', label: 'space' },
};

// Platform-specific key mappings
const keyMappings = {
  mac: {
    cmd: '⌘',
    option: '⌥',
    alt: '⌥',
    shift: '⇧',
    ctrl: '⌃',
    control: '⌃',
    enter: '↵',
    return: '↵',
    delete: '⌫',
    backspace: '⌫',
    tab: '⇥',
    space: '␣',
    esc: '⎋',
    escape: '⎋',
  },
  windows: {
    cmd: 'Win',
    win: 'Win',
    alt: 'Alt',
    shift: 'Shift',
    ctrl: 'Ctrl',
    control: 'Ctrl',
    enter: 'Enter',
    return: 'Enter',
    delete: 'Del',
    backspace: 'Backspace',
    tab: 'Tab',
    space: 'Space',
    esc: 'Esc',
    escape: 'Esc',
  },
  linux: {
    cmd: 'Super',
    super: 'Super',
    alt: 'Alt',
    shift: 'Shift',
    ctrl: 'Ctrl',
    control: 'Ctrl',
    enter: 'Enter',
    return: 'Enter',
    delete: 'Del',
    backspace: 'Backspace',
    tab: 'Tab',
    space: 'Space',
    esc: 'Esc',
    escape: 'Esc',
  },
};

// Detect platform if auto
const getPlatform = () => {
  if (platform !== 'auto') return platform;
  // Default to windows for SSR
  return 'windows';
};

const currentPlatform = getPlatform();
const mappings = keyMappings[currentPlatform] || keyMappings.windows;

// Transform keys based on platform
const transformKey = (key: string) => {
  const lowercaseKey = key.toLowerCase();
  return (mappings as any)[lowercaseKey] || key;
};

// Generate accessible description
const generateDescription = () => {
  if (description) return description;
  if (keys.length === 0) return undefined;

  const keyNames = keys.map((key) => transformKey(key));
  const separatorLabel = separatorConfig[separator].label;

  if (keys.length === 1) {
    return `Press ${keyNames[0]} key`;
  }

  return `Press ${keyNames.join(` ${separatorLabel} `)} keys`;
};

const rootClasses = ['kbd', sizeClasses[size].root, variantClasses[variant], className]
  .filter(Boolean)
  .join(' ');
const keyClass = ['kbd__key', sizeClasses[size].key].join(' ');
const separatorClass = ['kbd__separator', sizeClasses[size].separator].join(' ');

const separatorSymbol = separatorConfig[separator].symbol;
const accessibleDescription = generateDescription();

// Generate unique ID for aria-describedby if needed
const descriptionId = description
  ? `kbd-desc-${Math.random().toString(36).slice(2, 8)}`
  : undefined;
---

{
  keys.length > 0 ? (
    <span
      class={rootClasses}
      role="group"
      aria-label={ariaLabel || accessibleDescription}
      aria-describedby={descriptionId}
    >
      {keys.map((key, i) => (
        <>
          <kbd
            class={keyClass}
            title={`${transformKey(key)} key`}
          >
            {transformKey(key)}
          </kbd>
          {i < keys.length - 1 && (
            <span
              class={separatorClass}
              aria-hidden="true"
            >
              {separatorSymbol}
            </span>
          )}
        </>
      ))}

      {description && (
        <span id={descriptionId} class="sr-only">
          {description}
        </span>
      )}
    </span>
  ) : (
    <span class={rootClasses}>
      <kbd
        class={keyClass}
        aria-label={ariaLabel}
        aria-describedby={descriptionId}
        title="Keyboard shortcut"
      >
        <slot />

        {description && (
          <span id={descriptionId} class="sr-only">
            {description}
          </span>
        )}
      </kbd>
    </span>
  )
}

<style is:inline>
  .kbd {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
      'Liberation Mono', 'Courier New', monospace;
  }

  .kbd--size-xs {
    gap: 0.25rem;
  }

  .kbd--size-sm {
    gap: 0.4rem;
  }

  .kbd--size-md {
    gap: 0.6rem;
  }

  .kbd--size-lg {
    gap: 0.8rem;
  }

  .kbd--size-xl {
    gap: 1rem;
  }

  .kbd__key {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2rem;
    border-radius: 0.45rem;
    border: 1px solid #cbd5f5;
    background-color: #f8fafc;
    color: #0f172a;
    font-weight: 600;
    line-height: 1.2;
    box-shadow: 0 2px 4px rgba(15, 23, 42, 0.08);
    transition:
      background-color 0.15s ease,
      transform 0.15s ease,
      box-shadow 0.15s ease,
      border-color 0.15s ease;
    padding: 0.45rem 0.85rem;
    cursor: default;
    user-select: none;
  }

  .kbd__key:focus-visible {
    outline: 2px solid #2563eb;
    outline-offset: 2px;
  }

  .kbd__key:active {
    transform: translateY(1px);
    box-shadow: 0 1px 2px rgba(15, 23, 42, 0.2);
  }

  .kbd__key--size-xs {
    font-size: 0.7rem;
    padding: 0.2rem 0.4rem;
    min-width: 1.25rem;
  }

  .kbd__key--size-sm {
    font-size: 0.8rem;
    padding: 0.3rem 0.55rem;
    min-width: 1.5rem;
  }

  .kbd__key--size-md {
    font-size: 0.9rem;
    min-width: 2rem;
  }

  .kbd__key--size-lg {
    font-size: 1rem;
    padding: 0.55rem 1rem;
    min-width: 2.5rem;
  }

  .kbd__key--size-xl {
    font-size: 1.125rem;
    padding: 0.65rem 1.2rem;
    min-width: 3rem;
  }

  .kbd__separator {
    color: #64748b;
    font-weight: 600;
  }

  .kbd__separator--size-xs {
    font-size: 0.7rem;
  }

  .kbd__separator--size-sm {
    font-size: 0.8rem;
  }

  .kbd__separator--size-md {
    font-size: 0.9rem;
  }

  .kbd__separator--size-lg {
    font-size: 1rem;
  }

  .kbd__separator--size-xl {
    font-size: 1.125rem;
  }

  .kbd--variant-default .kbd__key {
    background-color: #eef2ff;
    border-color: #c7d2fe;
  }

  .kbd--variant-outlined .kbd__key {
    background-color: #ffffff;
    border-width: 2px;
    border-color: #94a3b8;
  }

  .kbd--variant-minimal .kbd__key {
    background-color: #f1f5f9;
    border-color: #e2e8f0;
    box-shadow: none;
  }

  .kbd--variant-filled .kbd__key {
    background-color: #0f172a;
    color: #f8fafc;
    border-color: rgba(248, 250, 252, 0.3);
  }

  :where(.dark) .kbd__key {
    background-color: #1f2937;
    border-color: #475569;
    color: #f8fafc;
    box-shadow: 0 2px 6px rgba(2, 6, 23, 0.8);
  }

  :where(.dark) .kbd__key:focus-visible {
    outline-color: #818cf8;
  }

  :where(.dark) .kbd--variant-default .kbd__key {
    background-color: #1e1b4b;
    border-color: #4338ca;
  }

  :where(.dark) .kbd--variant-outlined .kbd__key {
    background-color: transparent;
    border-color: #94a3b8;
  }

  :where(.dark) .kbd--variant-minimal .kbd__key {
    background-color: #0f172a;
    border-color: #1e293b;
  }

  :where(.dark) .kbd__separator {
    color: #cbd5f5;
  }

  @media (prefers-contrast: high) {
    .kbd__key {
      border-width: 2px;
      font-weight: 700;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .kbd__key {
      transition: none;
    }

    .kbd__key:active {
      transform: none;
    }
  }
</style>
