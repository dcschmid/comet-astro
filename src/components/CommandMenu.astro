---
interface Command {
  id: string;
  label: string;
  description?: string;
  icon?: string;
  action?: string;
  keywords?: string[];
}

interface Props {
  commands?: Command[];
  placeholder?: string;
  shortcut?: string;
  className?: string;
}

const {
  commands = [],
  placeholder = 'Search commands...',
  shortcut = 'Ctrl+K',
  className = '',
} = Astro.props as Props & Record<string, any>;
---

<div class={`command-menu ${className}`} data-command-menu aria-hidden="true">
  <div class="command-menu__dialog" role="dialog" aria-modal="true" aria-label="Command menu">
    <div class="command-menu__input-wrap">
      <label for="comet-cmd-input" class="sr-only">{placeholder}</label>
      <input
        id="comet-cmd-input"
        type="text"
        placeholder={placeholder}
        class="command-menu__input"
        data-command-input
        role="combobox"
        aria-expanded="false"
        aria-autocomplete="list"
        aria-haspopup="listbox"
        aria-controls="comet-cmd-list"
      />
      <div class="command-menu__shortcut">
        <span class="command-menu__shortcut-key">{shortcut}</span>
        <span class="command-menu__shortcut-key command-menu__shortcut-key--secondary">
          Esc
        </span>
      </div>
    </div>

    <div
      id="comet-cmd-list"
      class="command-menu__list"
      data-command-list
      role="listbox"
      aria-label="Available commands"
    >
      {
        commands?.length ? (
          commands.map((cmd, i) => (
            <button
              type="button"
              data-command-item
              data-command-id={cmd.id}
              data-command-action={cmd.action}
              data-command-keywords={cmd.keywords?.join(' ')}
              role="option"
              aria-selected="false"
              tabindex={i === 0 ? 0 : -1}
              class="command-menu__item"
            >
              {cmd.icon && (
                <span class="command-menu__item-icon" aria-hidden>
                  {cmd.icon}
                </span>
              )}
              <div class="command-menu__item-body">
                <div class="command-menu__item-label">{cmd.label}</div>
                {cmd.description && (
                  <p class="command-menu__item-description">
                    {cmd.description}
                  </p>
                )}
              </div>
            </button>
          ))
        ) : (
          <div class="command-menu__empty">No commands available</div>
        )
      }
    </div>

    <div class="command-menu__footer">
      Press {shortcut} or Esc to close
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    const menu = document.querySelector('[data-command-menu]');
    if (!(menu instanceof HTMLElement)) return;
    const input = menu.querySelector('[data-command-input]');
    const list = menu.querySelector('[data-command-list]');
    if (!(input instanceof HTMLInputElement) || !(list instanceof HTMLElement))
      return;

    const getItems = () =>
      Array.from(list.querySelectorAll('[data-command-item]')).filter(
        (el): el is HTMLElement => el instanceof HTMLElement
      );
    const getVisibleItems = () => getItems().filter((item) => !item.classList.contains('hidden'));

    let activeIndex = -1;
    let isOpen = false;
    let lastFocused: HTMLElement | null = null;

    const setAriaSelected = (item: HTMLElement, selected: boolean) => {
      item.setAttribute('aria-selected', selected ? 'true' : 'false');
      item.tabIndex = selected ? 0 : -1;
      item.classList.toggle('command-menu__item--selected', selected);
    };

    const resetActive = () => {
      getItems().forEach((item) => setAriaSelected(item, false));
      activeIndex = -1;
    };

    const focusItem = (index: number) => {
      const visible = getVisibleItems();
      if (!visible.length) return;
      const clamped = Math.max(0, Math.min(index, visible.length - 1));
      visible.forEach((item, idx) => setAriaSelected(item, idx === clamped));
      visible[clamped].focus({ preventScroll: true });
      activeIndex = clamped;
    };

    const filterCommands = (query: string) => {
      const normalized = (query || '').trim().toLowerCase();
      getItems().forEach((item) => {
        const labelEl = item.querySelector('.command-menu__item-label');
        const label = labelEl?.textContent?.toLowerCase() || '';
        const keywords = (item.getAttribute('data-command-keywords') || '').toLowerCase();
        const matches =
          !normalized ||
          label.includes(normalized) ||
          keywords.includes(normalized);
        item.classList.toggle('hidden', !matches);
      });
      resetActive();
      const visible = getVisibleItems();
      if (visible.length) visible[0].tabIndex = 0;
    };

    const open = () => {
      if (isOpen) return;
      isOpen = true;
      lastFocused = document.activeElement instanceof HTMLElement ? document.activeElement : null;
      menu.classList.add('command-menu--open');
      menu.setAttribute('aria-hidden', 'false');
      input.setAttribute('aria-expanded', 'true');
      document.body.style.setProperty('overflow', 'hidden');
      window.setTimeout(() => input.focus({ preventScroll: true }), 20);
    };

    const close = () => {
      if (!isOpen) return;
      isOpen = false;
      menu.classList.remove('command-menu--open');
      menu.setAttribute('aria-hidden', 'true');
      input.setAttribute('aria-expanded', 'false');
      input.value = '';
      filterCommands('');
      document.body.style.removeProperty('overflow');
      if (lastFocused && typeof lastFocused.focus === 'function') {
        lastFocused.focus({ preventScroll: true });
      }
    };

    input.addEventListener('input', () => filterCommands(input.value));

    input.addEventListener('keydown', (event) => {
      const visible = getVisibleItems();
      if (!visible.length) return;
      if (event.key === 'ArrowDown') {
        event.preventDefault();
        focusItem(0);
      } else if (event.key === 'Escape') {
        close();
      }
    });

    list.addEventListener('keydown', (event) => {
      const visible = getVisibleItems();
      if (!visible.length) return;
      if (event.key === 'ArrowDown') {
        event.preventDefault();
        focusItem(activeIndex + 1);
      } else if (event.key === 'ArrowUp') {
        event.preventDefault();
        focusItem(activeIndex - 1);
      } else if (event.key === 'Home') {
        event.preventDefault();
        focusItem(0);
      } else if (event.key === 'End') {
        event.preventDefault();
        focusItem(visible.length - 1);
      } else if (event.key === 'Escape') {
        event.preventDefault();
        close();
      } else if (event.key === 'Enter') {
        event.preventDefault();
        const current = visible[activeIndex];
        if (current && typeof current.click === 'function') current.click();
      }
    });

    list.addEventListener('click', (event) => {
      const target = event.target instanceof HTMLElement ? event.target.closest('[data-command-item]') : null;
      if (!(target instanceof HTMLElement)) return;
      const action = target.getAttribute('data-command-action');
      if (action) window.location.assign(action);
      close();
    });

    menu.addEventListener('click', (event) => {
      if (event.target === menu) close();
    });

    document.addEventListener('keydown', (event) => {
      if ((event.ctrlKey || event.metaKey) && event.key.toLowerCase() === 'k') {
        event.preventDefault();
        open();
      } else if (event.key === 'Escape') {
        close();
      }
    });

    filterCommands('');
  })();
</script>

<style is:inline>
  .command-menu {
    position: fixed;
    inset: 0;
    z-index: 50;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 4rem;
    background: rgba(2, 6, 23, 0.7);
    backdrop-filter: blur(8px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
  }

  .command-menu--open {
    opacity: 1;
    pointer-events: auto;
  }

  .command-menu__dialog {
    width: min(42rem, calc(100% - 2rem));
    border-radius: 1.5rem;
    border: 1px solid rgba(148, 163, 184, 0.35);
    background: #ffffff;
    color: #0f172a;
    box-shadow: 0 25px 65px rgba(15, 23, 42, 0.3);
    overflow: hidden;
  }

  :where(.dark) .command-menu__dialog {
    background: #020617;
    color: #f8fafc;
    border-color: rgba(148, 163, 184, 0.35);
  }

  .command-menu__input-wrap {
    position: relative;
    padding: 1rem 1.25rem;
  }

  .command-menu__input {
    width: 100%;
    border-radius: 0.9rem;
    border: 1px solid rgba(148, 163, 184, 0.6);
    background: rgba(248, 250, 252, 0.9);
    padding: 0.85rem 1rem;
    font-size: 0.95rem;
    font-weight: 600;
    color: #0f172a;
  }

  :where(.dark) .command-menu__input {
    background: rgba(15, 23, 42, 0.9);
    color: #f8fafc;
    border-color: rgba(148, 163, 184, 0.5);
  }

  .command-menu__shortcut {
    position: absolute;
    top: 1rem;
    right: 1.25rem;
    display: none;
    gap: 0.25rem;
    font-size: 0.65rem;
    text-transform: uppercase;
  }

  @media (min-width: 640px) {
    .command-menu__shortcut {
      display: inline-flex;
    }
  }

  .command-menu__shortcut-key {
    border-radius: 0.4rem;
    border: 1px solid rgba(148, 163, 184, 0.4);
    padding: 0.25rem 0.5rem;
    font-weight: 600;
    background: rgba(255, 255, 255, 0.7);
    color: #334155;
  }

  :where(.dark) .command-menu__shortcut-key {
    background: rgba(15, 23, 42, 0.8);
    color: #cbd5f5;
  }

  .command-menu__shortcut-key--secondary {
    opacity: 0.65;
  }

  .command-menu__list {
    max-height: 18rem;
    overflow-y: auto;
    padding: 0.5rem;
  }

  .command-menu__item {
    width: 100%;
    display: flex;
    gap: 0.75rem;
    padding: 0.75rem;
    border-radius: 0.85rem;
    background: transparent;
    border: none;
    text-align: left;
    cursor: pointer;
    transition: background-color 0.2s ease;
  }

  .command-menu__item:hover,
  .command-menu__item--selected {
    background: rgba(14, 165, 233, 0.12);
  }

  :where(.dark) .command-menu__item:hover,
  :where(.dark) .command-menu__item--selected {
    background: rgba(14, 165, 233, 0.2);
  }

  .command-menu__item-icon {
    font-size: 1.25rem;
    color: #0ea5e9;
  }

  .command-menu__item-label {
    font-size: 0.95rem;
    font-weight: 600;
  }

  .command-menu__item-description {
    margin: 0.2rem 0 0;
    font-size: 0.78rem;
    color: rgba(15, 23, 42, 0.7);
  }

  :where(.dark) .command-menu__item-description {
    color: rgba(248, 250, 252, 0.7);
  }

  .command-menu__empty {
    padding: 2rem 1rem;
    text-align: center;
    font-size: 0.9rem;
    color: rgba(15, 23, 42, 0.7);
  }

  :where(.dark) .command-menu__empty {
    color: rgba(248, 250, 252, 0.7);
  }

  .command-menu__footer {
    border-top: 1px solid rgba(148, 163, 184, 0.35);
    padding: 0.85rem 1.25rem;
    font-size: 0.75rem;
    color: rgba(15, 23, 42, 0.7);
    background: rgba(248, 250, 252, 0.65);
  }

  :where(.dark) .command-menu__footer {
    background: rgba(15, 23, 42, 0.9);
    color: rgba(248, 250, 252, 0.6);
  }
</style>
