---
/**
 * Generic, accessible site footer with WCAG AAA compliance
 */
interface LinkItem {
  href: string;
  label: string;
  ariaLabel?: string;
  external?: boolean;
}

interface Props {
  brand?: string;
  brandUrl?: string;
  year?: number;
  legalLinks?: LinkItem[];
  socialLinks?: LinkItem[];
  externalLinks?: LinkItem[];
  showBrand?: boolean;
  showYear?: boolean;
  variant?: 'simple' | 'detailed';
  className?: string;
  ariaLabel?: string;
}

const {
  brand = 'Your Project',
  brandUrl,
  year = new Date().getFullYear(),
  legalLinks = [],
  socialLinks = [],
  externalLinks = [],
  showBrand = true,
  showYear = true,
  variant = 'simple',
  className = '',
  ariaLabel = 'Site footer',
} = Astro.props as Props;

const rootClasses = [
  'site-footer',
  `site-footer--${variant}`,
  showBrand ? 'site-footer--has-brand' : 'site-footer--no-brand',
  className,
]
  .filter(Boolean)
  .join(' ');
---

<footer class={rootClasses} role="contentinfo" aria-label={ariaLabel}>
  <div class="site-footer__inner">
    {
      showBrand && (
        <div class="site-footer__brand">
          {brandUrl ? (
            <a
              href={brandUrl}
              class="site-footer__brand-link"
              aria-label={`${brand} homepage`}
            >
              &copy; {showYear ? year : ''} {brand}
            </a>
          ) : (
            <span class="site-footer__brand-text">
              &copy; {showYear ? year : ''} {brand}
            </span>
          )}
        </div>
      )
    }

    {socialLinks.length > 0 && (
      <nav aria-label="Social media links" class="site-footer__nav site-footer__nav--social">
        {socialLinks.map((link) => (
          <a
            href={link.href}
            target={link.external ? '_blank' : undefined}
            rel={link.external ? 'noopener noreferrer' : undefined}
            aria-label={
              link.ariaLabel || `${link.label}${link.external ? ' (opens in new window)' : ''}`
            }
            class="site-footer__link site-footer__link--social"
          >
            {link.label}
            {link.external && <span class="sr-only"> (opens in new window)</span>}
          </a>
        ))}
      </nav>
    )}

    {legalLinks.length > 0 && (
      <nav aria-label="Legal and policy links" class="site-footer__nav site-footer__nav--legal">
        {legalLinks.map((link) => (
          <a
            href={link.href}
            target={link.external ? '_blank' : undefined}
            rel={link.external ? 'noopener noreferrer' : undefined}
            aria-label={link.ariaLabel || link.label}
            class="site-footer__link site-footer__link--legal"
          >
            {link.label}
            {link.external && <span class="sr-only"> (opens in new window)</span>}
          </a>
        ))}
      </nav>
    )}

    {externalLinks.length > 0 && (
      <nav aria-label="External links" class="site-footer__nav site-footer__nav--external">
        {externalLinks.map((link) => (
          <a
            href={link.href}
            target={link.external ? '_blank' : undefined}
            rel={link.external ? 'noopener noreferrer' : undefined}
            aria-label={
              link.ariaLabel || `${link.label}${link.external ? ' (opens in new window)' : ''}`
            }
            class="site-footer__link site-footer__link--external"
          >
            {link.label}
            {link.external && <span class="sr-only"> (opens in new window)</span>}
          </a>
        ))}
      </nav>
    )}
  </div>
</footer>

<style is:inline>
  .site-footer {
    margin-top: 3rem;
    border-top: 1px solid rgba(15, 23, 42, 0.12);
    background: rgba(255, 255, 255, 0.95);
    color: #475569;
    padding: 2.5rem 0;
    backdrop-filter: blur(6px);
  }
  :where(.dark) .site-footer {
    border-color: rgba(148, 163, 184, 0.3);
    background: rgba(2, 6, 23, 0.9);
    color: #cbd5f5;
  }
  .site-footer__inner {
    width: min(100%, 80rem);
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .site-footer--simple .site-footer__inner {
    gap: 1rem;
  }
  @media (min-width: 48rem) {
    .site-footer--simple .site-footer__inner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 1.25rem 2rem;
    }
  }
  .site-footer--detailed .site-footer__inner {
    gap: 2rem;
  }
  .site-footer__brand {
    text-align: center;
  }
  @media (min-width: 48rem) {
    .site-footer__brand {
      text-align: left;
    }
  }
  .site-footer__brand-link,
  .site-footer__brand-text {
    font-size: 1rem;
    font-weight: 600;
    color: #0f172a;
  }
  :where(.dark) .site-footer__brand-link,
  :where(.dark) .site-footer__brand-text {
    color: #f8fafc;
  }
  .site-footer__brand-link {
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .site-footer__brand-link:hover {
    color: #2563eb;
  }
  .site-footer__nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
  }
  @media (min-width: 48rem) {
    .site-footer__nav--legal {
      justify-content: flex-end;
    }
    .site-footer__nav--social {
      justify-content: flex-start;
    }
  }
  .site-footer__link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.9rem;
    font-weight: 600;
    border-radius: 0.85rem;
    padding: 0.5rem 1rem;
    transition:\n      background-color 0.2s ease,\n      border-color 0.2s ease,\n      color 0.2s ease,\n      box-shadow 0.2s ease;
  }
  .site-footer__link:focus-visible {
    outline: 2px solid rgba(37, 99, 235, 0.75);
    outline-offset: 2px;
  }
  .site-footer__link--social {
    border: 1px solid rgba(15, 23, 42, 0.15);
    background: rgba(255, 255, 255, 0.8);
    color: #0f172a;
  }
  .site-footer__link--social:hover {
    border-color: rgba(37, 99, 235, 0.4);
    background: rgba(219, 234, 254, 0.7);
    box-shadow: 0 10px 20px rgba(15, 23, 42, 0.1);
  }
  .site-footer__link--legal,
  .site-footer__link--external {
    border: 1px solid transparent;
    color: #475569;
  }
  .site-footer__link--legal:hover,
  .site-footer__link--external:hover {
    background: rgba(148, 163, 184, 0.15);
    color: #0f172a;
  }
  :where(.dark) .site-footer__link--social {
    border-color: rgba(148, 163, 184, 0.4);
    background: rgba(15, 23, 42, 0.7);
    color: #f8fafc;
  }
  :where(.dark) .site-footer__link--legal,
  :where(.dark) .site-footer__link--external {
    color: #cbd5f5;
  }
  .site-footer__link .sr-only {
    position: absolute;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    width: 1px;
    height: 1px;
    margin: -1px;
    border: 0;
    padding: 0;
    overflow: hidden;
  }
</style>
