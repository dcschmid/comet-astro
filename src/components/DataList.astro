---
/**
 * DataList - semantic definition list with accessible styling and responsive variants
 */
interface Item {
  term: string;
  description: string | string[];
}

interface Props {
  items: Item[];
  variant?: 'default' | 'horizontal' | 'striped';
  divider?: boolean;
  className?: string;
}

const {
  items,
  variant = 'default',
  divider = false,
  className = '',
} = Astro.props;

const isHorizontal = variant === 'horizontal';

const baseClasses = [
  'data-list',
  `data-list--${variant}`,
  divider && !isHorizontal ? 'data-list--divider' : '',
  className,
]
  .filter(Boolean)
  .join(' ');
---

<dl class={baseClasses}>
  {
    items.map((item, index) => (
      <div class={`data-list__item ${isHorizontal ? 'data-list__item--inline' : ''}`}>
        <dt
          class={`data-list__term ${
            isHorizontal ? 'data-list__term--inline' : ''
          }`}
        >
          {item.term}
        </dt>
        <dd
          class={`data-list__description ${
            isHorizontal ? 'data-list__description--inline' : ''
          }`}
        >
          {Array.isArray(item.description) ? (
            <ul class="data-list__list">
              {item.description.map((desc) => (
                <li class="data-list__list-item">{desc}</li>
              ))}
            </ul>
          ) : (
            item.description
          )}
        </dd>
        {divider && !isHorizontal && index < items.length - 1 && (
          <hr class="data-list__divider" />
        )}
      </div>
    ))
  }
</dl>

<style is:inline>
  .data-list {
    --dl-text: var(--dl-text-light, #0f172a);
    --dl-subtext: var(--dl-subtext-light, #475569);
    --dl-muted: var(--dl-muted-light, #64748b);
    --dl-border: var(--dl-border-light, #e2e8f0);
    --dl-border-strong: var(--dl-border-strong-light, #cbd5f5);
    --dl-strip-bg: var(--dl-strip-bg-light, rgba(15, 23, 42, 0.03));
    --dl-strip-border: var(--dl-strip-border-light, rgba(15, 23, 42, 0.08));
    --dl-shadow: var(--dl-shadow-light, 0 6px 18px rgba(15, 23, 42, 0.05));
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    font-size: 0.95rem;
    color: var(--dl-text);
  }
  :where(.dark) .data-list {
    --dl-text: var(--dl-text-dark, #f8fafc);
    --dl-subtext: var(--dl-subtext-dark, #cbd5f5);
    --dl-muted: var(--dl-muted-dark, #94a3b8);
    --dl-border: var(--dl-border-dark, #334155);
    --dl-border-strong: var(--dl-border-strong-dark, #475569);
    --dl-strip-bg: var(--dl-strip-bg-dark, rgba(15, 23, 42, 0.45));
    --dl-strip-border: var(--dl-strip-border-dark, rgba(148, 163, 184, 0.4));
    --dl-shadow: var(--dl-shadow-dark, 0 10px 24px rgba(2, 6, 23, 0.5));
  }
  .data-list__item {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 0.25rem 0;
  }
  .data-list__term {
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--dl-muted);
  }
  .data-list__description {
    margin: 0;
    line-height: 1.6;
    color: var(--dl-text);
  }
  .data-list__list {
    list-style: disc;
    padding-left: 1.25rem;
    margin: 0.25rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .data-list__list-item::marker {
    color: var(--dl-subtext);
  }
  .data-list__list-item {
    padding-left: 0.2rem;
  }
  .data-list__divider {
    border: none;
    border-top: 1px solid var(--dl-border);
    margin: 0.85rem 0 0;
  }
  .data-list--divider .data-list__item:last-of-type .data-list__divider {
    display: none;
  }
  .data-list--horizontal {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 0.6rem 1.25rem;
    align-items: baseline;
  }
  @media (min-width: 40rem) {
    .data-list--horizontal {
      grid-template-columns: auto minmax(0, 1fr);
    }
  }
  .data-list__item--inline {
    display: contents;
  }
  .data-list__term--inline {
    margin: 0;
    align-self: flex-start;
    text-align: right;
  }
  @media (max-width: 39.9375rem) {
    .data-list__term--inline {
      text-align: left;
    }
  }
  .data-list__description--inline {
    margin-left: 0;
  }
  .data-list--striped .data-list__item {
    padding: 0.85rem 1rem;
    border-radius: 0.85rem;
    border: 1px solid transparent;
    transition:
      background-color 0.2s ease,
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }
  .data-list--striped .data-list__item:nth-of-type(odd) {
    background: var(--dl-strip-bg);
    border-color: var(--dl-strip-border);
    box-shadow: var(--dl-shadow);
  }
  .data-list--striped .data-list__item:nth-of-type(even) {
    background: transparent;
    border-color: transparent;
  }
  .data-list--striped .data-list__divider {
    display: none;
  }
  @media (prefers-reduced-motion: reduce) {
    .data-list--striped .data-list__item {
      transition: none;
    }
  }
</style>
