---
interface Props {
  /** Current progress value */
  value: number;
  /** Maximum value (default: 100) */
  max?: number;
  /** Visual variant of the progress bar */
  variant?:
    | 'default'
    | 'success'
    | 'warning'
    | 'error'
    | 'info'
    | 'gradient'
    | 'minimal';
  /** Size of the progress bar */
  size?: 'xs' | 'sm' | 'md' | 'lg' | 'xl';
  /** Whether to show percentage label */
  showLabel?: boolean;
  /** Custom label text */
  label?: string;
  /** Position of the label */
  labelPosition?: 'top' | 'bottom' | 'inline';
  /** Whether progress bar is indeterminate (loading state) */
  indeterminate?: boolean;
  /** Disable the progress bar */
  disabled?: boolean;
  /** Custom aria-label for accessibility */
  ariaLabel?: string;
  /** ID of element that describes the progress bar */
  ariaDescribedBy?: string;
  /** Additional CSS classes */
  class?: string;
}

const {
  value,
  max = 100,
  variant = 'default',
  size = 'md',
  showLabel = false,
  label,
  labelPosition = 'top',
  indeterminate = false,
  disabled = false,
  ariaLabel,
  ariaDescribedBy,
  class: className = '',
} = Astro.props;

const percentage = indeterminate
  ? 0
  : Math.min(Math.max((value / max) * 100, 0), 100);

const displayLabel = label || (showLabel ? `${Math.round(percentage)}%` : null);
const rootClasses = [
  'progress-bar',
  `progress-bar--variant-${variant}`,
  `progress-bar--size-${size}`,
  disabled ? 'progress-bar--disabled' : '',
  className,
]
  .filter(Boolean)
  .join(' ');
---

<div
  class={rootClasses}
  role="group"
  aria-labelledby={displayLabel ? 'progress-label' : undefined}
>
  {
    displayLabel && labelPosition === 'top' && (
      <div class="progress-bar__label-row progress-bar__label-row--top">
        <span id="progress-label" class="progress-bar__label">
          {label || 'Progress'}
        </span>
        {showLabel && (
          <span class="progress-bar__value">
            {indeterminate ? 'Loading...' : `${Math.round(percentage)}%`}
          </span>
        )}
      </div>
    )
  }

  {
    displayLabel &&
      labelPosition === 'inline' &&
      size !== 'xs' &&
      size !== 'sm' && (
        <div class="progress-bar__track progress-bar__track--inline">
          <div
            class={`progress-bar__fill ${indeterminate ? 'progress-bar__fill--indeterminate' : ''}`}
            style={indeterminate ? undefined : `width: ${percentage}%`}
            role="progressbar"
            aria-valuenow={indeterminate ? undefined : value}
            aria-valuemin="0"
            aria-valuemax={max}
            aria-label={ariaLabel || displayLabel || 'Progress'}
            aria-describedby={ariaDescribedBy}
          />
          <div class="progress-bar__inline-label">
            <div
              class="progress-bar__inline-text"
            >
              {indeterminate ? 'Loading...' : `${Math.round(percentage)}%`}
            </div>
          </div>
        </div>
      )
  }

  {
        (!displayLabel ||
          labelPosition !== 'inline' ||
          size === 'xs' ||
          size === 'sm') && (
          <div class="progress-bar__track">
            <div
              class={`progress-bar__fill ${indeterminate ? 'progress-bar__fill--indeterminate' : ''}`}
              style={indeterminate ? undefined : `width: ${percentage}%`}
              role="progressbar"
              aria-valuenow={indeterminate ? undefined : value}
          aria-valuemin="0"
          aria-valuemax={max}
          aria-label={ariaLabel || displayLabel || 'Progress'}
          aria-describedby={ariaDescribedBy}
        />
        {indeterminate && (
          <div
            class="progress-bar__shimmer"
          />
        )}
      </div>
    )
  }

  {
    displayLabel && labelPosition === 'bottom' && (
      <div class="progress-bar__label-row progress-bar__label-row--bottom">
        <span class="progress-bar__label">{label || 'Progress'}</span>
        {showLabel && (
          <span class="progress-bar__value">
            {indeterminate ? 'Loading...' : `${Math.round(percentage)}%`}
          </span>
        )}
      </div>
    )
  }
</div>

<style>
  .progress-bar {
    width: 100%;
  }

  .progress-bar__track {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: 999px;
    background-color: rgba(148, 163, 184, 0.4);
    transition: opacity 0.2s ease;
  }

  .progress-bar--disabled .progress-bar__track {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .progress-bar__fill {
    height: 100%;
    border-radius: inherit;
    transition: width 0.4s ease;
    background-color: #2563eb;
  }

  .progress-bar__track--inline {
    position: relative;
  }

  .progress-bar__inline-label {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }

  .progress-bar__inline-text {
    font-size: 0.85rem;
    font-weight: 600;
    color: #ffffff;
    mix-blend-mode: difference;
  }

  .progress-bar__shimmer {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.5),
      transparent
    );
    animation: shimmer 1.5s ease-in-out infinite;
  }

  .progress-bar__label-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 0.5rem;
  }

  .progress-bar__label-row--bottom {
    margin-top: 0.5rem;
    margin-bottom: 0;
  }

  .progress-bar__label {
    font-weight: 600;
    color: #0f172a;
  }

  .progress-bar__value {
    font-variant-numeric: tabular-nums;
    color: inherit;
  }

  .progress-bar--size-xs .progress-bar__label,
  .progress-bar--size-xs .progress-bar__value {
    font-size: 0.75rem;
  }

  .progress-bar--size-sm .progress-bar__label,
  .progress-bar--size-sm .progress-bar__value {
    font-size: 0.85rem;
  }

  .progress-bar--size-lg .progress-bar__label,
  .progress-bar--size-lg .progress-bar__value {
    font-size: 1rem;
  }

  .progress-bar--size-xl .progress-bar__label,
  .progress-bar--size-xl .progress-bar__value {
    font-size: 1.1rem;
  }

  .progress-bar--size-xs .progress-bar__track {
    height: 0.25rem;
  }

  .progress-bar--size-sm .progress-bar__track {
    height: 0.35rem;
  }

  .progress-bar--size-md .progress-bar__track {
    height: 0.5rem;
  }

  .progress-bar--size-lg .progress-bar__track {
    height: 0.75rem;
  }

  .progress-bar--size-xl .progress-bar__track {
    height: 1rem;
  }

  .progress-bar--variant-success .progress-bar__fill {
    background-color: #16a34a;
  }

  .progress-bar--variant-warning .progress-bar__fill {
    background-color: #d97706;
  }

  .progress-bar--variant-error .progress-bar__fill {
    background-color: #dc2626;
  }

  .progress-bar--variant-info .progress-bar__fill {
    background-color: #0ea5e9;
  }

  .progress-bar--variant-gradient .progress-bar__fill {
    background-image: linear-gradient(
      90deg,
      #2563eb,
      #7c3aed,
      #db2777
    );
  }

  .progress-bar--variant-minimal .progress-bar__fill {
    background-color: #475569;
  }

  .progress-bar--variant-success .progress-bar__track {
    background-color: rgba(16, 185, 129, 0.2);
  }

  .progress-bar--variant-warning .progress-bar__track {
    background-color: rgba(251, 191, 36, 0.25);
  }

  .progress-bar--variant-error .progress-bar__track {
    background-color: rgba(239, 68, 68, 0.25);
  }

  .progress-bar--variant-info .progress-bar__track {
    background-color: rgba(14, 165, 233, 0.25);
  }

  @keyframes shimmer {
    0% {
      transform: translateX(-100%);
    }
    100% {
      transform: translateX(100%);
    }
  }

  :where(.dark) .progress-bar__track {
    background-color: rgba(71, 85, 105, 0.6);
  }

  :where(.dark) .progress-bar__label {
    color: #f8fafc;
  }

  :where(.dark) .progress-bar__value {
    color: #f8fafc;
  }

  :where(.dark) .progress-bar--variant-success .progress-bar__track {
    background-color: rgba(34, 197, 94, 0.25);
  }

  :where(.dark) .progress-bar--variant-warning .progress-bar__track {
    background-color: rgba(251, 191, 36, 0.25);
  }

  :where(.dark) .progress-bar--variant-error .progress-bar__track {
    background-color: rgba(248, 113, 113, 0.25);
  }

  :where(.dark) .progress-bar--variant-info .progress-bar__track {
    background-color: rgba(56, 189, 248, 0.25);
  }
</style>
