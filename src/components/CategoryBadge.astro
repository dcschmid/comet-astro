---
interface Props {
  category?: string;
  label?: string;
  tone?:
    | 'purple'
    | 'blue'
    | 'emerald'
    | 'amber'
    | 'rose'
    | 'sky'
    | 'indigo'
    | 'slate'
    | 'neutral';
  as?: 'span' | 'div';
  href?: string;
  ariaLabel?: string;
  size?: 'sm' | 'md' | 'lg';
  className?: string;
}

const {
  category,
  label,
  tone,
  as = 'span',
  href,
  ariaLabel,
  size = 'md',
  className = '',
} = Astro.props as Props;

const text = (label ?? category ?? 'Category').trim();
const categoryKey = (category ?? text).toLowerCase();
const heuristics = () => {
  if (!categoryKey) return 'slate';
  if (categoryKey.includes('rock')) return 'purple';
  if (categoryKey.includes('pop')) return 'sky';
  if (categoryKey.includes('jazz')) return 'amber';
  if (categoryKey.includes('hip') || categoryKey.includes('rap'))
    return 'emerald';
  if (categoryKey.includes('classical')) return 'indigo';
  return 'slate';
};
const toneKey = (tone || heuristics()) as NonNullable<Props['tone']>;
const sizeKey = size ?? 'md';

const Tag = href ? 'a' : as === 'div' ? 'div' : 'span';
const classes = [
  'category-badge',
  `category-badge--tone-${toneKey}`,
  `category-badge--size-${sizeKey}`,
  href ? 'category-badge--interactive' : '',
  className,
]
  .filter(Boolean)
  .join(' ');
const ariaAttrs: Record<string, string> = {};
if (ariaLabel) ariaAttrs['aria-label'] = ariaLabel;
---

<Tag class={classes} href={href} {...ariaAttrs}>
  <span class="category-badge__text">{text}</span>
</Tag>

<style is:inline>
  .category-badge {
    --category-bg: #0f172a;
    --category-border: rgba(148, 163, 184, 0.55);
    --category-text: #f8fafc;
    --category-font-size: 0.75rem;
    --category-padding-y: 0.2rem;
    --category-padding-x: 0.75rem;
    --category-letter-spacing: 0.14em;
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
    border-radius: 999px;
    border: 1px solid var(--category-border);
    background: var(--category-bg);
    color: var(--category-text);
    padding: var(--category-padding-y) var(--category-padding-x);
    font-size: var(--category-font-size);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--category-letter-spacing);
    transition: transform 0.2s ease, background-color 0.2s ease;
  }

  .category-badge__text {
    line-height: 1;
  }

  .category-badge:focus-visible {
    outline: 2px solid #38bdf8;
    outline-offset: 2px;
  }

  .category-badge--interactive {
    cursor: pointer;
  }

  .category-badge--interactive:hover,
  .category-badge--interactive:focus-visible {
    transform: translateY(-1px);
  }

  .category-badge--size-sm {
    --category-font-size: 0.65rem;
    --category-padding-y: 0.15rem;
    --category-padding-x: 0.55rem;
  }

  .category-badge--size-lg {
    --category-font-size: 0.85rem;
    --category-padding-y: 0.3rem;
    --category-padding-x: 1rem;
  }

  .category-badge--tone-purple {
    --category-bg: #6d28d9;
    --category-border: #8b5cf6;
    --category-text: #f8fafc;
  }

  .category-badge--tone-blue {
    --category-bg: #1d4ed8;
    --category-border: #60a5fa;
    --category-text: #f8fafc;
  }

  .category-badge--tone-emerald {
    --category-bg: #047857;
    --category-border: #34d399;
    --category-text: #f0fdf4;
  }

  .category-badge--tone-amber {
    --category-bg: #d97706;
    --category-border: #fbbf24;
    --category-text: #1c1917;
  }

  .category-badge--tone-rose {
    --category-bg: #be123c;
    --category-border: #fb7185;
    --category-text: #fff1f2;
  }

  .category-badge--tone-sky {
    --category-bg: #0ea5e9;
    --category-border: #38bdf8;
    --category-text: #022c22;
  }

  .category-badge--tone-indigo {
    --category-bg: #4338ca;
    --category-border: #6366f1;
    --category-text: #eef2ff;
  }

  .category-badge--tone-slate {
    --category-bg: #475569;
    --category-border: #94a3b8;
    --category-text: #f8fafc;
  }

  .category-badge--tone-neutral {
    --category-bg: #52525b;
    --category-border: #a1a1aa;
    --category-text: #f8fafc;
  }
</style>
