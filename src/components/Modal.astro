---
/**
 * Modal - Enhanced with WCAG AAA compliance, multiple variants, and responsive design
 */

interface Props {
  // Content
  id?: string;
  open?: boolean;
  title?: string;
  closeLabel?: string;

  // Variants
  variant?: 'default' | 'danger' | 'success' | 'warning';
  size?: 'sm' | 'md' | 'lg' | 'xl' | 'fullscreen';

  // Layout
  position?: 'center' | 'top' | 'bottom';
  backdrop?: 'default' | 'blur' | 'dark' | 'none';
  closable?: boolean;

  // Accessibility
  ariaLabel?: string;
  ariaDescribedBy?: string;
  preventBodyScroll?: boolean;

  // Classes
  class?: string;
  className?: string;
}

const {
  open = false,
  title,
  closeLabel = 'Close',
  variant = 'default',
  size = 'md',
  position = 'center',
  backdrop = 'default',
  closable = true,
  ariaLabel,
  ariaDescribedBy,
  preventBodyScroll = true,
  class: className,
  className: legacyClassName,
} = Astro.props;

const hasFooter = Astro.slots.has('footer');

// Generate unique IDs for accessibility
const modalId = `comet-modal-${Math.random().toString(36).slice(2, 9)}`;
const titleId = title ? `${modalId}-title` : undefined;
const descriptionId =
  ariaDescribedBy || (hasFooter ? `${modalId}-footer` : undefined);

const sizeTokens = {
  sm: { maxWidth: '28rem' },
  md: { maxWidth: '36rem' },
  lg: { maxWidth: '48rem' },
  xl: { maxWidth: '64rem' },
  fullscreen: { maxWidth: '100%', maxHeight: '100%' },
} as const;

const inlineStyles = Object.entries({
  '--modal-max-width': sizeTokens[size]?.maxWidth ?? '36rem',
  '--modal-max-height': size === 'fullscreen' ? '100%' : '90vh',
}).reduce((acc, [k, v]) => `${acc}${k}: ${v}; `, '');

const userClasses = [className, legacyClassName].filter(Boolean).join(' ');

const rootClasses = [
  'modal',
  `modal--variant-${variant}`,
  `modal--size-${size}`,
  `modal--position-${position}`,
  `modal--backdrop-${backdrop}`,
  open ? 'modal--open' : 'modal--closed',
  userClasses,
]
  .filter(Boolean)
  .join(' ');
---

<div
  id={Astro.props.id || modalId}
  role="dialog"
  aria-modal="true"
  aria-labelledby={titleId}
  aria-describedby={descriptionId}
  aria-label={ariaLabel || (title ? undefined : 'Modal dialog')}
  class={rootClasses}
  data-open={open ? 'true' : 'false'}
  data-modal-root
  data-prevent-body-scroll={preventBodyScroll ? 'true' : 'false'}
  data-variant={variant}
  data-size={size}
>
  <div
    class="modal__backdrop"
    data-modal-backdrop={backdrop !== 'none' && closable ? 'true' : undefined}
    aria-hidden="true"
  />

  <div
    class="modal__dialog"
    data-modal-dialog
    role="document"
    tabindex="-1"
    style={inlineStyles}
  >
    <header class="modal__header">
      {
        title && (
          <h2
            id={titleId}
            class="modal__title"
          >
            {title}
          </h2>
        )
      }

      {
        closable && (
          <button
            type="button"
            class="modal__close-button"
            data-modal-close
            aria-label={closeLabel}
          >
            <span aria-hidden="true" class="modal__close-icon">
              ×
            </span>
          </button>
        )
      }
    </header>

    <div
      class="modal__content"
    >
      <slot />
    </div>

    {
      hasFooter && (
        <footer
          id={ariaDescribedBy ? undefined : `${modalId}-footer`}
          class="modal__footer"
        >
          <slot name="footer" />
        </footer>
      )
    }
  </div>
</div>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const SELECTOR_MODAL = '[data-modal-root]';
    const SELECTOR_OPEN = '[data-modal-open]';
    const SELECTOR_CLOSE = '[data-modal-close]';
    const SELECTOR_BACKDROP = '[data-modal-backdrop]';

    const updateScrollLock = () => {
      const lockTarget = document.querySelector(
        `${SELECTOR_MODAL}[data-open="true"][data-prevent-body-scroll="true"]`
      );
      document.body.style.overflow = lockTarget ? 'hidden' : '';
    };

    const closeModal = (modal) => {
      if (!(modal instanceof HTMLElement)) return;
      modal.classList.remove('modal--open');
      modal.classList.add('modal--closed');
      modal.setAttribute('data-open', 'false');
      updateScrollLock();
    };

    const openModal = (modal) => {
      if (!(modal instanceof HTMLElement)) return;
      modal.classList.add('modal--open');
      modal.classList.remove('modal--closed');
      modal.setAttribute('data-open', 'true');
      updateScrollLock();
    };

    document.addEventListener('click', (event) => {
      const targetNode = event.target;
      if (!(targetNode instanceof HTMLElement)) return;

      const openTrigger = targetNode.closest(SELECTOR_OPEN);
      if (openTrigger) {
        event.preventDefault();
        const modalId = openTrigger.getAttribute('data-modal-open');
        const modal = modalId ? document.getElementById(modalId) : null;
        if (modal) openModal(modal);
        return;
      }

      const closeButton = targetNode.closest(SELECTOR_CLOSE);
      if (closeButton) {
        event.preventDefault();
        const modal = closeButton.closest(SELECTOR_MODAL);
        closeModal(modal);
        return;
      }

      if (targetNode.matches(SELECTOR_BACKDROP)) {
        event.preventDefault();
        const modal = targetNode.closest(SELECTOR_MODAL);
        closeModal(modal);
      }
    });

    document.addEventListener('keydown', (event) => {
      if (event.key !== 'Escape') return;
      const openModalElement = document.querySelector(
        `${SELECTOR_MODAL}[data-open="true"]`
      );
      closeModal(openModalElement);
    });
  });
</script>

<style>
  .modal {
    position: fixed;
    inset: 0;
    z-index: 50;
    display: flex;
    padding: 2rem 1rem;
  }

  .modal--position-center {
    align-items: center;
    justify-content: center;
  }

  .modal--position-top {
    align-items: flex-start;
    justify-content: center;
    padding-top: 5rem;
  }

  .modal--position-bottom {
    align-items: flex-end;
    justify-content: center;
    padding-bottom: 5rem;
  }

  .modal--closed {
    display: none;
  }

  .modal__backdrop {
    position: absolute;
    inset: 0;
    background-color: rgba(15, 23, 42, 0.75);
    transition: opacity 0.2s ease;
  }

  .modal--backdrop-blur .modal__backdrop {
    backdrop-filter: blur(4px);
  }

  .modal--backdrop-dark .modal__backdrop {
    background-color: rgba(0, 0, 0, 0.9);
  }

  .modal--backdrop-none .modal__backdrop {
    background-color: transparent;
    pointer-events: none;
  }

  .modal__dialog {
    position: relative;
    z-index: 10;
    width: 100%;
    max-width: var(--modal-max-width, 36rem);
    max-height: var(--modal-max-height, 90vh);
    border-radius: 1.5rem;
    border: 1px solid #e2e8f0;
    background-color: #ffffff;
    color: #0f172a;
    box-shadow: 0 30px 90px rgba(15, 23, 42, 0.2);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .modal--size-fullscreen .modal__dialog {
    border-radius: 0;
  }

  .modal__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.5rem;
    border-bottom: 1px solid #e2e8f0;
  }

  .modal__title {
    font-size: 1.25rem;
    font-weight: 600;
    color: inherit;
    margin: 0;
  }

  .modal__close-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 0.75rem;
    border: 1px solid #cbd5f5;
    background-color: #f8fafc;
    color: #475569;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .modal__close-button:hover {
    background-color: #e2e8f0;
    color: #0f172a;
  }

  .modal__close-button:focus-visible {
    outline: 2px solid #3b82f6;
    outline-offset: 2px;
  }

  .modal__close-icon {
    font-size: 1.25rem;
    line-height: 1;
  }

  .modal__content {
    padding: 1.5rem;
    flex: 1;
    overflow-y: auto;
    color: #475569;
  }

  .modal__footer {
    border-top: 1px solid #e2e8f0;
    padding: 1.5rem;
    color: #475569;
  }

  .modal--variant-danger .modal__dialog {
    border-color: #fecdd3;
  }

  .modal--variant-danger .modal__title {
    color: #be123c;
  }

  .modal--variant-success .modal__dialog {
    border-color: #bbf7d0;
  }

  .modal--variant-success .modal__title {
    color: #16a34a;
  }

  .modal--variant-warning .modal__dialog {
    border-color: #fde68a;
  }

  .modal--variant-warning .modal__title {
    color: #b45309;
  }

  :where(.dark) .modal__backdrop {
    background-color: rgba(2, 6, 23, 0.85);
  }

  :where(.dark) .modal__dialog {
    background-color: #0f172a;
    border-color: #1e293b;
    color: #f8fafc;
    box-shadow: 0 30px 90px rgba(0, 0, 0, 0.4);
  }

  :where(.dark) .modal__header,
  :where(.dark) .modal__footer {
    border-color: #1f2937;
  }

  :where(.dark) .modal__content,
  :where(.dark) .modal__footer {
    color: #cbd5f5;
  }

  :where(.dark) .modal__close-button {
    border-color: #334155;
    background-color: #1e293b;
    color: #cbd5f5;
  }

  :where(.dark) .modal__close-button:hover {
    background-color: #334155;
  }
</style>
