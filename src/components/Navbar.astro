---
/**
 * Navbar - Enhanced responsive navigation with WCAG AAA compliance
 */

interface NavItem {
  href: string;
  label: string;
  external?: boolean;
  active?: boolean;
}

interface Props {
  // Content
  items?: NavItem[];
  brand?: string;
  brandHref?: string;

  // Styling
  variant?: 'default' | 'minimal' | 'glass';
  position?: 'static' | 'sticky' | 'fixed';

  // Layout
  maxWidth?: 'sm' | 'md' | 'lg' | 'xl' | 'full';

  // Accessibility
  ariaLabel?: string;

  // Classes
  class?: string;
  className?: string;
}

const {
  items = [],
  brand = 'Comet',
  brandHref = '/',
  variant = 'default',
  position = 'static',
  maxWidth = 'xl',
  ariaLabel = 'Main navigation',
  class: className,
  className: legacyClassName,
} = Astro.props;

const navId = `comet-nav-${Math.random().toString(36).slice(2, 9)}`;
const userClasses = [className, legacyClassName].filter(Boolean).join(' ');

const widthMap = {
  sm: '42rem',
  md: '56rem',
  lg: '72rem',
  xl: '80rem',
  full: '100%',
} as const;

const rootClasses = [
  'navbar',
  `navbar--variant-${variant}`,
  `navbar--position-${position}`,
  userClasses,
]
  .filter(Boolean)
  .join(' ');
---

<header class={rootClasses} role="banner">
  <div class="navbar__inner" style={`--navbar-max-width: ${widthMap[maxWidth]}`}>
    <!-- Brand/Logo -->
    <a
      href={brandHref}
      class="navbar__brand"
      aria-label={`${brand} - Go to homepage`}
    >
      {brand}
    </a>

    <!-- Mobile Menu Toggle -->
    <button
      type="button"
      class="navbar__toggle"
      data-nav-toggle
      aria-controls={navId}
      aria-expanded="false"
      aria-label="Toggle navigation menu"
    >
      <span class="navbar__toggle-label">Menu</span>
      <span
        class="navbar__toggle-icon"
        aria-hidden="true"
        data-nav-icon>☰</span
      >
    </button>

    <!-- Navigation -->
    <nav
      id={navId}
      class="navbar__menu"
      data-nav
      role="navigation"
      aria-label={ariaLabel}
    >
      <ul class="navbar__list">
        {
          items.map((item) => (
            <li>
              <a
                href={item.href}
                target={item.external ? '_blank' : undefined}
                rel={item.external ? 'noopener noreferrer' : undefined}
                class={`navbar__link ${item.active ? 'navbar__link--active' : ''}`.trim()}
                aria-current={item.active ? 'page' : undefined}
              >
                {item.label}
                {item.external && (
                  <>
                    <span class="navbar__external-icon" aria-hidden="true">
                      ↗
                    </span>
                    <span class="sr-only"> (opens in new window)</span>
                  </>
                )}
              </a>
            </li>
          ))
        }

        <!-- Actions Slot -->
        <li class="navbar__actions">
          <slot name="actions" />
        </li>
      </ul>
    </nav>
  </div>
</header>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const navbars = document.querySelectorAll('.navbar');

    navbars.forEach((navbar) => {
      const toggle = navbar.querySelector('[data-nav-toggle]');
      const nav = navbar.querySelector('[data-nav]');
      const icon = navbar.querySelector('[data-nav-icon]');

      if (!(toggle instanceof HTMLElement) || !(nav instanceof HTMLElement))
        return;

      let isOpen = false;

      const updateVisibility = (nextOpen) => {
        isOpen = nextOpen;
        toggle.setAttribute('aria-expanded', String(nextOpen));

        if (icon) {
          icon.textContent = nextOpen ? '✕' : '☰';
          icon.style.transform = nextOpen ? 'rotate(180deg)' : 'rotate(0deg)';
        }

        if (window.innerWidth >= 768) {
          nav.classList.remove('navbar__menu--hidden');
          return;
        }

        nav.classList.toggle('navbar__menu--hidden', !nextOpen);

        if (nextOpen) {
          const firstLink = nav.querySelector('a');
          if (firstLink) {
            firstLink.focus();
          }
        }
      };

      // Toggle click handler
      toggle.addEventListener('click', (event) => {
        event.preventDefault();
        updateVisibility(!isOpen);
      });

      // Escape key handler
      navbar.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && isOpen) {
          updateVisibility(false);
          toggle.focus();
        }
      });

      // Close menu when clicking nav links on mobile
      nav.addEventListener('click', (event) => {
        const link =
          event.target instanceof HTMLElement
            ? event.target.closest('a[href]')
            : null;

        if (link && window.innerWidth < 768) {
          updateVisibility(false);
        }
      });

      // Handle window resize
      const handleResize = () => {
        const isDesktop = window.innerWidth >= 768;

        if (isDesktop) {
          nav.classList.remove('navbar__menu--hidden');
          updateVisibility(false);
        } else {
          nav.classList.toggle('navbar__menu--hidden', !isOpen);
        }
      };

      window.addEventListener('resize', handleResize);

      // Initialize
      updateVisibility(false);
    });
  });
</script>

<style>
  .navbar {
    width: 100%;
    border-bottom: 1px solid rgba(148, 163, 184, 0.4);
    background-color: #ffffff;
    color: #0f172a;
  }

  .navbar--position-sticky {
    position: sticky;
    top: 0;
    z-index: 40;
  }

  .navbar--position-fixed {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 40;
  }

  .navbar__inner {
    margin: 0 auto;
    max-width: var(--navbar-max-width, 80rem);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.75rem 1.5rem;
  }

  .navbar__brand {
    font-size: 1.125rem;
    font-weight: 600;
    text-decoration: none;
    color: inherit;
    padding: 0.25rem 0.5rem;
    border-radius: 0.5rem;
  }

  .navbar__brand:focus-visible {
    outline: 2px solid #3b82f6;
    outline-offset: 2px;
  }

  .navbar__toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    min-width: 2.5rem;
    min-height: 2.5rem;
    border: 1px solid rgba(148, 163, 184, 0.6);
    border-radius: 0.75rem;
    background-color: rgba(248, 250, 252, 0.9);
    color: inherit;
    font-size: 0.9rem;
    font-weight: 600;
    padding: 0.4rem 0.75rem;
    cursor: pointer;
    transition: background-color 0.2s ease, border-color 0.2s ease;
  }

  .navbar__toggle:hover {
    background-color: rgba(248, 250, 252, 1);
  }

  .navbar__toggle:focus-visible {
    outline: 2px solid #3b82f6;
    outline-offset: 2px;
  }

  .navbar__toggle-icon {
    font-size: 1.1rem;
    transition: transform 0.2s ease;
  }

  .navbar__menu {
    width: 100%;
  }

  .navbar__menu--hidden {
    display: none;
  }

  .navbar__list {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin: 0.75rem 0 0;
    padding: 0;
    list-style: none;
  }

  .navbar__link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 0.75rem;
    border-radius: 0.75rem;
    text-decoration: none;
    color: inherit;
    font-weight: 500;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .navbar__link:hover,
  .navbar__link:focus-visible {
    background-color: rgba(59, 130, 246, 0.1);
    color: #1d4ed8;
  }

  .navbar__link--active {
    background-color: rgba(59, 130, 246, 0.15);
    color: #1d4ed8;
  }

  .navbar__external-icon {
    font-size: 0.75rem;
  }

  .navbar__actions {
    margin-top: 0.75rem;
  }

  @media (min-width: 768px) {
    .navbar__toggle {
      display: none;
    }

    .navbar__menu {
      display: block !important;
      width: auto;
    }

    .navbar__list {
      flex-direction: row;
      align-items: center;
      margin-top: 0;
      gap: 0.5rem;
    }

    .navbar__actions {
      margin-top: 0;
      margin-left: 1rem;
    }
  }

  :where(.dark) .navbar {
    border-color: rgba(51, 65, 85, 0.6);
    background-color: rgba(15, 23, 42, 0.9);
    color: #f8fafc;
  }

  :where(.dark) .navbar__toggle {
    border-color: rgba(148, 163, 184, 0.3);
    background-color: rgba(15, 23, 42, 0.8);
  }

  .navbar--variant-glass {
    background-color: rgba(255, 255, 255, 0.75);
    backdrop-filter: blur(10px);
    border-color: rgba(148, 163, 184, 0.4);
  }

  .navbar--variant-minimal {
    border-color: transparent;
    background-color: transparent;
  }

  :where(.dark) .navbar--variant-glass {
    background-color: rgba(15, 23, 42, 0.75);
  }
</style>
