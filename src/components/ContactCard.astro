---
/**
 * ContactCard - person card with contact info
 */
interface Props {
  name: string;
  role?: string;
  email?: string;
  avatar?: string;
  website?: string;
  className?: string;
}

const {
  name,
  role,
  email,
  avatar,
  website,
  className = '',
} = Astro.props as Props;

const initials = name
  .split(' ')
  .filter(Boolean)
  .map((part) => part[0] || '')
  .join('')
  .slice(0, 2)
  .toUpperCase();
---

<article class={`contact-card ${className}`.trim()}>
  {
    avatar ? (
      <img
        src={avatar}
        alt={`Portrait of ${name}`}
        class="contact-card__avatar"
        loading="lazy"
        decoding="async"
      />
    ) : (
      <div
        class="contact-card__avatar contact-card__avatar--initials"
        aria-hidden="true"
      >
        <span class="contact-card__initials">{initials}</span>
      </div>
    )
  }
  <div class="contact-card__body">
    <div class="contact-card__name">{name}</div>
    {
      role && (
        <div class="contact-card__role">{role}</div>
      )
    }
    <div class="contact-card__links">
      {
        email && (
          <a
            href={`mailto:${email}`}
            class="contact-card__link"
            aria-label={`Send email to ${name}`}
          >
            {email}
          </a>
        )
      }
      {
        website && (
          <a
            href={website}
            target="_blank"
            rel="noopener noreferrer"
            class="contact-card__link"
            aria-label={`Visit ${name}'s website`}
          >
            Website<span class="sr-only"> (opens in new window)</span>
          </a>
        )
      }
    </div>
  </div>
</article>

<style is:inline>
  .contact-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    border-radius: 1.25rem;
    border: 1px solid rgba(148, 163, 184, 0.45);
    background: #ffffff;
    color: #0f172a;
    padding: 1.25rem;
    box-shadow: 0 20px 45px rgba(15, 23, 42, 0.08);
  }

  @media (min-width: 640px) {
    .contact-card {
      flex-direction: row;
      align-items: center;
    }
  }

  :where(.dark) .contact-card {
    background: #0f172a;
    color: #f8fafc;
    border-color: rgba(148, 163, 184, 0.35);
  }

  .contact-card__avatar {
    width: 4rem;
    height: 4rem;
    border-radius: 999px;
    object-fit: cover;
    box-shadow: 0 10px 25px rgba(15, 23, 42, 0.15);
    border: 2px solid rgba(148, 163, 184, 0.35);
    flex-shrink: 0;
  }

  .contact-card__avatar--initials {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #4338ca, #ec4899);
    color: #ffffff;
  }

  .contact-card__initials {
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  .contact-card__body {
    flex: 1;
    min-width: 0;
  }

  .contact-card__name {
    font-size: 1.15rem;
    font-weight: 700;
    color: inherit;
  }

  .contact-card__role {
    font-size: 0.9rem;
    color: rgba(15, 23, 42, 0.7);
  }

  :where(.dark) .contact-card__role {
    color: rgba(248, 250, 252, 0.7);
  }

  .contact-card__links {
    margin-top: 0.75rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    font-size: 0.9rem;
  }

  .contact-card__link {
    display: inline-flex;
    align-items: center;
    border-radius: 0.65rem;
    border: 1px solid rgba(59, 130, 246, 0.35);
    padding: 0.35rem 0.85rem;
    color: #2563eb;
    text-decoration: none;
    background: rgba(59, 130, 246, 0.08);
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .contact-card__link:hover {
    background: rgba(59, 130, 246, 0.15);
    color: #1d4ed8;
  }

  .contact-card__link:focus-visible {
    outline: 2px solid rgba(59, 130, 246, 0.6);
    outline-offset: 2px;
  }

  :where(.dark) .contact-card__link {
    color: #cbd5f5;
    background: rgba(59, 130, 246, 0.2);
    border-color: rgba(59, 130, 246, 0.35);
  }
</style>
