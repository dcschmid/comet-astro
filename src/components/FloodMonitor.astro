---
/**
 * FloodMonitor – Minimal river level & discharge snapshot (WCAG AAA).
 * Tailwind-only; shows: Discharge, Level, Trend (optional), Risk, Updated.
 */
interface Props {
  stationId?: string;
  apiUrl?: string; // optional custom endpoint returning { discharge, level?, trend?, updated? }
  latitude?: number; // if apiUrl not provided, use lat/lon with Open‑Meteo flood API
  longitude?: number;
  location?: string;
  riverName?: string;
  thresholds?: { watch: number; warning: number; emergency: number };
  refreshInterval?: number;
  disableFetch?: boolean;
  showTrend?: boolean;
  ariaLabel?: string;
  class?: string;
}

const props = Astro.props as Props;
const {
  stationId,
  apiUrl,
  latitude,
  longitude,
  location = 'Demo Location',
  riverName = 'River',
  thresholds = { watch: 50, warning: 100, emergency: 200 },
  refreshInterval = 0,
  disableFetch = false,
  showTrend = true,
  ariaLabel,
  class: className = '',
} = props;

const fallback = {
  discharge: 42.3,
  level: 2.18,
  trend: 'stable',
  updated: new Date().toISOString(),
};
const label = ariaLabel || `Flood monitor for ${location}`;
const rootClasses = ['flood-monitor', className].filter(Boolean).join(' ');

const classifyRisk = (d: number) => {
  if (d >= thresholds.emergency)
    return { level: 'Emergency', modifier: 'emergency' };
  if (d >= thresholds.warning)
    return { level: 'Warning', modifier: 'warning' };
  if (d >= thresholds.watch) return { level: 'Watch', modifier: 'watch' };
  return { level: 'Normal', modifier: 'normal' };
};
const initialRisk = classifyRisk(fallback.discharge);
---

<div
  class={rootClasses}
  role="region"
  aria-label={label}
  aria-busy={!disableFetch &&
  (apiUrl || (latitude != null && longitude != null))
    ? 'true'
    : 'false'}
  data-flood-monitor
  data-api={apiUrl}
  data-station={stationId}
  data-lat={latitude}
  data-lon={longitude}
  data-refresh={refreshInterval}
  data-disable-fetch={disableFetch}
  data-state={!disableFetch &&
  (apiUrl || (latitude != null && longitude != null))
    ? 'loading'
    : 'static'}
  data-thresholds={JSON.stringify(thresholds)}
>
  <header class="flood-monitor__header">
    <h2 class="flood-monitor__title">
      <span aria-hidden="true" class="flood-monitor__title-icon">🌊</span>
      <span class="flood-monitor__location" data-location>{location}</span>
    </h2>
    <p class="flood-monitor__status" aria-live="polite" data-status>
      {!disableFetch && apiUrl ? 'Lade Flussdaten …' : 'Statische Demodaten'}
    </p>
  </header>

  <div class="flood-monitor__metrics" data-metrics>
    <div class="flood-monitor__metric" data-metric="discharge">
      <span class="flood-monitor__metric-label">Discharge</span>
      <span class="flood-monitor__metric-value" data-discharge
        >{fallback.discharge.toFixed(1)} m³/s</span
      >
      <span class="flood-monitor__risk" data-risk>
        <span
          class={`flood-monitor__risk-dot flood-monitor__risk-dot--${initialRisk.modifier}`}
          data-risk-indicator
          aria-hidden="true"></span>
        <span class="flood-monitor__risk-text" data-risk-text
          >{initialRisk.level}</span
        >
      </span>
    </div>
    <div class="flood-monitor__metric" data-metric="level">
      <span class="flood-monitor__metric-label">Level</span>
      <span class="flood-monitor__metric-value" data-level
        >{fallback.level.toFixed(2)} m</span
      >
      <span class="flood-monitor__metric-subtext">{riverName}</span>
    </div>
    {
      showTrend && (
        <div class="flood-monitor__metric" data-metric="trend">
          <span class="flood-monitor__metric-label">Trend</span>
          <span class="flood-monitor__metric-value" data-trend>
            {fallback.trend}
          </span>
          <span class="flood-monitor__metric-subtext" data-trend-arrow aria-hidden="true">
            →
          </span>
        </div>
      )
    }
    <div class="flood-monitor__metric" data-metric="thresholds">
      <span class="flood-monitor__metric-label">Thresholds</span>
      <span class="flood-monitor__metric-value" data-th
        >{
          `${thresholds.watch}/${thresholds.warning}/${thresholds.emergency}`
        }</span
      >
      <span class="flood-monitor__metric-subtext">watch/warn/emerg</span>
    </div>
    <div class="flood-monitor__metric" data-metric="updated">
      <span class="flood-monitor__metric-label">Updated</span>
      <span class="flood-monitor__metric-value" data-updated>Just now</span>
      <span
        class="flood-monitor__status-note flood-monitor__status-note--loading"
        data-loading>Lädt…</span
      >
      <span
        class="flood-monitor__status-note flood-monitor__status-note--error"
        data-error>Fehler</span
      >
    </div>
  </div>

  <p class="flood-monitor__disclaimer" data-disclaimer>
    {
      !disableFetch && (apiUrl || (latitude != null && longitude != null))
        ? 'Live Daten (Open‑Meteo Flood API oder benutzerdefinierter Endpunkt). Fallback bei Fehler.'
        : 'Demodaten. apiUrl oder latitude+longitude setzen für Live-Aktualisierung.'
    } AAA Kontrast eingehalten.
  </p>

  <footer class="flood-monitor__footer">
    <span class="flood-monitor__source"
      >Quelle:
      <span class="flood-monitor__link">Hydro Service</span></span
    >
    <span class="flood-monitor__refresh" data-refresh-indicator
      >{
        refreshInterval > 0 ? `Auto ${refreshInterval}m` : 'Kein Auto-Refresh'
      }</span
    >
  </footer>
</div>

<script>
  function initFloodMonitor(el) {
    let api = el.dataset.api;
    const refresh = parseInt(el.dataset.refresh || '0');
    const disableFetch = el.dataset.disableFetch === 'true';
    const thresholds = (() => {
      try {
        return JSON.parse(el.dataset.thresholds || '{}');
      } catch {
        return {};
      }
    })();
    const lat = el.dataset.lat ? parseFloat(el.dataset.lat) : undefined;
    const lon = el.dataset.lon ? parseFloat(el.dataset.lon) : undefined;
    const statusEl = el.querySelector('[data-status]');
    const dischargeEl = el.querySelector('[data-discharge]');
    const levelEl = el.querySelector('[data-level]');
    const riskEl = el.querySelector('[data-risk]');
    const trendEl = el.querySelector('[data-trend]');
    const trendArrowEl = el.querySelector('[data-trend-arrow]');
    const updEl = el.querySelector('[data-updated]');
    const loadingEl = el.querySelector('[data-loading]');
    const errorEl = el.querySelector('[data-error]');

    const classify = (d) => {
      if (d >= thresholds.emergency) return ['Emergency', 'emergency'];
      if (d >= thresholds.warning) return ['Warning', 'warning'];
      if (d >= thresholds.watch) return ['Watch', 'watch'];
      return ['Normal', 'normal'];
    };

    const LOADING_CLASS = 'flood-monitor--loading';
    const STATUS_VISIBLE_CLASS = 'flood-monitor__status-note--visible';
    const RISK_DOT_BASE = 'flood-monitor__risk-dot';
    const RISK_DOT_PREFIX = 'flood-monitor__risk-dot--';

    const setState = (s) => {
      el.dataset.state = s;
      el.setAttribute('aria-busy', s === 'loading' ? 'true' : 'false');
      el.classList.toggle(LOADING_CLASS, s === 'loading');
      if (loadingEl)
        loadingEl.classList.toggle(STATUS_VISIBLE_CLASS, s === 'loading');
      if (errorEl)
        errorEl.classList.toggle(STATUS_VISIBLE_CLASS, s === 'error');
    };

    function buildAutoApi() {
      if (api) return api; // custom overrides
      if (typeof lat === 'number' && typeof lon === 'number') {
        const params = new URLSearchParams({
          latitude: String(lat),
          longitude: String(lon),
          daily: 'river_discharge',
          past_days: '2', // for trend diff
          forecast_days: '1',
        });
        return `https://flood-api.open-meteo.com/v1/flood?${params.toString()}`;
      }
      return undefined;
    }

    async function fetchData() {
      api = buildAutoApi();
      if (!api || disableFetch) {
        if (statusEl) statusEl.textContent = 'Fallback Werte aktiv';
        return;
      }
      setState('loading');
      if (statusEl) statusEl.textContent = 'Lade Flussdaten …';
      try {
        const res = await fetch(api);
        if (!res.ok) throw 0;
        const data = await res.json();
        // Open-Meteo flood API structure: daily.time[], daily.river_discharge[]
        let discharge = null;
        let trend = 'stable';
        if (data.daily && Array.isArray(data.daily.river_discharge)) {
          const arr = data.daily.river_discharge;
          // latest non-null
          for (let i = arr.length - 1; i >= 0; i--) {
            if (arr[i] != null) {
              discharge = arr[i];
              break;
            }
          }
          // trend from last two valid points
          let prev = null;
          for (let i = arr.length - 1; i >= 0; i--) {
            if (arr[i] != null && arr[i] !== discharge) {
              prev = arr[i];
              break;
            }
          }
          if (prev != null && discharge != null) {
            const delta = discharge - prev;
            if (Math.abs(delta) < 0.01) trend = 'stable';
            else if (delta > 0) trend = 'rising';
            else trend = 'falling';
          }
        }
        // Level not provided by API → keep previous fallback level or hide label if desired
        // fallback reference moved outside function scope → retrieve from attribute or inline constant
        const level =
          typeof data.level === 'number'
            ? data.level
            : window.__floodFallbackLevel || 2.18;
        if (discharge !== null && dischargeEl) {
          dischargeEl.textContent = `${discharge.toFixed(1)} m³/s`;
          const [txt, indicatorMod] = classify(discharge);
          const riskTextEl = riskEl?.querySelector('[data-risk-text]');
          const riskIndicatorEl = riskEl?.querySelector(
            '[data-risk-indicator]'
          );
          if (riskTextEl) riskTextEl.textContent = txt;
          if (riskIndicatorEl) {
            riskIndicatorEl.className = `${RISK_DOT_BASE} ${RISK_DOT_PREFIX}${indicatorMod}`;
          }
        }
        if (levelEl) {
          levelEl.textContent = `${level.toFixed(2)} m`;
        }
        if (trendEl) {
          trendEl.textContent = trend;
        }
        if (trendArrowEl) {
          trendArrowEl.textContent =
            trend === 'rising' ? '↑' : trend === 'falling' ? '↓' : '→';
        }
        if (updEl) {
          updEl.textContent = new Date().toLocaleTimeString([], {
            hour: '2-digit',
            minute: '2-digit',
          });
        }
        if (statusEl) statusEl.textContent = 'Live Daten geladen';
        setState('ready');
      } catch {
        if (statusEl) statusEl.textContent = 'Live Fehler (Fallback angezeigt)';
        setState('error');
      }
    }

    // expose fallback level for runtime (avoid closure issues after bundling)
    if (!window.__floodFallbackLevel) window.__floodFallbackLevel = 2.18;
    fetchData();
    if (refresh > 0 && api && !disableFetch)
      setInterval(fetchData, refresh * 60 * 1000);
  }

  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('[data-flood-monitor]').forEach(initFloodMonitor);
  });
</script>

<style is:inline>
  .flood-monitor {
    --flood-bg: #ffffff;
    --flood-border: rgba(15, 23, 42, 0.12);
    --flood-heading: #0f172a;
    --flood-subtext: #475569;
    --flood-card-bg: rgba(248, 250, 252, 0.9);
    --flood-card-border: rgba(15, 23, 42, 0.08);
    width: 100%;
    border-radius: 1.75rem;
    border: 1px solid var(--flood-border);
    background: var(--flood-bg);
    box-shadow: 0 28px 65px rgba(15, 23, 42, 0.08);
    padding: clamp(1.5rem, 4vw, 2.75rem);
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  :where(.dark) .flood-monitor {
    --flood-bg: #0f172a;
    --flood-border: rgba(148, 163, 184, 0.4);
    --flood-heading: #f8fafc;
    --flood-subtext: #cbd5f5;
    --flood-card-bg: rgba(15, 23, 42, 0.65);
    --flood-card-border: rgba(148, 163, 184, 0.3);
    box-shadow: 0 32px 70px rgba(2, 6, 23, 0.65);
  }
  .flood-monitor__header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  @media (min-width: 48rem) {
    .flood-monitor__header {
      flex-direction: row;
      align-items: flex-start;
      justify-content: space-between;
    }
  }
  .flood-monitor__title {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: clamp(1.25rem, 3vw, 1.8rem);
    font-weight: 700;
    color: var(--flood-heading);
    margin: 0;
  }
  .flood-monitor__title-icon {
    font-size: 2rem;
  }
  .flood-monitor__location {
    min-width: 0;
    display: inline-flex;
    max-width: 100%;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .flood-monitor__status {
    margin: 0;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--flood-subtext);
  }
  .flood-monitor__metrics {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }
  @media (min-width: 40rem) {
    .flood-monitor__metrics {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
  @media (min-width: 70rem) {
    .flood-monitor__metrics {
      grid-template-columns: repeat(5, minmax(0, 1fr));
    }
  }
  .flood-monitor__metric {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    border-radius: 1rem;
    border: 1px solid var(--flood-card-border);
    background: var(--flood-card-bg);
    padding: 0.85rem 1rem;
    min-height: 5rem;
  }
  .flood-monitor__metric-label {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--flood-subtext);
  }
  .flood-monitor__metric-value {
    font-size: clamp(1rem, 2vw, 1.25rem);
    font-weight: 700;
    color: var(--flood-heading);
  }
  .flood-monitor__metric-subtext {
    font-size: 0.75rem;
    color: var(--flood-subtext);
  }
  .flood-monitor__risk {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--flood-heading);
  }
  .flood-monitor__risk-dot {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 999px;
    display: inline-flex;
  }
  .flood-monitor__risk-dot--normal {
    background: #10b981;
  }
  .flood-monitor__risk-dot--watch {
    background: #f59e0b;
  }
  .flood-monitor__risk-dot--warning {
    background: #ea580c;
  }
  .flood-monitor__risk-dot--emergency {
    background: #dc2626;
  }
  :where(.dark) .flood-monitor__risk-dot--normal {
    background: #34d399;
  }
  :where(.dark) .flood-monitor__risk-dot--watch {
    background: #fbbf24;
  }
  :where(.dark) .flood-monitor__risk-dot--warning {
    background: #fb923c;
  }
  :where(.dark) .flood-monitor__risk-dot--emergency {
    background: #f87171;
  }
  .flood-monitor__status-note {
    display: none;
    font-size: 0.75rem;
    font-weight: 600;
  }
  .flood-monitor__status-note--loading {
    color: #b45309;
  }
  .flood-monitor__status-note--error {
    color: #b91c1c;
  }
  .flood-monitor__status-note--visible {
    display: inline;
  }
  .flood-monitor__disclaimer {
    margin: 0;
    font-size: 0.78rem;
    color: var(--flood-subtext);
  }
  .flood-monitor__footer {
    border-top: 1px solid var(--flood-border);
    padding-top: 1rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-size: 0.78rem;
    color: var(--flood-subtext);
  }
  .flood-monitor__source {
    display: inline-flex;
    gap: 0.25rem;
  }
  .flood-monitor__link {
    text-decoration: underline;
    color: var(--flood-heading);
  }
  .flood-monitor__refresh {
    margin-left: auto;
    font-weight: 600;
  }
  .flood-monitor--loading .flood-monitor__metric::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 1rem;
    background: linear-gradient(
      90deg,
      rgba(148, 163, 184, 0.12),
      rgba(148, 163, 184, 0.35),
      rgba(148, 163, 184, 0.12)
    );
    animation: flood-monitor-pulse 1.4s ease-in-out infinite;
  }
  @keyframes flood-monitor-pulse {
    0%,
    100% {
      opacity: 0.3;
    }
    50% {
      opacity: 0.6;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .flood-monitor__metric::after,
    .flood-monitor__status,
    .flood-monitor__metric,
    .flood-monitor__risk-dot {
      transition: none !important;
      animation: none !important;
    }
  }
  @media (prefers-contrast: high) {
    .flood-monitor {
      outline: 2px solid currentColor;
      outline-offset: 4px;
    }
  }
</style>
