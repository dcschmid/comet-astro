---
/**
 * EmptyState - accessible placeholder with actions and WCAG AAA compliance
 */
interface Action {
  href: string;
  label: string;
  target?: '_blank' | '_self' | '_parent' | '_top';
  ariaLabel?: string;
}

interface Props {
  title: string;
  description?: string;
  primary?: Action;
  secondary?: Action;
  className?: string;
  iconBg?: 'blue' | 'green' | 'purple' | 'red' | 'orange' | 'slate';
  size?: 'sm' | 'md' | 'lg';
  ariaLabelledby?: string;
  ariaDescribedby?: string;
}

const {
  title,
  description,
  primary,
  secondary,
  className = '',
  iconBg = 'blue',
  size = 'md',
  ariaLabelledby,
  ariaDescribedby,
} = Astro.props as Props;

const rootClasses = [
  'empty-state',
  `empty-state--icon-${iconBg}`,
  `empty-state--size-${size}`,
  className,
]
  .filter(Boolean)
  .join(' ');
---

<section
  class={rootClasses}
  role="region"
  aria-labelledby={ariaLabelledby}
  aria-describedby={ariaDescribedby}
>
  <div class="empty-state__icon" aria-hidden="true">
    <slot name="icon">
      <svg
        width="28"
        height="28"
        viewBox="0 0 24 24"
        fill="none"
        aria-hidden="true"
      >
        <path
          d="M12 9v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    </slot>
  </div>
  <h3 class="empty-state__title">
    {title}
  </h3>
  {
    description && (
      <p class="empty-state__description">
        {description}
      </p>
    )
  }

  <div class="empty-state__actions">
    {
      primary && (
        <a
          href={primary.href}
          target={primary.target || '_self'}
          rel={primary.target === '_blank' ? 'noopener noreferrer' : undefined}
          aria-label={primary.ariaLabel}
          class="empty-state__button empty-state__button--primary"
        >
          {primary.label}
        </a>
      )
    }
    {
      secondary && (
        <a
          href={secondary.href}
          target={secondary.target || '_self'}
          rel={
            secondary.target === '_blank' ? 'noopener noreferrer' : undefined
          }
          aria-label={secondary.ariaLabel}
          class="empty-state__button empty-state__button--secondary"
        >
          {secondary.label}
        </a>
      )
    }
  </div>

  <div class="empty-state__slot">
    <slot />
  </div>
</section>

<style is:inline>
  .empty-state {
    --empty-bg: #ffffff;
    --empty-border: rgba(15, 23, 42, 0.15);
    --empty-shadow: 0 25px 50px rgba(15, 23, 42, 0.12);
    --empty-ring: rgba(15, 23, 42, 0.12);
    --empty-text: #0f172a;
    --empty-subtext: #475569;
    --empty-radius: 2rem;
    width: 100%;
    border-radius: var(--empty-radius);
    border: 1px solid var(--empty-border);
    background: var(--empty-bg);
    color: var(--empty-text);
    box-shadow: var(--empty-shadow);
    padding: 2.5rem;
    text-align: center;
    ring: 1px solid var(--empty-ring);
  }
  .empty-state--size-sm {
    padding: 1.75rem;
    --empty-radius: 1.5rem;
  }
  .empty-state--size-lg {
    padding: 3.25rem;
    --empty-radius: 2.5rem;
  }
  :where(.dark) .empty-state {
    --empty-bg: #0f172a;
    --empty-border: rgba(148, 163, 184, 0.45);
    --empty-shadow: 0 30px 65px rgba(2, 6, 23, 0.75);
    --empty-ring: rgba(148, 163, 184, 0.35);
    --empty-text: #f8fafc;
    --empty-subtext: #cbd5f5;
  }
  .empty-state__icon {
    width: 3.5rem;
    height: 3.5rem;
    margin: 0 auto 1.5rem;
    border-radius: 1.5rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    box-shadow: 0 14px 35px rgba(15, 23, 42, 0.2);
  }
  .empty-state--size-sm .empty-state__icon {
    width: 3rem;
    height: 3rem;
    border-radius: 1.2rem;
  }
  .empty-state--size-lg .empty-state__icon {
    width: 4rem;
    height: 4rem;
    border-radius: 1.75rem;
  }
  .empty-state--icon-blue .empty-state__icon {
    background: linear-gradient(135deg, #2563eb, #7c3aed);
  }
  .empty-state--icon-green .empty-state__icon {
    background: linear-gradient(135deg, #059669, #10b981);
  }
  .empty-state--icon-purple .empty-state__icon {
    background: linear-gradient(135deg, #7c3aed, #9333ea);
  }
  .empty-state--icon-red .empty-state__icon {
    background: linear-gradient(135deg, #dc2626, #f97316);
  }
  .empty-state--icon-orange .empty-state__icon {
    background: linear-gradient(135deg, #f97316, #f59e0b);
  }
  .empty-state--icon-slate .empty-state__icon {
    background: linear-gradient(135deg, #1f2937, #475569);
  }
  .empty-state__title {
    margin: 0 0 0.75rem;
    font-size: 1.6rem;
    font-weight: 600;
    color: var(--empty-text);
  }
  .empty-state--size-sm .empty-state__title {
    font-size: 1.3rem;
  }
  .empty-state--size-lg .empty-state__title {
    font-size: 2rem;
  }
  .empty-state__description {
    margin: 0 auto 2rem;
    max-width: 38rem;
    font-size: 1rem;
    color: var(--empty-subtext);
  }
  .empty-state--size-sm .empty-state__description {
    font-size: 0.95rem;
  }
  .empty-state--size-lg .empty-state__description {
    font-size: 1.1rem;
  }
  .empty-state__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
  }
  .empty-state__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.75rem;
    padding: 0.75rem 1.75rem;
    border-radius: 0.9rem;
    font-weight: 600;
    border: 2px solid transparent;
    text-decoration: none;
    transition:
      background-color 0.2s ease,
      border-color 0.2s ease,
      color 0.2s ease,
      box-shadow 0.2s ease;
  }
  .empty-state__button:focus-visible {
    outline: 2px solid rgba(59, 130, 246, 0.7);
    outline-offset: 2px;
  }
  .empty-state__button--primary {
    background: #2563eb;
    border-color: #1d4ed8;
    color: #fff;
    box-shadow: 0 15px 35px rgba(37, 99, 235, 0.35);
  }
  .empty-state__button--primary:hover {
    background: #1d4ed8;
    border-color: #1e40af;
  }
  .empty-state__button--secondary {
    background: #fff;
    border-color: rgba(15, 23, 42, 0.2);
    color: var(--empty-text);
    box-shadow: 0 10px 25px rgba(15, 23, 42, 0.08);
  }
  .empty-state__button--secondary:hover {
    background: rgba(248, 250, 252, 0.9);
    border-color: rgba(15, 23, 42, 0.3);
  }
  :where(.dark) .empty-state__button--secondary {
    background: rgba(15, 23, 42, 0.7);
    border-color: rgba(148, 163, 184, 0.3);
    color: #f8fafc;
  }
  .empty-state__slot {
    margin-top: 1.5rem;
    color: var(--empty-subtext);
  }
  @media (prefers-reduced-motion: reduce) {
    .empty-state__button,
    .empty-state__icon {
      transition: none;
    }
  }
</style>
