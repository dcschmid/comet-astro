---
interface Props {
  ratio?: '1/1' | '4/3' | '16/9' | '21/9' | '3/2' | '2/3' | number | string;
  className?: string;
}

const { ratio = '16/9', className = '' } = Astro.props;

const ratioMap: Record<string, number> = {
  '1/1': 1,
  '4/3': 4 / 3,
  '16/9': 16 / 9,
  '21/9': 21 / 9,
  '3/2': 3 / 2,
  '2/3': 2 / 3,
};

const parseNumericRatio = (value: Props['ratio']): number => {
  if (typeof value === 'number' && Number.isFinite(value) && value > 0) {
    return value;
  }
  if (typeof value === 'string') {
    const trimmed = value.trim();
    if (!trimmed) return ratioMap['16/9'];
    if (ratioMap[trimmed]) return ratioMap[trimmed];
    if (trimmed.includes('/')) {
      const [n, d] = trimmed.split('/').map(Number);
      if (Number.isFinite(n) && Number.isFinite(d) && d !== 0) {
        return n / d;
      }
    }
    const numeric = Number(trimmed);
    if (Number.isFinite(numeric) && numeric > 0) return numeric;
  }
  return ratioMap['16/9'];
};

const numericRatio = parseNumericRatio(ratio);
const ratioKey =
  typeof ratio === 'string' && ratioMap[ratio]
    ? ratio.replace('/', '-')
    : 'custom';

const containerClass = [
  'aspect-frame',
  `aspect-frame--ratio-${ratioKey}`,
  className,
]
  .filter(Boolean)
  .join(' ');

const styleAttr = `--aspect-ratio: ${numericRatio};`;
---

<div class={containerClass} style={styleAttr}>
  <div class="aspect-frame__viewport">
    <slot />
  </div>
</div>

<style is:inline>
  .aspect-frame {
    position: relative;
    width: 100%;
    display: block;
    aspect-ratio: var(--aspect-ratio, 16 / 9);
  }

  .aspect-frame__viewport {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  @supports not (aspect-ratio: 1 / 1) {
    .aspect-frame {
      aspect-ratio: auto;
    }

    .aspect-frame::before {
      content: '';
      display: block;
      padding-bottom: calc(100% / var(--aspect-ratio, 16 / 9));
    }

    .aspect-frame__viewport {
      position: absolute;
      inset: 0;
    }
  }
</style>
