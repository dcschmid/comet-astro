---
/**
 * Badge - small label indicator
 */
interface Props {
  label: string;
  variant?: 'neutral' | 'primary' | 'success' | 'warning' | 'danger';
  className?: string;
}

const { label, variant = 'neutral', className = '' } = Astro.props as Props;

const variants = ['neutral', 'primary', 'success', 'warning', 'danger'] as const;
type VariantKey = (typeof variants)[number];
const variantKey = variants.includes(variant as VariantKey)
  ? (variant as VariantKey)
  : 'neutral';

const classes = ['badge', `badge--${variantKey}`, className].filter(Boolean).join(' ');
---

<span class={classes} data-badge>{label}</span>

<style is:inline>
  .badge {
    --badge-bg: #0f172a;
    --badge-border: #1f2937;
    --badge-text: #f8fafc;
    --badge-shadow: 0 8px 18px rgba(15, 23, 42, 0.15);
    --badge-bg-dark: #f1f5f9;
    --badge-border-dark: #cbd5f5;
    --badge-text-dark: #020617;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.25rem 0.65rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border: 1px solid var(--badge-border);
    background: var(--badge-bg);
    color: var(--badge-text);
    box-shadow: var(--badge-shadow);
    transition:
      background-color 0.2s ease,
      color 0.2s ease,
      border-color 0.2s ease;
  }

  :where(.dark) .badge {
    background: var(--badge-bg-dark, var(--badge-bg));
    border-color: var(--badge-border-dark, var(--badge-border));
    color: var(--badge-text-dark, var(--badge-text));
  }

  .badge--neutral {
    --badge-bg: #0f172a;
    --badge-border: rgba(148, 163, 184, 0.45);
    --badge-text: #e2e8f0;
    --badge-bg-dark: #e2e8f0;
    --badge-border-dark: rgba(15, 23, 42, 0.45);
    --badge-text-dark: #0f172a;
  }

  .badge--primary {
    --badge-bg: #1d3b8a;
    --badge-border: #1e40af;
    --badge-text: #eff6ff;
    --badge-bg-dark: #dbeafe;
    --badge-border-dark: #93c5fd;
    --badge-text-dark: #0f172a;
  }

  .badge--success {
    --badge-bg: #064e3b;
    --badge-border: #047857;
    --badge-text: #d1fae5;
    --badge-bg-dark: #dcfce7;
    --badge-border-dark: #86efac;
    --badge-text-dark: #022c22;
  }

  .badge--warning {
    --badge-bg: #713f12;
    --badge-border: #d97706;
    --badge-text: #fef3c7;
    --badge-bg-dark: #fef3c7;
    --badge-border-dark: #fcd34d;
    --badge-text-dark: #78350f;
  }

  .badge--danger {
    --badge-bg: #7f1d1d;
    --badge-border: #dc2626;
    --badge-text: #fee2e2;
    --badge-bg-dark: #fee2e2;
    --badge-border-dark: #fca5a5;
    --badge-text-dark: #7f1d1d;
  }
</style>
