---
import { cn } from '../utils/cn';

interface Props {
  /** Visual variant of the prose container */
  variant?: 'default' | 'minimal' | 'bordered' | 'elevated' | 'article';
  /** Typography size scale */
  size?: 'xs' | 'sm' | 'md' | 'lg' | 'xl' | '2xl';
  /** Color scheme variant */
  theme?: 'default' | 'invert' | 'muted' | 'high-contrast';
  /** Maximum width constraint */
  maxWidth?: 'sm' | 'md' | 'lg' | 'xl' | '2xl' | 'full' | 'none';
  /** Enable reading mode optimizations */
  readingMode?: boolean;
  /** HTML content to render (alternative to slot) */
  html?: string;
  /** Disable automatic text processing */
  raw?: boolean;
  /** Custom aria-label for accessibility */
  ariaLabel?: string;
  /** ID of element that describes the prose content */
  ariaDescribedBy?: string;
  /** Additional CSS classes */
  class?: string;
}

const {
  variant = 'default',
  size = 'lg',
  theme = 'default',
  maxWidth = 'lg',
  readingMode = false,
  html = undefined,
  raw = false,
  ariaLabel,
  ariaDescribedBy,
  class: className = '',
} = Astro.props;

// Sanitize HTML content
let sanitizedHtml = html;
if (typeof html === 'string' && !raw) {
  sanitizedHtml = html
    .replace(/\\n/g, '\n')
    .replace(/\n?\s*```\s*$/m, '')
    .replace(/```/g, '')
    .replace(/\\`/g, '')
    .replace(/&#96;|&#x60;|&grave;/g, '')
    .trim();
}

// Base prose size classes
const rootClasses = [
  'prose-block',
  `prose-block--variant-${variant}`,
  `prose-block--size-${size}`,
  `prose-block--theme-${theme}`,
  `prose-block--width-${maxWidth}`,
  readingMode ? 'prose-block--reading' : '',
  className,
]
  .filter(Boolean)
  .join(' ');
---

<article
  class={rootClasses}
  role="article"
  aria-label={ariaLabel}
  aria-describedby={ariaDescribedBy}
>
{sanitizedHtml ? <div set:html={sanitizedHtml} /> : <slot />}
</article>

<style>
  .prose-block {
    color: #0f172a;
    line-height: 1.7;
    max-width: 60ch;
    margin: 0 auto;
  }

  .prose-block--width-sm {
    max-width: 45ch;
  }

  .prose-block--width-md {
    max-width: 55ch;
  }

  .prose-block--width-lg {
    max-width: 65ch;
  }

  .prose-block--width-xl {
    max-width: 72ch;
  }

  .prose-block--width-2xl {
    max-width: 80ch;
  }

  .prose-block--width-full {
    max-width: 100%;
  }

  .prose-block--width-none {
    max-width: none;
  }

  .prose-block p {
    margin: 1.25rem 0;
  }

  .prose-block h1,
  .prose-block h2,
  .prose-block h3,
  .prose-block h4 {
    margin: 2rem 0 1rem;
    font-weight: 700;
    line-height: 1.2;
    color: inherit;
  }

  .prose-block h1 {
    font-size: clamp(2rem, 4.5vw, 2.75rem);
  }

  .prose-block h2 {
    font-size: clamp(1.75rem, 3.5vw, 2.25rem);
  }

  .prose-block h3 {
    font-size: clamp(1.5rem, 3vw, 1.85rem);
  }

  .prose-block h4 {
    font-size: clamp(1.25rem, 2.5vw, 1.5rem);
  }

  .prose-block--variant-bordered,
  .prose-block--variant-elevated {
    border: 1px solid rgba(148, 163, 184, 0.6);
    border-radius: 1.25rem;
    padding: 1.5rem;
    background-color: #ffffff;
  }

  .prose-block--variant-elevated {
    box-shadow: 0 25px 75px rgba(15, 23, 42, 0.15);
  }

  .prose-block--variant-article h1,
  .prose-block--variant-article h2,
  .prose-block--variant-article h3 {
    scroll-margin-top: 6rem;
  }

  .prose-block em,
  .prose-block strong {
    color: inherit;
  }

  .prose-block code {
    background-color: rgba(59, 130, 246, 0.08);
    color: #1d4ed8;
    border-radius: 0.4rem;
    padding: 0.15rem 0.4rem;
    font-size: 0.9em;
  }

  .prose-block pre {
    background-color: rgba(15, 23, 42, 0.95);
    color: #f8fafc;
    padding: 1rem;
    border-radius: 1rem;
    overflow-x: auto;
  }

  .prose-block a {
    color: #1d4ed8;
    text-decoration: none;
    font-weight: 600;
  }

  .prose-block a:hover {
    text-decoration: underline;
  }

  .prose-block ul,
  .prose-block ol {
    margin: 1.25rem 0;
    padding-left: 1.5rem;
  }

  .prose-block blockquote {
    border-left: 4px solid rgba(59, 130, 246, 0.4);
    background-color: rgba(59, 130, 246, 0.08);
    padding: 1rem 1.25rem;
    border-radius: 0.75rem;
    font-style: italic;
  }

  .prose-block--theme-invert {
    background-color: #0f172a;
    color: #f8fafc;
  }

  :where(.dark) .prose-block--variant-elevated {
    background-color: #0f172a;
    border-color: rgba(51, 65, 85, 0.7);
  }

  :where(.dark) .prose-block--variant-bordered {
    border-color: rgba(51, 65, 85, 0.7);
  }
</style>
