---
/**
 * ClimateProjections – Minimal, accessible Astro + Tailwind component.
 * WCAG AAA focused: high contrast text, clear semantics, no overengineering.
 */
interface Props {
  location?: string;
  scenario?: 'SSP2-4.5' | 'SSP5-8.5' | 'RCP8.5';
  startYear?: number;
  endYear?: number;
  region?: string;
  showExtremes?: boolean;
  variant?: 'default' | 'compact';
  class?: string;
  ariaLabel?: string;
  data?: ClimateDatum[];
}
interface ClimateDatum {
  metric: string;
  baseline: string;
  projected: string;
  change: string; // Include leading + or - (ASCII hyphen) for detection
  confidence: 'high' | 'medium' | 'low';
}
const {
  location,
  scenario = 'SSP5-8.5',
  startYear = 1990,
  endYear = 2050,
  region = 'Selected Region',
  showExtremes = true,
  variant = 'default',
  class: className = '',
  ariaLabel,
  data = [] as ClimateDatum[],
  ...rest
} = Astro.props as Props;

// Fallback demo dataset (multi‑model mean style placeholders)
const fallback: ClimateDatum[] = [
  {
    metric: 'Mean Temp',
    baseline: '13.1°C',
    projected: '15.2°C',
    change: '+2.1°C',
    confidence: 'high',
  },
  {
    metric: 'Max Temp',
    baseline: '28.4°C',
    projected: '31.1°C',
    change: '+2.7°C',
    confidence: 'high',
  },
  {
    metric: 'Min Temp',
    baseline: '2.9°C',
    projected: '4.4°C',
    change: '+1.5°C',
    confidence: 'medium',
  },
  {
    metric: 'Annual Precip',
    baseline: '650 mm',
    projected: '665 mm',
    change: '+15 mm',
    confidence: 'medium',
  },
  {
    metric: 'Summer Rain',
    baseline: '180 mm',
    projected: '160 mm',
    change: '-20 mm',
    confidence: 'low',
  },
];
const rows = data.length ? data : fallback;

const classes = [
  'climate',
  variant === 'compact' ? 'climate--compact' : '',
  className,
]
  .filter(Boolean)
  .join(' ');

const confidenceBadge = (c: ClimateDatum['confidence']) => {
  return `climate__confidence climate__confidence--${c}`;
};

// Utility: derive color class for change cell
const changeClass = (val: string) => {
  if (val.startsWith('+')) return 'climate__change climate__change--warm';
  if (val.startsWith('-')) return 'climate__change climate__change--cool';
  return 'climate__change climate__change--neutral';
};

const label = ariaLabel || `Climate projections for ${location || region}`;
---

<div
  class={classes}
  role="region"
  aria-label={label}
  data-climate-projections
  data-scenario={scenario}
  {...rest}
>
  <header class="climate__header">
    <div class="climate__title-row">
      <h2 class="climate__title">
        <span aria-hidden="true" class="climate__title-icon">🌡️</span>
        <span>Climate Projections</span>
      </h2>
      <div class="climate__meta" aria-label="Projection horizon and scenario">
        <span class="climate__badge">Baseline {startYear}</span>
        <span class="climate__badge">Horizon {endYear}</span>
        <span class="climate__badge climate__badge--scenario">
          Scenario {scenario}
        </span>
      </div>
    </div>
    <p class="climate__intro">
      Summary for
      <strong>{location || region}</strong>. Placeholder multi‑model mean under
      <code>{scenario}</code>. Confidence badges use simple evidence agreement.
    </p>
  </header>

  <div class="climate__table-wrapper">
    <table class="climate__table" aria-describedby="climate-caption">
      <caption id="climate-caption" class="sr-only"
        >Baseline vs projected climate metrics and changes for {
          location || region
        } under {scenario} scenario.</caption
      >
      <thead class="climate__head">
        <tr>
          <th scope="col">Metric</th>
          <th scope="col">Baseline</th>
          <th scope="col">Projected {endYear}</th>
          <th scope="col">Change</th>
          <th scope="col">Confidence</th>
        </tr>
      </thead>
      <tbody class="climate__body">
        {
          rows.map((r) => (
            <tr class="climate__row">
              <th scope="row" class="climate__cell climate__cell--metric">
                {r.metric}
              </th>
              <td class="climate__cell">{r.baseline}</td>
              <td class="climate__cell">{r.projected}</td>
              <td class="climate__cell">
                <span class={changeClass(r.change)}>{r.change}</span>
              </td>
              <td class="climate__cell">
                <span class={confidenceBadge(r.confidence)}>
                  {r.confidence}
                </span>
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>

  {
    showExtremes && (
      <section class="climate__extremes" aria-labelledby="extremes-heading">
        <h3 id="extremes-heading" class="climate__extremes-title">
          <span aria-hidden="true">⚠️</span> Extremes (illustrative)
        </h3>
        <div class="climate__extremes-grid">
          <div class="climate__extreme-card">
            <p class="climate__extreme-label">Hot Days &gt;30°C</p>
            <p class="climate__extreme-value">
              Baseline: 5 → Projected: 12
            </p>
          </div>
          <div class="climate__extreme-card">
            <p class="climate__extreme-label">Heavy Rain Events</p>
            <p class="climate__extreme-value">
              Baseline: 7 → Projected: 9
            </p>
          </div>
          <div class="climate__extreme-card">
            <p class="climate__extreme-label">Frost Days</p>
            <p class="climate__extreme-value">
              Baseline: 20 → Projected: 14
            </p>
          </div>
        </div>
      </section>
    )
  }

  <footer class="climate__legend" aria-labelledby="confidence-heading">
    <h3 id="confidence-heading" class="sr-only">Confidence legend</h3>
    <div class="climate__legend-badges">
      <span class="climate__legend-pill climate__legend-pill--high">
        High: robust agreement
      </span>
      <span class="climate__legend-pill climate__legend-pill--medium">
        Medium: moderate agreement
      </span>
      <span class="climate__legend-pill climate__legend-pill--low">
        Low: limited evidence
      </span>
    </div>
    <p class="climate__legend-note">
      Illustrative values only. Use authoritative datasets for planning.
      Scenario <code class="font-mono text-indigo-700 dark:text-indigo-300"
        >{scenario}</code
      >.
    </p>
  </footer>
</div>

<style is:inline>
  .climate {
    border-radius: 1.25rem;
    border: 1px solid rgba(148, 163, 184, 0.45);
    background: #ffffff;
    color: #0f172a;
    padding: 1.5rem;
    box-shadow: 0 20px 45px rgba(15, 23, 42, 0.08);
  }

  :where(.dark) .climate {
    background: #0f172a;
    color: #f8fafc;
    border-color: rgba(148, 163, 184, 0.35);
  }

  .climate--compact {
    padding: 1rem;
    font-size: 0.95rem;
  }

  .climate__header {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .climate__title-row {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  @media (min-width: 768px) {
    .climate__title-row {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }

  .climate__title {
    margin: 0;
    font-size: 1.35rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .climate__title-icon {
    font-size: 1.8rem;
  }

  .climate__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    font-size: 0.8rem;
  }

  .climate__badge {
    border-radius: 0.55rem;
    padding: 0.2rem 0.65rem;
    font-weight: 600;
    background: rgba(15, 23, 42, 0.08);
    color: inherit;
  }

  :where(.dark) .climate__badge {
    background: rgba(248, 250, 252, 0.1);
  }

  .climate__badge--scenario {
    background: rgba(99, 102, 241, 0.15);
    color: #4338ca;
  }

  :where(.dark) .climate__badge--scenario {
    background: rgba(99, 102, 241, 0.2);
    color: #c4b5fd;
  }

  .climate__intro {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.6;
    color: rgba(15, 23, 42, 0.8);
  }

  :where(.dark) .climate__intro {
    color: rgba(248, 250, 252, 0.75);
  }

  .climate__intro code {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    color: #4338ca;
  }

  :where(.dark) .climate__intro code {
    color: #c4b5fd;
  }

  .climate__table-wrapper {
    border-radius: 1rem;
    border: 1px solid rgba(148, 163, 184, 0.35);
    overflow: hidden;
  }

  .climate__table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.95rem;
  }

  .climate__head {
    background: rgba(226, 232, 240, 0.6);
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
  }

  :where(.dark) .climate__head {
    background: rgba(15, 23, 42, 0.9);
  }

  .climate__head th {
    text-align: left;
    padding: 0.85rem;
  }

  .climate__row {
    border-top: 1px solid rgba(148, 163, 184, 0.2);
  }

  :where(.dark) .climate__row {
    border-color: rgba(148, 163, 184, 0.12);
  }

  .climate__cell {
    padding: 0.75rem 0.85rem;
  }

  .climate__cell--metric {
    font-weight: 600;
  }

  .climate__change {
    font-weight: 600;
  }

  .climate__change--warm {
    color: #dc2626;
  }

  .climate__change--cool {
    color: #0284c7;
  }

  .climate__confidence {
    display: inline-flex;
    border-radius: 999px;
    padding: 0.2rem 0.65rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.05em;
  }

  .climate__confidence--high {
    background: rgba(16, 185, 129, 0.2);
    color: #065f46;
  }

  .climate__confidence--medium {
    background: rgba(251, 191, 36, 0.26);
    color: #92400e;
  }

  .climate__confidence--low {
    background: rgba(100, 116, 139, 0.25);
    color: #334155;
  }

  .climate__extremes {
    margin-top: 1.75rem;
  }

  .climate__extremes-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0 0 0.75rem;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .climate__extremes-grid {
    display: grid;
    gap: 1rem;
  }

  @media (min-width: 768px) {
    .climate__extremes-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .climate__extreme-card {
    border-radius: 1rem;
    border: 1px solid rgba(148, 163, 184, 0.35);
    background: rgba(248, 250, 252, 0.6);
    padding: 1rem;
  }

  :where(.dark) .climate__extreme-card {
    background: rgba(15, 23, 42, 0.75);
    border-color: rgba(148, 163, 184, 0.2);
  }

  .climate__extreme-label {
    margin: 0 0 0.3rem;
    font-size: 0.8rem;
    font-weight: 700;
  }

  .climate__extreme-value {
    margin: 0;
    font-size: 0.85rem;
    color: rgba(15, 23, 42, 0.8);
  }

  :where(.dark) .climate__extreme-value {
    color: rgba(248, 250, 252, 0.85);
  }

  .climate__legend {
    margin-top: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .climate__legend-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    font-size: 0.75rem;
  }

  .climate__legend-pill {
    border-radius: 0.6rem;
    padding: 0.25rem 0.7rem;
    font-weight: 600;
  }

  .climate__legend-pill--high {
    background: rgba(16, 185, 129, 0.2);
    color: #065f46;
  }

  .climate__legend-pill--medium {
    background: rgba(251, 191, 36, 0.25);
    color: #92400e;
  }

  .climate__legend-pill--low {
    background: rgba(100, 116, 139, 0.25);
    color: #334155;
  }

  .climate__legend-note {
    margin: 0;
    font-size: 0.8rem;
    color: rgba(15, 23, 42, 0.7);
  }

  :where(.dark) .climate__legend-note {
    color: rgba(248, 250, 252, 0.65);
  }

  .climate__legend-note code {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    color: #4338ca;
  }

  :where(.dark) .climate__legend-note code {
    color: #c4b5fd;
  }

  @media (prefers-reduced-motion: reduce) {
    [data-climate-projections] * {
      transition: none !important;
    }
  }

  @media (prefers-contrast: high) {
    [data-climate-projections] {
      outline: 2px solid currentColor;
    }
  }
</style>
