---
interface Props {
  code?: string; // Raw code string
  highlighted?: string; // Pre-highlighted HTML (e.g. from Shiki)
  language?: string; // Prism / Shiki language id
  title?: string; // Optional title bar string
  filename?: string; // Alternate to title (takes precedence if provided)
  showLineNumbers?: boolean; // Render line numbers gutter
  highlightLines?: number[]; // Lines to highlight (1-based)
  wrap?: boolean; // Soft wrap long lines
  copyable?: boolean; // Show copy button
  className?: string; // Extra utility classes
  useShiki?: boolean; // Automatically highlight with Shiki
  shikiTheme?: string; // Theme when using Shiki
}

const {
  code,
  highlighted,
  language = 'plaintext',
  title,
  filename,
  showLineNumbers = false,
  highlightLines = [],
  wrap = false,
  copyable = true,
  className = '',
  useShiki = false,
  shikiTheme = 'github-dark',
} = Astro.props as Props;

const displayTitle = filename || title;
const lines = code?.split('\n') || [];
const highlightSet = new Set(highlightLines);

let shikiOutput = highlighted;
if (!shikiOutput && useShiki && code) {
  const { codeToHtml } = await import('shiki');
  shikiOutput = await codeToHtml(code, {
    lang: language,
    theme: shikiTheme,
  });
}
const escapeHtml = (value: string) =>
  value.replace(/[&<>"']/g, (char) => {
    switch (char) {
      case '&':
        return '&amp;';
      case '<':
        return '&lt;';
      case '>':
        return '&gt;';
      case '"':
        return '&quot;';
      case "'":
        return '&#39;';
      default:
        return char;
    }
  });

const variantClasses = [
  'code-block',
  displayTitle ? 'code-block--with-header' : '',
  wrap ? 'code-block--wrap' : '',
  className,
]
  .filter(Boolean)
  .join(' ');
const numberedHtml = (() => {
  const content = lines
    .map((line, i) => {
      const lineNum = i + 1;
      const isHighlighted = highlightSet.has(lineNum);
      const highlightCls = isHighlighted
        ? 'code-block__line code-block__line--highlight'
        : 'code-block__line';
      return `<span class="${highlightCls}"><span class="code-block__line-number">${lineNum}</span>${escapeHtml(line || ' ')}</span>`;
    })
    .join('\n');
  return `<code class="language-${language}">${content}</code>`;
})();
---

<div class={variantClasses}>
  {
    displayTitle && (
      <div class="code-block__header">
        <span class="code-block__title">
          {displayTitle}
        </span>
        {language && (
          <span class="code-block__language">
            {language}
          </span>
        )}
      </div>
    )
  }
  <div class="code-block__body">
    {
      copyable && (
        <button
          type="button"
          class="code-block__copy"
          data-copy-button
          aria-describedby="copy-status"
        >
          Copy
        </button>
      )
    }
    <span id="copy-status" class="sr-only" aria-live="polite"></span>
    {shikiOutput ? (
      <div
        class="code-block__pre code-block__pre--shiki"
        set:html={shikiOutput}
      ></div>
    ) : showLineNumbers ? (
      <pre class="code-block__pre" set:html={`<code class="language-${language}">${numberedHtml}</code>`}></pre>
    ) : (
      <pre class="code-block__pre">
        <code class={`language-${language}`}>{code}</code>
      </pre>
    )}
  </div>
</div>

<script is:inline>
  (function () {
    const container = document.currentScript?.previousElementSibling;
    if (!(container instanceof HTMLElement)) return;
    const button = container.querySelector('[data-copy-button]');
    const status = container.querySelector('#copy-status');
    const codeElement = container.querySelector('code');
    if (
      !(button instanceof HTMLElement) ||
      !(codeElement instanceof HTMLElement)
    )
      return;

    if (button) {
      button.addEventListener('click', async () => {
        const text = codeElement?.textContent || '';
        try {
          await navigator.clipboard.writeText(text);
          button.setAttribute('data-state', 'copied');
          button.textContent = 'Copied';
          if (status) status.textContent = 'Code copied to clipboard';
          window.setTimeout(() => {
            button.removeAttribute('data-state');
            button.textContent = 'Copy';
            if (status) status.textContent = '';
          }, 1800);
        } catch {
          button.textContent = 'Error';
          if (status) status.textContent = 'Copy failed';
          window.setTimeout(() => {
            button.textContent = 'Copy';
            if (status) status.textContent = '';
          }, 1800);
        }
      });
    }
  })();
</script>

<style>
  .code-block {
    position: relative;
    border-radius: 1rem;
    border: 1px solid rgba(148, 163, 184, 0.4);
    background: #f8fafc;
    color: #0f172a;
    box-shadow: 0 20px 45px rgba(15, 23, 42, 0.08);
    overflow: hidden;
  }

  :where(.dark) .code-block {
    background: #0f172a;
    color: #f8fafc;
    border-color: rgba(148, 163, 184, 0.35);
  }

  .code-block__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0.85rem 1.2rem;
    border-bottom: 1px solid rgba(148, 163, 184, 0.35);
    background: rgba(226, 232, 240, 0.6);
  }

  :where(.dark) .code-block__header {
    background: rgba(15, 23, 42, 0.9);
  }

  .code-block__title {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(15, 23, 42, 0.8);
  }

  :where(.dark) .code-block__title {
    color: rgba(248, 250, 252, 0.8);
  }

  .code-block__language {
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(15, 23, 42, 0.65);
  }

  :where(.dark) .code-block__language {
    color: rgba(248, 250, 252, 0.6);
  }

  .code-block__body {
    position: relative;
    padding: 1rem 1rem 1rem 1rem;
  }

  .code-block__copy {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    border-radius: 0.5rem;
    border: 1px solid rgba(148, 163, 184, 0.4);
    background: rgba(255, 255, 255, 0.75);
    color: #0f172a;
    padding: 0.25rem 0.85rem;
    font-size: 0.75rem;
    display: inline-flex;
    gap: 0.25rem;
    align-items: center;
    backdrop-filter: blur(8px);
    cursor: pointer;
  }

  :where(.dark) .code-block__copy {
    background: rgba(15, 23, 42, 0.85);
    color: #f8fafc;
    border-color: rgba(148, 163, 184, 0.5);
  }

  .code-block__copy:focus-visible {
    outline: 2px solid rgba(59, 130, 246, 0.65);
    outline-offset: 2px;
  }

  .code-block__pre {
    margin: 0;
    overflow-x: auto;
    font-size: 0.85rem;
    line-height: 1.65;
    font-family:
      'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
      'Liberation Mono', 'Courier New', monospace;
    white-space: pre;
    tab-size: 2;
  }

  .code-block--wrap .code-block__pre {
    white-space: pre-wrap;
    word-break: break-word;
  }

  .code-block__line {
    display: block;
    padding-left: 0.25rem;
  }

  .code-block__line-number {
    display: inline-block;
    width: 2rem;
    margin-right: 0.75rem;
    text-align: right;
    color: rgba(148, 163, 184, 0.7);
    user-select: none;
  }

  :where(.dark) .code-block__line-number {
    color: rgba(148, 163, 184, 0.5);
  }

  .code-block__line--highlight {
    background: rgba(99, 102, 241, 0.1);
    border-left: 2px solid rgba(99, 102, 241, 0.6);
    padding-left: 0.25rem;
    border-radius: 0.35rem;
  }

  :where(.dark) .code-block__line--highlight {
    background: rgba(99, 102, 241, 0.2);
    border-color: rgba(165, 180, 252, 0.8);
  }
</style>
