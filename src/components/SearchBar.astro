---
/**
 * SearchBar - Accessible search form with WCAG AAA compliance
 */
interface Props {
  /** Initial search value */
  value?: string;
  /** Placeholder text for the search input */
  placeholder?: string;
  /** Form action URL */
  action?: string;
  /** Input name attribute */
  name?: string;
  /** Form method */
  method?: 'get' | 'post';
  /** Submit button label */
  submitLabel?: string;
  /** Label for the search input */
  label?: string;
  /** Help text displayed below the search bar */
  helpText?: string;
  /** Whether the search is disabled */
  disabled?: boolean;
  /** Whether the search is required */
  required?: boolean;
  /** Whether the search has an error state */
  error?: boolean | string;
  /** Visual variant of the search bar */
  variant?: 'default' | 'minimal' | 'outlined' | 'filled';
  /** Size of the search bar */
  size?: 'sm' | 'md' | 'lg';
  /** Show search icon */
  showIcon?: boolean;
  /** Show submit button */
  showButton?: boolean;
  /** Enable live search suggestions */
  enableSuggestions?: boolean;
  /** Custom ID for the search input */
  id?: string;
  /** Custom aria-label for accessibility */
  ariaLabel?: string;
  /** ID of element that describes the search */
  ariaDescribedBy?: string;
  /** Additional CSS classes */
  class?: string;
}

const {
  value = '',
  placeholder = 'Search…',
  action = '#',
  name = 'q',
  method = 'get',
  submitLabel = 'Search',
  label,
  helpText,
  disabled = false,
  required = false,
  error = false,
  variant = 'default',
  size = 'md',
  showIcon = true,
  showButton = true,
  enableSuggestions = false,
  id: propId,
  ariaLabel,
  ariaDescribedBy,
  class: className = '',
} = Astro.props;

const id = propId || `search-${Math.random().toString(36).slice(2, 10)}`;
const inputId = `${id}-input`;
const helpId = helpText ? `${id}-help` : undefined;
const errorId = error ? `${id}-error` : undefined;
const suggestionsId = enableSuggestions ? `${id}-suggestions` : undefined;
const finalAriaDescribedBy =
  [ariaDescribedBy, helpId, errorId].filter(Boolean).join(' ') || undefined;

const rootClasses = [
  'search-bar',
  `search-bar--variant-${variant}`,
  `search-bar--size-${size}`,
  showIcon ? 'search-bar--with-icon' : '',
  showButton ? 'search-bar--with-button' : '',
  enableSuggestions ? 'search-bar--with-suggestions' : '',
  error ? 'search-bar--error' : '',
  disabled ? 'search-bar--disabled' : '',
  className,
]
  .filter(Boolean)
  .join(' ');

const labelClasses = [
  'search-bar__label',
  required ? 'search-bar__label--required' : '',
  disabled ? 'search-bar__label--disabled' : '',
]
  .filter(Boolean)
  .join(' ');

const helpClasses = [
  'search-bar__message',
  'search-bar__message--help',
  error ? 'search-bar__message--error' : '',
]
  .filter(Boolean)
  .join(' ');

const errorClasses = ['search-bar__message', 'search-bar__message--error']
  .filter(Boolean)
  .join(' ');
---

<div class={rootClasses}>
  {
    label && (
      <label class={labelClasses} for={inputId}>
        {label}
      </label>
    )
  }

  <form role="search" method={method} action={action} class="search-bar__form">
    <div class="search-bar__field" data-search-container>
      {
        showIcon && (
          <div class="search-bar__icon">
            <svg
              class="search-bar__icon-graphic"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <circle cx="11" cy="11" r="8" />
              <path d="M21 21l-4.35-4.35" stroke-linecap="round" />
            </svg>
          </div>
        )
      }

      <input
        id={inputId}
        type="search"
        name={name}
        value={value}
        placeholder={placeholder}
        class="search-bar__input"
        aria-label={ariaLabel || placeholder}
        aria-describedby={finalAriaDescribedBy}
        aria-expanded={enableSuggestions ? 'false' : undefined}
        aria-autocomplete={enableSuggestions ? 'list' : undefined}
        aria-controls={suggestionsId}
        aria-required={required ? 'true' : 'false'}
        aria-invalid={error ? 'true' : 'false'}
        enterkeyhint="search"
        autocomplete="search"
        disabled={disabled}
        required={required}
        data-search-input
        data-testid="search-input"
      />

      {
        showButton && (
          <button
            type="submit"
            class="search-bar__button"
            disabled={disabled}
            aria-label={submitLabel}
            data-testid="search-button"
          >
            <span class="search-bar__button-text">{submitLabel}</span>
            <span class="search-bar__button-icon" aria-hidden="true">
              <svg
                class="search-bar__button-graphic"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <circle cx="11" cy="11" r="8" />
                <path d="M21 21l-4.35-4.35" stroke-linecap="round" />
              </svg>
            </span>
          </button>
        )
      }
    </div>

    {
      enableSuggestions && (
        <div
          id={suggestionsId}
          class="search-bar__suggestions"
          role="listbox"
          aria-label="Search suggestions"
          data-search-suggestions
        >
          {/* Suggestions populated via script */}
        </div>
      )
    }
  </form>

  {
    (helpText || error) && (
      <div class="search-bar__messages">
        {helpText && (
          <p id={helpId} class={helpClasses}>
            {helpText}
          </p>
        )}
        {error && (
          <p id={errorId} class={errorClasses} role="alert">
            {typeof error === 'string'
              ? error
              : 'Please check your search query.'}
          </p>
        )}
      </div>
    )
  }
</div>

<style is:inline>
  .search-bar {
    --search-bar-border-color: #cbd5f5;
    --search-bar-border-width: 1px;
    --search-bar-background: #ffffff;
    --search-bar-focus-border: #2563eb;
    --search-bar-focus-ring: rgba(37, 99, 235, 0.25);
    --search-bar-placeholder-color: #64748b;
    --search-bar-icon-color: #64748b;
    --search-bar-field-min-height: 2.75rem;
    --search-bar-input-padding-y: 0.75rem;
    --search-bar-input-padding-x: 1rem;
    --search-bar-font-size: 0.95rem;
    --search-bar-button-bg: #2563eb;
    --search-bar-button-color: #f8fafc;
    --search-bar-button-hover: #1d4ed8;
    --search-bar-button-border-color: rgba(255, 255, 255, 0.2);
    --search-bar-button-border-width: 1px;
    --search-bar-button-padding-x: 1rem;
    --search-bar-icon-size: 1.1rem;
    --search-bar-icon-padding: 0.85rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    width: 100%;
  }

  .search-bar--size-sm {
    --search-bar-field-min-height: 2.5rem;
    --search-bar-input-padding-y: 0.5rem;
    --search-bar-input-padding-x: 0.85rem;
    --search-bar-font-size: 0.875rem;
    --search-bar-icon-size: 1rem;
    --search-bar-button-padding-x: 0.85rem;
  }

  .search-bar--size-lg {
    --search-bar-field-min-height: 3rem;
    --search-bar-input-padding-y: 0.85rem;
    --search-bar-input-padding-x: 1.25rem;
    --search-bar-font-size: 1rem;
    --search-bar-icon-size: 1.25rem;
    --search-bar-button-padding-x: 1.25rem;
  }

  .search-bar--variant-minimal {
    --search-bar-background: #f8fafc;
    --search-bar-border-color: #e2e8f0;
    --search-bar-focus-border: #94a3b8;
    --search-bar-focus-ring: rgba(148, 163, 184, 0.3);
    --search-bar-button-bg: #e2e8f0;
    --search-bar-button-color: #0f172a;
    --search-bar-button-hover: #cbd5f5;
    --search-bar-icon-color: #94a3b8;
    --search-bar-placeholder-color: #94a3b8;
    --search-bar-button-border-color: #d5dbe5;
  }

  .search-bar--variant-outlined {
    --search-bar-border-width: 2px;
    --search-bar-background: transparent;
    --search-bar-button-border-color: #cbd5f5;
    --search-bar-button-border-width: 2px;
  }

  .search-bar--variant-filled {
    --search-bar-background: #e2e8f0;
    --search-bar-border-color: transparent;
    --search-bar-button-border-color: transparent;
  }

  .search-bar--error {
    --search-bar-border-color: #dc2626;
    --search-bar-focus-border: #dc2626;
    --search-bar-focus-ring: rgba(220, 38, 38, 0.25);
  }

  .search-bar--disabled {
    opacity: 0.65;
    pointer-events: none;
  }

  .search-bar__label {
    font-weight: 600;
    color: #0f172a;
    font-size: 0.95rem;
  }

  .search-bar__label--required::after {
    content: ' *';
    color: #dc2626;
    font-weight: 600;
  }

  .search-bar__label--disabled {
    opacity: 0.6;
  }

  .search-bar__form {
    position: relative;
  }

  .search-bar__field {
    display: flex;
    align-items: center;
    border-radius: 1rem;
    border: var(--search-bar-border-width, 1px) solid
      var(--search-bar-border-color);
    background-color: var(--search-bar-background);
    min-height: var(--search-bar-field-min-height);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .search-bar__field:focus-within {
    border-color: var(--search-bar-focus-border);
    box-shadow: 0 0 0 2px var(--search-bar-focus-ring);
  }

  .search-bar__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding-inline: var(--search-bar-icon-padding);
    color: var(--search-bar-icon-color);
  }

  .search-bar__icon-graphic,
  .search-bar__button-graphic {
    width: var(--search-bar-icon-size);
    height: var(--search-bar-icon-size);
    stroke-width: 1.8;
  }

  .search-bar__input {
    flex: 1;
    border: 0;
    background: transparent;
    padding: var(--search-bar-input-padding-y)
      var(--search-bar-input-padding-x);
    font-size: var(--search-bar-font-size);
    color: #0f172a;
    min-height: var(--search-bar-field-min-height);
  }

  .search-bar__input::placeholder {
    color: var(--search-bar-placeholder-color);
  }

  .search-bar__input:focus {
    outline: none;
  }

  .search-bar__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    padding-inline: var(--search-bar-button-padding-x);
    min-height: var(--search-bar-field-min-height);
    border: 0;
    border-left: var(--search-bar-button-border-width, 1px) solid
      var(--search-bar-button-border-color);
    border-radius: 0 1rem 1rem 0;
    background-color: var(--search-bar-button-bg);
    color: var(--search-bar-button-color);
    font-weight: 600;
    font-size: var(--search-bar-font-size);
    transition: background-color 0.2s ease;
  }

  .search-bar__button-text {
    display: none;
  }

  .search-bar__button-icon {
    display: inline-flex;
  }

  .search-bar__button:hover:not(:disabled) {
    background-color: var(--search-bar-button-hover);
  }

  .search-bar__button:focus-visible {
    outline: 2px solid var(--search-bar-focus-border);
    outline-offset: 2px;
  }

  .search-bar__button:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .search-bar__messages {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .search-bar__message {
    font-size: 0.85rem;
    color: #475569;
  }

  .search-bar__message--error {
    color: #dc2626;
  }

  .search-bar__suggestions {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    margin-top: 0.35rem;
    background-color: #ffffff;
    border: 1px solid rgba(15, 23, 42, 0.15);
    border-radius: 0.9rem;
    box-shadow: 0 18px 35px rgba(15, 23, 42, 0.15);
    max-height: 15rem;
    overflow-y: auto;
    display: none;
    z-index: 40;
  }

  .search-bar__suggestions--visible {
    display: block;
  }

  .search-bar__suggestion {
    padding: 0.55rem 0.85rem;
    cursor: pointer;
    font-size: 0.9rem;
    color: #0f172a;
    transition: background-color 0.2s ease;
  }

  .search-bar__suggestion:hover,
  .search-bar__suggestion--active {
    background-color: rgba(37, 99, 235, 0.15);
  }

  .search-bar__suggestion--active {
    font-weight: 600;
  }

  .search-bar__suggestions {
    scrollbar-width: thin;
    scrollbar-color: rgb(156 163 175) transparent;
  }

  .search-bar__suggestions::-webkit-scrollbar {
    width: 8px;
  }

  .search-bar__suggestions::-webkit-scrollbar-track {
    background: transparent;
  }

  .search-bar__suggestions::-webkit-scrollbar-thumb {
    background: rgb(156 163 175);
    border-radius: 4px;
  }

  @media (min-width: 640px) {
    .search-bar__button-text {
      display: inline;
    }

    .search-bar__button-icon {
      display: none;
    }
  }

  @media (prefers-color-scheme: dark) {
    .search-bar {
      --search-bar-background: #0f172a;
      --search-bar-border-color: #475569;
      --search-bar-focus-border: #60a5fa;
      --search-bar-focus-ring: rgba(96, 165, 250, 0.35);
      --search-bar-button-bg: #60a5fa;
      --search-bar-button-color: #0f172a;
      --search-bar-button-hover: #3b82f6;
      --search-bar-placeholder-color: #cbd5f5;
      --search-bar-icon-color: #cbd5f5;
      color: #f1f5f9;
    }

    .search-bar--variant-minimal {
      --search-bar-background: #1f2937;
      --search-bar-border-color: #334155;
      --search-bar-button-bg: #334155;
      --search-bar-button-color: #e2e8f0;
      --search-bar-button-hover: #475569;
      --search-bar-placeholder-color: #cbd5f5;
      --search-bar-icon-color: #cbd5f5;
    }

    .search-bar__input {
      color: #f8fafc;
    }

    .search-bar__suggestions {
      background-color: #0f172a;
      border-color: rgba(148, 163, 184, 0.35);
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5);
      scrollbar-color: rgb(75 85 99) transparent;
    }

    .search-bar__suggestions::-webkit-scrollbar-thumb {
      background: rgb(75 85 99);
    }

    .search-bar__suggestion {
      color: #f8fafc;
    }
  }
</style>

<script is:inline>
  (function setupSearchBar() {
    const SUGGESTIONS_VISIBLE = 'search-bar__suggestions--visible';
    const SUGGESTION_ACTIVE = 'search-bar__suggestion--active';

    const searchContainers = document.querySelectorAll(
      '[data-search-container]'
    );

    searchContainers.forEach((container) => {
      const input = container.querySelector('[data-search-input]');
      const suggestionsContainer = container.parentElement?.querySelector(
        '[data-search-suggestions]'
      );

      if (!(input instanceof HTMLInputElement)) return;

      // Handle search suggestions if enabled
      if (suggestionsContainer) {
        let suggestionTimeout;

        const showSuggestions = () => {
          suggestionsContainer.classList.add(SUGGESTIONS_VISIBLE);
          input.setAttribute('aria-expanded', 'true');
        };

        const hideSuggestions = () => {
          suggestionsContainer.classList.remove(SUGGESTIONS_VISIBLE);
          input.setAttribute('aria-expanded', 'false');
        };

        const createSuggestionItem = (text, isHighlighted = false) => {
          const item = document.createElement('div');
          item.className = 'search-bar__suggestion';
          if (isHighlighted) {
            item.classList.add(SUGGESTION_ACTIVE);
          }
          item.textContent = text;
          item.setAttribute('role', 'option');
          item.setAttribute('aria-selected', isHighlighted ? 'true' : 'false');
          return item;
        };

        // Mock suggestions for demo (in real implementation, fetch from API)
        const getSuggestions = (query) => {
          if (!query.trim()) return [];

          const mockSuggestions = [
            'Search results',
            'Search tips',
            'Search documentation',
            'Search examples',
            'Search help',
          ];

          return mockSuggestions
            .filter((item) => item.toLowerCase().includes(query.toLowerCase()))
            .slice(0, 5);
        };

        input.addEventListener('input', (event) => {
          clearTimeout(suggestionTimeout);
          const query = event.target.value;

          if (query.length < 2) {
            hideSuggestions();
            return;
          }

          suggestionTimeout = setTimeout(() => {
            const suggestions = getSuggestions(query);
            suggestionsContainer.innerHTML = '';

            if (suggestions.length > 0) {
              suggestions.forEach((suggestion, index) => {
                const item = createSuggestionItem(suggestion, index === 0);
                item.addEventListener('click', () => {
                  input.value = suggestion;
                  hideSuggestions();
                  input.form?.submit();
                });
                suggestionsContainer.appendChild(item);
              });
              showSuggestions();
            } else {
              hideSuggestions();
            }
          }, 300);
        });

        // Keyboard navigation for suggestions
        input.addEventListener('keydown', (event) => {
          if (suggestionsContainer.classList.contains(SUGGESTIONS_VISIBLE)) {
            const items = Array.from(
              suggestionsContainer.querySelectorAll('[role="option"]')
            );
            const currentIndex = items.findIndex(
              (item) => item.getAttribute('aria-selected') === 'true'
            );

            if (event.key === 'ArrowDown') {
              event.preventDefault();
              const nextIndex =
                currentIndex < items.length - 1 ? currentIndex + 1 : 0;
              items.forEach((item, index) => {
                item.setAttribute(
                  'aria-selected',
                  index === nextIndex ? 'true' : 'false'
                );
                item.classList.toggle(SUGGESTION_ACTIVE, index === nextIndex);
              });
            } else if (event.key === 'ArrowUp') {
              event.preventDefault();
              const prevIndex =
                currentIndex > 0 ? currentIndex - 1 : items.length - 1;
              items.forEach((item, index) => {
                item.setAttribute(
                  'aria-selected',
                  index === prevIndex ? 'true' : 'false'
                );
                item.classList.toggle(SUGGESTION_ACTIVE, index === prevIndex);
              });
            } else if (event.key === 'Enter') {
              const selectedItem = items.find(
                (item) => item.getAttribute('aria-selected') === 'true'
              );
              if (selectedItem) {
                event.preventDefault();
                input.value = selectedItem.textContent || '';
                hideSuggestions();
                input.form?.submit();
              }
            } else if (event.key === 'Escape') {
              hideSuggestions();
            }
          }
        });

        // Hide suggestions when clicking outside
        document.addEventListener('click', (event) => {
          if (
            !container.contains(event.target) &&
            !suggestionsContainer.contains(event.target)
          ) {
            hideSuggestions();
          }
        });
      }
    });
  })();
</script>
