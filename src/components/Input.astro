---
/**
 * Input - WCAG AAA compliant form input component
 * Supports all standard HTML input types with enhanced accessibility features
 */
interface Props {
  type?:
    | 'text'
    | 'email'
    | 'password'
    | 'number'
    | 'tel'
    | 'url'
    | 'search'
    | 'date'
    | 'datetime-local'
    | 'time'
    | 'month'
    | 'week';
  name: string;
  label?: string;
  placeholder?: string;
  value?: string | number;
  required?: boolean;
  disabled?: boolean;
  readonly?: boolean;
  error?: string;
  helperText?: string;
  size?: 'sm' | 'md' | 'lg';
  variant?: 'default' | 'filled' | 'outlined';
  className?: string;
  id?: string;
  autocomplete?: string;
  pattern?: string;
  minlength?: number;
  maxlength?: number;
  min?: string | number;
  max?: string | number;
  step?: string | number;
  prefix?: string;
  suffix?: string;
  showCharCount?: boolean;
  ariaLabel?: string;
  ariaLabelledby?: string;
  ariaDescribedby?: string;
}

const {
  type = 'text',
  name,
  label,
  placeholder,
  value,
  required = false,
  disabled = false,
  readonly = false,
  error,
  helperText,
  size = 'md',
  variant = 'default',
  className = '',
  id = name,
  autocomplete,
  pattern,
  minlength,
  maxlength,
  min,
  max,
  step,
  prefix,
  suffix,
  showCharCount = false,
  ariaLabel,
  ariaLabelledby,
  ariaDescribedby,
} = Astro.props;

const sizeClasses = {
  sm: 'input--size-sm',
  md: 'input--size-md',
  lg: 'input--size-lg',
} as const;

const variantClasses = {
  default: 'input__field--variant-default',
  filled: 'input__field--variant-filled',
  outlined: 'input__field--variant-outlined',
} as const;

const wrapperClasses = ['input', sizeClasses[size], className]
  .filter(Boolean)
  .join(' ');
const labelClasses = ['input__label', disabled ? 'input__label--disabled' : '']
  .filter(Boolean)
  .join(' ');
const showCount = showCharCount && maxlength;

const inputClasses = [
  'input__field',
  variantClasses[variant],
  error ? 'input__field--error' : '',
  disabled ? 'input__field--disabled' : '',
  readonly ? 'input__field--readonly' : '',
  prefix ? 'input__field--has-prefix' : '',
  suffix || showCount ? 'input__field--has-suffix' : '',
].filter(Boolean);
const helperClasses = ['input__helper', error ? 'input__helper--error' : '']
  .filter(Boolean)
  .join(' ');

// Generate IDs
const inputId = id || `input-${Math.random().toString(36).slice(2, 8)}`;
const descriptionId =
  error || helperText ? `${inputId}-description` : undefined;
const charCountId = showCharCount ? `${inputId}-char-count` : undefined;

// Combine aria-describedby
const computedAriaDescribedby =
  [ariaDescribedby, descriptionId, charCountId].filter(Boolean).join(' ') ||
  undefined;

// Character count calculation
const currentLength = value ? String(value).length : 0;
---

<div class={wrapperClasses}>
  <!-- Label -->
  {
    label && (
      <label
        for={inputId}
        class={labelClasses}
      >
        {label}
        {required && (
          <span class="input__label-required" aria-hidden="true" title="Required field">
            *
          </span>
        )}
      </label>
    )
  }

  <!-- Input Container -->
  <div class="input__wrapper">
    <!-- Prefix -->
    {
      prefix && (
        <div class="input__prefix">
          <span>{prefix}</span>
        </div>
      )
    }

    <!-- Input Field -->
    <input
      type={type}
      id={inputId}
      name={name}
      placeholder={placeholder}
      value={value}
      required={required}
      disabled={disabled}
      readonly={readonly}
      autocomplete={autocomplete}
      pattern={pattern}
      minlength={minlength}
      maxlength={maxlength}
      min={min}
      max={max}
      step={step}
      aria-invalid={error ? 'true' : 'false'}
      aria-describedby={computedAriaDescribedby}
      aria-label={ariaLabel}
      aria-labelledby={ariaLabelledby}
      class={inputClasses.join(' ')}
    />

    <!-- Suffix -->
    {
      suffix && (
        <div class="input__suffix">
          <span>{suffix}</span>
        </div>
      )
    }

    <!-- Character Count -->
    {
      showCount && (
        <div
          id={charCountId}
          class={`input__counter ${currentLength > maxlength! ? 'input__counter--error' : ''}`}
          aria-live="polite"
        >
          <span>
            {currentLength}/{maxlength}
          </span>
        </div>
      )
    }
  </div>

  <!-- Helper Text / Error Message -->
  {
    (error || helperText) && (
      <div
        id={descriptionId}
        class={helperClasses}
        role={error ? 'alert' : undefined}
        aria-live={error ? 'polite' : undefined}
      >
        {error && (
          <span class="input__helper-row">
            <svg
              class="input__helper-icon"
              fill="currentColor"
              viewBox="0 0 20 20"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-8-3a1 1 0 00-.867.5 1 1 0 11-1.731-1A3 3 0 0113 8a3.001 3.001 0 01-2 2.83V11a1 1 0 11-2 0v-1a1 1 0 011-1 1 1 0 100-2zm0 8a1 1 0 100-2 1 1 0 000 2z"
                clip-rule="evenodd"
              />
            </svg>
            {error}
          </span>
        )}
        {!error && helperText && helperText}
      </div>
    )
  }
</div>

<style is:inline>
  .input {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .input__label {
    font-weight: 600;
    color: #0f172a;
    line-height: 1.4;
  }

  .input--size-sm .input__label {
    font-size: 0.85rem;
  }

  .input--size-lg .input__label {
    font-size: 1rem;
  }

  .input__label--disabled {
    color: #94a3b8;
  }

  .input__label-required {
    margin-left: 0.25rem;
    color: #b91c1c;
  }

  .input__wrapper {
    position: relative;
  }

  .input__field {
    width: 100%;
    border-radius: 0.75rem;
    border: 1px solid #94a3b8;
    background-color: #ffffff;
    color: #0f172a;
    transition: border-color 0.2s ease, box-shadow 0.2s ease,
      background-color 0.2s ease;
    padding: 0.65rem 1rem;
    font-size: 0.95rem;
  }

  .input--size-sm .input__field {
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
  }

  .input--size-lg .input__field {
    padding: 0.9rem 1.25rem;
    font-size: 1rem;
  }

  .input__field:focus-visible {
    outline: 2px solid #1d4ed8;
    outline-offset: 2px;
    border-color: #1d4ed8;
  }

  .input__field--readonly {
    cursor: default;
  }

  .input__field--disabled {
    background-color: #f1f5f9;
    color: #94a3b8;
    cursor: not-allowed;
  }

  .input__field--error {
    border-color: #b91c1c;
    background-color: rgba(248, 113, 113, 0.15);
  }

  .input--size-sm .input__field--has-prefix {
    padding-left: 2.25rem;
  }

  .input--size-md .input__field--has-prefix {
    padding-left: 2.5rem;
  }

  .input--size-lg .input__field--has-prefix {
    padding-left: 2.75rem;
  }

  .input--size-sm .input__field--has-suffix {
    padding-right: 2.25rem;
  }

  .input--size-md .input__field--has-suffix {
    padding-right: 3rem;
  }

  .input--size-lg .input__field--has-suffix {
    padding-right: 3.5rem;
  }

  .input__field--variant-default {
    background-color: #ffffff;
  }

  .input__field--variant-filled {
    background-color: #f8fafc;
  }

  .input__field--variant-outlined {
    border-width: 2px;
  }

  .input__prefix,
  .input__suffix,
  .input__counter {
    position: absolute;
    top: 0;
    bottom: 0;
    display: flex;
    align-items: center;
    color: #64748b;
    pointer-events: none;
    font-size: 0.85rem;
    padding: 0 0.75rem;
  }

  .input--size-sm .input__prefix,
  .input--size-sm .input__suffix,
  .input--size-sm .input__counter {
    font-size: 0.75rem;
  }

  .input--size-lg .input__prefix,
  .input--size-lg .input__suffix,
  .input--size-lg .input__counter {
    font-size: 0.9rem;
  }

  .input__prefix {
    left: 0;
  }

  .input__suffix,
  .input__counter {
    right: 0;
  }

  .input__counter--error {
    color: #b91c1c;
  }

  .input__helper {
    font-size: 0.8rem;
    color: #64748b;
    line-height: 1.4;
  }

  .input__helper--error {
    color: #b91c1c;
  }

  .input--size-sm .input__helper {
    font-size: 0.7rem;
  }

  .input--size-lg .input__helper {
    font-size: 0.85rem;
  }

  .input__helper-row {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .input__helper-icon {
    color: inherit;
    width: 1rem;
    height: 1rem;
  }

  .input--size-sm .input__helper-icon {
    width: 0.85rem;
    height: 0.85rem;
  }

  .input--size-lg .input__helper-icon {
    width: 1.1rem;
    height: 1.1rem;
  }

  .input__helper--error .input__helper-icon {
    color: #b91c1c;
  }

  :where(.dark) .input__label {
    color: #f8fafc;
  }

  :where(.dark) .input__field {
    background-color: #0f172a;
    color: #f8fafc;
    border-color: #475569;
  }

  :where(.dark) .input__field:focus-visible {
    outline-color: #60a5fa;
    border-color: #60a5fa;
  }

  :where(.dark) .input__field--variant-filled {
    background-color: #1f2937;
  }

  :where(.dark) .input__field--error {
    border-color: #f87171;
    background-color: rgba(248, 113, 113, 0.2);
  }

  :where(.dark) .input__field--disabled {
    background-color: #1e293b;
    color: #64748b;
  }

  :where(.dark) .input__prefix,
  :where(.dark) .input__suffix,
  :where(.dark) .input__counter {
    color: #cbd5f5;
  }

  :where(.dark) .input__helper {
    color: #cbd5f5;
  }

  :where(.dark) .input__helper--error,
  :where(.dark) .input__counter--error,
  :where(.dark) .input__label-required {
    color: #f87171;
  }
