---
/**
 * LanguageSwitcher - WCAG AAA compliant language picker with enhanced accessibility
 * Provides internationalization support with optimal user experience
 */
interface Lang {
  code: string;
  label: string;
  href: string;
  flag?: string;
  nativeName?: string;
  direction?: 'ltr' | 'rtl';
}

interface Props {
  current?: string;
  languages: Lang[];
  size?: 'sm' | 'md' | 'lg';
  variant?: 'default' | 'minimal' | 'compact' | 'dropdown';
  showFlags?: boolean;
  showNativeNames?: boolean;
  position?: 'start' | 'center' | 'end';
  className?: string;
  ariaLabel?: string;
  dropdownLabel?: string;
}

const { 
  current, 
  languages = [], 
  size = 'md',
  variant = 'default',
  showFlags = false,
  showNativeNames = false,
  position = 'start',
  className = '',
  ariaLabel = 'Language switcher',
  dropdownLabel = 'Select language'
} = Astro.props as Props;

// Enhanced size classes with responsive design
const sizeModifier = `language-switcher--size-${size}`;
const variantModifier = `language-switcher--variant-${variant}`;
const positionModifier = `language-switcher--position-${position}`;
const rootClasses = [
  'language-switcher',
  sizeModifier,
  variantModifier,
  positionModifier,
  className,
]
  .filter(Boolean)
  .join(' ');
const labelClasses = [
  'language-switcher__label',
  variant === 'compact' ? 'language-switcher__label--compact' : '',
]
  .filter(Boolean)
  .join(' ');
const codeClasses = [
  'language-switcher__code',
  variant === 'compact' && !showFlags
    ? 'language-switcher__code--visible'
    : '',
]
  .filter(Boolean)
  .join(' ');

// Get flag emoji for language code
const getFlagEmoji = (code: string, customFlag?: string) => {
  if (customFlag) return customFlag;
  
  const flagMap: Record<string, string> = {
    'en': '🇺🇸', 'de': '🇩🇪', 'fr': '🇫🇷', 'es': '🇪🇸', 'it': '🇮🇹',
    'pt': '🇵🇹', 'nl': '🇳🇱', 'ru': '🇷🇺', 'ja': '🇯🇵', 'ko': '🇰🇷',
    'zh': '🇨🇳', 'ar': '🇸🇦', 'hi': '🇮🇳', 'tr': '🇹🇷', 'pl': '🇵🇱',
    'sv': '🇸🇪', 'da': '🇩🇰', 'no': '🇳🇴', 'fi': '🇫🇮', 'hu': '🇭🇺',
  };
  
  return flagMap[code.toLowerCase()] || '🌐';
};

// Current language for active state
const currentLang = languages.find(lang => lang.code === current);

// Generate unique ID for dropdown
const dropdownId = `language-switcher-${Math.random().toString(36).slice(2, 8)}`;
---

{variant === 'dropdown' ? (
  <div class={rootClasses}>
    <button
      type="button"
      id={dropdownId}
      aria-haspopup="listbox"
      aria-expanded="false"
      aria-label={ariaLabel}
      class="language-switcher__toggle"
    >
      {showFlags && currentLang && (
        <span
          class="language-switcher__flag"
          aria-hidden="true"
        >
          {getFlagEmoji(currentLang.code, currentLang.flag)}
        </span>
      )}

      <span class="language-switcher__toggle-label">
        {currentLang?.label || dropdownLabel}
        {showNativeNames && currentLang?.nativeName && (
          <span class="language-switcher__native-name">
            {currentLang.nativeName}
          </span>
        )}
      </span>

      {/* Dropdown Arrow */}
      <svg
        class="language-switcher__icon"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </button>
    
    {/* Dropdown Menu (hidden by default, controlled by JavaScript) */}
    <div
      role="listbox"
      aria-labelledby={dropdownId}
      class="language-switcher__menu language-switcher__menu--hidden"
    >
      {languages.map((language) => {
        const isActive = current === language.code;
        const menuItemClasses = [
          'language-switcher__menu-item',
          isActive ? 'language-switcher__menu-item--active' : '',
        ]
          .filter(Boolean)
          .join(' ');
        return (
          <a
            href={language.href}
            lang={language.code}
            hreflang={language.code}
            dir={language.direction || 'ltr'}
            role="option"
            aria-selected={isActive}
            class={menuItemClasses}
          >
            {showFlags && (
              <span
                class="language-switcher__flag"
                aria-hidden="true"
              >
                {getFlagEmoji(language.code, language.flag)}
              </span>
            )}

            <span class="language-switcher__menu-label">
              {language.label}
              {showNativeNames && language.nativeName && (
                <span class="language-switcher__native-name">
                  {language.nativeName}
                </span>
              )}
            </span>

            {isActive && (
              <svg
                class="language-switcher__icon language-switcher__icon--active"
                fill="currentColor"
                viewBox="0 0 20 20"
                aria-hidden="true"
              >
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
            )}
          </a>
        );
      })}
    </div>
  </div>
) : (
  <nav
    aria-label={ariaLabel}
    class={rootClasses}
    role="group"
  >
    {languages.map((language) => {
      const isActive = current === language.code;
      const optionClasses = [
        'language-switcher__option',
        isActive ? 'language-switcher__option--active' : '',
      ]
        .filter(Boolean)
        .join(' ');
      return (
        <a
          href={language.href}
          lang={language.code}
          hreflang={language.code}
          dir={language.direction || 'ltr'}
          aria-current={isActive ? 'page' : undefined}
          aria-label={`Switch to ${language.label}${language.nativeName ? ` (${language.nativeName})` : ''}`}
          class={optionClasses}
        >
          {showFlags && (
            <span
              class="language-switcher__flag"
              aria-hidden="true"
              title={`${language.label} flag`}
            >
              {getFlagEmoji(language.code, language.flag)}
            </span>
          )}

          <span class={labelClasses}>
            {language.label}
            {showNativeNames && language.nativeName && (
              <span class="language-switcher__native-name">
                {language.nativeName}
              </span>
            )}
          </span>

          {variant === 'compact' && !showFlags && (
            <span class={codeClasses}>
              {language.code}
            </span>
          )}
        </a>
      );
    })}
  </nav>
)}

{variant === 'dropdown' && (
  <script is:inline>
    // Simple dropdown functionality
    document.addEventListener('DOMContentLoaded', function() {
      const dropdowns = document.querySelectorAll('[aria-haspopup="listbox"]');

      dropdowns.forEach(function(button) {
        const menu = button.nextElementSibling;
        if (!menu) return;
        const hiddenClass = 'language-switcher__menu--hidden';

        // Toggle dropdown
        button.addEventListener('click', function(e) {
          e.preventDefault();
          const isOpen = button.getAttribute('aria-expanded') === 'true';

          // Close all other dropdowns
          dropdowns.forEach(function(otherButton) {
            if (otherButton !== button) {
              otherButton.setAttribute('aria-expanded', 'false');
              const otherMenu = otherButton.nextElementSibling;
              if (otherMenu) otherMenu.classList.add(hiddenClass);
            }
          });

          // Toggle current dropdown
          button.setAttribute('aria-expanded', (!isOpen).toString());
          menu.classList.toggle(hiddenClass);
        });

        // Close on outside click
        document.addEventListener('click', function(e) {
          if (!button.contains(e.target) && !menu.contains(e.target)) {
            button.setAttribute('aria-expanded', 'false');
            menu.classList.add(hiddenClass);
          }
        });

        // Close on escape key
        document.addEventListener('keydown', function(e) {
          if (e.key === 'Escape') {
            button.setAttribute('aria-expanded', 'false');
            menu.classList.add(hiddenClass);
            button.focus();
          }
        });

        // Arrow key navigation
        button.addEventListener('keydown', function(e) {
          if (e.key === 'ArrowDown' || e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            button.setAttribute('aria-expanded', 'true');
            menu.classList.remove(hiddenClass);

            // Focus first option
            const firstOption = menu.querySelector('[role="option"]');
            if (firstOption) firstOption.focus();
          }
        });

        // Menu navigation
        menu.addEventListener('keydown', function(e) {
          const options = Array.from(menu.querySelectorAll('[role="option"]'));
          const currentIndex = options.findIndex(option => option === document.activeElement);
          
          if (e.key === 'ArrowDown') {
            e.preventDefault();
            const nextIndex = (currentIndex + 1) % options.length;
            options[nextIndex].focus();
          } else if (e.key === 'ArrowUp') {
            e.preventDefault();
            const prevIndex = currentIndex > 0 ? currentIndex - 1 : options.length - 1;
            options[prevIndex].focus();
          } else if (e.key === 'Home') {
            e.preventDefault();
            options[0].focus();
          } else if (e.key === 'End') {
            e.preventDefault();
            options[options.length - 1].focus();
          }
        });
      });
    });
  </script>
)}

<style is:inline>
  .language-switcher {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .language-switcher--size-sm {
    gap: 0.25rem;
  }

  .language-switcher--size-md {
    gap: 0.5rem;
  }

  .language-switcher--size-lg {
    gap: 0.75rem;
  }

  .language-switcher--variant-dropdown {
    position: relative;
    display: inline-block;
    flex-wrap: nowrap;
  }

  .language-switcher:not(.language-switcher--variant-dropdown).language-switcher--position-start {
    justify-content: flex-start;
  }

  .language-switcher:not(.language-switcher--variant-dropdown).language-switcher--position-center {
    justify-content: center;
  }

  .language-switcher:not(.language-switcher--variant-dropdown).language-switcher--position-end {
    justify-content: flex-end;
  }

  .language-switcher__toggle,
  .language-switcher__option,
  .language-switcher__menu-item {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border-radius: 0.8rem;
    border: 1px solid #cbd5f5;
    background-color: #ffffff;
    color: #0f172a;
    text-decoration: none;
    transition:
      background-color 0.15s ease,
      color 0.15s ease,
      border-color 0.15s ease,
      transform 0.1s ease;
    cursor: pointer;
  }

  .language-switcher__toggle {
    width: 100%;
    justify-content: space-between;
  }

  .language-switcher__option {
    font-weight: 600;
  }

  .language-switcher__option--active,
  .language-switcher__menu-item--active {
    background-color: #0f172a;
    border-color: #0f172a;
    color: #f8fafc;
  }

  .language-switcher__toggle:hover,
  .language-switcher__option:hover,
  .language-switcher__menu-item:hover {
    background-color: #f8fafc;
  }

  .language-switcher__option:active {
    transform: scale(0.96);
  }

  .language-switcher__flag {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
  }

  .language-switcher__toggle-label,
  .language-switcher__menu-label,
  .language-switcher__label {
    display: inline-flex;
    flex-direction: column;
    text-align: left;
    line-height: 1.2;
  }

  .language-switcher__native-name {
    font-size: 0.8em;
    color: #475569;
    font-weight: 400;
  }

  .language-switcher__icon {
    width: 1rem;
    height: 1rem;
    color: #475569;
  }

  .language-switcher__icon--active {
    color: inherit;
  }

  .language-switcher__menu {
    position: absolute;
    top: calc(100% + 0.25rem);
    left: 0;
    min-width: 100%;
    border: 1px solid #e2e8f0;
    border-radius: 0.85rem;
    background-color: #ffffff;
    box-shadow: 0 16px 30px rgba(15, 23, 42, 0.15);
    padding: 0.25rem 0;
    z-index: 20;
  }

  .language-switcher__menu--hidden {
    display: none;
  }

  .language-switcher__menu-item {
    display: flex;
    width: 100%;
    padding: 0.5rem 1rem;
  }

  .language-switcher__menu-item:first-of-type {
    border-top-left-radius: 0.85rem;
    border-top-right-radius: 0.85rem;
  }

  .language-switcher__menu-item:last-of-type {
    border-bottom-left-radius: 0.85rem;
    border-bottom-right-radius: 0.85rem;
  }

  .language-switcher--size-sm .language-switcher__option,
  .language-switcher--size-sm .language-switcher__toggle,
  .language-switcher--size-sm .language-switcher__menu-item {
    min-height: 28px;
    padding: 0.35rem 0.75rem;
    font-size: 0.8rem;
  }

  .language-switcher--size-md .language-switcher__option,
  .language-switcher--size-md .language-switcher__toggle,
  .language-switcher--size-md .language-switcher__menu-item {
    min-height: 36px;
    padding: 0.5rem 1rem;
    font-size: 0.9rem;
  }

  .language-switcher--size-lg .language-switcher__option,
  .language-switcher--size-lg .language-switcher__toggle,
  .language-switcher--size-lg .language-switcher__menu-item {
    min-height: 44px;
    padding: 0.65rem 1.25rem;
    font-size: 1rem;
  }

  .language-switcher--size-sm .language-switcher__flag {
    font-size: 0.85rem;
  }

  .language-switcher--size-lg .language-switcher__flag {
    font-size: 1.2rem;
  }

  .language-switcher--variant-minimal .language-switcher__option {
    border-color: transparent;
    background-color: transparent;
    font-weight: 500;
  }

  .language-switcher--variant-compact .language-switcher__option {
    padding-inline: 0.75rem;
  }

  .language-switcher__label--compact {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
  }

  @media (min-width: 640px) {
    .language-switcher__label--compact {
      position: static;
      width: auto;
      height: auto;
      padding: 0;
      margin: 0;
      overflow: visible;
      clip: auto;
    }
  }

  .language-switcher__code {
    display: none;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
      'Liberation Mono', 'Courier New', monospace;
    text-transform: uppercase;
    font-size: 0.8rem;
  }

  .language-switcher__code--visible {
    display: inline-block;
  }

  @media (min-width: 640px) {
    .language-switcher__code--visible {
      display: none;
    }
  }

  .language-switcher__toggle:focus-visible,
  .language-switcher__option:focus-visible,
  .language-switcher__menu-item:focus-visible {
    outline: 2px solid #2563eb;
    outline-offset: 2px;
  }

  @media (prefers-contrast: high) {
    .language-switcher__option,
    .language-switcher__toggle {
      border-width: 2px;
      font-weight: 600;
    }

    .language-switcher__option--active,
    .language-switcher__menu-item--active {
      text-decoration: underline;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .language-switcher__option,
    .language-switcher__toggle,
    .language-switcher__menu-item {
      transition: none;
    }

    .language-switcher__option:active {
      transform: none;
    }
  }

  [dir='rtl'] .language-switcher__menu {
    left: auto;
    right: 0;
  }

  :where(.dark) .language-switcher__option,
  :where(.dark) .language-switcher__toggle,
  :where(.dark) .language-switcher__menu-item {
    background-color: #0f172a;
    border-color: #475569;
    color: #f8fafc;
  }

  :where(.dark) .language-switcher__option--active,
  :where(.dark) .language-switcher__menu-item--active {
    background-color: #f8fafc;
    color: #0f172a;
    border-color: #f8fafc;
  }

  :where(.dark) .language-switcher__menu {
    background-color: #0f172a;
    border-color: #1f2937;
    box-shadow: 0 20px 35px rgba(2, 6, 23, 0.7);
  }

  :where(.dark) .language-switcher__native-name {
    color: #94a3b8;
  }

  .language-switcher--variant-dropdown .language-switcher__toggle-label {
    flex: 1;
  }

  .language-switcher--variant-dropdown .language-switcher__toggle {
    gap: 0.5rem;
  }
</style>
