---
/**
 * AirQuality - Accessible air quality monitoring component
 * WCAG AAA compliant air quality display with real-time data
 */

interface Props {
  latitude?: number;
  longitude?: number;
  location?: string;
  aqiSystem?: 'european' | 'us' | 'both';
  size?: 'xs' | 'sm' | 'md' | 'lg' | 'xl';
  variant?: 'default' | 'minimal' | 'dashboard';
  showHealthAdvice?: boolean;
  color?:
    | 'classicBlue'
    | 'natureGreen'
    | 'warmPurple'
    | 'skyCyan'
    | 'orangeAccent';
  class?: string;
}

const {
  latitude,
  longitude,
  location,
  aqiSystem = 'both',
  size = 'md',
  variant = 'default',
  showHealthAdvice = true,
  color = 'classicBlue',
  language = 'en',
  domain = 'both',
  class: className = '',
  ...rest
} = Astro.props;

const sizeOptions = ['xs', 'sm', 'md', 'lg', 'xl'] as const;
const variantOptions = ['default', 'minimal', 'dashboard'] as const;
const colorOptions = [
  'classicBlue',
  'natureGreen',
  'warmPurple',
  'skyCyan',
  'orangeAccent',
] as const;
type SizeOption = (typeof sizeOptions)[number];
type VariantOption = (typeof variantOptions)[number];
type ColorOption = (typeof colorOptions)[number];
const sizeKey = sizeOptions.includes(size as SizeOption) ? size : 'md';
const variantKey = variantOptions.includes(variant as VariantOption)
  ? variant
  : 'default';
const colorKey = colorOptions.includes(color as ColorOption)
  ? color
  : 'classicBlue';

const rootClasses = [
  'air-quality',
  `air-quality--size-${sizeKey}`,
  `air-quality--variant-${variantKey}`,
  `air-quality--palette-${colorKey}`,
  className,
]
  .filter(Boolean)
  .join(' ');

