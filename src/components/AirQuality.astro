const translationsScript = `window.__AIR_QUALITY_TRANSLATIONS = window.__AIR_QUALITY_TRANSLATIONS || ${translationsJSON};`;
const t = (key) =>
  (TRANSLATIONS[language] && TRANSLATIONS[language][key]) ||
  TRANSLATIONS.en[key] ||
  key;
---

<div
  class={rootClasses}
  role="region"
  aria-label={`${t('aria_for')} ${location || t('your_location')}`}
  data-air-quality-widget
  data-latitude={latitude}
  data-longitude={longitude}
  data-language={language}
  data-domain={domain}
  data-location={location}
  data-aqi-system={aqiSystem}
  {...rest}
>
  <div class="air-quality__body">
    <header class="air-quality__header">
      <div class="air-quality__title-row">
        <span class="air-quality__title-icon" aria-hidden="true">🫁</span>
        <h2 class="air-quality__title">{t('air_quality')}</h2>
      </div>
      <div class="air-quality__meta-row">
        <div class="air-quality__location">
          {
            location ? (
              <span class="air-quality__location-value">{location}</span>
            ) : null
          }
        </div>
        <div class="air-quality__update-time" aria-live="polite">
          {t('updating')}
        </div>
      </div>
    </header>

    <div class="air-quality__loading" aria-live="polite">
      <div class="air-quality__spinner" aria-hidden="true"></div>
      <span class="air-quality__loading-text">{t('loading_data')}</span>
    </div>

    <div class="air-quality__error is-hidden" role="alert">
      <div class="air-quality__error-icon" aria-hidden="true">⚠️</div>
      <h3 class="air-quality__error-title">{t('error_title')}</h3>
      <p class="air-quality__error-message"></p>
      <button class="air-quality__retry-button" type="button">
        {t('try_again')}
      </button>
    </div>

    <div class="air-quality__content is-hidden">
      <div
        class={`air-quality__aqi-grid ${aqiSystem === 'both' ? 'air-quality__aqi-grid--dual' : ''}`}
      >
        {
          (aqiSystem === 'european' || aqiSystem === 'both') && (
            <div
              class="air-quality__aqi-card air-quality__aqi-card--eu"
              role="group"
              aria-labelledby="eu-aqi-label"
            >
              <h3 id="eu-aqi-label" class="air-quality__aqi-heading">
                {t('eu_aqi')}
              </h3>
              <div
                class="air-quality__aqi-value air-quality__aqi-value--eu"
                aria-label="European Air Quality Index"
              >
                --
              </div>
              <div class="air-quality__aqi-desc air-quality__aqi-desc--eu">
                Loading...
              </div>
              <div class="air-quality__aqi-bar">
                <div
                  class="air-quality__aqi-indicator air-quality__aqi-indicator--eu"
                  style="left: 0%;"
                />
              </div>
            </div>
          )
        }

        {
          (aqiSystem === 'us' || aqiSystem === 'both') && (
            <div
              class="air-quality__aqi-card air-quality__aqi-card--us"
              role="group"
              aria-labelledby="us-aqi-label"
            >
              <h3 id="us-aqi-label" class="air-quality__aqi-heading">
                {t('us_aqi')}
              </h3>
              <div
                class="air-quality__aqi-value air-quality__aqi-value--us"
                aria-label="US Air Quality Index"
              >
                --
              </div>
              <div class="air-quality__aqi-desc air-quality__aqi-desc--us">
                Loading...
              </div>
              <div class="air-quality__aqi-bar">
                <div
                  class="air-quality__aqi-indicator air-quality__aqi-indicator--us"
                  style="left: 0%;"
                />
              </div>
            </div>
          )
        }
      </div>

      {
        showHealthAdvice && (
          <div class="air-quality__advice">
            <h3 class="air-quality__advice-heading">
              {t('health_recommendations')}
            </h3>
            <div class="air-quality__advice-list">
              <div class="air-quality__advice-entry">
                <div class="air-quality__advice-emoji" aria-hidden="true">
                  👥
                </div>
                <div>
                  <div class="air-quality__advice-label">
                    {t('general_population')}
                  </div>
                  <div class="air-quality__advice-text air-quality__advice-text--general">
                    {t('assessing')}
                  </div>
                </div>
              </div>
              <div class="air-quality__advice-entry">
                <div class="air-quality__advice-emoji" aria-hidden="true">
                  🤧
                </div>
                <div>
                  <div class="air-quality__advice-label">
                    {t('sensitive_individuals')}
                  </div>
                  <div class="air-quality__advice-text air-quality__advice-text--sensitive">
                    {t('assessing')}
                  </div>
                  <div
                    class="air-quality__pollutant-badges"
                    aria-hidden="false"
                  />
                  <div class="air-quality__pollutant-legend" />
                  <div class="air-quality__pollutant-coverage" />
                </div>
              </div>
            </div>
          </div>
        )
      }
    </div>
  </div>
</div>

<script is:inline set:html={translationsScript} />
<script type="module" is:inline>
  const POLLUTANTS = ['pm2_5', 'pm10', 'no2', 'o3', 'so2', 'co'];
  const SUPPORT_CACHE = new Map();
  const CLIENT_TRANSLATIONS = window.__AIR_QUALITY_TRANSLATIONS || {};

  class AirQuality {
    constructor(element) {
      this.element = element;
      this.lang = element.dataset.language || 'en';
      this.domain = element.dataset.domain || 'auto';
      this.latitude = parseFloat(element.dataset.latitude) || null;
      this.longitude = parseFloat(element.dataset.longitude) || null;
      this.location = element.dataset.location || null;
      this.aqiSystem = element.dataset.aqiSystem || 'both';

      this.controller = null;
      this.supportMap = {};
      this.refs = this.collectRefs(element);
      this.bindEvents();
      this.init();
    }

    collectRefs(root) {
      return {
        loading: root.querySelector('.air-quality__loading'),
        error: root.querySelector('.air-quality__error'),
        content: root.querySelector('.air-quality__content'),
        retry: root.querySelector('.air-quality__retry-button'),
        errorMessage: root.querySelector('.air-quality__error-message'),
        adviceGeneral: root.querySelector('.air-quality__advice-text--general'),
        adviceSensitive: root.querySelector(
          '.air-quality__advice-text--sensitive'
        ),
        pollutantBadges: root.querySelector('.air-quality__pollutant-badges'),
        pollutantLegend: root.querySelector('.air-quality__pollutant-legend'),
        pollutantCoverage: root.querySelector(
          '.air-quality__pollutant-coverage'
        ),
        updateTime: root.querySelector('.air-quality__update-time'),
        aqi: {
          eu: {
            value: root.querySelector('.air-quality__aqi-value--eu'),
            desc: root.querySelector('.air-quality__aqi-desc--eu'),
            indicator: root.querySelector('.air-quality__aqi-indicator--eu'),
          },
          us: {
            value: root.querySelector('.air-quality__aqi-value--us'),
            desc: root.querySelector('.air-quality__aqi-desc--us'),
            indicator: root.querySelector('.air-quality__aqi-indicator--us'),
          },
        },
      };
    }

    bindEvents() {
      this.refs.retry?.addEventListener('click', () => this.fetchData());
    }

    tLang(key) {
      const dictionary =
        CLIENT_TRANSLATIONS[this.lang] || CLIENT_TRANSLATIONS.en;
      return dictionary[key] || CLIENT_TRANSLATIONS.en[key] || key;
    }

    async init() {
      await this.getCoordinates();
      await this.fetchData();
    }

    cacheKey() {
      return `${this.latitude}_${this.longitude}_${this.domain || 'auto'}`;
    }

    async detectSupportedPollutants() {
      const cacheKey = this.cacheKey();
      if (SUPPORT_CACHE.has(cacheKey)) {
        return SUPPORT_CACHE.get(cacheKey);
      }

      const localKey = `aq_supported_${cacheKey}`;
      try {
        const raw = localStorage.getItem(localKey);
        if (raw) {
          const parsed = JSON.parse(raw);
          if (Date.now() - parsed.t < 60 * 60 * 1000) {
            SUPPORT_CACHE.set(cacheKey, parsed.payload);
            return parsed.payload;
          }
        }
      } catch {
        // ignore
      }

      const checks = await Promise.all(
        POLLUTANTS.map(async (pollutant) => {
          const domainParam =
            this.domain && this.domain !== 'auto'
              ? `&domain=${this.domain}`
              : '';
          const base = `https://air-quality-api.open-meteo.com/v1/air-quality?latitude=${this.latitude}&longitude=${this.longitude}&timezone=auto${domainParam}`;
          const tryFetch = async (type) => {
            const url = `${base}&${type}=${pollutant}`;
            const response = await fetch(url, {
              signal: this.controller?.signal,
            });
            if (!response.ok) return null;
            return response.json();
          };

          try {
            const hourly = await tryFetch('hourly');
            if (hourly?.hourly && Array.isArray(hourly.hourly[pollutant])) {
              return { pollutant, method: 'hourly' };
            }
          } catch {
            /* noop */
          }

          try {
            const current = await tryFetch('current');
            if (current?.current && current.current[pollutant] != null) {
              return { pollutant, method: 'current' };
            }
          } catch {
            /* noop */
          }

          return { pollutant, method: null };
        })
      );

      const map = {};
      checks.forEach((item) => {
        if (item.method) map[item.pollutant] = item.method;
      });
      SUPPORT_CACHE.set(cacheKey, map);
      try {
        localStorage.setItem(
          localKey,
          JSON.stringify({ t: Date.now(), payload: map })
        );
      } catch {
        // ignore storage write errors
      }
      return map;
    }

    async getCoordinates() {
      if (this.latitude && this.longitude) return;
      if (!('geolocation' in navigator)) return;
      try {
        const position = await new Promise((resolve, reject) => {
          navigator.geolocation.getCurrentPosition(resolve, reject, {
            timeout: 10000,
          });
        });
        this.latitude = position.coords.latitude;
        this.longitude = position.coords.longitude;
      } catch {
        this.showError(this.tLang('location_denied'));
      }
    }

    cancelPending() {
      if (this.controller) {
        this.controller.abort();
      }
      this.controller = new AbortController();
    }

    async fetchData() {
      if (!this.latitude || !this.longitude) {
        this.showError(this.tLang('no_location_provided'));
        return;
      }

      this.cancelPending();
      this.showLoading();

      const baseParams = `latitude=${this.latitude}&longitude=${this.longitude}&timezone=auto`;
      try {
        const currentUrl = `https://air-quality-api.open-meteo.com/v1/air-quality?${baseParams}&current=european_aqi,us_aqi`;
        const currentRes = await fetch(currentUrl, {
          signal: this.controller.signal,
        });
        if (!currentRes.ok) {
          throw new Error(`API error: ${currentRes.status}`);
        }
        const currentData = await currentRes.json();
        if (currentData.error) {
          throw new Error(currentData.reason || 'AirQuality current API error');
        }

        try {
          this.supportMap = await this.detectSupportedPollutants();
        } catch {
          this.supportMap = {};
        }

        const hourlyPollutants = POLLUTANTS.filter(
          (pollutant) => this.supportMap[pollutant] === 'hourly'
        );
        const domainParam =
          this.domain && this.domain !== 'auto' ? `&domain=${this.domain}` : '';

        const hourlyPromises = hourlyPollutants.map(async (pollutant) => {
          const url = `https://air-quality-api.open-meteo.com/v1/air-quality?${baseParams}${domainParam}&hourly=${pollutant}`;
          try {
            const response = await fetch(url, {
              signal: this.controller.signal,
            });
            if (!response.ok) return null;
            const json = await response.json();
            return json.hourly?.[pollutant]
              ? { pollutant, data: json.hourly[pollutant] }
              : null;
          } catch {
            return null;
          }
        });

        const currentPollutantList = POLLUTANTS.filter(
          (pollutant) => this.supportMap[pollutant] === 'current'
        );

        const currentPollutantPromises = currentPollutantList.map(
          async (pollutant) => {
            const url = `https://air-quality-api.open-meteo.com/v1/air-quality?${baseParams}${domainParam}&current=${pollutant}`;
            try {
              const response = await fetch(url, {
                signal: this.controller.signal,
              });
              if (!response.ok) return null;
              const json = await response.json();
              return json.current?.[pollutant] != null
                ? { pollutant, value: json.current[pollutant] }
                : null;
            } catch {
              return null;
            }
          }
        );

        const [hourlyResults, currentResults] = await Promise.all([
          Promise.all(hourlyPromises),
          Promise.all(currentPollutantPromises),
        ]);

        const mergedHourly = {};
        hourlyResults
          .filter(Boolean)
          .forEach(({ pollutant, data }) => (mergedHourly[pollutant] = data));

        const mergedCurrent = {};
        currentResults
          .filter(Boolean)
          .forEach(
            ({ pollutant, value }) => (mergedCurrent[pollutant] = value)
          );

        const merged = {
          ...currentData,
          current: {
            ...(currentData.current || {}),
            ...mergedCurrent,
          },
          hourly: mergedHourly,
        };

        this.handleData(merged);
        this.showContent();
      } catch (error) {
        if (error.name === 'AbortError') return;
        console.error('AirQuality fetch error', error);
        this.showError(this.tLang('fetch_failed'));
      }
    }

    handleData(data) {
      const current = data.current;
      if (!current) return;

      this.updateAQIBlock({
        system: 'eu',
        value: current.european_aqi,
        levelGetter: this.getEuropeanAQILevel,
        scale: 1,
      });

      this.updateAQIBlock({
        system: 'us',
        value: current.us_aqi,
        levelGetter: this.getUSAQILevel,
        scale: 1 / 5,
      });

      const aqiValue =
        current.european_aqi != null
          ? Math.round(current.european_aqi)
          : current.us_aqi != null
            ? Math.round(current.us_aqi)
            : 0;

      const components = {};
      const hourly = data.hourly || {};

      const getLatest = (arr) => {
        if (!Array.isArray(arr)) return undefined;
        for (let i = arr.length - 1; i >= 0; i -= 1) {
          const value = arr[i];
          if (value != null) return value;
        }
        return undefined;
      };

      const pickValue = (key) => {
        if (current && current[key] != null) return current[key];
        if (
          this.supportMap &&
          this.supportMap[key] === 'current' &&
          current &&
          current[key] != null
        ) {
          return current[key];
        }
        return getLatest(hourly[key]);
      };

      POLLUTANTS.forEach((pollutant) => {
        components[pollutant] = pickValue(pollutant);
      });

      this.updateHealthAdvice({ aqi: aqiValue, components });
      this.updateLastUpdated();
      this.updateCoverage();
    }

    updateAQIBlock({ system, value, levelGetter, scale }) {
      if (value == null || !this.refs.aqi[system]) return;
      const refs = this.refs.aqi[system];
      const level = levelGetter(Math.round(value));
      requestAnimationFrame(() => {
        if (refs.value) {
          refs.value.textContent = Math.round(value).toString();
          refs.value.className = `air-quality__aqi-value air-quality__aqi-value--${system} aqi-${level.class}`;
        }
        if (refs.desc) {
          refs.desc.textContent = level.description;
          refs.desc.className = `air-quality__aqi-desc air-quality__aqi-desc--${system} aqi-${level.class}`;
        }
        if (refs.indicator) {
          const position = Math.min(Math.max(value * scale, 0), 100);
          refs.indicator.style.left = `${position}%`;
        }
      });
    }

    getEuropeanAQILevel(aqi) {
      if (aqi <= 20) return { class: 'good', description: 'Good' };
      if (aqi <= 40) return { class: 'fair', description: 'Fair' };
      if (aqi <= 60) return { class: 'moderate', description: 'Moderate' };
      if (aqi <= 80) return { class: 'poor', description: 'Poor' };
      return { class: 'very-poor', description: 'Very Poor' };
    }

    getUSAQILevel(aqi) {
      if (aqi <= 50) return { class: 'good', description: 'Good' };
      if (aqi <= 100) return { class: 'moderate', description: 'Moderate' };
      if (aqi <= 150)
        return {
          class: 'unhealthy-sensitive',
          description: 'Unhealthy for Sensitive Groups',
        };
      if (aqi <= 200) return { class: 'unhealthy', description: 'Unhealthy' };
      if (aqi <= 300)
        return { class: 'very-unhealthy', description: 'Very Unhealthy' };
      return { class: 'hazardous', description: 'Hazardous' };
    }

    updateHealthAdvice({ aqi = 0, components = {} } = {}) {
      let general = 'Air quality is being assessed...';
      let sensitive = 'Air quality is being assessed...';

      if (aqi <= 50) {
        general = this.tLang('advice_excellent_general');
        sensitive = this.tLang('advice_excellent_sensitive');
      } else if (aqi <= 100) {
        general = this.tLang('advice_acceptable_general');
        sensitive = this.tLang('advice_acceptable_sensitive');
      } else if (aqi <= 150) {
        general = this.tLang('advice_moderate_general');
        sensitive = this.tLang('advice_moderate_sensitive');
      } else if (aqi <= 200) {
        general = this.tLang('advice_poor_general');
        sensitive = this.tLang('advice_poor_sensitive');
      } else if (aqi <= 300) {
        general = this.tLang('advice_very_poor_general');
        sensitive = this.tLang('advice_very_poor_sensitive');
      } else {
        general = this.tLang('advice_hazardous_general');
        sensitive = this.tLang('advice_hazardous_sensitive');
      }

      const thresholds = {
        pm2_5: 35,
        pm10: 50,
        no2: 200,
        o3: 120,
        so2: 125,
        co: 10000,
      };

      const elevated = [];
      let maxSeverity = 'low';
      const severityOrder = { low: 0, moderate: 1, high: 2, 'very-high': 3 };

      const getSeverity = (key, value) => {
        const threshold = thresholds[key];
        if (threshold == null) return 'unknown';
        if (value < threshold * 0.5) return 'low';
        if (value < threshold) return 'moderate';
        if (value < threshold * 1.5) return 'high';
        return 'very-high';
      };

      Object.entries(components).forEach(([key, raw]) => {
        const value = Number(raw);
        if (!Number.isFinite(value)) return;
        const severity = getSeverity(key, value);
        if (severityOrder[severity] > severityOrder[maxSeverity]) {
          maxSeverity = severity;
        }
        if (thresholds[key] != null && value >= thresholds[key]) {
          elevated.push(`${key.toUpperCase()}: ${value}`);
        }
      });

      if (elevated.length > 0) {
        const note = ` ${this.tLang('elevated_note')} ${elevated.join(', ')}.`;
        general += note;
        sensitive += note;
      } else if (maxSeverity === 'moderate') {
        const caution = ` ${this.tLang('pollutant_moderate_caution')}`;
        if (!general.includes(caution)) general += caution;
        if (!sensitive.includes(caution)) sensitive += caution;
      } else if (severityOrder[maxSeverity] >= severityOrder['high']) {
        general = this.tLang('advice_poor_general');
        sensitive = this.tLang('advice_poor_sensitive');
      }

      if (this.refs.adviceGeneral) {
        this.refs.adviceGeneral.textContent = general;
      }
      if (this.refs.adviceSensitive) {
        this.refs.adviceSensitive.textContent = sensitive;
      }

      this.updatePollutantList(components);
    }

    updatePollutantList(components = {}) {
      const container = this.refs.pollutantBadges;
      const legend = this.refs.pollutantLegend;
      if (!container) return;

      container.innerHTML = '';

      const units = {
        pm2_5: 'µg/m³',
        pm10: 'µg/m³',
        no2: 'µg/m³',
        o3: 'µg/m³',
        so2: 'µg/m³',
        co: 'µg/m³',
      };

      const thresholds = {
        pm2_5: 35,
        pm10: 50,
        no2: 200,
        o3: 120,
        so2: 125,
        co: 10000,
      };

      const severityFor = (key, value) => {
        const threshold = thresholds[key];
        if (threshold == null) return 'unknown';
        if (value < threshold * 0.5) return 'low';
        if (value < threshold) return 'moderate';
        if (value < threshold * 1.5) return 'high';
        return 'very-high';
      };

      let rendered = 0;
      const fragment = document.createDocumentFragment();

      Object.entries(components).forEach(([key, raw]) => {
        const value = Number(raw);
        if (!Number.isFinite(value)) return;
        const severity = severityFor(key, value);

        const badge = document.createElement('div');
        badge.className = `air-quality__pollutant-badge air-quality__pollutant-badge--${severity}`;
        badge.setAttribute('role', 'status');
        const label = `${key.toUpperCase()}: ${value}${units[key] ? ` ${units[key]}` : ''}`;
        badge.textContent = label;
        badge.title = label;
        badge.setAttribute('aria-label', label);
        fragment.appendChild(badge);
        rendered += 1;
      });

      container.appendChild(fragment);

      if (legend) {
        legend.innerHTML =
          rendered === 0
            ? this.tLang('no_pollutant_data')
            : this.tLang('legend_text');

        const detailsId = 'pollutant-explainer';
        let details = legend.querySelector(`#${detailsId}`);
        if (!details) {
          details = document.createElement('details');
          details.id = detailsId;
          details.className = 'air-quality__legend-details';
          details.innerHTML = `
            <summary class="air-quality__legend-summary">${this.tLang(
              'explainer_summary'
            )}</summary>
            <ul class="air-quality__legend-list">
              <li><strong>PM2.5</strong>: ${this.tLang('explainer_pm2_5')}</li>
              <li><strong>PM10</strong>: ${this.tLang('explainer_pm10')}</li>
              <li><strong>NO2</strong>: ${this.tLang('explainer_no2')}</li>
              <li><strong>O3</strong>: ${this.tLang('explainer_o3')}</li>
              <li><strong>SO2</strong>: ${this.tLang('explainer_so2')}</li>
              <li><strong>CO</strong>: ${this.tLang('explainer_co')}</li>
            </ul>
          `;
          legend.appendChild(details);
        }
      }
    }

    updateCoverage() {
      const el = this.refs.pollutantCoverage;
      if (!el) return;
      const map = this.supportMap || {};
      const supported = Object.keys(map).filter((key) => map[key]);
      if (supported.length === 0) {
        el.textContent = '';
        return;
      }
      const label = this.tLang('measured_label') || 'Measured:';
      const others =
        this.tLang('measured_others_not') || '(others not available)';
      const text = `${label} ${supported
        .map((key) => key.toUpperCase())
        .join(', ')} ${others}`;

      el.innerHTML = `
        <span class="air-quality__coverage-info">
          <svg aria-hidden="true" class="air-quality__coverage-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M12 2a10 10 0 100 20 10 10 0 000-20z"></path>
          </svg>
          <span class="air-quality__sr-only">${text}</span>
          <span class="air-quality__coverage-text">${label} ${supported
            .map((key) => key.toUpperCase())
            .join(
              ', '
            )}<span class="air-quality__coverage-muted"> ${others}</span></span>
        </span>
      `;
    }

    updateLastUpdated() {
      if (!this.refs.updateTime) return;
      const now = new Date();
      this.refs.updateTime.textContent = `${this.tLang('updated')} ${now.toLocaleTimeString(
        [],
        {
          hour: '2-digit',
          minute: '2-digit',
        }
      )}`;
    }

    showLoading() {
      this.refs.loading?.classList.remove('is-hidden');
      this.refs.error?.classList.add('is-hidden');
      this.refs.content?.classList.add('is-hidden');
    }

    showError(message) {
      this.refs.loading?.classList.add('is-hidden');
      this.refs.error?.classList.remove('is-hidden');
      this.refs.content?.classList.add('is-hidden');
      if (this.refs.errorMessage) {
        this.refs.errorMessage.textContent = message;
      }
    }

    showContent() {
      this.refs.loading?.classList.add('is-hidden');
      this.refs.error?.classList.add('is-hidden');
      this.refs.content?.classList.remove('is-hidden');
    }
  }

  const hydrate = () => {
    document
      .querySelectorAll('[data-air-quality-widget]')
      .forEach((element) => {
        if (!element.__airQualityInstance) {
          element.__airQualityInstance = new AirQuality(element);
        }
      });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', hydrate, { once: true });
  } else {
    hydrate();
  }

  document.addEventListener('astro:page-load', hydrate);
</script>

