---
import ButtonLink from './ButtonLink.astro';
import Badge from './Badge.astro';

export type CardVariant = 'vertical' | 'horizontal' | 'compact' | 'featured';
export type CardSize = 'sm' | 'md' | 'lg';
export type CardElevation = 'none' | 'sm' | 'md' | 'lg';

export type Action = {
  href: string;
  label: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  target?: '_blank' | '_self' | '_parent' | '_top';
  rel?: string;
  disabled?: boolean;
};

export type BadgeItem = {
  label: string;
  variant?: 'neutral' | 'primary' | 'success' | 'warning' | 'danger' | 'info';
};

export interface UniversalCardProps {
  variant?: CardVariant;
  size?: CardSize;
  elevation?: CardElevation;
  interactive?: boolean;
  className?: string;
  href?: string;
  target?: '_blank' | '_self' | '_parent' | '_top';
  rel?: string;
  ariaLabel?: string;
  imageSrc?: string;
  imageAlt?: string;
  imageRounded?: boolean;
  imageAspect?: '16:9' | '4:3' | '1:1' | '3:2' | '21:9';
  imagePlaceholder?: boolean;
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  description?: string;
  longDescription?: boolean;
  badges?: BadgeItem[];
  tags?: string[];
  meta?: string[];
  status?: 'draft' | 'published' | 'archived' | 'featured';
  actions?: Action[];
  loading?: boolean;
  disabled?: boolean;
  headingLevel?: 1 | 2 | 3 | 4 | 5 | 6;
  role?: string;
}

const {
  variant = 'vertical',
  size = 'md',
  elevation = 'sm',
  interactive = true,
  className = '',
  href,
  target = '_self',
  rel,
  ariaLabel,
  imageSrc,
  imageAlt = '',
  imageRounded = true,
  imageAspect = '16:9',
  imagePlaceholder = false,
  eyebrow,
  title,
  subtitle,
  description,
  longDescription = false,
  badges = [],
  tags = [],
  meta = [],
  status,
  actions = [],
  loading = false,
  disabled = false,
  headingLevel = 3,
  role = 'article',
} = Astro.props as UniversalCardProps;

const HeadingTag = `h${headingLevel}` as any;
const relFinal = href && target === '_blank' ? `noopener noreferrer ${rel || ''}`.trim() : rel;
const cardId = `card-${Math.random().toString(36).slice(2, 9)}`;

const rootClasses = [
  'universal-card',
  `universal-card--variant-${variant}`,
  `universal-card--size-${size}`,
  `universal-card--elevation-${elevation}`,
  interactive && !disabled ? 'universal-card--interactive' : '',
  disabled ? 'universal-card--disabled' : '',
  loading ? 'universal-card--loading' : '',
  status ? `universal-card--status-${status}` : '',
  className,
]
  .filter(Boolean)
  .join(' ');

const imageWrapperClasses = [
  'universal-card__media',
  imageRounded ? 'universal-card__media--rounded' : '',
  variant === 'horizontal' ? 'universal-card__media--horizontal' : '',
]
  .filter(Boolean)
  .join(' ');
---

<article
  id={cardId}
  class={rootClasses}
  role={role}
  aria-label={ariaLabel || title}
  aria-busy={loading}
  data-card-variant={variant}
  data-card-size={size}
  data-interactive={interactive && !disabled}
>
  {loading && (
    <div class="universal-card__overlay" aria-hidden="true">
      <div class="universal-card__spinner" />
    </div>
  )}

  {variant === 'horizontal' && (
    <div class={imageWrapperClasses}>
      <slot name="media">
        {(imageSrc || imagePlaceholder) && (
          <div class="universal-card__media-inner" data-aspect={imageAspect}>
            {href ? (
              <a
                href={href}
                target={target}
                rel={relFinal}
                aria-label={ariaLabel || `View ${title || 'content'}`}
                class="universal-card__media-link"
              >
                {imageSrc ? (
                  <img src={imageSrc} alt={imageAlt} loading="lazy" decoding="async" />
                ) : (
                  <div class="universal-card__media-placeholder" aria-hidden="true" />
                )}
              </a>
            ) : imageSrc ? (
              <img src={imageSrc} alt={imageAlt} loading="lazy" decoding="async" />
            ) : (
              <div class="universal-card__media-placeholder" aria-hidden="true" />
            )}
          </div>
        )}
      </slot>
    </div>
  )}

  {variant !== 'horizontal' && variant !== 'compact' && (
    <slot name="media">
      {(imageSrc || imagePlaceholder) && (
        <div class={imageWrapperClasses} data-section="top">
          {href ? (
            <a
              href={href}
              target={target}
              rel={relFinal}
              aria-label={ariaLabel || `View ${title || 'content'}`}
              class="universal-card__media-link"
            >
              <div class="universal-card__media-inner" data-aspect={imageAspect}>
                {imageSrc ? (
                  <img src={imageSrc} alt={imageAlt} loading="lazy" decoding="async" />
                ) : (
                  <div class="universal-card__media-placeholder" aria-hidden="true" />
                )}
              </div>
            </a>
          ) : (
            <div class="universal-card__media-inner" data-aspect={imageAspect}>
              {imageSrc ? (
                <img src={imageSrc} alt={imageAlt} loading="lazy" decoding="async" />
              ) : (
                <div class="universal-card__media-placeholder" aria-hidden="true" />
              )}
            </div>
          )}
        </div>
      )}
    </slot>
  )}

  <div class="universal-card__content">
    {(eyebrow || badges.length > 0) && (
      <div class="universal-card__eyebrow">
        {eyebrow && <span class="universal-card__text-eyebrow">{eyebrow}</span>}
        {badges.length > 0 && (
          <div class="universal-card__badges">
            {badges.map((badge) => (
              <Badge variant={badge.variant || 'neutral'}>{badge.label}</Badge>
            ))}
          </div>
        )}
      </div>
    )}

    {title && (
      <HeadingTag class="universal-card__title">
        {href ? (
          <a href={href} target={target} rel={relFinal} class="universal-card__title-link">
            {title}
          </a>
        ) : (
          title
        )}
      </HeadingTag>
    )}

    {subtitle && <p class="universal-card__subtitle">{subtitle}</p>}

    {description && (
      <p class={['universal-card__description', longDescription ? 'universal-card__description--long' : ''].join(' ')}>
        {description}
      </p>
    )}

    {tags.length > 0 && (
      <div class="universal-card__tags">
        {tags.map((tag) => (
          <span class="universal-card__tag">{tag}</span>
        ))}
      </div>
    )}

    {meta.length > 0 && (
      <div class="universal-card__meta">
        {meta.map((item) => (
          <span class="universal-card__meta-item">{item}</span>
        ))}
      </div>
    )}

    {actions.length > 0 && (
      <div class="universal-card__actions">
        {actions.map((action) => (
          <ButtonLink
            href={action.href}
            variant={action.variant || 'primary'}
            target={action.target}
            rel={action.rel}
            disabled={action.disabled}
          >
            {action.label}
          </ButtonLink>
        ))}
      </div>
    )}
  </div>
</article>

<style>
  .universal-card {
    position: relative;
    display: flex;
    flex-direction: column;
    border-radius: 1rem;
    border: 1px solid rgba(148, 163, 184, 0.6);
    background: #fff;
    color: #0f172a;
    transition: box-shadow 0.2s ease, transform 0.2s ease, border-color 0.2s ease;
  }

  :where(.dark) .universal-card {
    background: #0f172a;
    border-color: rgba(71, 85, 105, 0.6);
    color: #f8fafc;
  }

  .universal-card--variant-horizontal {
    flex-direction: row;
    gap: 1rem;
  }

  .universal-card--variant-compact {
    padding: 0.8rem;
  }

  .universal-card--variant-featured {
    border-width: 2px;
  }

  .universal-card--size-sm {
    font-size: 0.85rem;
    gap: 0.5rem;
  }

  .universal-card--size-lg {
    font-size: 1rem;
    gap: 1rem;
  }

  .universal-card--elevation-sm {
    box-shadow: 0 10px 25px rgba(15, 23, 42, 0.08);
  }

  .universal-card--elevation-md {
    box-shadow: 0 15px 35px rgba(15, 23, 42, 0.12);
  }

  .universal-card--elevation-lg {
    box-shadow: 0 30px 45px rgba(15, 23, 42, 0.18);
  }

  .universal-card--interactive:hover {
    transform: translateY(-2px);
    box-shadow: 0 18px 40px rgba(15, 23, 42, 0.2);
  }

  .universal-card--interactive:focus-within {
    outline: 2px solid rgba(59, 130, 246, 0.4);
    outline-offset: 4px;
  }

  .universal-card--disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .universal-card--status-draft {
    border-color: #fbbf24;
    background: #fffbeb;
  }

  .universal-card--status-published {
    border-color: #34d399;
    background: #ecfdf5;
  }

  .universal-card--status-archived {
    border-color: #94a3b8;
    background: #e2e8f0;
  }

  .universal-card--status-featured {
    border-color: #60a5fa;
    background: #eff6ff;
  }

  .universal-card__overlay {
    position: absolute;
    inset: 0;
    background: rgba(255, 255, 255, 0.65);
    border-radius: inherit;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 5;
  }

  .universal-card__spinner {
    width: 1.75rem;
    height: 1.75rem;
    border: 2px solid rgba(148, 163, 184, 0.6);
    border-top-color: rgba(37, 99, 235, 0.9);
    border-radius: 999px;
    animation: spin 1s linear infinite;
  }

  .universal-card__media {
    position: relative;
    overflow: hidden;
  }

  .universal-card__media--rounded {
    border-radius: 1rem;
  }

  .universal-card__media-inner {
    position: relative;
    background: rgba(226, 232, 240, 0.9);
  }

  .universal-card__media-inner[data-aspect='16:9'] {
    aspect-ratio: 16 / 9;
  }
  .universal-card__media-inner[data-aspect='4:3'] {
    aspect-ratio: 4 / 3;
  }
  .universal-card__media-inner[data-aspect='1:1'] {
    aspect-ratio: 1;
  }
  .universal-card__media-inner[data-aspect='3:2'] {
    aspect-ratio: 3 / 2;
  }
  .universal-card__media-inner[data-aspect='21:9'] {
    aspect-ratio: 21 / 9;
  }

  .universal-card__media-inner img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .universal-card__media-placeholder {
    width: 100%;
    height: 100%;
    background: rgba(148, 163, 184, 0.35);
  }

  .universal-card__content {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1rem;
  }

  .universal-card__eyebrow {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .universal-card__text-eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.75rem;
    font-weight: 600;
    color: rgba(71, 85, 105, 0.9);
  }

  .universal-card__title {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 700;
  }

  .universal-card__title-link {
    color: inherit;
    text-decoration: none;
  }

  .universal-card__title-link:hover {
    text-decoration: underline;
  }

  .universal-card__subtitle {
    margin: 0;
    font-size: 0.95rem;
    color: rgba(100, 116, 139, 0.85);
  }

  .universal-card__description {
    margin: 0;
    line-height: 1.6;
    color: rgba(71, 85, 105, 0.95);
  }

  .universal-card__description--long {
    max-height: 14rem;
    overflow: auto;
  }

  .universal-card__tags,
  .universal-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .universal-card__tag,
  .universal-card__meta-item {
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.2rem 0.5rem;
    border-radius: 999px;
    background: rgba(226, 232, 240, 0.6);
  }

  :where(.dark) .universal-card__tag,
  :where(.dark) .universal-card__meta-item {
    background: rgba(30, 41, 59, 0.7);
  }

  .universal-card__actions {
    margin-top: 0.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }
</style>
