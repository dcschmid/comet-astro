---
interface Props {
  value?: string;
  placeholder?: string;
  label?: string;
  helpText?: string;
  readOnly?: boolean;
  disabled?: boolean;
  required?: boolean;
  error?: boolean;
  variant?: 'default' | 'minimal' | 'bordered' | 'elevated';
  size?: 'sm' | 'md' | 'lg';
  maxLength?: number;
  showCharCount?: boolean;
  toolbar?: Array<
    | 'bold'
    | 'italic'
    | 'underline'
    | 'strike'
    | 'code'
    | 'quote'
    | 'link'
    | 'ordered-list'
    | 'unordered-list'
    | 'heading'
    | 'clear'
    | 'undo'
    | 'redo'
  >;
  name?: string;
  id?: string;
  ariaLabel?: string;
  ariaDescribedBy?: string;
  class?: string;
}

const {
  value = '',
  placeholder = 'Start typing…',
  label,
  helpText,
  readOnly = false,
  disabled = false,
  required = false,
  error = false,
  variant = 'default',
  size = 'md',
  maxLength,
  showCharCount = false,
  toolbar = [
    'bold',
    'italic',
    'underline',
    'strike',
    'quote',
    'code',
    'link',
    'heading',
    'ordered-list',
    'unordered-list',
    'undo',
    'redo',
    'clear',
  ],
  name,
  id: propId,
  ariaLabel,
  ariaDescribedBy,
  class: className = '',
} = Astro.props;

const hasError = Boolean(error);

const id = propId || `rich-text-${Math.random().toString(36).slice(2, 10)}`;
const helpId = helpText ? `${id}-help` : undefined;
const errorId = error ? `${id}-error` : undefined;
const charCountId = showCharCount ? `${id}-char-count` : undefined;
const finalAriaDescribedBy =
  [ariaDescribedBy, helpId, errorId, charCountId].filter(Boolean).join(' ') ||
  undefined;

const rootClasses = [
  'rich-text',
  `rich-text--variant-${variant}`,
  `rich-text--size-${size}`,
  disabled ? 'rich-text--disabled' : '',
  hasError ? 'rich-text--error' : '',
  className,
]
  .filter(Boolean)
  .join(' ');
---

<div
  id={id}
  class={rootClasses}
  data-rich-text-root
  data-max-length={maxLength}
  data-show-char-count={showCharCount}
>
  {label && (
    <label class="rich-text__label" for={`${id}-content`}>
      {label}
      {required && <span class="rich-text__required">*</span>}
    </label>
  )}

  {
    !readOnly && !disabled && (
      <div
        class="rich-text__toolbar"
        data-rich-text-toolbar
        role="toolbar"
        aria-label="Text formatting options"
      >
        {toolbar.includes('bold') && (
          <button
            type="button"
            class="rich-text__button rich-text__button--bold"
            data-rich-text-action="bold"
            aria-label="Bold"
            title="Bold (Ctrl+B)"
            disabled={disabled}
          >
            B
          </button>
        )}
        {toolbar.includes('italic') && (
          <button
            type="button"
            class="rich-text__button rich-text__button--italic"
            data-rich-text-action="italic"
            aria-label="Italic"
            title="Italic (Ctrl+I)"
            disabled={disabled}
          >
            I
          </button>
        )}
        {toolbar.includes('underline') && (
          <button
            type="button"
            class="rich-text__button rich-text__button--underline"
            data-rich-text-action="underline"
            aria-label="Underline"
            title="Underline (Ctrl+U)"
            disabled={disabled}
          >
            U
          </button>
        )}
        {toolbar.includes('strike') && (
          <button
            type="button"
            class="rich-text__button"
            data-rich-text-action="strikeThrough"
            aria-label="Strikethrough"
            title="Strikethrough"
            disabled={disabled}
          >
            S
          </button>
        )}
        {toolbar.includes('heading') && (
          <button
            type="button"
            class="rich-text__button rich-text__button--bold"
            data-rich-text-action="formatBlock"
            data-arg="h3"
            aria-label="Heading"
            title="Heading"
            disabled={disabled}
          >
            H
          </button>
        )}
        {toolbar.includes('quote') && (
          <button
            type="button"
            class="rich-text__button"
            data-rich-text-action="formatBlock"
            data-arg="blockquote"
            aria-label="Quote"
            title="Quote"
            disabled={disabled}
          >
            ❝
          </button>
        )}
        {toolbar.includes('code') && (
          <button
            type="button"
            class="rich-text__button rich-text__button--mono"
            data-rich-text-action="formatBlock"
            data-arg="pre"
            aria-label="Code"
            title="Code block"
            disabled={disabled}
          >
            {'</>'}
          </button>
        )}
        {toolbar.includes('link') && (
          <button
            type="button"
            class="rich-text__button"
            data-rich-text-action="link"
            aria-label="Insert link"
            title="Insert link"
            disabled={disabled}
          >
            🔗
          </button>
        )}
        {toolbar.includes('ordered-list') && (
          <button
            type="button"
            class="rich-text__button"
            data-rich-text-action="insertOrderedList"
            aria-label="Numbered list"
            title="Numbered list"
            disabled={disabled}
          >
            1.
          </button>
        )}
        {toolbar.includes('unordered-list') && (
          <button
            type="button"
            class="rich-text__button"
            data-rich-text-action="insertUnorderedList"
            aria-label="Bullet list"
            title="Bullet list"
            disabled={disabled}
          >
            •
          </button>
        )}
        <div class="rich-text__divider" aria-hidden="true" />
        {toolbar.includes('undo') && (
          <button
            type="button"
            class="rich-text__button"
            data-rich-text-action="undo"
            aria-label="Undo"
            title="Undo (Ctrl+Z)"
            disabled={disabled}
          >
            ↺
          </button>
        )}
        {toolbar.includes('redo') && (
          <button
            type="button"
            class="rich-text__button"
            data-rich-text-action="redo"
            aria-label="Redo"
            title="Redo (Ctrl+Y)"
            disabled={disabled}
          >
            ↻
          </button>
        )}
        {toolbar.includes('clear') && (
          <button
            type="button"
            class="rich-text__button"
            data-rich-text-action="clear"
            aria-label="Clear formatting"
            title="Clear formatting"
            disabled={disabled}
          >
            ✕
          </button>
        )}
      </div>
    )
  }

  <textarea
    name={name ?? undefined}
    hidden
    data-rich-text-input
    required={required}
    disabled={disabled}
    aria-hidden="true"
  >{value}</textarea>

  <div class="sr-only" aria-live="polite" aria-atomic="true" data-rich-text-live></div>

  <div
    id={`${id}-content`}
    class={`rich-text__editor ${readOnly ? 'rich-text__editor--readonly' : ''}`}
    data-rich-text-editor
    data-placeholder={placeholder}
    data-empty={value ? 'false' : 'true'}
    contenteditable={!readOnly && !disabled}
    role="textbox"
    aria-multiline="true"
    aria-label={ariaLabel || placeholder}
    aria-describedby={finalAriaDescribedBy}
    aria-readonly={readOnly ? 'true' : 'false'}
    aria-disabled={disabled ? 'true' : 'false'}
    aria-required={required ? 'true' : 'false'}
    aria-invalid={hasError ? 'true' : 'false'}
    spellcheck="true"
    set:html={value || ''}
  ></div>

  {(helpText || error || showCharCount) && (
    <div class="rich-text__messages">
      {helpText && (
        <p id={helpId} class="rich-text__help">
          {helpText}
        </p>
      )}
      {error && (
        <p id={errorId} class="rich-text__error" role="alert">
          {typeof error === 'string' ? error : 'Please check the content.'}
        </p>
      )}
      {
        showCharCount && (
          <p id={charCountId} class="rich-text__count">
            <span data-rich-text-count>0</span>
            <span aria-hidden="true">
              {' '}
              / {maxLength ?? '∞'}
            </span>
          </p>
        )
      }
    </div>
  )}
</div>

<style>
  .rich-text {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .rich-text__label {
    font-weight: 600;
    color: #0f172a;
  }

  .rich-text__toolbar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 0.75rem;
    border-radius: 1rem;
    border: 1px solid rgba(148, 163, 184, 0.5);
    background: #ffffff;
  }

  .rich-text__button {
    border: none;
    border-radius: 0.75rem;
    padding: 0.35rem 0.5rem;
    background: transparent;
    color: #1e293b;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.2s ease, transform 0.2s ease;
  }

  .rich-text__button:hover {
    background-color: rgba(59, 130, 246, 0.1);
  }

  .rich-text__button:focus-visible {
    outline: 2px solid #2563eb;
    outline-offset: 2px;
  }

  .rich-text__divider {
    width: 1px;
    height: 1.5rem;
    background-color: rgba(148, 163, 184, 0.6);
  }

  .rich-text__editor {
    min-height: 180px;
    border-radius: 1rem;
    border: 1px solid rgba(148, 163, 184, 0.5);
    padding: 1rem;
    background-color: #ffffff;
    color: #0f172a;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .rich-text__editor[contenteditable='true']:empty::before,
  .rich-text__editor[data-empty='true']::before {
    content: attr(data-placeholder);
    color: rgba(51, 65, 85, 0.65);
    pointer-events: none;
  }

  .rich-text__editor:focus-within {
    border-color: #2563eb;
    box-shadow: 0 0 0 2px rgba(37, 99, 235, 0.2);
  }

  .rich-text__editor--readonly {
    background-color: #f8fafc;
  }

  .rich-text__messages {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    font-size: 0.85rem;
  }

  .rich-text__help {
    color: #475569;
  }

  .rich-text__error {
    color: #dc2626;
  }

  .rich-text__count {
    text-align: right;
    color: #64748b;
    font-variant-numeric: tabular-nums;
  }

  .rich-text__count--limit {
    color: #dc2626;
  }

  .rich-text--size-sm .rich-text__editor {
    min-height: 120px;
    padding: 0.75rem;
  }

  .rich-text--size-lg .rich-text__editor {
    min-height: 240px;
    padding: 1.25rem;
  }

  .rich-text--variant-minimal .rich-text__toolbar,
  .rich-text--variant-minimal .rich-text__editor {
    background-color: #f8fafc;
    border-color: rgba(148, 163, 184, 0.4);
  }

  .rich-text--variant-bordered .rich-text__toolbar,
  .rich-text--variant-bordered .rich-text__editor {
    border-width: 2px;
  }

  .rich-text--variant-elevated .rich-text__toolbar,
  .rich-text--variant-elevated .rich-text__editor {
    box-shadow: 0 25px 75px rgba(15, 23, 42, 0.1);
  }

  .rich-text--error .rich-text__editor {
    border-color: rgba(239, 68, 68, 0.8);
  }

  .rich-text__editor--limit {
    border-color: rgba(239, 68, 68, 0.8);
  }

  :where(.dark) .rich-text__toolbar,
  :where(.dark) .rich-text__editor {
    background-color: #0f172a;
    border-color: rgba(71, 85, 105, 0.6);
    color: #f1f5f9;
  }

  :where(.dark) .rich-text__button {
    color: #e2e8f0;
  }

  :where(.dark) .rich-text__button:hover {
    background-color: rgba(59, 130, 246, 0.25);
  }

  :where(.dark)
    .rich-text__editor[contenteditable='true']:empty::before,
  :where(.dark) .rich-text__editor[data-empty='true']::before {
    color: rgba(226, 232, 240, 0.65);
  }
</style>

<script
  is:inline
  define:vars={{
    id,
    maxLength,
    showCharCount,
    readOnly,
    disabled,
    hasError,
  }}
>
  (() => {
    const root = document.getElementById(id);
    if (!(root instanceof HTMLElement)) return;

    const editor = root.querySelector('[data-rich-text-editor]');
    const hiddenInput = root.querySelector('[data-rich-text-input]');
    const toolbar = root.querySelector('[data-rich-text-toolbar]');
    const charCount = root.querySelector('[data-rich-text-count]');
    const liveRegion = root.querySelector('[data-rich-text-live]');

    if (!(editor instanceof HTMLElement)) return;

    const limit = typeof maxLength === 'number' ? maxLength : null;
    const showCount = Boolean(showCharCount);
    const isReadOnly = Boolean(readOnly);
    const isDisabled = Boolean(disabled);
    const baseError = Boolean(hasError);

    const allowedKeys = new Set([
      'Backspace',
      'Delete',
      'ArrowLeft',
      'ArrowRight',
      'ArrowUp',
      'ArrowDown',
      'Home',
      'End',
      'PageUp',
      'PageDown',
      'Tab',
      'Escape',
      'Shift',
    ]);

    const announce = (message) => {
      if (!(liveRegion instanceof HTMLElement)) return;
      liveRegion.textContent = message;
    };

    const updateEmptyState = () => {
      const length = editor.textContent
        ? editor.textContent.trim().length
        : 0;
      editor.setAttribute('data-empty', String(length === 0));
    };

    const updateCharCount = () => {
      if (!showCount || !(charCount instanceof HTMLElement)) return;
      const textLength = editor.innerText.trim().length;
      charCount.textContent = textLength.toString();
      const overLimit = limit !== null && textLength > limit;
      charCount.classList.toggle('rich-text__count--limit', overLimit);
      editor.classList.toggle('rich-text__editor--limit', overLimit);
      if (overLimit) {
        editor.setAttribute('aria-invalid', 'true');
        announce(`Character limit exceeded by ${textLength - limit}`);
      } else if (!baseError) {
        editor.setAttribute('aria-invalid', 'false');
        announce('');
      }
    };

    const sync = (emit = true) => {
      const html = editor.innerHTML.trim();
      if (hiddenInput instanceof HTMLTextAreaElement) {
        hiddenInput.value = html;
      }
      if (emit) {
        root.dispatchEvent(
          new CustomEvent('rich-text:change', {
            bubbles: true,
            detail: { value: html },
          })
        );
      }
      updateEmptyState();
      updateCharCount();
    };

    const exec = (command, value) => {
      if (!command) return;
      if (command === 'clear') {
        document.execCommand('removeFormat');
        document.execCommand('unlink');
        return;
      }
      if (command === 'link') {
        const url = window.prompt('Enter URL');
        if (url) {
          document.execCommand('createLink', false, url);
        }
        return;
      }
      const formatValue = command === 'formatBlock' && !value ? 'p' : value;
      document.execCommand(command, false, formatValue);
    };

    updateEmptyState();
    updateCharCount();

    if (isReadOnly || isDisabled) {
      return;
    }

    editor.addEventListener('keydown', (event) => {
      if (event.ctrlKey || event.metaKey) {
        const key = event.key.toLowerCase();
        if (key === 'b' || key === 'i' || key === 'u') {
          event.preventDefault();
          exec(
            key === 'b' ? 'bold' : key === 'i' ? 'italic' : 'underline'
          );
          sync();
          return;
        }
        if (key === 'z') {
          event.preventDefault();
          exec(event.shiftKey ? 'redo' : 'undo');
          sync();
          return;
        }
        if (key === 'y') {
          event.preventDefault();
          exec('redo');
          sync();
          return;
        }
      }

      if (limit !== null && !event.ctrlKey && !event.metaKey) {
        const textLength = editor.innerText.length;
        if (textLength >= limit && !allowedKeys.has(event.key)) {
          event.preventDefault();
          announce(`Character limit of ${limit} reached`);
        }
      }
    });

    if (toolbar instanceof HTMLElement) {
      toolbar.addEventListener('click', (event) => {
        const target =
          event.target instanceof HTMLElement
            ? event.target.closest('[data-rich-text-action]')
            : null;
        if (!(target instanceof HTMLElement)) return;
        const action = target.getAttribute('data-rich-text-action');
        const arg = target.getAttribute('data-arg') || undefined;
        exec(action, arg);
        editor.focus();
        sync();
      });
    }

    editor.addEventListener('input', () => sync());
    editor.addEventListener('blur', () => sync(false));
    editor.addEventListener('paste', () => {
      setTimeout(() => sync(), 10);
    });

    root.addEventListener('rich-text:set', (event) => {
      const detail = event && 'detail' in event ? event.detail : null;
      const nextValue =
        detail && typeof detail.value === 'string' ? detail.value : '';
      editor.innerHTML = nextValue;
      sync(false);
    });

    const observer = new MutationObserver(() => sync(false));
    observer.observe(editor, { childList: true, subtree: true });
  })();
</script>
