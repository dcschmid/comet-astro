---
/**
 * Stack - WCAG AAA compliant flex layout with BEM styling
 * Provides semantic spacing, alignment, and responsive gap controls
 */
interface Props {
  direction?: 'vertical' | 'horizontal';
  gap?: 'none' | 'xs' | 'sm' | 'md' | 'lg' | 'xl' | '2xl' | '3xl' | '4xl';
  align?: 'start' | 'center' | 'end' | 'stretch' | 'baseline';
  justify?: 'start' | 'center' | 'end' | 'between' | 'around' | 'evenly';
  wrap?: boolean;
  responsive?: {
    sm?: 'none' | 'xs' | 'sm' | 'md' | 'lg' | 'xl' | '2xl' | '3xl' | '4xl';
    md?: 'none' | 'xs' | 'sm' | 'md' | 'lg' | 'xl' | '2xl' | '3xl' | '4xl';
    lg?: 'none' | 'xs' | 'sm' | 'md' | 'lg' | 'xl' | '2xl' | '3xl' | '4xl';
    xl?: 'none' | 'xs' | 'sm' | 'md' | 'lg' | 'xl' | '2xl' | '3xl' | '4xl';
  };
  as?:
    | 'div'
    | 'section'
    | 'article'
    | 'nav'
    | 'ul'
    | 'ol'
    | 'header'
    | 'footer'
    | 'main'
    | 'aside';
  role?: string;
  ariaLabel?: string;
  ariaLabelledby?: string;
  debug?: boolean;
  class?: string;
}

const {
  direction = 'vertical',
  gap = 'md',
  align = 'stretch',
  justify = 'start',
  wrap = false,
  responsive,
  as: Element = 'div',
  role,
  ariaLabel,
  ariaLabelledby,
  debug = false,
  class: className = '',
} = Astro.props as Props;

const gapValues = {
  none: '0px',
  xs: '0.25rem',
  sm: '0.5rem',
  md: '1rem',
  lg: '1.5rem',
  xl: '2rem',
  '2xl': '3rem',
  '3xl': '4rem',
  '4xl': '5rem',
} as const;

const rootClasses = [
  'stack',
  `stack--direction-${direction}`,
  `stack--gap-${gap}`,
  `stack--align-${align}`,
  `stack--justify-${justify}`,
  wrap ? 'stack--wrap' : '',
  debug ? 'stack--debug' : '',
  className,
]
  .filter(Boolean)
  .join(' ');

const breakpointVarMap: Record<'sm' | 'md' | 'lg' | 'xl', string> = {
  sm: '--stack-gap-sm',
  md: '--stack-gap-md',
  lg: '--stack-gap-lg',
  xl: '--stack-gap-xl',
};

const responsiveStyleEntries =
  responsive != null
    ? (Object.entries(responsive) as Array<
        ['sm' | 'md' | 'lg' | 'xl', Props['gap']]
      >)
        .filter(([, value]) => Boolean(value))
        .map(([key, value]) => {
          const cssVar = breakpointVarMap[key];
          const gapToken =
            value != null ? gapValues[value] : undefined;
          return cssVar && gapToken ? `${cssVar}: ${gapToken};` : '';
        })
        .filter(Boolean)
    : [];

const inlineStyles =
  responsiveStyleEntries.length > 0
    ? responsiveStyleEntries.join(' ')
    : undefined;

const debugInfo = debug ? `${direction} ${gap} ${align} ${justify}` : undefined;
---

<Element
  class={rootClasses}
  style={inlineStyles}
  role={role}
  aria-label={ariaLabel}
  aria-labelledby={ariaLabelledby}
  data-direction={direction}
  data-gap={gap}
  data-debug-info={debugInfo}
>
  <slot />
</Element>

<style>
  .stack {
    --stack-gap: 1rem;
    display: flex;
    flex-direction: column;
    gap: var(--stack-gap);
    width: 100%;
  }

  .stack--direction-horizontal {
    flex-direction: row;
  }

  .stack--direction-vertical {
    flex-direction: column;
  }

  .stack--wrap {
    flex-wrap: wrap;
  }

  .stack--align-start {
    align-items: flex-start;
  }

  .stack--align-center {
    align-items: center;
  }

  .stack--align-end {
    align-items: flex-end;
  }

  .stack--align-stretch {
    align-items: stretch;
  }

  .stack--align-baseline {
    align-items: baseline;
  }

  .stack--justify-start {
    justify-content: flex-start;
  }

  .stack--justify-center {
    justify-content: center;
  }

  .stack--justify-end {
    justify-content: flex-end;
  }

  .stack--justify-between {
    justify-content: space-between;
  }

  .stack--justify-around {
    justify-content: space-around;
  }

  .stack--justify-evenly {
    justify-content: space-evenly;
  }

  .stack--gap-none {
    --stack-gap: 0px;
  }

  .stack--gap-xs {
    --stack-gap: 0.25rem;
  }

  .stack--gap-sm {
    --stack-gap: 0.5rem;
  }

  .stack--gap-md {
    --stack-gap: 1rem;
  }

  .stack--gap-lg {
    --stack-gap: 1.5rem;
  }

  .stack--gap-xl {
    --stack-gap: 2rem;
  }

  .stack--gap-2xl {
    --stack-gap: 3rem;
  }

  .stack--gap-3xl {
    --stack-gap: 4rem;
  }

  .stack--gap-4xl {
    --stack-gap: 5rem;
  }

  .stack--debug {
    outline: 2px dashed rgba(255, 0, 255, 0.5);
    outline-offset: 2px;
    background: repeating-linear-gradient(
      45deg,
      rgba(255, 0, 255, 0.05),
      rgba(255, 0, 255, 0.05) 4px,
      transparent 4px,
      transparent 8px
    );
    position: relative;
  }

  .stack--debug::before {
    content: 'Stack: ' attr(data-debug-info);
    position: absolute;
    top: -1.5rem;
    left: 0;
    background: rgba(255, 0, 255, 0.9);
    color: #fff;
    padding: 2px 6px;
    font-size: 10px;
    font-family: monospace;
    border-radius: 2px;
    white-space: nowrap;
    pointer-events: none;
    z-index: 10;
  }

  .stack__divider {
    width: 100%;
    height: 1px;
    background-color: currentColor;
    opacity: 0.2;
  }

  .stack--interactive:focus-within {
    outline: 2px solid transparent;
    box-shadow: 0 0 0 2px rgb(59 130 246 / 0.5);
  }

  :where(.dark) .stack--interactive:focus-within {
    box-shadow: 0 0 0 2px rgb(96 165 250 / 0.5);
  }

  @media (prefers-color-scheme: dark) {
    .stack--debug {
      outline-color: rgba(255, 255, 0, 0.6);
      background: repeating-linear-gradient(
        45deg,
        rgba(255, 255, 0, 0.05),
        rgba(255, 255, 0, 0.05) 4px,
        transparent 4px,
        transparent 8px
      );
    }

    .stack--debug::before {
      background: rgba(255, 255, 0, 0.9);
      color: #000;
    }
  }

  @media (prefers-contrast: high) {
    .stack--debug {
      outline-width: 3px !important;
    }

    .stack--debug::before {
      font-weight: 700 !important;
    }

    .stack__divider {
      opacity: 0.6 !important;
    }
  }

  @media (min-width: 640px) {
    .stack {
      gap: var(--stack-gap-sm, var(--stack-gap));
    }
  }

  @media (min-width: 768px) {
    .stack {
      gap: var(--stack-gap-md, var(--stack-gap-sm, var(--stack-gap)));
    }
  }

  @media (min-width: 1024px) {
    .stack {
      gap: var(
        --stack-gap-lg,
        var(--stack-gap-md, var(--stack-gap-sm, var(--stack-gap)))
      );
    }
  }

  @media (min-width: 1280px) {
    .stack {
      gap: var(
        --stack-gap-xl,
        var(
          --stack-gap-lg,
          var(--stack-gap-md, var(--stack-gap-sm, var(--stack-gap)))
        )
      );
    }
  }
</style>
