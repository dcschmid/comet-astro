---
interface Props {
  id: string;
  title?: string;
  size?: 'sm' | 'md' | 'lg' | 'xl' | 'full';
  dismissible?: boolean;
  className?: string;
}

const {
  id,
  title,
  size = 'md',
  dismissible = true,
  className = '',
} = Astro.props;

const baseClasses = ['dialog', `dialog--${size}`, className]
  .filter(Boolean)
  .join(' ');
---

<dialog
  id={id}
  class={baseClasses}
  data-dialog
  aria-modal="true"
  role="dialog"
  aria-labelledby={title ? `${id}-title` : undefined}
>
  <div class="dialog__surface">
    {
      dismissible && (
        <button
          type="button"
          class="dialog__close"
          data-dialog-close
          aria-label="Close dialog"
        >
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <path d="M18 6L6 18M6 6l12 12" />
          </svg>
        </button>
      )
    }
    {
      title && (
        <header class="dialog__header">
          <h2
            id={`${id}-title`}
            class="dialog__title"
          >
            {title}
          </h2>
        </header>
      )
    }
    <div class="dialog__body">
      <slot />
    </div>
    <footer class="dialog__footer">
      <div class="dialog__actions">
        <slot name="actions">
          {
            dismissible && (
              <button
                type="button"
                class="dialog__button"
                data-dialog-close
              >
                Close
              </button>
            )
          }
        </slot>
      </div>
    </footer>
  </div>
</dialog>

<script is:inline>
  (function () {
    const dialogs = Array.from(
      document.querySelectorAll('[data-dialog]')
    ).filter((el) => el instanceof HTMLDialogElement);
    if (!dialogs.length) return;

    let focusedElementBeforeDialog = null;

    const getFocusableElements = (element) => {
      return element.querySelectorAll(
        'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])'
      );
    };

    const trapFocus = (dialog) => {
      const focusableElements = getFocusableElements(dialog);
      const firstFocusable = focusableElements[0];
      const lastFocusable = focusableElements[focusableElements.length - 1];

      dialog.addEventListener('keydown', (event) => {
        if (event.key === 'Tab') {
          if (event.shiftKey) {
            if (document.activeElement === firstFocusable) {
              event.preventDefault();
              lastFocusable?.focus();
            }
          } else {
            if (document.activeElement === lastFocusable) {
              event.preventDefault();
              firstFocusable?.focus();
            }
          }
        }
      });
    };

    const closeDialog = (dialog) => {
      try {
        dialog.close();
      } catch {
        dialog.removeAttribute('open');
      }

      // Restore focus to the element that opened the dialog
      if (focusedElementBeforeDialog) {
        focusedElementBeforeDialog.focus();
        focusedElementBeforeDialog = null;
      }
    };

    dialogs.forEach((dialog) => {
      // Handle ESC key and prevent default cancel behavior
      dialog.addEventListener('cancel', (event) => {
        event.preventDefault();
        closeDialog(dialog);
      });

      // Close on backdrop click
      dialog.addEventListener('click', (event) => {
        if (event.target === dialog) {
          closeDialog(dialog);
        }
      });

      // Handle close buttons
      dialog.querySelectorAll('[data-dialog-close]').forEach((button) => {
        button.addEventListener('click', () => closeDialog(dialog));
      });

      // Setup focus trap when dialog opens
      dialog.addEventListener('close', () => {
        closeDialog(dialog);
      });
    });

    // Handle dialog triggers
    document.addEventListener('click', (event) => {
      const trigger =
        event.target instanceof HTMLElement
          ? event.target.closest('[data-dialog-trigger]')
          : null;
      if (!trigger) return;

      const targetId = trigger.getAttribute('data-dialog-trigger');
      if (!targetId) return;

      const dialog = document.getElementById(targetId);
      if (!(dialog instanceof HTMLDialogElement)) return;

      // Store the focused element
      focusedElementBeforeDialog = document.activeElement;

      try {
        dialog.showModal();

        // Focus first focusable element or the dialog itself
        const focusableElements = getFocusableElements(dialog);
        const firstFocusable = focusableElements[0];
        if (firstFocusable) {
          firstFocusable.focus();
        } else {
          dialog.focus();
        }

        // Setup focus trap
        trapFocus(dialog);
      } catch {
        dialog.setAttribute('open', 'true');
      }
    });
  })();
</script>

<style is:inline>
  .dialog {
    --dialog-width: 32rem;
    --dialog-bg: var(--dialog-bg-light, #ffffff);
    --dialog-border: var(--dialog-border-light, rgba(15, 23, 42, 0.08));
    --dialog-header-bg: var(--dialog-header-bg-light, rgba(15, 23, 42, 0.03));
    --dialog-footer-bg: var(--dialog-footer-bg-light, rgba(15, 23, 42, 0.02));
    --dialog-text: var(--dialog-text-light, #0f172a);
    --dialog-subtle: var(--dialog-subtle-light, #475569);
    --dialog-close-bg: var(--dialog-close-bg-light, rgba(255, 255, 255, 0.95));
    --dialog-close-hover: var(--dialog-close-hover-light, rgba(15, 23, 42, 0.08));
    --dialog-shadow: var(--dialog-shadow-light, 0 30px 60px rgba(15, 23, 42, 0.25));
    border: none;
    padding: 0;
    margin: 0;
    width: min(var(--dialog-width), calc(100% - 2rem));
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    max-height: calc(100vh - 2rem);
    color: var(--dialog-text);
    background: transparent;
  }
  :where(.dark) .dialog {
    --dialog-bg: var(--dialog-bg-dark, #0f172a);
    --dialog-border: var(--dialog-border-dark, rgba(148, 163, 184, 0.35));
    --dialog-header-bg: var(--dialog-header-bg-dark, rgba(148, 163, 184, 0.12));
    --dialog-footer-bg: var(--dialog-footer-bg-dark, rgba(148, 163, 184, 0.08));
    --dialog-text: var(--dialog-text-dark, #f8fafc);
    --dialog-subtle: var(--dialog-subtle-dark, #cbd5f5);
    --dialog-close-bg: var(--dialog-close-bg-dark, rgba(15, 23, 42, 0.7));
    --dialog-close-hover: var(--dialog-close-hover-dark, rgba(148, 163, 184, 0.35));
    --dialog-shadow: var(--dialog-shadow-dark, 0 40px 70px rgba(2, 6, 23, 0.65));
  }
  .dialog--sm {
    --dialog-width: 22rem;
  }
  .dialog--md {
    --dialog-width: 28rem;
  }
  .dialog--lg {
    --dialog-width: 36rem;
  }
  .dialog--xl {
    --dialog-width: 42rem;
  }
  .dialog--full {
    --dialog-width: min(64rem, 100% - 2rem);
  }
  .dialog::backdrop {
    background: rgba(2, 6, 23, 0.75);
    backdrop-filter: blur(2px);
  }
  .dialog__surface {
    position: relative;
    background: var(--dialog-bg);
    border-radius: 1.5rem;
    border: 1px solid var(--dialog-border);
    box-shadow: var(--dialog-shadow);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    max-height: 100%;
  }
  .dialog__close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    z-index: 1;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 999px;
    border: 1px solid transparent;
    background: var(--dialog-close-bg);
    color: var(--dialog-text);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition:
      background-color 0.2s ease,
      color 0.2s ease,
      border-color 0.2s ease;
  }
  .dialog__close:hover {
    background: var(--dialog-close-hover);
  }
  .dialog__close:focus-visible {
    outline: 2px solid var(--dialog-subtle);
    outline-offset: 2px;
  }
  .dialog__header {
    padding: 1rem 1.5rem;
    background: var(--dialog-header-bg);
    border-bottom: 1px solid var(--dialog-border);
  }
  .dialog__title {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--dialog-text);
  }
  .dialog__body {
    padding: 1.5rem;
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--dialog-text);
    overflow-y: auto;
  }
  .dialog__footer {
    border-top: 1px solid var(--dialog-border);
    background: var(--dialog-footer-bg);
    padding: 1rem 1.5rem;
  }
  .dialog__actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  @media (min-width: 640px) {
    .dialog__actions {
      flex-direction: row;
      justify-content: flex-end;
      align-items: center;
    }
  }
  .dialog__button {
    border-radius: 0.85rem;
    border: 1px solid var(--dialog-border);
    background: var(--dialog-bg);
    padding: 0.65rem 1.5rem;
    font-weight: 600;
    color: var(--dialog-text);
    cursor: pointer;
    transition:
      background-color 0.2s ease,
      border-color 0.2s ease,
      color 0.2s ease;
  }
  .dialog__button:hover {
    border-color: var(--dialog-subtle);
    background: rgba(37, 99, 235, 0.05);
  }
  .dialog__button:focus-visible {
    outline: 2px solid var(--dialog-subtle);
    outline-offset: 2px;
  }
  @media (prefers-reduced-motion: reduce) {
    .dialog__surface,
    .dialog__close,
    .dialog__button {
      transition: none;
    }
  }
</style>
