---
/**
 * LoadingSpinner - WCAG AAA compliant loading indicator
 */
interface Props {
  /** Accessible label for screen readers */
  label?: string;
  /** Spinner size */
  size?: 'xs' | 'sm' | 'md' | 'lg' | 'xl';
  /** Visual variant */
  variant?:
    | 'default'
    | 'primary'
    | 'secondary'
    | 'success'
    | 'warning'
    | 'error'
    | 'neutral';
  /** Spinner animation type */
  animation?: 'spin' | 'pulse' | 'bounce' | 'dots' | 'bars' | 'orbit';
  /** Speed of animation */
  speed?: 'slow' | 'normal' | 'fast';
  /** Show text label alongside spinner */
  showLabel?: boolean;
  /** Center the spinner */
  centered?: boolean;
  /** Full screen overlay */
  overlay?: boolean;
  /** Custom color override */
  color?: string;
  /** Thickness of spinner stroke */
  thickness?: 'thin' | 'normal' | 'thick';
  /** Custom CSS classes */
  className?: string;
  /** Disable animation (for reduced motion) */
  disableAnimation?: boolean;
  /** Inline display mode */
  inline?: boolean;
  /** Progress value for determinate loading */
  progress?: number;
  /** Show progress percentage */
  showProgress?: boolean;
}

const {
  label = 'Loading…',
  size = 'md',
  variant = 'default',
  animation = 'spin',
  speed = 'normal',
  showLabel = false,
  centered = false,
  overlay = false,
  color,
  thickness = 'normal',
  className,
  disableAnimation = false,
  inline = false,
  progress,
  showProgress = false,
} = Astro.props as Props;

// Size mappings with WCAG AAA compliant minimum touch targets

const sizeDimensions = {
  xs: 16,
  sm: 20,
  md: 24,
  lg: 32,
  xl: 48,
};

const rootClasses = [
  'loading-spinner',
  `loading-spinner--size-${size}`,
  `loading-spinner--variant-${variant}`,
  `loading-spinner--animation-${animation}`,
  `loading-spinner--speed-${speed}`,
  `loading-spinner--thickness-${thickness}`,
  centered && !overlay ? 'loading-spinner--centered' : '',
  inline ? 'loading-spinner--inline' : '',
  disableAnimation ? 'loading-spinner--static' : '',
  showLabel ? 'loading-spinner--with-label' : '',
  overlay ? 'loading-spinner--overlay' : '',
  className,
]
  .filter(Boolean)
  .join(' ');
const labelClasses = 'loading-spinner__label';
const dimension = sizeDimensions[size];
const strokeWidth = thickness === 'thin' ? 2 : thickness === 'thick' ? 4 : 3;
const spinnerStyle = color ? ({ '--loading-spinner-color': color } as Record<string, string>) : undefined;

// Calculate progress for determinate loading
const isProgress =
  typeof progress === 'number' && progress >= 0 && progress <= 100;
const circumference = 2 * Math.PI * 10; // radius = 10
const strokeDasharray = isProgress ? circumference : undefined;
const strokeDashoffset = isProgress
  ? circumference - (progress / 100) * circumference
  : undefined;
---

<div
  class={rootClasses}
  role="status"
  aria-live="polite"
  aria-label={label}
  style={spinnerStyle}
>
  <div class="loading-spinner__icon">
    {
      animation === 'spin' && (
        <svg
          class="loading-spinner__svg"
          width={dimension}
          height={dimension}
          viewBox="0 0 24 24"
          fill="none"
          aria-hidden="true"
        >
          {isProgress ? (
            <g>
              <circle
                cx="12"
                cy="12"
                r="10"
                stroke="currentColor"
                stroke-width={strokeWidth}
                class="loading-spinner__track"
                fill="none"
              />
              <circle
                cx="12"
                cy="12"
                r="10"
                stroke="currentColor"
                stroke-width={strokeWidth}
                class="loading-spinner__indicator"
                fill="none"
                stroke-dasharray={strokeDasharray}
                stroke-dashoffset={strokeDashoffset}
                stroke-linecap="round"
                transform="rotate(-90 12 12)"
                style={{ transition: 'stroke-dashoffset 0.3s ease' }}
              />
            </g>
          ) : (
            <g>
              <circle
                cx="12"
                cy="12"
                r="10"
                stroke="currentColor"
                stroke-width={strokeWidth}
                class="loading-spinner__track"
              />
              <path
                class="loading-spinner__indicator"
                fill="currentColor"
                d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"
              />
            </g>
          )}
        </svg>
      )
    }

    {
      animation === 'pulse' && (
        <div
          class={`loading-spinner__pulse${disableAnimation ? ' loading-spinner__pulse--static' : ''}`}
          aria-hidden="true"
        />
      )
    }

    {
      animation === 'dots' && (
        <div class="loading-spinner__dots" aria-hidden="true">
          <div
            class={`loading-spinner__dot${disableAnimation ? ' loading-spinner__dot--static' : ''}`}
            style={!disableAnimation ? { animationDelay: '0s' } : {}}
          />
          <div
            class={`loading-spinner__dot${disableAnimation ? ' loading-spinner__dot--static' : ''}`}
            style={!disableAnimation ? { animationDelay: '0.2s' } : {}}
          />
          <div
            class={`loading-spinner__dot${disableAnimation ? ' loading-spinner__dot--static' : ''}`}
            style={!disableAnimation ? { animationDelay: '0.4s' } : {}}
          />
        </div>
      )
    }

    {
      animation === 'bars' && (
        <div class="loading-spinner__bars" aria-hidden="true">
          <div class={`loading-spinner__bar${disableAnimation ? ' loading-spinner__bar--static' : ''}`} style={!disableAnimation ? { animationDelay: '0s', height: '40%' } : { height: '60%' }} />
          <div class={`loading-spinner__bar${disableAnimation ? ' loading-spinner__bar--static' : ''}`} style={!disableAnimation ? { animationDelay: '0.1s', height: '70%' } : { height: '60%' }} />
          <div class={`loading-spinner__bar${disableAnimation ? ' loading-spinner__bar--static' : ''}`} style={!disableAnimation ? { animationDelay: '0.2s', height: '50%' } : { height: '60%' }} />
          <div class={`loading-spinner__bar${disableAnimation ? ' loading-spinner__bar--static' : ''}`} style={!disableAnimation ? { animationDelay: '0.3s', height: '80%' } : { height: '60%' }} />
        </div>
      )
    }

    {
      animation === 'bounce' && (
        <div class={`loading-spinner__bounce${disableAnimation ? ' loading-spinner__bounce--static' : ''}`} aria-hidden="true">
          <div class="loading-spinner__bounce-core" />
        </div>
      )
    }

    {
      animation === 'orbit' && (
        <div class={`loading-spinner__orbit${disableAnimation ? ' loading-spinner__orbit--static' : ''}`} aria-hidden="true">
          <div class="loading-spinner__orbit-dot" />
          <div class="loading-spinner__orbit-dot loading-spinner__orbit-dot--trail" />
        </div>
      )
    }

    <!-- Progress percentage overlay -->
    {
      isProgress && showProgress && (
        <div class="loading-spinner__progress-overlay">
          <span class="loading-spinner__progress-value">{Math.round(progress)}%</span>
        </div>
      )
    }
  </div>

  {showLabel && (
    <span class={labelClasses}>
      {label}
      {isProgress && showProgress && <span class="loading-spinner__progress">{Math.round(progress)}%</span>}
    </span>
  )}

  <span class="loading-spinner__sr-only">
    {label}
    {isProgress && ` ${Math.round(progress)}% complete`}
  </span>
</div>

<style is:inline>
  .loading-spinner {
    --loading-spinner-size: 1.5rem;
    --loading-spinner-color: #475569;
    --loading-spinner-track: #cbd5f5;
    --loading-spinner-text: #0f172a;
    --loading-spinner-speed: 1s;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--loading-spinner-text);
  }

  .loading-spinner:not(.loading-spinner--with-label) {
    gap: 0;
  }

  .loading-spinner--inline {
    display: inline-flex;
  }

  .loading-spinner--centered {
    justify-content: center;
  }

  .loading-spinner__icon {
    position: relative;
    width: var(--loading-spinner-size);
    height: var(--loading-spinner-size);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .loading-spinner__svg {
    width: 100%;
    height: 100%;
    color: var(--loading-spinner-color);
  }

  .loading-spinner--animation-spin .loading-spinner__svg {
    animation: spinner-rotate var(--loading-spinner-speed) linear infinite;
  }

  .loading-spinner--static .loading-spinner__svg {
    animation: none;
  }

  .loading-spinner__track {
    color: var(--loading-spinner-track);
    opacity: 0.35;
  }

  .loading-spinner__indicator {
    color: var(--loading-spinner-color);
  }

  .loading-spinner__pulse {
    width: 100%;
    height: 100%;
    border-radius: 999px;
    background-color: var(--loading-spinner-color);
    opacity: 0.7;
    animation: spinner-pulse var(--loading-spinner-speed) ease-in-out infinite;
  }

  .loading-spinner--static .loading-spinner__pulse {
    animation: none;
  }

  .loading-spinner__dots {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.3rem;
  }

  .loading-spinner__dot {
    width: 0.35rem;
    height: 0.35rem;
    border-radius: 999px;
    background-color: var(--loading-spinner-color);
    animation: spinner-dots var(--loading-spinner-speed) ease-in-out infinite;
  }

  .loading-spinner--static .loading-spinner__dot {
    animation: none;
    opacity: 0.7;
  }

  .loading-spinner__bars {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    gap: 0.25rem;
  }

  .loading-spinner__bar {
    width: 0.2rem;
    border-radius: 0.125rem;
    background-color: var(--loading-spinner-color);
    animation: spinner-bars var(--loading-spinner-speed) ease-in-out infinite;
  }

  .loading-spinner--static .loading-spinner__bar {
    animation: none;
  }

  .loading-spinner__bounce {
    width: 100%;
    height: 100%;
    border-radius: 999px;
    background-color: rgba(226, 232, 240, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    animation: spinner-bounce var(--loading-spinner-speed) ease-in-out infinite;
  }

  .loading-spinner--static .loading-spinner__bounce {
    animation: none;
  }

  .loading-spinner__bounce-core {
    width: 50%;
    height: 50%;
    border-radius: 999px;
    background-color: var(--loading-spinner-color);
    opacity: 0.8;
  }

  .loading-spinner__orbit {
    position: relative;
    width: 100%;
    height: 100%;
    animation: spinner-rotate var(--loading-spinner-speed) linear infinite;
  }

  .loading-spinner--static .loading-spinner__orbit {
    animation: none;
  }

  .loading-spinner__orbit-dot {
    position: absolute;
    left: 50%;
    width: 0.35rem;
    height: 0.35rem;
    border-radius: 999px;
    background-color: var(--loading-spinner-color);
    transform: translateX(-50%);
  }

  .loading-spinner__orbit-dot--trail {
    bottom: 0;
    opacity: 0.5;
  }

  .loading-spinner__orbit-dot:not(.loading-spinner__orbit-dot--trail) {
    top: 0;
  }

  .loading-spinner__progress-overlay {
    position: absolute;
    inset: 0.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }

  .loading-spinner__progress-value {
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--loading-spinner-text);
  }

  .loading-spinner__label {
    font-weight: 600;
    color: var(--loading-spinner-text);
  }

  .loading-spinner__progress {
    margin-left: 0.35rem;
    font-size: 0.85em;
    color: var(--loading-spinner-text);
    opacity: 0.85;
  }

  .loading-spinner__sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
  }

  .loading-spinner--size-xs {
    --loading-spinner-size: 1rem;
  }

  .loading-spinner--size-sm {
    --loading-spinner-size: 1.25rem;
  }

  .loading-spinner--size-lg {
    --loading-spinner-size: 2rem;
  }

  .loading-spinner--size-xl {
    --loading-spinner-size: 3rem;
  }

  .loading-spinner--speed-slow {
    --loading-spinner-speed: 2s;
  }

  .loading-spinner--speed-fast {
    --loading-spinner-speed: 0.5s;
  }

  .loading-spinner--variant-default {
    --loading-spinner-color: #475569;
    --loading-spinner-track: #cbd5f5;
    --loading-spinner-text: #0f172a;
  }

  .loading-spinner--variant-primary {
    --loading-spinner-color: #2563eb;
    --loading-spinner-track: rgba(191, 219, 254, 0.8);
    --loading-spinner-text: #1d4ed8;
  }

  .loading-spinner--variant-secondary {
    --loading-spinner-color: #475569;
    --loading-spinner-track: #cbd5f5;
    --loading-spinner-text: #1f2937;
  }

  .loading-spinner--variant-success {
    --loading-spinner-color: #16a34a;
    --loading-spinner-track: rgba(187, 247, 208, 0.7);
    --loading-spinner-text: #166534;
  }

  .loading-spinner--variant-warning {
    --loading-spinner-color: #f59e0b;
    --loading-spinner-track: rgba(254, 243, 199, 0.8);
    --loading-spinner-text: #b45309;
  }

  .loading-spinner--variant-error {
    --loading-spinner-color: #dc2626;
    --loading-spinner-track: rgba(254, 202, 202, 0.8);
    --loading-spinner-text: #991b1b;
  }

  .loading-spinner--variant-neutral {
    --loading-spinner-color: #64748b;
    --loading-spinner-track: rgba(226, 232, 240, 0.9);
    --loading-spinner-text: #1f2937;
  }

  .loading-spinner--overlay {
    position: fixed;
    inset: 0;
    z-index: 60;
    background-color: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(8px);
    justify-content: center;
    align-items: center;
    flex-direction: column;
    min-height: 100vh;
    gap: 1rem;
  }

  .loading-spinner__label {
    font-weight: 600;
    color: var(--loading-spinner-text);
  }

  .loading-spinner--size-xs .loading-spinner__label {
    font-size: 0.75rem;
  }

  .loading-spinner--size-sm .loading-spinner__label {
    font-size: 0.85rem;
  }

  .loading-spinner--size-md .loading-spinner__label {
    font-size: 0.95rem;
  }

  .loading-spinner--size-lg .loading-spinner__label {
    font-size: 1.05rem;
  }

  .loading-spinner--size-xl .loading-spinner__label {
    font-size: 1.2rem;
  }

  @keyframes spinner-rotate {
    to {
      transform: rotate(360deg);
    }
  }

  @keyframes spinner-pulse {
    0%,
    100% {
      transform: scale(0.9);
      opacity: 0.6;
    }
    50% {
      transform: scale(1.05);
      opacity: 1;
    }
  }

  @keyframes spinner-dots {
    0%,
    80%,
    100% {
      transform: scale(0.8);
      opacity: 0.5;
    }
    40% {
      transform: scale(1.2);
      opacity: 1;
    }
  }

  @keyframes spinner-bars {
    0%,
    100% {
      transform: scaleY(0.4);
      opacity: 0.7;
    }
    50% {
      transform: scaleY(1);
      opacity: 1;
    }
  }

  @keyframes spinner-bounce {
    0%,
    100% {
      transform: scale(0.95);
    }
    50% {
      transform: scale(1.05);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .loading-spinner__svg,
    .loading-spinner__pulse,
    .loading-spinner__dot,
    .loading-spinner__bar,
    .loading-spinner__bounce,
    .loading-spinner__orbit {
      animation: none !important;
    }
  }

  :where(.dark) .loading-spinner {
    --loading-spinner-text: #f8fafc;
  }

  :where(.dark) .loading-spinner--variant-default {
    --loading-spinner-track: rgba(30, 41, 59, 0.8);
  }

  :where(.dark) .loading-spinner--variant-primary {
    --loading-spinner-track: rgba(37, 99, 235, 0.35);
  }

  :where(.dark) .loading-spinner--variant-success {
    --loading-spinner-track: rgba(34, 197, 94, 0.35);
  }

  :where(.dark) .loading-spinner--variant-warning {
    --loading-spinner-track: rgba(251, 191, 36, 0.35);
  }

  :where(.dark) .loading-spinner--variant-error {
    --loading-spinner-track: rgba(248, 113, 113, 0.35);
  }

  :where(.dark) .loading-spinner--variant-neutral {
    --loading-spinner-track: rgba(148, 163, 184, 0.5);
  }

  :where(.dark) .loading-spinner--overlay {
    background-color: rgba(2, 6, 23, 0.85);
  }
</style>
