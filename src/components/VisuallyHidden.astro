---
export interface VisuallyHiddenProps {
  as?:
    | 'span'
    | 'div'
    | 'p'
    | 'h1'
    | 'h2'
    | 'h3'
    | 'h4'
    | 'h5'
    | 'h6'
    | 'label'
    | 'legend'
    | 'caption';
  focusable?: boolean;
  skipLink?: boolean;
  debug?: boolean;
  ariaLive?: 'off' | 'polite' | 'assertive';
  ariaLabel?: string;
  role?: string;
  className?: string;
}

const {
  as: Tag = 'span',
  focusable = false,
  skipLink = false,
  debug = false,
  ariaLive,
  ariaLabel,
  role,
  className = '',
} = Astro.props as VisuallyHiddenProps;

const classes = [
  'visually-hidden',
  focusable ? 'visually-hidden--focusable' : '',
  skipLink ? 'visually-hidden--skiplink' : '',
  debug ? 'visually-hidden--debug' : '',
  className,
]
  .filter(Boolean)
  .join(' ');
---

<Tag
  class={classes}
  aria-live={ariaLive}
  aria-label={ariaLabel}
  role={role}
  tabindex={focusable ? 0 : undefined}
  data-visually-hidden={debug ? 'debug' : 'true'}
>
  <slot />

  {debug && <span class="visually-hidden__debug-label">[Visually Hidden - Debug Mode]</span>}
</Tag>

<style>
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
    white-space: nowrap;
  }

  .visually-hidden--focusable:focus,
  .visually-hidden--focusable:focus-visible {
    position: static;
    width: auto;
    height: auto;
    margin: 0;
    overflow: visible;
    clip: auto;
    white-space: normal;
    padding: 0.5rem 0.75rem;
    background: #2563eb;
    color: #ffffff;
    border: 2px solid #1d4ed8;
    border-radius: 0.5rem;
    box-shadow: 0 10px 25px rgba(15, 23, 42, 0.35);
    z-index: 9990;
  }

  :where(.dark) .visually-hidden--focusable:focus,
  :where(.dark) .visually-hidden--focusable:focus-visible {
    background: #60a5fa;
    color: #0f172a;
    border-color: #3b82f6;
  }

  .visually-hidden--skiplink:focus,
  .visually-hidden--skiplink:focus-visible {
    position: fixed;
    top: 1rem;
    left: 1rem;
    font-weight: 600;
    font-size: 0.9rem;
  }

  .visually-hidden--debug {
    position: static !important;
    width: auto !important;
    height: auto !important;
    margin: 0 !important;
    overflow: visible !important;
    clip: auto !important;
    padding: 0.5rem;
    border: 2px dashed rgba(234, 179, 8, 0.8);
    background: rgba(254, 240, 138, 0.6);
    color: #92400e;
    font-family: monospace;
    font-size: 0.8rem;
  }

  :where(.dark) .visually-hidden--debug {
    background: rgba(251, 191, 36, 0.2);
    color: #fde68a;
    border-color: rgba(251, 191, 36, 0.8);
  }

  .visually-hidden__debug-label {
    margin-left: 0.5rem;
    opacity: 0.7;
  }
</style>
