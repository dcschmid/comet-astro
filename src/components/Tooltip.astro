---
export interface TooltipProps {
  content: string;
  variant?: 'default' | 'dark' | 'light' | 'info' | 'success' | 'warning' | 'error';
  size?: 'sm' | 'md' | 'lg';
  position?: 'top' | 'bottom' | 'left' | 'right' | 'top-start' | 'top-end' | 'bottom-start' | 'bottom-end';
  trigger?: 'hover' | 'focus' | 'click' | 'manual';
  delay?: number;
  hideDelay?: number;
  disabled?: boolean;
  allowHTML?: boolean;
  maxWidth?: 'xs' | 'sm' | 'md' | 'lg' | 'xl';
  className?: string;
}

const {
  content,
  variant = 'default',
  size = 'md',
  position = 'top',
  trigger = 'hover',
  delay = 0,
  hideDelay = 0,
  disabled = false,
  allowHTML = false,
  maxWidth = 'xs',
  className = '',
} = Astro.props as TooltipProps;

const tooltipId = `tooltip-${Math.random().toString(36).slice(2, 9)}`;
const rootClasses = [
  'tooltip',
  `tooltip--variant-${variant}`,
  `tooltip--size-${size}`,
  `tooltip--position-${position}`,
  `tooltip--max-${maxWidth}`,
  className,
]
  .filter(Boolean)
  .join(' ');
---

<div
  class={['tooltip__root', !disabled ? 'tooltip__root--active' : '', className].filter(Boolean).join(' ')}
  data-tooltip-root
  data-trigger={trigger}
  data-delay={delay}
  data-hide-delay={hideDelay}
  data-disabled={disabled}
>
  <slot />

  {!disabled && (
    <div
      id={tooltipId}
      class={rootClasses}
      role="tooltip"
      aria-hidden="true"
      data-tooltip
    >
      {allowHTML ? <Fragment set:html={content} /> : content}
      <div class="tooltip__arrow" aria-hidden="true" />
    </div>
  )}
</div>

<script is:inline>
  (function () {
    const roots = Array.from(document.querySelectorAll('[data-tooltip-root]'));
    if (!roots.length) return;

    roots.forEach((root) => {
      if (!(root instanceof HTMLElement)) return;
      const tooltip = root.querySelector('[data-tooltip]');
      if (!(tooltip instanceof HTMLElement)) return;

      const trigger = root.getAttribute('data-trigger') || 'hover';
      const delay = Number.parseInt(root.getAttribute('data-delay') || '0', 10);
      const hideDelay = Number.parseInt(root.getAttribute('data-hide-delay') || '0', 10);
      const disabled = root.getAttribute('data-disabled') === 'true';
      if (disabled) return;

      const selector = [
        'a[href]',
        'button',
        'input',
        'textarea',
        'select',
        '[tabindex]:not([tabindex="-1"])',
        '[role="button"]',
        '[role="link"]',
      ].join(',');
      const focusable = root.querySelector(selector);
      const target =
        focusable instanceof HTMLElement
          ? focusable
          : root.firstElementChild instanceof HTMLElement
            ? root.firstElementChild
            : null;
      if (!target) return;

      let showTimeout;
      let hideTimeout;
      let isVisible = false;

      const showTooltip = () => {
        clearTimeout(hideTimeout);
        if (isVisible) return;
        showTimeout = setTimeout(() => {
          tooltip.classList.add('tooltip--visible');
          tooltip.setAttribute('aria-hidden', 'false');
          isVisible = true;
        }, delay);
      };

      const hideTooltip = () => {
        clearTimeout(showTimeout);
        if (!isVisible) return;
        hideTimeout = setTimeout(() => {
          tooltip.classList.remove('tooltip--visible');
          tooltip.setAttribute('aria-hidden', 'true');
          isVisible = false;
        }, hideDelay);
      };

      if (!target.getAttribute('aria-describedby')) {
        target.setAttribute('aria-describedby', tooltip.id);
      }

      const handleKeyDown = (event) => {
        if (event.key === 'Escape' && isVisible) {
          event.preventDefault();
          hideTooltip();
          target.focus();
        }
      };

      if (trigger === 'hover' || trigger === 'focus') {
        if (trigger === 'hover') {
          target.addEventListener('mouseenter', showTooltip);
          target.addEventListener('mouseleave', hideTooltip);
          tooltip.addEventListener('mouseenter', showTooltip);
          tooltip.addEventListener('mouseleave', hideTooltip);
        }

        if (trigger === 'focus') {
          target.addEventListener('focus', showTooltip);
          target.addEventListener('blur', hideTooltip);
        }

        target.addEventListener('keydown', handleKeyDown);
      } else if (trigger === 'click') {
        target.addEventListener('click', (event) => {
          event.preventDefault();
          if (isVisible) {
            hideTooltip();
          } else {
            showTooltip();
          }
        });

        target.addEventListener('keydown', (event) => {
          if (event.key === 'Enter' || event.key === ' ') {
            event.preventDefault();
            if (isVisible) {
              hideTooltip();
            } else {
              showTooltip();
            }
          } else if (event.key === 'Escape' && isVisible) {
            event.preventDefault();
            hideTooltip();
            target.focus();
          }
        });

        document.addEventListener('click', (event) => {
          if (!root.contains(event.target) && isVisible) {
            hideTooltip();
          }
        });
      }

      const updatePosition = () => {
        if (!isVisible) return;
        const tooltipRect = tooltip.getBoundingClientRect();
        if (tooltipRect.right > window.innerWidth) {
          tooltip.style.transform = 'translateX(-10%)';
        }
        if (tooltipRect.bottom > window.innerHeight) {
          tooltip.style.transform = 'translateY(-10%)';
        }
      };

      window.addEventListener('resize', updatePosition);
      window.addEventListener('scroll', updatePosition);
    });

    if (!document.querySelector('.sr-only-styles')) {
      const style = document.createElement('style');
      style.className = 'sr-only-styles';
      style.textContent = `
        .sr-only {
          position: absolute;
          width: 1px;
          height: 1px;
          padding: 0;
          margin: -1px;
          overflow: hidden;
          clip: rect(0, 0, 0, 0);
          white-space: nowrap;
          border: 0;
        }
      `;
      document.head.appendChild(style);
    }

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      const style = document.createElement('style');
      style.textContent = `
        [data-tooltip] {
          transition: none !important;
        }
      `;
      document.head.appendChild(style);
    }
  })();
</script>

<style>
  .tooltip__root {
    position: relative;
    display: inline-block;
  }

  .tooltip {
    position: absolute;
    z-index: 50;
    padding: 0.5rem 0.75rem;
    border-radius: 0.75rem;
    border: 1px solid rgba(148, 163, 184, 0.6);
    background: #0f172a;
    color: #f8fafc;
    font-size: 0.9rem;
    box-shadow: 0 12px 30px rgba(15, 23, 42, 0.2);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.2s ease, visibility 0.2s ease;
    white-space: nowrap;
  }

  .tooltip--visible {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .tooltip__arrow {
    position: absolute;
    width: 0;
    height: 0;
    border-style: solid;
  }

  .tooltip--position-top {
    bottom: 100%;
    left: 50%;
    transform: translateX(-50%);
    margin-bottom: 0.5rem;
  }

  .tooltip--position-bottom {
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    margin-top: 0.5rem;
  }

  .tooltip--position-left {
    right: 100%;
    top: 50%;
    transform: translateY(-50%);
    margin-right: 0.5rem;
  }

  .tooltip--position-right {
    left: 100%;
    top: 50%;
    transform: translateY(-50%);
    margin-left: 0.5rem;
  }

  .tooltip--position-top .tooltip__arrow,
  .tooltip--position-top-start .tooltip__arrow,
  .tooltip--position-top-end .tooltip__arrow {
    top: 100%;
    border-width: 6px 6px 0;
    border-color: currentColor transparent transparent transparent;
    left: 50%;
    transform: translateX(-50%);
  }

  .tooltip--position-bottom .tooltip__arrow,
  .tooltip--position-bottom-start .tooltip__arrow,
  .tooltip--position-bottom-end .tooltip__arrow {
    bottom: 100%;
    border-width: 0 6px 6px;
    border-color: transparent transparent currentColor transparent;
    left: 50%;
    transform: translateX(-50%);
  }

  .tooltip--position-left .tooltip__arrow {
    left: 100%;
    border-width: 6px 0 6px 6px;
    border-color: transparent transparent transparent currentColor;
    top: 50%;
    transform: translateY(-50%);
  }

  .tooltip--position-right .tooltip__arrow {
    right: 100%;
    border-width: 6px 6px 6px 0;
    border-color: transparent currentColor transparent transparent;
    top: 50%;
    transform: translateY(-50%);
  }

  .tooltip--size-sm {
    font-size: 0.75rem;
    padding: 0.35rem 0.6rem;
  }

  .tooltip--size-lg {
    font-size: 1rem;
    padding: 0.6rem 1rem;
  }

  .tooltip--max-xs {
    max-width: 16rem;
  }

  .tooltip--max-sm {
    max-width: 20rem;
  }

  .tooltip--max-md {
    max-width: 24rem;
  }

  .tooltip--max-lg {
    max-width: 28rem;
  }

  .tooltip--max-xl {
    max-width: 32rem;
  }

  .tooltip--variant-dark {
    background: #0f172a;
    color: #f8fafc;
  }

  .tooltip--variant-light {
    background: #f8fafc;
    color: #0f172a;
    border-color: rgba(148, 163, 184, 0.6);
  }

  .tooltip--variant-info {
    background: #1d4ed8;
  }

  .tooltip--variant-success {
    background: #15803d;
  }

  .tooltip--variant-warning {
    background: #d97706;
  }

  .tooltip--variant-error {
    background: #dc2626;
  }

  @media (prefers-contrast: high) {
    .tooltip {
      border-width: 2px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tooltip {
      transition: none;
    }
  }
</style>
