---
export interface Event {
  date: string;
  title: string;
  description?: string;
  icon?: string;
  variant?: 'default' | 'success' | 'warning' | 'error' | 'info';
  href?: string;
  target?: '_blank' | '_self';
}

interface Props {
  events: Event[];
  variant?: 'default' | 'minimal' | 'bordered' | 'filled';
  size?: 'sm' | 'md' | 'lg';
  orientation?: 'vertical' | 'horizontal';
  showConnector?: boolean;
  dense?: boolean;
  className?: string;
  ariaLabel?: string;
}

const {
  events,
  variant = 'default',
  size = 'md',
  orientation = 'vertical',
  showConnector = true,
  dense = false,
  className = '',
  ariaLabel = 'Timeline of events',
} = Astro.props as Props;

if (!events?.length) {
  throw new Error('Timeline: events array is required and must not be empty');
}

const timelineId = `timeline-${Math.random().toString(36).slice(2, 9)}`;
const rootClasses = [
  'timeline',
  `timeline--variant-${variant}`,
  `timeline--size-${size}`,
  `timeline--orientation-${orientation}`,
  dense ? 'timeline--dense' : '',
  showConnector ? 'timeline--with-connector' : 'timeline--without-connector',
  className,
]
  .filter(Boolean)
  .join(' ');
---

<div
  id={timelineId}
  class={rootClasses}
  role="region"
  aria-label={ariaLabel}
  aria-orientation={orientation}
>
  {showConnector && <div class="timeline__connector" aria-hidden="true" />}

  <ol class="timeline__events">
    {events.map((event, index) => {
      const Wrapper = event.href ? 'a' : 'div';
      const wrapperProps = event.href
        ? {
            href: event.href,
            target: event.target || '_self',
            rel: event.target === '_blank' ? 'noopener noreferrer' : undefined,
          }
        : {};

      return (
        <li class="timeline__event" role="listitem">
          <div class={['timeline__marker', `timeline__marker--${event.variant || 'default'}`].join(' ')}>
            {event.icon ? (
              <span class="timeline__marker-icon" aria-hidden="true" role="img">
                {event.icon}
              </span>
            ) : (
              <span class="timeline__marker-dot" aria-hidden="true" />
            )}
          </div>

          <Wrapper
            {...wrapperProps}
            class={[
              'timeline__card',
              event.href ? 'timeline__card--link' : '',
            ]
              .filter(Boolean)
              .join(' ')}
            role={event.href ? 'link' : 'article'}
            aria-describedby={`${timelineId}-event-${index}`}
          >
            <time class="timeline__date" datetime={event.date}>
              {new Date(event.date).toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
              })}
            </time>

            <h3 class="timeline__title">
              {event.title}
              {event.href && <span class="sr-only"> (link)</span>}
            </h3>

            {event.description && (
              <p id={`${timelineId}-event-${index}`} class="timeline__description">
                {event.description}
              </p>
            )}

            {event.href && event.target === '_blank' && (
              <span class="timeline__external">
                <span>Open in new tab</span>
                <svg class="timeline__external-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                  />
                </svg>
              </span>
            )}
          </Wrapper>

          <span class="sr-only">
            Event {index + 1} of {events.length}
            {index + 1 === events.length ? ' (final event)' : ''}
          </span>
        </li>
      );
    })}
  </ol>
</div>

<style>
  .timeline {
    position: relative;
    color: #0f172a;
  }

  :where(.dark) .timeline {
    color: #f8fafc;
  }

  .timeline__events {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .timeline--dense .timeline__events {
    gap: 1.25rem;
  }

  .timeline--orientation-horizontal .timeline__events {
    flex-direction: row;
    overflow-x: auto;
    gap: 2rem;
  }

  .timeline__connector {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .timeline--orientation-vertical .timeline__connector {
    left: 1.5rem;
    width: 2px;
    background: rgba(148, 163, 184, 0.6);
  }

  .timeline--orientation-horizontal .timeline__connector {
    top: 1.5rem;
    height: 2px;
    background: rgba(148, 163, 184, 0.6);
  }

  :where(.dark) .timeline__connector {
    background: rgba(71, 85, 105, 0.7);
  }

  .timeline__event {
    position: relative;
    padding-left: 3rem;
  }

  .timeline--orientation-horizontal .timeline__event {
    padding-left: 0;
    padding-top: 3rem;
    min-width: 14rem;
  }

  .timeline__marker {
    position: absolute;
    left: 0;
    top: 0.2rem;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 999px;
    border: 3px solid #fff;
    background: #2563eb;
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8px 15px rgba(37, 99, 235, 0.25);
    z-index: 1;
  }

  :where(.dark) .timeline__marker {
    border-color: #0f172a;
  }

  .timeline--orientation-horizontal .timeline__marker {
    top: 0;
    left: 0;
  }

  .timeline__marker-icon {
    font-size: 0.9rem;
  }

  .timeline__marker-dot {
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 999px;
    background: currentColor;
  }

  .timeline__card {
    display: block;
    border-radius: 1rem;
    padding: 1rem;
    background: #fff;
    border: 1px solid rgba(148, 163, 184, 0.5);
    box-shadow: 0 12px 30px rgba(15, 23, 42, 0.08);
    transition: box-shadow 0.2s ease, background 0.2s ease, border-color 0.2s ease;
  }

  :where(.dark) .timeline__card {
    background: #0f172a;
    border-color: rgba(71, 85, 105, 0.7);
  }

  .timeline__card--link {
    cursor: pointer;
  }

  .timeline__card--link:hover {
    box-shadow: 0 15px 35px rgba(37, 99, 235, 0.25);
  }

  .timeline__card--link:focus-visible {
    outline: 2px solid rgba(59, 130, 246, 0.4);
    outline-offset: 4px;
  }

  .timeline__date {
    display: block;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(100, 116, 139, 0.9);
    font-weight: 600;
  }

  .timeline__title {
    margin: 0.35rem 0 0;
    font-size: 1.05rem;
    font-weight: 700;
  }

  .timeline__description {
    margin: 0.75rem 0 0;
    line-height: 1.5;
    color: rgba(71, 85, 105, 0.95);
  }

  :where(.dark) .timeline__description,
  :where(.dark) .timeline__date {
    color: rgba(203, 213, 225, 0.9);
  }

  .timeline__external {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    margin-top: 0.75rem;
    font-size: 0.85rem;
    color: #2563eb;
  }

  :where(.dark) .timeline__external {
    color: #93c5fd;
  }

  .timeline__external-icon {
    width: 0.85rem;
    height: 0.85rem;
  }

  .timeline--size-sm .timeline__marker {
    width: 1.75rem;
    height: 1.75rem;
    border-width: 2px;
  }

  .timeline--size-sm .timeline__card {
    padding: 0.85rem;
  }

  .timeline--size-sm .timeline__event {
    padding-left: 2.5rem;
  }

  .timeline--size-lg .timeline__marker {
    width: 2.75rem;
    height: 2.75rem;
    border-width: 4px;
  }

  .timeline--size-lg .timeline__card {
    padding: 1.25rem;
  }

  .timeline--size-lg .timeline__event {
    padding-left: 3.5rem;
  }

  .timeline--variant-minimal .timeline__card {
    background: transparent;
    border-color: rgba(148, 163, 184, 0.3);
    box-shadow: none;
  }

  .timeline--variant-bordered .timeline__card {
    border-width: 2px;
  }

  .timeline--variant-filled .timeline__card {
    background: rgba(241, 245, 249, 0.6);
  }

  :where(.dark) .timeline--variant-filled .timeline__card {
    background: rgba(15, 23, 42, 0.75);
  }
</style>
