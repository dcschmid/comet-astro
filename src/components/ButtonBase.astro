---
import Icon from './Icon.astro';

/**
 * ButtonBase - Shared styling and logic for Button and ButtonLink components
 * Provides consistent appearance, accessibility, and behavior across button variants
 */

export interface ButtonBaseProps {
  /** Visual style variant */
  variant?:
    | 'primary'
    | 'secondary'
    | 'ghost'
    | 'success'
    | 'destructive'
    | 'warning'
    | 'cyan'
    | 'teal'
    | 'purple'
    | 'indigo'
    | 'info'
    | 'classic'
    | 'nature'
    | 'warm'
    | 'sky'
    | 'orange';
  /** Size variant */
  size?: 'sm' | 'md' | 'lg';
  /** Loading state (shows spinner, disables content) */
  loading?: boolean;
  /** Accessible label announced while loading */
  loadingLabel?: string;
  /** Additional CSS classes */
  class?: string;
  /** ARIA label for accessibility */
  ariaLabel?: string;
  /** Whether the component is disabled */
  disabled?: boolean;
  /** Optional icon name (renders using Icon component before the content) */
  icon?: string;
  /** Optional id attribute for DOM selection or JS hooks */
  id?: string;
}

interface Props extends ButtonBaseProps {
  /** Element type to render - 'button' or 'a' */
  as: 'button' | 'a';
  /** Button type (only for button elements) */
  type?: 'button' | 'submit' | 'reset';
  /** Link href (only for anchor elements) */
  href?: string;
  /** Link target */
  target?: '_blank' | '_self' | '_parent' | '_top';
  /** Link rel attribute */
  rel?: string;
  /** Whether to force external link behavior */
  external?: boolean;
  /** Screen reader text for external links */
  externalLabel?: string;
  /** Additional HTML attributes */
  [key: string]: any;
}

const {
  as,
  variant = 'primary',
  size = 'md',
  class: className = '',
  ariaLabel,
  id,
  disabled = false,
  loading = false,
  loadingLabel = 'Loading',
  icon,
  type = 'button',
  href,
  target,
  rel,
  external,
  externalLabel = 'opens in new window',
  ...rest
} = Astro.props;

const variantOptions = [
  'primary',
  'secondary',
  'ghost',
  'success',
  'destructive',
  'warning',
  'cyan',
  'teal',
  'purple',
  'indigo',
  'info',
  'classic',
  'nature',
  'warm',
  'sky',
  'orange',
] as const;
type VariantKey = (typeof variantOptions)[number];
const variantKey = variantOptions.includes(variant as VariantKey)
  ? (variant as VariantKey)
  : 'primary';

const sizeOptions = ['sm', 'md', 'lg'] as const;
type SizeKey = (typeof sizeOptions)[number];
const sizeKey = sizeOptions.includes(size as SizeKey) ? (size as SizeKey) : 'md';

const finalClasses = [
  'button',
  `button--variant-${variantKey}`,
  `button--size-${sizeKey}`,
  loading ? 'button--loading' : '',
  disabled ? 'button--disabled' : '',
  className,
]
  .filter(Boolean)
  .join(' ');

// External link detection and configuration
const isExternalByUrl = href && /^https?:\/\//i.test(href);
const isExternal =
  external !== undefined ? external : target === '_blank' || isExternalByUrl;
const finalTarget = isExternal ? '_blank' : target || '_self';
const finalRel = isExternal
  ? `noopener noreferrer${rel ? ` ${rel}` : ''}`
  : rel;

// Remove component-specific props from forwarded attributes
const forwardedAttrs = (() => {
  const excluded = [
    'as',
    'variant',
    'size',
    'class',
    'ariaLabel',
    'disabled',
    'loading',
    'loadingLabel',
    'type',
    'href',
    'target',
    'rel',
    'external',
    'externalLabel',
    'icon',
  ];
  const result: Record<string, any> = {};
  for (const [key, value] of Object.entries(rest)) {
    if (!excluded.includes(key)) {
      result[key] = value;
    }
  }
  return result;
})();
---

{
  as === 'a' ? (
    <a
      href={href}
      class={finalClasses}
      id={id}
      aria-label={ariaLabel}
      aria-busy={loading ? 'true' : undefined}
      target={finalTarget}
      rel={finalRel}
      {...forwardedAttrs}
    >
      {loading && (
        <span class="button__spinner" aria-hidden="true">
          <svg viewBox="0 0 24 24" class="button__spinner-icon">
            <circle
              class="button__spinner-track"
              cx="12"
              cy="12"
              r="10"
              stroke="currentColor"
              stroke-width="4"
              fill="none"
            />
            <path
              class="button__spinner-head"
              fill="currentColor"
              d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"
            />
          </svg>
        </span>
      )}
      {loading && <span class="button__sr-only">{loadingLabel}</span>}
      {icon && !loading && (
        <Icon
          name={icon}
          size={size === 'sm' ? 'sm' : size === 'lg' ? 'lg' : 'md'}
          decorative={!!ariaLabel}
          ariaLabel={ariaLabel ? undefined : icon}
          className="button__icon button__icon--left"
        />
      )}
      <slot name="iconLeft" />
      <slot />
      {isExternal && (
        <>
          <span class="button__sr-only"> ({externalLabel})</span>
          <svg
            aria-hidden="true"
            class="button__external-icon"
            viewBox="0 0 20 20"
            fill="none"
          >
            <path
              d="M5 5h4m0 0h6m-6 0v6m6-6-9.5 9.5"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </>
      )}
      <slot name="iconRight" />
    </a>
  ) : (
    <button
      type={type}
      class={finalClasses}
      id={id}
      disabled={disabled}
      aria-label={ariaLabel}
      aria-busy={loading ? 'true' : undefined}
      {...forwardedAttrs}
    >
      {loading && (
        <span class="button__spinner" aria-hidden="true">
          <svg viewBox="0 0 24 24" class="button__spinner-icon">
            <circle
              class="button__spinner-track"
              cx="12"
              cy="12"
              r="10"
              stroke="currentColor"
              stroke-width="4"
              fill="none"
            />
            <path
              class="button__spinner-head"
              fill="currentColor"
              d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"
            />
          </svg>
        </span>
      )}
      {loading && <span class="button__sr-only">{loadingLabel}</span>}
      {icon && !loading && (
        <Icon
          name={icon}
          size={size === 'sm' ? 'sm' : size === 'lg' ? 'lg' : 'md'}
          decorative={!!ariaLabel}
          ariaLabel={ariaLabel ? undefined : icon}
          className="button__icon button__icon--left"
        />
      )}
      <slot name="iconLeft" />
      <slot />
      <slot name="iconRight" />
    </button>
  )
}

<style is:inline>
  .button {
    --button-bg: #1d4ed8;
    --button-bg-hover: #1e40af;
    --button-bg-active: #1d4ed8;
    --button-border: transparent;
    --button-text: #ffffff;
    --button-shadow: 0 12px 20px rgba(15, 23, 42, 0.15);
    --button-focus-ring: rgba(59, 130, 246, 0.45);
    --button-padding-y: 0.55rem;
    --button-padding-x: 1.25rem;
    --button-font-size: 0.95rem;
    --button-height: 2.5rem;
    --button-radius: 0.85rem;
    --button-gap: 0.5rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--button-radius);
    border: 1px solid var(--button-border);
    background: var(--button-bg);
    color: var(--button-text);
    font-weight: 600;
    font-size: var(--button-font-size);
    padding: var(--button-padding-y) var(--button-padding-x);
    min-height: var(--button-height);
    min-width: 2.5rem;
    gap: var(--button-gap);
    text-decoration: none;
    transition:
      background-color 0.2s ease,
      border-color 0.2s ease,
      color 0.2s ease,
      transform 0.2s ease,
      box-shadow 0.2s ease;
    box-shadow: var(--button-shadow);
    cursor: pointer;
  }

  .button:focus-visible {
    outline: 3px solid var(--button-focus-ring);
    outline-offset: 3px;
  }

  .button:hover:not(.button--disabled):not(.button--loading) {
    background: var(--button-bg-hover);
  }

  .button:active:not(.button--disabled):not(.button--loading) {
    transform: translateY(1px);
    background: var(--button-bg-active);
  }

  .button--disabled,
  .button[disabled] {
    opacity: 0.6;
    cursor: not-allowed;
    pointer-events: none;
  }

  .button--loading {
    cursor: wait;
  }

  .button__spinner {
    display: inline-flex;
    width: 1.25rem;
    height: 1.25rem;
    animation: button-spin 1s linear infinite;
    margin-right: calc(var(--button-gap) / 2);
  }

  .button__spinner-icon {
    width: 100%;
    height: 100%;
  }

  .button__spinner-track {
    opacity: 0.25;
  }

  .button__spinner-head {
    opacity: 0.9;
  }

  .button__icon {
    display: inline-flex;
  }

  .button__icon--left {
    margin-right: calc(var(--button-gap) / 2);
  }

  .button__external-icon,
  .button__icon--right {
    margin-left: calc(var(--button-gap) / 2);
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
  }

  :where(slot[name='iconLeft'])::slotted(*) {
    margin-right: calc(var(--button-gap) / 2);
  }

  :where(slot[name='iconRight'])::slotted(*) {
    margin-left: calc(var(--button-gap) / 2);
  }

  .button__sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Size modifiers */
  .button--size-sm {
    --button-padding-y: 0.35rem;
    --button-padding-x: 0.9rem;
    --button-font-size: 0.85rem;
    --button-height: 2.25rem;
  }

  .button--size-lg {
    --button-padding-y: 0.75rem;
    --button-padding-x: 1.65rem;
    --button-font-size: 1rem;
    --button-height: 3rem;
  }

  /* Variant tokens */
  .button--variant-primary {
    --button-bg: #1d4ed8;
    --button-bg-hover: #1e40af;
    --button-bg-active: #1e3a8a;
    --button-text: #f8fafc;
    --button-focus-ring: rgba(59, 130, 246, 0.45);
    --button-shadow: 0 12px 20px rgba(29, 78, 216, 0.25);
  }

  .button--variant-secondary {
    --button-bg: #0f172a;
    --button-bg-hover: #1e293b;
    --button-bg-active: #0f172a;
    --button-text: #f8fafc;
    --button-border: rgba(148, 163, 184, 0.35);
    --button-shadow: inset 0 0 0 1px rgba(148, 163, 184, 0.15);
    --button-focus-ring: rgba(100, 116, 139, 0.45);
  }

  :where(.dark) .button--variant-primary {
    --button-bg: #60a5fa;
    --button-bg-hover: #3b82f6;
    --button-bg-active: #2563eb;
    --button-text: #0f172a;
    --button-shadow: 0 12px 20px rgba(37, 99, 235, 0.35);
  }

  :where(.dark) .button--variant-secondary {
    --button-bg: #1e293b;
    --button-bg-hover: #334155;
    --button-text: #f8fafc;
    --button-border: rgba(148, 163, 184, 0.35);
  }

  :where(.dark) .button--variant-ghost {
    --button-text: #f8fafc;
    --button-bg-hover: rgba(148, 163, 184, 0.15);
    --button-bg-active: rgba(148, 163, 184, 0.25);
  }

  :where(.dark) .button--variant-success {
    --button-bg: #4ade80;
    --button-bg-hover: #22c55e;
    --button-bg-active: #16a34a;
    --button-text: #022c22;
  }

  :where(.dark) .button--variant-destructive {
    --button-bg: #f87171;
    --button-bg-hover: #ef4444;
    --button-bg-active: #dc2626;
    --button-text: #450a0a;
  }

  :where(.dark) .button--variant-warning {
    --button-bg: #fde047;
    --button-bg-hover: #facc15;
    --button-bg-active: #fbbf24;
    --button-text: #1c1917;
  }

  :where(.dark) .button--variant-cyan {
    --button-bg: #22d3ee;
    --button-bg-hover: #06b6d4;
    --button-bg-active: #0891b2;
    --button-text: #022c22;
  }

  :where(.dark) .button--variant-teal {
    --button-bg: #5eead4;
    --button-bg-hover: #2dd4bf;
    --button-bg-active: #14b8a6;
    --button-text: #042f2e;
  }

  :where(.dark) .button--variant-purple {
    --button-bg: #c4b5fd;
    --button-bg-hover: #a78bfa;
    --button-bg-active: #8b5cf6;
    --button-text: #2e1065;
  }

  :where(.dark) .button--variant-indigo {
    --button-bg: #a5b4fc;
    --button-bg-hover: #818cf8;
    --button-bg-active: #6366f1;
    --button-text: #1e1b4b;
  }

  :where(.dark) .button--variant-info {
    --button-bg: #7dd3fc;
    --button-bg-hover: #38bdf8;
    --button-bg-active: #0ea5e9;
    --button-text: #082f49;
  }

  :where(.dark) .button--variant-classic {
    --button-bg: #0f172a;
    --button-bg-hover: #1e293b;
    --button-text: #f8fafc;
    --button-border: rgba(148, 163, 184, 0.5);
  }

  :where(.dark) .button--variant-nature {
    --button-bg: #0c0a09;
    --button-bg-hover: #1c1917;
    --button-text: #f5f5f4;
    --button-border: rgba(68, 64, 60, 0.6);
  }

  :where(.dark) .button--variant-warm {
    --button-bg: #0f0c29;
    --button-bg-hover: #1f1537;
    --button-text: #f3e8ff;
    --button-border: rgba(196, 181, 253, 0.5);
  }

  :where(.dark) .button--variant-sky {
    --button-bg: #0f172a;
    --button-bg-hover: #0e7490;
    --button-text: #e0f2fe;
    --button-border: rgba(14, 165, 233, 0.4);
  }

  :where(.dark) .button--variant-orange {
    --button-bg: #1c1917;
    --button-bg-hover: #292524;
    --button-text: #fed7aa;
    --button-border: rgba(251, 146, 60, 0.55);
  }

  .button--variant-ghost {
    --button-bg: transparent;
    --button-bg-hover: rgba(148, 163, 184, 0.15);
    --button-bg-active: rgba(148, 163, 184, 0.25);
    --button-text: #0f172a;
    --button-border: transparent;
    --button-shadow: none;
    --button-focus-ring: rgba(100, 116, 139, 0.45);
  }

  .button--variant-success {
    --button-bg: #16a34a;
    --button-bg-hover: #15803d;
    --button-bg-active: #166534;
    --button-text: #f8fafc;
    --button-shadow: 0 12px 20px rgba(22, 163, 74, 0.25);
    --button-focus-ring: rgba(74, 222, 128, 0.45);
  }

  .button--variant-destructive {
    --button-bg: #dc2626;
    --button-bg-hover: #b91c1c;
    --button-bg-active: #991b1b;
    --button-text: #fef2f2;
    --button-shadow: 0 12px 20px rgba(220, 38, 38, 0.25);
    --button-focus-ring: rgba(248, 113, 113, 0.45);
  }

  .button--variant-warning {
    --button-bg: #fbbf24;
    --button-bg-hover: #f59e0b;
    --button-bg-active: #d97706;
    --button-text: #0f172a;
    --button-shadow: 0 12px 20px rgba(251, 191, 36, 0.25);
    --button-focus-ring: rgba(251, 191, 36, 0.55);
  }

  .button--variant-cyan {
    --button-bg: #0891b2;
    --button-bg-hover: #0e7490;
    --button-bg-active: #155e75;
    --button-text: #ecfeff;
    --button-focus-ring: rgba(34, 211, 238, 0.45);
  }

  .button--variant-teal {
    --button-bg: #0f766e;
    --button-bg-hover: #0d9488;
    --button-bg-active: #0f766e;
    --button-text: #f0fdfa;
    --button-focus-ring: rgba(94, 234, 212, 0.45);
  }

  .button--variant-purple {
    --button-bg: #7c3aed;
    --button-bg-hover: #6d28d9;
    --button-bg-active: #5b21b6;
    --button-text: #f5f3ff;
    --button-focus-ring: rgba(167, 139, 250, 0.5);
  }

  .button--variant-indigo {
    --button-bg: #4f46e5;
    --button-bg-hover: #4338ca;
    --button-bg-active: #3730a3;
    --button-text: #eef2ff;
    --button-focus-ring: rgba(129, 140, 248, 0.5);
  }

  .button--variant-info {
    --button-bg: #0284c7;
    --button-bg-hover: #0369a1;
    --button-bg-active: #075985;
    --button-text: #e0f2fe;
    --button-focus-ring: rgba(56, 189, 248, 0.45);
  }

  .button--variant-classic {
    --button-bg: #ffffff;
    --button-bg-hover: #eff6ff;
    --button-bg-active: #dbeafe;
    --button-text: #0f172a;
    --button-border: rgba(148, 163, 184, 0.5);
    --button-focus-ring: rgba(59, 130, 246, 0.4);
  }

  .button--variant-nature {
    --button-bg: #f5f5f4;
    --button-bg-hover: #ecfccb;
    --button-bg-active: #d9f99d;
    --button-text: #1c1917;
    --button-border: rgba(120, 113, 108, 0.4);
    --button-focus-ring: rgba(34, 197, 94, 0.35);
  }

  .button--variant-warm {
    --button-bg: #faf5ff;
    --button-bg-hover: #ede9fe;
    --button-bg-active: #ddd6fe;
    --button-text: #312e81;
    --button-border: rgba(129, 140, 248, 0.45);
    --button-focus-ring: rgba(129, 140, 248, 0.45);
  }

  .button--variant-sky {
    --button-bg: #f0f9ff;
    --button-bg-hover: #e0f2fe;
    --button-bg-active: #bae6fd;
    --button-text: #0e7490;
    --button-border: rgba(14, 165, 233, 0.35);
    --button-focus-ring: rgba(14, 165, 233, 0.45);
  }

  .button--variant-orange {
    --button-bg: #fff7ed;
    --button-bg-hover: #ffedd5;
    --button-bg-active: #fed7aa;
    --button-text: #9a3412;
    --button-border: rgba(251, 146, 60, 0.4);
    --button-focus-ring: rgba(251, 146, 60, 0.45);
  }

  @keyframes button-spin {
    to {
      transform: rotate(360deg);
    }
  }
</style>
