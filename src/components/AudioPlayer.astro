    width: 100%;
    appearance: none;
    height: 0.85rem;
    border-radius: 999px;
    border: 1px solid rgba(15, 23, 42, 0.08);
    background: linear-gradient(
      90deg,
      var(--seek-fill) 0%,
      var(--seek-fill) var(--seek-percent),
      var(--seek-bg) var(--seek-percent),
      var(--seek-bg) 100%
