    );
    --focus-ring-offset: var(
      --focus-ring-offset-color-dark,
      var(--focus-ring-offset-color-light)
    );
    --seek-fill: var(--seek-fill-dark, var(--seek-fill-light));
    --seek-bg: var(--seek-bg-dark, var(--seek-bg-light));
  }

  .rotate-180 {
    transform: rotate(180deg);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
