    );
    --ap-transcript-shell-border: var(
      --ap-transcript-shell-border-dark,
      var(--ap-transcript-shell-border-light)
    );
    --ap-transcript-panel-bg: var(
      --ap-transcript-panel-bg-dark,
      var(--ap-transcript-panel-bg-light)
    );
    --ap-transcript-panel-border: var(
      --ap-transcript-panel-border-dark,
      var(--ap-transcript-panel-border-light)
    );
    --ap-transcript-entry-bg: var(
      --ap-transcript-entry-bg-dark,
