---
interface Props {
  src: string;
  title?: string;
  artist?: string;
  cover?: string;
  autoplay?: boolean;
  loop?: boolean;
  variant?: 'compact' | 'full';
  coverAspect?: 'square' | 'wide';
  palette?:
    | 'classicBlue'
    | 'natureGreen'
    | 'warmPurple'
    | 'skyCyan'
    | 'orangeAccent';
  captionsSrc?: string;
  captionsLabel?: string;
  className?: string;
}

const {
  src,
  title,
  artist,
  cover,
  autoplay = false,
  loop = false,
  variant = 'full',
  coverAspect = 'square',
  palette = 'classicBlue',
  captionsSrc,
  captionsLabel = 'Transcript',
  className = '',
} = Astro.props as Props;

const paletteNames = [
  'classicBlue',
  'natureGreen',
  'warmPurple',
  'skyCyan',
  'orangeAccent',
] as const;
type PaletteName = (typeof paletteNames)[number];
const paletteSet = new Set<PaletteName>(paletteNames);
const paletteKey = (
  paletteSet.has(palette as PaletteName) ? palette : 'classicBlue'
) as PaletteName;
const shouldShowMetadata = variant === 'full' && (title || artist);
const hasWideCover = variant === 'full' && cover && coverAspect === 'wide';
const showMediaSection = variant === 'full' && (cover || shouldShowMetadata);
const hasTranscript = Boolean(captionsSrc);
const transcriptSrcAttr = hasTranscript ? captionsSrc : undefined;
const playerId = `audio-player-${Math.random().toString(36).slice(2, 9)}`;
import Icon from './Icon.astro';

const audioMimeType = (() => {
  if (!src) return undefined;
  const lower = src.split('?')[0].toLowerCase();
  if (lower.endsWith('.mp3')) return 'audio/mpeg';
  if (lower.endsWith('.ogg') || lower.endsWith('.oga')) return 'audio/ogg';
  if (lower.endsWith('.wav')) return 'audio/wav';
  if (lower.endsWith('.m4a') || lower.endsWith('.aac')) return 'audio/mp4';
  return undefined;
})();

const baseClassNames = [
  'audio-player',
  `audio-player--${variant}`,
  showMediaSection ? 'audio-player--has-media' : 'audio-player--no-media',
  hasWideCover ? 'audio-player--wide-cover' : '',
  variant === 'compact' && cover ? 'audio-player--has-thumbnail' : '',
  `audio-player--palette-${paletteKey}`,
  className,
]
  .filter(Boolean)
  .join(' ');

const innerClasses = ['audio-player__inner'];
if (variant === 'full' && showMediaSection) {
  innerClasses.push('audio-player__inner--full');
}

const mediaClasses = ['audio-player__media'];
if (hasWideCover) {
  mediaClasses.push('audio-player__media--wide');
}

const coverClasses = ['audio-player__cover'];
if (hasWideCover) {
  coverClasses.push('audio-player__cover--wide');
}

const coverInnerClasses = ['audio-player__cover-inner'];
if (hasWideCover) {
  coverInnerClasses.push('audio-player__cover-inner--wide');
}

const controlsClasses = [
  'audio-player__controls',
  `audio-player__controls--${variant}`,
];
const controlsBodyClasses = ['audio-player__controls-body'];
const transcriptEntryClasses = 'audio-player__transcript-entry';
---

<div
  id={playerId}
  class={baseClassNames.trim()}
  data-audio-player
  data-variant={variant}
  data-palette={paletteKey}
  data-transcript-src={transcriptSrcAttr}
  data-transcript-label={captionsLabel}
  aria-live="polite"
>
  <div class={innerClasses.join(' ')}>
    {
      showMediaSection && (
        <div class={mediaClasses.join(' ')}>
          {cover && (
            <div class={coverClasses.join(' ')}>
              <div class={coverInnerClasses.join(' ')}>
                <img
                  src={cover}
                  alt={title ? `${title} cover art` : 'Album cover'}
                  class="audio-player__cover-image"
                />
              </div>
            </div>
          )}
          {shouldShowMetadata && (
            <div class="audio-player__metadata">
              {title && <p class="audio-player__title">{title}</p>}
              {artist && <p class="audio-player__artist">{artist}</p>}
            </div>
          )}
        </div>
      )
    }

    <audio
      src={src}
      preload="metadata"
      loop={loop}
      autoplay={autoplay}
      class="audio-player__element sr-only"
      data-audio
      aria-label={title ? `Audio player for ${title}` : 'Audio player'}
    >
      <source src={src} type={audioMimeType || undefined} />
      Your browser does not support the audio element.
    </audio>

    <div class={controlsClasses.join(' ')}>
      {
        variant === 'compact' && cover && (
          <img
            src={cover}
            alt={title ? `${title} cover art` : 'Album cover'}
            class="audio-player__thumbnail"
          />
        )
      }
      <div class={controlsBodyClasses.join(' ')}>
        <div class="audio-player__buttons">
          <button
            type="button"
            class="audio-player__button audio-player__button--primary"
            data-play-pause
            aria-label="Play or pause audio"
            aria-pressed="false"
          >
            <span data-play-icon>
              <Icon name="play" size="xl" decorative />
            </span>
            <span data-pause-icon class="hidden">
              <Icon name="pause" size="xl" decorative />
            </span>
          </button>

          <button
            type="button"
            class="audio-player__button audio-player__button--ghost"
            data-mute
            aria-label="Mute or unmute audio"
            aria-pressed="false"
          >
            <span data-volume-icon class="audio-player__button-icon">
              <Icon name="volume" size="xl" decorative />
            </span>
            <span data-mute-icon class="audio-player__button-icon hidden">
              <Icon name="mute" size="xl" decorative />
            </span>
          </button>
        </div>

        <div class="audio-player__seek">
          <div class="audio-player__seek-row">
            <span
              class="audio-player__time audio-player__time--current"
              data-current-time>0:00</span
            >
            <div class="audio-player__range-track">
              <input
                type="range"
                min="0"
                value="0"
                step="0.1"
                id="seek-label"
                class="audio-player__range"
                data-seek
                role="slider"
                aria-label="Seek position"
                aria-valuemin="0"
                aria-valuemax="100"
                aria-valuenow="0"
              />
            </div>
            <span
              class="audio-player__time audio-player__time--duration"
              data-duration>0:00</span
            >
          </div>
        </div>
      </div>
    </div>

    {
      hasTranscript && (
        <div class="audio-player__transcript">
          <div class="audio-player__transcript-shell" data-transcript-container>
            <button
              type="button"
              class="audio-player__transcript-toggle"
              data-transcript-toggle
              aria-expanded="true"
              aria-controls={`${playerId}-transcript`}
              aria-label={`${captionsLabel} (click to show or hide)`}
            >
              <span data-transcript-toggle-label>{captionsLabel}</span>
              <span
                class="audio-player__transcript-toggle-icon"
                data-transcript-toggle-icon
              >
                <Icon
                  name="chevron-down"
                  size="lg"
                  decorative
                  aria-hidden="true"
                />
              </span>
            </button>
            <div
              id={`${playerId}-transcript`}
              class="audio-player__transcript-panel"
              data-transcript-panel
              role="group"
            >
              <div
                class="audio-player__transcript-status"
                data-transcript-loading
              >
                Loading transcript…
              </div>
              <div
                class="audio-player__transcript-status audio-player__transcript-status--error hidden"
                data-transcript-error
              >
                Unable to load transcript.
              </div>
              <ol
                class="audio-player__transcript-list hidden"
                data-transcript-list
              />
            </div>
          </div>
        </div>
      )
    }
  </div>
</div>

<script is:inline define:vars={{ transcriptEntryClass: transcriptEntryClasses }}
>
  (() => {
    const HYDRATED_ATTR = 'data-audio-player-ready';
    const hydratedPlayers = new WeakSet();
    const transcriptCache = new Map();
    const transcriptClassName = transcriptEntryClass;

    const clamp = (value, min, max) => Math.min(Math.max(value, min), max);

    const formatTime = (seconds) => {
      if (!Number.isFinite(seconds) || seconds < 0) return '0:00';
      const mins = Math.floor(seconds / 60);
      const secs = Math.floor(seconds % 60);
      return `${mins}:${String(secs).padStart(2, '0')}`;
    };

    const escapeHtml = (value) =>
      String(value ?? '').replace(/[&<>"']/g, (char) => {
        const map = {
          '&': '&amp;',
          '<': '&lt;',
          '>': '&gt;',
          '"': '&quot;',
          "'": '&#39;',
        };
        return map[char] || char;
      });

    const parseTime = (value = '') => {
      const parts = value.split(':').map((segment) => segment.trim());
      if (parts.length === 3) {
        const [hours, minutes, seconds] = parts;
        return (
          Number(hours) * 3600 +
          Number(minutes) * 60 +
          parseFloat(seconds.replace(',', '.'))
        );
      }
      if (parts.length === 2) {
        const [minutes, seconds] = parts;
        return Number(minutes) * 60 + parseFloat(seconds.replace(',', '.'));
      }
      return Number(value) || 0;
    };

    const parseVtt = (text) => {
      const sanitized = text.replace(/\r/g, '');
      const chunks = sanitized.split(/\n\n+/);
      const cues = [];
      chunks.forEach((chunk) => {
        const lines = chunk.trim().split('\n').filter(Boolean);
        if (!lines.length) return;
        const header = lines[0];
        let timingIndex = 0;
        if (header.startsWith('WEBVTT')) return;
        if (!header.includes('-->') && lines.length > 1) {
          timingIndex = 1;
        }
        const timingLine = lines[timingIndex];
        if (!timingLine || !timingLine.includes('-->')) return;
        const [rawStart, rawEnd] = timingLine
          .split('-->')
          .map((segment) => segment.trim().split(' ')[0]);
        const textLines = lines.slice(timingIndex + 1);
        const cueText = textLines.join(' ').trim();
        cues.push({
          start: parseTime(rawStart),
          end: parseTime(rawEnd),
          text: cueText,
        });
      });
      return cues;
    };

    const readDataUri = (uri) => {
      const commaIndex = uri.indexOf(',');
      if (commaIndex === -1) {
        throw new Error('Invalid data URI');
      }
      const meta = uri.slice(5, commaIndex);
      const payload = uri.slice(commaIndex + 1);
      const isBase64 = meta.includes(';base64');
      return isBase64 ? atob(payload.trim()) : decodeURIComponent(payload);
    };

    const fetchTranscript = async (src) => {
      if (transcriptCache.has(src)) return transcriptCache.get(src);
      const request = (async () => {
        const text = src.startsWith('data:')
          ? readDataUri(src)
          : await fetch(src).then((res) => {
              if (!res.ok) throw new Error('Transcript request failed');
              return res.text();
            });
        return parseVtt(text);
      })();
      transcriptCache.set(src, request);
      try {
        return await request;
      } catch (error) {
        transcriptCache.delete(src);
        throw error;
      }
    };

    const updateSeekVisual = (input, audio) => {
      if (
        !(input instanceof HTMLInputElement) ||
        !(audio instanceof HTMLAudioElement)
      ) {
        return;
      }
      const duration =
        Number.isFinite(audio.duration) && audio.duration > 0
          ? audio.duration
          : Number(input.max) || 0;
      const value = Number(input.value) || 0;
      const percent =
        duration > 0 ? clamp((value / duration) * 100, 0, 100) : 0;
      input.style.setProperty('--seek-percent', `${percent}%`);
      input.setAttribute('role', 'slider');
      input.setAttribute('aria-label', 'Seek position');
      input.setAttribute('aria-valuemin', '0');
      input.setAttribute('aria-valuemax', `${Math.floor(duration) || 0}`);
      input.setAttribute('aria-valuenow', `${Math.floor(value)}`);
      input.setAttribute('aria-valuetext', formatTime(value));
    };

    const hydrateTranscript = (player, audio) => {
      const transcriptSrc = player.getAttribute('data-transcript-src');
      if (!transcriptSrc) return;

      const transcriptToggle = player.querySelector('[data-transcript-toggle]');
      const transcriptPanel = player.querySelector('[data-transcript-panel]');
      const transcriptList = player.querySelector('[data-transcript-list]');
      const transcriptLoading = player.querySelector(
        '[data-transcript-loading]'
      );
      const transcriptError = player.querySelector('[data-transcript-error]');
      const transcriptToggleIcon = player.querySelector(
        '[data-transcript-toggle-icon]'
      );

      if (
        !(transcriptToggle instanceof HTMLElement) ||
        !(transcriptPanel instanceof HTMLElement) ||
        !(transcriptList instanceof HTMLOListElement)
      ) {
        return;
      }

      const state = {
        cues: [],
        activeIndex: -1,
        expanded: true,
        loading: false,
        loaded: false,
      };

      const setExpanded = (expanded) => {
        state.expanded = expanded;
        transcriptPanel.classList.toggle('hidden', !expanded);
        transcriptToggle.setAttribute(
          'aria-expanded',
          expanded ? 'true' : 'false'
        );
        transcriptToggleIcon?.classList.toggle('rotate-180', expanded);
      };

      const clearHighlights = () => {
        transcriptList
          .querySelectorAll('[data-transcript-entry]')
          .forEach((entry) => entry.setAttribute('data-active', 'false'));
      };

      const highlightCue = (time) => {
        if (!state.loaded || !state.cues.length) return;
        let nextIndex = state.cues.findIndex(
          (cue) => time >= cue.start && time < cue.end
        );
        if (nextIndex === -1 && time >= state.cues[state.cues.length - 1].end) {
          nextIndex = state.cues.length - 1;
        }
        if (nextIndex === state.activeIndex) return;
        state.activeIndex = nextIndex;
        clearHighlights();
        if (state.activeIndex >= 0) {
          const entry = transcriptList.querySelector(
            `[data-transcript-entry="${state.activeIndex}"]`
          );
          if (entry instanceof HTMLElement) {
            entry.setAttribute('data-active', 'true');
            entry.scrollIntoView({ block: 'nearest' });
          }
        }
      };

      const renderTranscript = () => {
        if (!state.loaded) return;
        transcriptLoading?.classList.add('hidden');
        transcriptError?.classList.add('hidden');

        if (!state.cues.length) {
          if (transcriptError instanceof HTMLElement) {
            transcriptError.textContent = 'No transcript cues available.';
            transcriptError.classList.remove('hidden');
          }
          return;
        }

        transcriptList.innerHTML = state.cues
          .map(
            (cue, index) => `
              <li>
                <button
                  type="button"
                  class="${transcriptClassName}"
                  data-transcript-entry="${index}"
                  data-cue-start="${cue.start}"
                  data-active="false"
                  aria-label="Jump to transcript at ${formatTime(cue.start)}"
                >
                  ${escapeHtml(cue.text)}
                </button>
              </li>
            `
          )
          .join('');
        transcriptList.classList.remove('hidden');
      };

      const ensureTranscript = async () => {
        if (state.loaded || state.loading) return;
        state.loading = true;
        transcriptLoading?.classList.remove('hidden');
        transcriptError?.classList.add('hidden');
        try {
          state.cues = await fetchTranscript(transcriptSrc);
          state.loaded = true;
          renderTranscript();
          highlightCue(audio.currentTime);
        } catch {
          if (transcriptError instanceof HTMLElement) {
            transcriptError.textContent = 'Unable to load transcript.';
            transcriptError.classList.remove('hidden');
          }
        } finally {
          state.loading = false;
          transcriptLoading?.classList.add('hidden');
        }
      };

      transcriptToggle.addEventListener('click', () => {
        const nextExpanded = !state.expanded;
        setExpanded(nextExpanded);
        if (nextExpanded) {
          ensureTranscript();
        }
      });

      transcriptList.addEventListener('click', (event) => {
        const target =
          event.target instanceof HTMLElement
            ? event.target.closest('[data-transcript-entry]')
            : null;
        if (!(target instanceof HTMLElement)) return;
        const start = Number(target.getAttribute('data-cue-start'));
        if (Number.isFinite(start)) {
          audio.currentTime = Math.max(start, 0);
          audio.play().catch(() => {});
        }
      });

      audio.addEventListener('timeupdate', () => {
        highlightCue(audio.currentTime);
      });

      audio.addEventListener('seeked', () => {
        highlightCue(audio.currentTime);
      });

      setExpanded(true);
      ensureTranscript();
    };

    const hydratePlayer = (player) => {
      if (!(player instanceof HTMLElement)) return;
      if (player.getAttribute(HYDRATED_ATTR) === 'true') return;
      if (hydratedPlayers.has(player)) return;
      const audio = player.querySelector('[data-audio]');
      if (!(audio instanceof HTMLAudioElement)) return;

      hydratedPlayers.add(player);
      player.setAttribute(HYDRATED_ATTR, 'true');

      const playPauseBtn = player.querySelector('[data-play-pause]');
      const playIcon = player.querySelector('[data-play-icon]');
      const pauseIcon = player.querySelector('[data-pause-icon]');
      const muteBtn = player.querySelector('[data-mute]');
      const volumeIcon = player.querySelector('[data-volume-icon]');
      const muteIcon = player.querySelector('[data-mute-icon]');
      const seekInput = player.querySelector('[data-seek]');
      const currentTimeEl = player.querySelector('[data-current-time]');
      const durationEl = player.querySelector('[data-duration]');
      const transcriptToggleLabel = player.querySelector(
        '[data-transcript-toggle-label]'
      );
      const transcriptLabel = player.getAttribute('data-transcript-label');

      if (transcriptToggleLabel instanceof HTMLElement && transcriptLabel) {
        transcriptToggleLabel.textContent = transcriptLabel;
      }

      const setPlayState = (isPlaying) => {
        playIcon?.classList.toggle('hidden', isPlaying);
        pauseIcon?.classList.toggle('hidden', !isPlaying);
        if (playPauseBtn instanceof HTMLElement) {
          playPauseBtn.setAttribute(
            'aria-label',
            isPlaying ? 'Pause audio' : 'Play audio'
          );
          playPauseBtn.setAttribute(
            'aria-pressed',
            isPlaying ? 'true' : 'false'
          );
        }
      };

      const setMuteState = (muted) => {
        volumeIcon?.classList.toggle('hidden', muted);
        muteIcon?.classList.toggle('hidden', !muted);
        if (muteBtn instanceof HTMLElement) {
          muteBtn.setAttribute('aria-pressed', muted ? 'true' : 'false');
          muteBtn.setAttribute(
            'aria-label',
            muted ? 'Unmute audio' : 'Mute audio'
          );
        }
      };

      playPauseBtn?.addEventListener('click', () => {
        if (audio.paused) {
          audio.play().catch(() => {});
        } else {
          audio.pause();
        }
      });

      muteBtn?.addEventListener('click', () => {
        audio.muted = !audio.muted;
        setMuteState(audio.muted);
      });

      const syncDuration = () => {
        const duration = Number.isFinite(audio.duration) ? audio.duration : 0;
        if (durationEl instanceof HTMLElement) {
          durationEl.textContent = formatTime(duration);
        }
        if (seekInput instanceof HTMLInputElement) {
          seekInput.max = duration > 0 ? String(duration) : '0';
          updateSeekVisual(seekInput, audio);
        }
      };

      const syncCurrentTime = () => {
        if (currentTimeEl instanceof HTMLElement) {
          currentTimeEl.textContent = formatTime(audio.currentTime);
        }
        if (
          seekInput instanceof HTMLInputElement &&
          Number.isFinite(audio.duration) &&
          audio.duration > 0
        ) {
          seekInput.value = String(audio.currentTime);
          updateSeekVisual(seekInput, audio);
        }
      };

      audio.addEventListener('loadedmetadata', () => {
        syncDuration();
        syncCurrentTime();
      });

      audio.addEventListener('durationchange', syncDuration);
      audio.addEventListener('timeupdate', syncCurrentTime);
      audio.addEventListener('play', () => setPlayState(true));
      audio.addEventListener('pause', () => setPlayState(false));
      audio.addEventListener('volumechange', () => setMuteState(audio.muted));

      const handleSeek = () => {
        if (!(seekInput instanceof HTMLInputElement)) return;
        const next = Number(seekInput.value);
        if (
          Number.isFinite(next) &&
          Number.isFinite(audio.duration) &&
          audio.duration > 0
        ) {
          audio.currentTime = clamp(next, 0, audio.duration);
        }
        updateSeekVisual(seekInput, audio);
      };

      if (seekInput instanceof HTMLInputElement) {
        seekInput.addEventListener('input', handleSeek);
        seekInput.addEventListener('change', handleSeek);
        updateSeekVisual(seekInput, audio);
      }

      setPlayState(!audio.paused);
      setMuteState(audio.muted);
      syncDuration();
      syncCurrentTime();

      hydrateTranscript(player, audio);
    };

    const hydrateAllPlayers = () => {
      document
        .querySelectorAll('[data-audio-player]')
        .forEach((player) => hydratePlayer(player));
    };

    const observeNewPlayers = () => {
      if (!('MutationObserver' in window)) return;
      const observer = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
          mutation.addedNodes.forEach((node) => {
            if (!(node instanceof HTMLElement)) return;
            if (node.matches('[data-audio-player]')) {
              hydratePlayer(node);
            } else {
              node
                .querySelectorAll?.('[data-audio-player]')
                .forEach((player) => hydratePlayer(player));
            }
          });
        });
      });
      observer.observe(document.documentElement, {
        childList: true,
        subtree: true,
      });
    };

    const init = () => {
      hydrateAllPlayers();
      observeNewPlayers();
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init, { once: true });
    } else {
      init();
    }

    document.addEventListener('astro:page-load', hydrateAllPlayers);
  })();
</script>

<style is:inline>
  .audio-player {
    --ap-bg: var(--ap-bg-light, #ffffff);
    --ap-border: var(--ap-border-light, #e5e7eb);
    --ap-bg-hover: var(--ap-hover-bg-light, var(--ap-bg-light));
    --ap-border-hover: var(--ap-hover-border-light, var(--ap-border-light));
    --ap-text: var(--ap-text-light, #111827);
    --ap-subtext: var(--ap-subtext-light, #4b5563);
    --ap-card-bg: var(--ap-card-bg-light, rgba(15, 23, 42, 0.03));
    --ap-card-border: var(--ap-card-border-light, rgba(15, 23, 42, 0.08));
    --ap-frame: var(--ap-frame-light, rgba(15, 23, 42, 0.15));
    --ap-primary-bg: var(--ap-primary-bg-light, #2563eb);
    --ap-primary-hover-bg: var(--ap-primary-hover-bg-light, #1d4ed8);
    --ap-primary-text: var(--ap-primary-text-light, #ffffff);
    --ap-ghost-border: var(--ap-ghost-border-light, #d1d5db);
    --ap-ghost-text: var(--ap-ghost-text-light, #374151);
    --ap-ghost-hover-border: var(--ap-ghost-hover-border-light, #2563eb);
    --ap-ghost-hover-text: var(--ap-ghost-hover-text-light, #2563eb);
    --ap-transcript-shell-bg: var(
      --ap-transcript-shell-bg-light,
      rgba(248, 250, 252, 0.9)
    );
    --ap-transcript-shell-border: var(
      --ap-transcript-shell-border-light,
      rgba(203, 213, 225, 0.75)
    );
    --ap-transcript-panel-bg: var(
      --ap-transcript-panel-bg-light,
      rgba(255, 255, 255, 0.95)
    );
    --ap-transcript-panel-border: var(
      --ap-transcript-panel-border-light,
      rgba(203, 213, 225, 0.7)
    );
    --ap-transcript-entry-bg: var(
      --ap-transcript-entry-bg-light,
      rgba(248, 250, 252, 0.7)
    );
    --ap-transcript-entry-hover: var(
      --ap-transcript-entry-hover-light,
      rgba(15, 23, 42, 0.05)
    );
    --ap-transcript-entry-text: var(--ap-transcript-entry-text-light, #1f2937);
    --ap-thumbnail-ring: var(--ap-thumbnail-ring-light, rgba(15, 23, 42, 0.1));
    --focus-ring-color: var(--focus-ring-color-light, #2563eb);
    --focus-ring-offset: var(
      --focus-ring-offset-color-light,
      rgba(255, 255, 255, 0.9)
    );
    --seek-fill: var(--seek-fill-light, #2563eb);
    --seek-bg: var(--seek-bg-light, #e2e8f0);
    --seek-percent: 0%;
