---
/**
 * ComponentDocsSections - shared scaffold for component documentation pages.
 * Usage:
 * <ComponentDocsSections
 *   overview={<Fragment>...</Fragment>}
 *   props={<Fragment>...</Fragment>}
 *   accessibility={<Fragment>...</Fragment>}
 *   theming={<Fragment>...</Fragment>}
 *   examples={<Fragment>...</Fragment>}
 * />
 * Any section can be omitted; empty ones are skipped.
 */
interface SectionProps {
  overview?: any;
  props?: any;
  accessibility?: any;
  theming?: any;
  examples?: any;
  interactive?: any;
}
const { overview, props, accessibility, theming, examples, interactive } =
  Astro.props as SectionProps;

const sections: { id: string; title: string; content?: any }[] = [
  { id: 'overview', title: 'Overview', content: overview },
  { id: 'examples', title: 'Examples', content: examples },
  { id: 'interactive', title: 'Interactive', content: interactive },
  { id: 'props', title: 'Props', content: props },
  { id: 'accessibility', title: 'Accessibility', content: accessibility },
  { id: 'theming', title: 'Theming & Contrast', content: theming },
];
---

<div class="component-docs">
  {
    sections
      .filter((s) => !!s.content)
      .map((section) => (
        <section id={section.id} class="component-docs__section">
          <div class="component-docs__header">
            <h2 class="component-docs__title">
              {section.title}
            </h2>
            <a
              href={`#${section.id}`}
              class="component-docs__permalink"
              aria-label={`Permalink ${section.title}`}
            >
              <span aria-hidden class="text-xs font-semibold">
                #
              </span>
            </a>
          </div>

          <div class="component-docs__content prose">
            {section.content}
          </div>
        </section>
      ))
  }
</div>

<style is:inline>
  .component-docs {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .component-docs__section {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .component-docs__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .component-docs__title {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 650;
    color: #0f172a;
  }

  :where(.dark) .component-docs__title {
    color: #f8fafc;
  }

  .component-docs__permalink {
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: rgba(15, 23, 42, 0.6);
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .component-docs__permalink:hover {
    background: rgba(14, 165, 233, 0.15);
    color: #0ea5e9;
  }

  :where(.dark) .component-docs__permalink {
    color: rgba(248, 250, 252, 0.6);
  }

  :where(.dark) .component-docs__permalink:hover {
    background: rgba(14, 165, 233, 0.2);
    color: #38bdf8;
  }

  .component-docs__permalink:focus-visible {
    outline: 2px solid rgba(59, 130, 246, 0.7);
    outline-offset: 2px;
  }

  .component-docs__content {
    max-width: none;
    font-size: 0.95rem;
    line-height: 1.65;
    color: rgba(15, 23, 42, 0.8);
  }

  :where(.dark) .component-docs__content {
    color: rgba(248, 250, 252, 0.75);
  }
</style>
