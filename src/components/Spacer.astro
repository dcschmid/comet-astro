---
/**
 * Spacer - WCAG AAA compliant spacing component
 * Provides semantic spacing between elements with responsive sizing
 */
interface Props {
  /** Size of the spacer */
  size?:
    | 'xs'
    | 'sm'
    | 'md'
    | 'lg'
    | 'xl'
    | '2xl'
    | '3xl'
    | '4xl'
    | '5xl'
    | 'auto';
  /** Direction of the spacing */
  axis?: 'horizontal' | 'vertical' | 'both';
  /** Responsive size variations */
  responsive?: {
    sm?: 'xs' | 'sm' | 'md' | 'lg' | 'xl' | '2xl' | '3xl' | '4xl' | '5xl';
    md?: 'xs' | 'sm' | 'md' | 'lg' | 'xl' | '2xl' | '3xl' | '4xl' | '5xl';
    lg?: 'xs' | 'sm' | 'md' | 'lg' | 'xl' | '2xl' | '3xl' | '4xl' | '5xl';
    xl?: 'xs' | 'sm' | 'md' | 'lg' | 'xl' | '2xl' | '3xl' | '4xl' | '5xl';
  };
  /** Show visual debug indicator */
  debug?: boolean;
  /** Additional CSS classes */
  class?: string;
  /** Semantic role for accessibility */
  role?: 'separator' | 'presentation' | 'none';
}

const {
  size = 'md',
  axis = 'vertical',
  responsive,
  debug = false,
  class: className = '',
  role = 'presentation',
} = Astro.props as Props;

const sizeMap: Record<Props['size'], string> = {
  xs: '0.25rem',
  sm: '0.5rem',
  md: '1rem',
  lg: '1.5rem',
  xl: '2rem',
  '2xl': '3rem',
  '3xl': '4rem',
  '4xl': '5rem',
  '5xl': '6rem',
  auto: 'auto',
};

const baseWidth =
  axis === 'vertical' ? '100%' : axis === 'horizontal' ? sizeMap[size] : sizeMap[size];
const baseHeight =
  axis === 'horizontal' ? '100%' : axis === 'vertical' ? sizeMap[size] : sizeMap[size];

const spacerId = `spacer-${Math.random().toString(36).slice(2, 9)}`;

const styleEntries: Record<string, string> = {
  width: baseWidth || 'auto',
  height: baseHeight || 'auto',
};

const responsiveStyles = responsive
  ? Object.entries(responsive)
      .map(([bp, val]) => {
        const widthValue =
          axis === 'vertical'
            ? '100%'
            : axis === 'horizontal'
              ? sizeMap[val]
              : sizeMap[val];
        const heightValue =
          axis === 'horizontal'
            ? '100%'
            : axis === 'vertical'
              ? sizeMap[val]
              : sizeMap[val];
        const queries: Record<string, number> = {
          sm: 640,
          md: 768,
          lg: 1024,
          xl: 1280,
        };
        const minWidth = queries[bp as keyof typeof queries];
        if (!minWidth) return '';
        return `
          @media (min-width: ${minWidth}px) {
            #${spacerId} {
              width: ${widthValue};
              height: ${heightValue};
            }
          }
        `;
      })
      .join('\n')
  : '';

const styleString = Object.entries(styleEntries)
  .map(([key, value]) => `${key}: ${value}`)
  .join('; ');

const spacerClass = [
  'spacer',
  `spacer--axis-${axis}`,
  `spacer--size-${size}`,
  debug ? 'spacer--debug' : '',
  className,
]
  .filter(Boolean)
  .join(' ');
---

<style is:inline>
  .spacer {
    display: block;
    flex-shrink: 0;
  }

  .spacer--axis-horizontal {
    display: inline-block;
  }

  .spacer--debug {
    position: relative;
    background: repeating-linear-gradient(
      45deg,
      rgba(255, 0, 0, 0.08),
      rgba(255, 0, 0, 0.08) 3px,
      transparent 3px,
      transparent 6px
    );
    border: 1px dashed rgba(255, 0, 0, 0.4);
  }

  .spacer--debug::after {
    content: attr(data-spacer-info);
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 10px;
    font-family: monospace;
    padding: 2px 6px;
    background-color: rgba(255, 0, 0, 0.85);
    color: white;
    border-radius: 4px;
    pointer-events: none;
  }

  @media (prefers-color-scheme: dark) {
    .spacer--debug {
      background: repeating-linear-gradient(
        45deg,
        rgba(255, 255, 0, 0.15),
        rgba(255, 255, 0, 0.15) 3px,
        transparent 3px,
        transparent 6px
      );
      border-color: rgba(255, 255, 0, 0.5);
    }

    .spacer--debug::after {
      background-color: rgba(255, 255, 0, 0.9);
      color: #111;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .spacer {
      transition: none;
    }
  }
</style>

{responsiveStyles && (
  <style is:inline set:html={responsiveStyles}></style>
)}

<div
  id={spacerId}
  class={spacerClass}
  style={styleString}
  role={role}
  aria-hidden={role === 'presentation' ? 'true' : undefined}
  data-spacer-size={size}
  data-spacer-axis={axis}
  data-spacer-info={debug ? `${size} ${axis}` : undefined}
>
  {
    debug && (
      <span class="sr-only">
        Spacer: {size} spacing in {axis} direction
      </span>
    )
  }
</div>
