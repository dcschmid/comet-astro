---
/**
 * MusicButtons - Enhanced music platform buttons with WCAG AAA compliance
 */

interface PlatformLink {
  platform: string;
  href: string;
  label?: string;
}

interface Props {
  // Content
  links: PlatformLink[];

  // Layout
  layout?: 'row' | 'column' | 'wrap' | 'grid';
  size?: 'sm' | 'md' | 'lg';

  // Styling
  variant?: 'default' | 'minimal' | 'filled';

  // Accessibility
  ariaLabel?: string;
  showIcons?: boolean;

  // Classes
  class?: string;
  className?: string;
}

const {
  links = [],
  layout = 'row',
  size = 'md',
  variant = 'default',
  ariaLabel = 'Music platforms',
  showIcons = true,
  class: className,
  className: legacyClassName,
} = Astro.props;

const userClasses = [className, legacyClassName].filter(Boolean).join(' ');
const sizeTokens = {
  sm: { minHeight: '44px', fontSize: '0.875rem', padding: '0.5rem 0.75rem', gap: '0.5rem' },
  md: { minHeight: '48px', fontSize: '1rem', padding: '0.75rem 1rem', gap: '0.75rem' },
  lg: { minHeight: '52px', fontSize: '1.125rem', padding: '1rem 1.5rem', gap: '0.75rem' },
} as const;

const inlineStyles = Object.entries({
  '--music-button-min-height': sizeTokens[size].minHeight,
  '--music-button-font-size': sizeTokens[size].fontSize,
  '--music-button-padding': sizeTokens[size].padding,
  '--music-button-gap': sizeTokens[size].gap,
}).reduce((acc, [k, v]) => `${acc}${k}: ${v}; `, '');

const rootClasses = [
  'music-buttons',
  `music-buttons--layout-${layout}`,
  `music-buttons--size-${size}`,
  `music-buttons--variant-${variant}`,
  userClasses,
]
  .filter(Boolean)
  .join(' ');

const platformColors = {
  spotify: '#10b981',
  apple: '#111827',
  applemusic: '#ec4899',
  youtube: '#ef4444',
  ytmusic: '#ef4444',
  soundcloud: '#f97316',
  bandcamp: '#0891b2',
  deezer: '#8b5cf6',
  tidal: '#111827',
} as const;

// Platform icons (simple text-based for better accessibility)
const platformIcons = {
  spotify: '♫',
  apple: '🍎',
  applemusic: '🍎',
  youtube: '▶',
  ytmusic: '▶',
  soundcloud: '☁',
  bandcamp: '🎵',
  deezer: '♪',
  tidal: '〜',
};

function getPlatformIcon(platform: string): string {
  const key = platform.toLowerCase();
  return platformIcons[key as keyof typeof platformIcons] || '♪';
}

function getDisplayLabel(link: PlatformLink): string {
  if (link.label) return link.label;

  // Friendly display names
  const platformNames = {
    spotify: 'Spotify',
    apple: 'Apple Music',
    applemusic: 'Apple Music',
    youtube: 'YouTube Music',
    ytmusic: 'YouTube Music',
    soundcloud: 'SoundCloud',
    bandcamp: 'Bandcamp',
    deezer: 'Deezer',
    tidal: 'Tidal',
  };

  const key = link.platform.toLowerCase();
  return platformNames[key as keyof typeof platformNames] || link.platform;
}

function getButtonClasses(platform: string) {
  const normalized = platform.toLowerCase() as keyof typeof platformColors;
  const color = platformColors[normalized] || '#1f2937';
  return {
    classes: [
      'music-buttons__button',
      showIcons ? 'music-buttons__button--with-icon' : '',
    ]
      .filter(Boolean)
      .join(' '),
    style: { '--music-platform-color': color },
  };
}
---

<nav
  class={rootClasses}
  style={inlineStyles}
  aria-label={ariaLabel}
  role="navigation"
>
  {
    links.map((link) => {
      const buttonClasses = getButtonClasses(link.platform);
      return (
        <a
          href={link.href}
          target="_blank"
          rel="noopener noreferrer"
          class={buttonClasses.classes}
          style={buttonClasses.style}
          data-platform={link.platform.toLowerCase()}
          aria-label={`Listen on ${getDisplayLabel(link)} (opens in new window)`}
        >
          {showIcons && (
            <span aria-hidden="true" class="music-buttons__icon">
              {getPlatformIcon(link.platform)}
            </span>
          )}
          <span>{getDisplayLabel(link)}</span>
          <span class="sr-only">(opens in new window)</span>
        </a>
      );
    })
  }
</nav>

<style>
  .music-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .music-buttons--layout-column {
    flex-direction: column;
  }

  .music-buttons--layout-row {
    flex-direction: row;
  }

  .music-buttons--layout-wrap {
    flex-wrap: wrap;
  }

  .music-buttons--layout-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }

  .music-buttons__button {
    min-height: var(--music-button-min-height, 48px);
    padding: var(--music-button-padding, 0.75rem 1rem);
    font-size: var(--music-button-font-size, 1rem);
    gap: var(--music-button-gap, 0.75rem);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.85rem;
    border: 2px solid var(--music-platform-color, #1f2937);
    background-color: rgba(15, 23, 42, 0.03);
    color: var(--music-platform-color, #1f2937);
    font-weight: 600;
    text-decoration: none;
    transition: transform 0.2s ease, background-color 0.2s ease,
      color 0.2s ease;
  }

  .music-buttons__button:hover {
    transform: scale(1.02);
    background-color: rgba(15, 23, 42, 0.08);
  }

  .music-buttons__button:active {
    transform: scale(0.98);
  }

  .music-buttons__button:focus-visible {
    outline: 2px solid #3b82f6;
    outline-offset: 2px;
  }

  .music-buttons--variant-minimal .music-buttons__button {
    background-color: transparent;
    border-color: rgba(15, 23, 42, 0.2);
  }

  .music-buttons--variant-filled .music-buttons__button {
    background-color: var(--music-platform-color, #1f2937);
    color: #ffffff;
  }

  .music-buttons__icon {
    font-size: 1.125em;
    line-height: 1;
  }

  :where(.dark) .music-buttons__button {
    background-color: rgba(148, 163, 184, 0.1);
    border-color: rgba(148, 163, 184, 0.5);
    color: #e2e8f0;
  }

  :where(.dark) .music-buttons--variant-filled .music-buttons__button {
    color: #0f172a;
  }
</style>
