---
interface Props {
  direction?: 'row' | 'column' | 'row-reverse' | 'column-reverse';
  wrap?: boolean | 'reverse';
  gap?: 'none' | 'xs' | 'sm' | 'md' | 'lg' | 'xl' | '2xl' | '3xl';
  justify?: 'start' | 'center' | 'end' | 'between' | 'around' | 'evenly';
  align?: 'start' | 'center' | 'end' | 'stretch' | 'baseline';
  inline?: boolean;
  as?:
    | 'div'
    | 'section'
    | 'article'
    | 'aside'
    | 'nav'
    | 'main'
    | 'header'
    | 'footer';
  role?: string;
  ariaLabel?: string;
  ariaLabelledby?: string;
  ariaDescribedby?: string;
  className?: string;
}

const {
  direction = 'row',
  wrap = false,
  gap = 'none',
  justify = 'start',
  align = 'stretch',
  inline = false,
  as = 'div',
  role,
  ariaLabel,
  ariaLabelledby,
  ariaDescribedby,
  className = '',
} = Astro.props;

const rootClasses = [
  'flex-stack',
  inline ? 'flex-stack--inline' : 'flex-stack--block',
  `flex-stack--direction-${direction}`,
  wrap === 'reverse'
    ? 'flex-stack--wrap-reverse'
    : wrap
      ? 'flex-stack--wrap'
      : 'flex-stack--nowrap',
  `flex-stack--gap-${gap}`,
  `flex-stack--justify-${justify}`,
  `flex-stack--align-${align}`,
  className,
]
  .filter(Boolean)
  .join(' ');

// Accessibility attributes
const accessibilityProps: Record<string, any> = {};
if (role) accessibilityProps.role = role;
if (ariaLabel) accessibilityProps['aria-label'] = ariaLabel;
if (ariaLabelledby) accessibilityProps['aria-labelledby'] = ariaLabelledby;
if (ariaDescribedby) accessibilityProps['aria-describedby'] = ariaDescribedby;

const Element = as;

// Build class string with proper spacing
---

<Element class={rootClasses} {...accessibilityProps}>
  <slot />
</Element>

<style is:inline>
  .flex-stack {
    display: flex;
  }
  .flex-stack--inline {
    display: inline-flex;
  }
  .flex-stack--block {
    display: flex;
  }
  .flex-stack--direction-row {
    flex-direction: row;
  }
  .flex-stack--direction-column {
    flex-direction: column;
  }
  .flex-stack--direction-row-reverse {
    flex-direction: row-reverse;
  }
  .flex-stack--direction-column-reverse {
    flex-direction: column-reverse;
  }
  .flex-stack--wrap {
    flex-wrap: wrap;
  }
  .flex-stack--wrap-reverse {
    flex-wrap: wrap-reverse;
  }
  .flex-stack--nowrap {
    flex-wrap: nowrap;
  }
  .flex-stack--gap-none {
    gap: 0;
  }
  .flex-stack--gap-xs {
    gap: 0.25rem;
  }
  .flex-stack--gap-sm {
    gap: 0.5rem;
  }
  .flex-stack--gap-md {
    gap: 1rem;
  }
  .flex-stack--gap-lg {
    gap: 1.5rem;
  }
  .flex-stack--gap-xl {
    gap: 2rem;
  }
  .flex-stack--gap-2xl {
    gap: 3rem;
  }
  .flex-stack--gap-3xl {
    gap: 4rem;
  }
  .flex-stack--justify-start {
    justify-content: flex-start;
  }
  .flex-stack--justify-center {
    justify-content: center;
  }
  .flex-stack--justify-end {
    justify-content: flex-end;
  }
  .flex-stack--justify-between {
    justify-content: space-between;
  }
  .flex-stack--justify-around {
    justify-content: space-around;
  }
  .flex-stack--justify-evenly {
    justify-content: space-evenly;
  }
  .flex-stack--align-start {
    align-items: flex-start;
  }
  .flex-stack--align-center {
    align-items: center;
  }
  .flex-stack--align-end {
    align-items: flex-end;
  }
  .flex-stack--align-stretch {
    align-items: stretch;
  }
  .flex-stack--align-baseline {
    align-items: baseline;
  }
</style>
