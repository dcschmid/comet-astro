---
type TextareaSize = 'sm' | 'md' | 'lg';
type TextareaVariant = 'default' | 'minimal' | 'bordered' | 'filled';
type ResizeOption = 'none' | 'vertical' | 'horizontal' | 'both';

interface Props {
  name: string;
  label?: string;
  placeholder?: string;
  value?: string;
  rows?: number;
  cols?: number;
  required?: boolean;
  disabled?: boolean;
  readonly?: boolean;
  error?: string;
  helperText?: string;
  maxLength?: number;
  minLength?: number;
  className?: string;
  id?: string;
  size?: TextareaSize;
  variant?: TextareaVariant;
  resize?: ResizeOption;
  autoGrow?: boolean;
  showCounter?: boolean;
  ariaLabel?: string;
  ariaDescribedBy?: string;
}

const {
  name,
  label,
  placeholder,
  value = '',
  rows = 4,
  cols,
  required = false,
  disabled = false,
  readonly = false,
  error,
  helperText,
  maxLength,
  minLength,
  className = '',
  id = name,
  size = 'md',
  variant = 'default',
  resize = 'vertical',
  autoGrow = false,
  showCounter = !!maxLength,
  ariaLabel,
  ariaDescribedBy,
} = Astro.props as Props;

const textareaId = id || `textarea-${Math.random().toString(36).slice(2, 9)}`;
const helperId = (error || helperText) ? `${textareaId}-help` : undefined;
const counterId = showCounter ? `${textareaId}-counter` : undefined;
const describedBy =
  [helperId, counterId, ariaDescribedBy].filter(Boolean).join(' ') || undefined;

const currentLength = value.length;
const isOverLimit = maxLength && currentLength > maxLength;
const hasError = Boolean(error);

const rootClasses = [
  'textarea',
  `textarea--size-${size}`,
  `textarea--variant-${variant}`,
  `textarea--resize-${resize}`,
  hasError ? 'textarea--error' : '',
  disabled ? 'textarea--disabled' : '',
  readonly ? 'textarea--readonly' : '',
  autoGrow ? 'textarea--auto' : '',
  className,
]
  .filter(Boolean)
  .join(' ');
---

<div class={rootClasses}>
  {label && (
    <label for={textareaId} class="textarea__label">
      {label}
      {required && (
        <span class="textarea__required" aria-hidden="true" title="Required field">
          *
        </span>
      )}
    </label>
  )}

  <div class="textarea__field">
    <textarea
      id={textareaId}
      name={name}
      placeholder={placeholder}
      rows={rows}
      cols={cols}
      required={required}
      disabled={disabled}
      readonly={readonly}
      maxlength={maxLength}
      minlength={minLength}
      aria-label={ariaLabel || label}
      aria-invalid={hasError ? 'true' : 'false'}
      aria-describedby={describedBy}
      aria-required={required ? 'true' : undefined}
      class="textarea__input"
      style={autoGrow ? `field-sizing: content; max-height: ${Math.max(rows * 1.5, 6)}rem;` : undefined}
    >{value}</textarea>

    {showCounter && maxLength && (
      <div
        class={[
          'textarea__counter-overlay',
          isOverLimit ? 'textarea__counter-overlay--alert' : '',
        ]
          .filter(Boolean)
          .join(' ')}
        aria-hidden="true"
      >
        {currentLength}/{maxLength}
      </div>
    )}
  </div>

  <div class="textarea__meta">
    {(error || helperText) && (
      <div
        id={helperId}
        class={[
          'textarea__helper',
          hasError ? 'textarea__helper--error' : '',
        ]
          .filter(Boolean)
          .join(' ')}
        role={hasError ? 'alert' : 'status'}
        aria-live={hasError ? 'assertive' : 'polite'}
      >
        {hasError && <span class="sr-only">Error: </span>}
        {error || helperText}
      </div>
    )}

    {showCounter && maxLength && (
      <div
        id={counterId}
        class={[
          'textarea__counter',
          isOverLimit ? 'textarea__counter--alert' : '',
        ]
          .filter(Boolean)
          .join(' ')}
        aria-live="polite"
        aria-atomic="true"
      >
        <span class="sr-only">
          {isOverLimit
            ? `Character limit exceeded: ${currentLength} of ${maxLength} characters`
            : `${currentLength} of ${maxLength} characters used`}
        </span>
        <span aria-hidden="true">
          {currentLength}/{maxLength}
        </span>
      </div>
    )}
  </div>

  {isOverLimit && (
    <div class="textarea__limit" role="alert" aria-live="assertive">
      Text exceeds maximum length of {maxLength} characters
    </div>
  )}

  {minLength && currentLength < minLength && currentLength > 0 && (
    <div class="textarea__minimum" role="status" aria-live="polite">
      At least {minLength - currentLength} more character{minLength - currentLength === 1 ? '' : 's'} required
    </div>
  )}
</div>

{autoGrow && (
  <script is:inline define:vars={{ textareaId }}>
    (function () {
      const textarea = document.getElementById(textareaId);
      if (!textarea) return;

      const adjustHeight = () => {
        textarea.style.height = 'auto';
        textarea.style.height = textarea.scrollHeight + 'px';
      };

      textarea.addEventListener('input', adjustHeight);
      textarea.addEventListener('change', adjustHeight);
      textarea.addEventListener('paste', () => {
        setTimeout(adjustHeight, 0);
      });

      if (textarea.value) adjustHeight();

      window.addEventListener('resize', adjustHeight);

      window.addEventListener('beforeunload', () => {
        textarea.removeEventListener('input', adjustHeight);
        textarea.removeEventListener('change', adjustHeight);
        window.removeEventListener('resize', adjustHeight);
      });
    })();
  </script>
)}

<style>
  .textarea {
    --textarea-font-size: 0.95rem;
    --textarea-label-size: 0.85rem;
    --textarea-helper-size: 0.85rem;
    --textarea-counter-size: 0.85rem;
    --textarea-padding: 0.75rem 1rem;
    --textarea-min-height: 6rem;
    --textarea-border: rgba(148, 163, 184, 0.8);
    --textarea-background: #fff;
    --textarea-color: #0f172a;
    --textarea-placeholder: #64748b;
    --textarea-muted: #64748b;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    width: 100%;
  }

  :where(.dark) .textarea {
    --textarea-border: rgba(71, 85, 105, 0.8);
    --textarea-background: #0f172a;
    --textarea-color: #f8fafc;
    --textarea-placeholder: #cbd5f5;
    --textarea-muted: #cbd5f5;
  }

  .textarea--size-sm {
    --textarea-font-size: 0.85rem;
    --textarea-label-size: 0.8rem;
    --textarea-helper-size: 0.75rem;
    --textarea-counter-size: 0.75rem;
    --textarea-padding: 0.5rem 0.75rem;
    --textarea-min-height: 5rem;
  }

  .textarea--size-lg {
    --textarea-font-size: 1rem;
    --textarea-label-size: 0.95rem;
    --textarea-helper-size: 0.95rem;
    --textarea-counter-size: 0.95rem;
    --textarea-padding: 1rem 1.25rem;
    --textarea-min-height: 7.5rem;
  }

  .textarea__label {
    font-size: var(--textarea-label-size);
    font-weight: 600;
    color: var(--textarea-color);
  }

  .textarea__required {
    margin-left: 0.25rem;
    color: #dc2626;
  }

  .textarea__field {
    position: relative;
  }

  .textarea__input {
    width: 100%;
    min-height: var(--textarea-min-height);
    padding: var(--textarea-padding);
    border-radius: 0.85rem;
    border: 1px solid var(--textarea-border);
    background: var(--textarea-background);
    color: var(--textarea-color);
    font-size: var(--textarea-font-size);
    line-height: 1.5;
    resize: vertical;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    outline: none;
  }

  .textarea--resize-none .textarea__input {
    resize: none;
  }

  .textarea--resize-horizontal .textarea__input {
    resize: horizontal;
  }

  .textarea--resize-both .textarea__input {
    resize: both;
  }

  .textarea--variant-default .textarea__input {
    box-shadow: 0 4px 12px rgba(15, 23, 42, 0.08);
  }

  .textarea--variant-minimal .textarea__input {
    border-radius: 0;
    border-width: 0 0 2px 0;
    padding-left: 0;
    padding-right: 0;
  }

  .textarea--variant-bordered .textarea__input {
    border-width: 2px;
  }

  .textarea--variant-filled .textarea__input {
    background: rgba(226, 232, 240, 0.6);
    border-color: transparent;
  }

  .textarea__input:focus-visible {
    border-color: rgb(59, 130, 246);
    box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.25);
  }

  .textarea--error .textarea__input {
    border-color: #dc2626;
  }

  .textarea--error .textarea__input:focus-visible {
    box-shadow: 0 0 0 2px rgba(220, 38, 38, 0.25);
  }

  .textarea--disabled .textarea__input {
    cursor: not-allowed;
    opacity: 0.6;
    background: rgba(226, 232, 240, 0.6);
  }

  .textarea--readonly .textarea__input {
    background: rgba(241, 245, 249, 0.4);
  }

  .textarea__input::placeholder {
    color: var(--textarea-placeholder);
  }

  .textarea__counter-overlay {
    position: absolute;
    bottom: 0.75rem;
    right: 1rem;
    font-size: 0.75rem;
    color: var(--textarea-muted);
    pointer-events: none;
    font-weight: 600;
  }

  .textarea__counter-overlay--alert {
    color: #dc2626;
  }

  .textarea__meta {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .textarea__helper {
    flex: 1;
    font-size: var(--textarea-helper-size);
    color: var(--textarea-placeholder);
  }

  .textarea__helper--error {
    color: #dc2626;
  }

  .textarea__counter {
    font-size: var(--textarea-counter-size);
    color: var(--textarea-placeholder);
    font-weight: 600;
  }

  .textarea__counter--alert {
    color: #dc2626;
  }

  .textarea__limit,
  .textarea__minimum {
    font-size: var(--textarea-helper-size);
    font-weight: 600;
  }

  .textarea__limit {
    color: #dc2626;
  }

  .textarea__minimum {
    color: #d97706;
  }

  @media (prefers-contrast: high) {
    .textarea__input {
      border-color: currentColor;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .textarea * {
      transition: none !important;
    }
  }
</style>
