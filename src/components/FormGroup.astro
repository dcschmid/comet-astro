---
/**
 * FormGroup - WCAG AAA compliant layout wrapper for form controls with enhanced accessibility
 */
interface Props {
  label?: string;
  description?: string;
  error?: string;
  helpText?: string;
  required?: boolean;
  optionalText?: string;
  layout?: 'vertical' | 'horizontal';
  size?: 'sm' | 'md' | 'lg';
  labelFor?: string;
  className?: string;
  labelClassName?: string;
  descriptionId?: string;
  errorId?: string;
  helpTextId?: string;
  hideLabel?: boolean;
  fieldsetMode?: boolean;
  legend?: string;
  ariaDescribedby?: string;
}

const {
  label,
  description,
  error,
  helpText,
  required = false,
  optionalText = 'Optional',
  layout = 'vertical',
  size = 'md',
  labelFor,
  className = '',
  labelClassName = '',
  descriptionId,
  errorId,
  helpTextId,
  hideLabel = false,
  fieldsetMode = false,
  legend,
  ariaDescribedby,
} = Astro.props as Props;

// Generate unique IDs for accessibility
const baseId =
  labelFor || `form-group-${Math.random().toString(36).substr(2, 9)}`;
const generatedDescriptionId = descriptionId || `${baseId}-description`;
const generatedErrorId = errorId || `${baseId}-error`;
const generatedHelpTextId = helpTextId || `${baseId}-help`;

// Build aria-describedby string
const describedByParts = [
  description ? generatedDescriptionId : null,
  helpText ? generatedHelpTextId : null,
  error ? generatedErrorId : null,
  ariaDescribedby || null,
].filter(Boolean);
const combinedDescribedBy =
  describedByParts.length > 0 ? describedByParts.join(' ') : undefined;

// Size-based spacing classes
const rootClasses = [
  'form-group',
  `form-group--size-${size}`,
  `form-group--layout-${layout}`,
  fieldsetMode ? 'form-group--fieldset' : 'form-group--standard',
  error ? 'form-group--has-error' : '',
  className,
]
  .filter(Boolean)
  .join(' ');

const Element = fieldsetMode ? 'fieldset' : 'div';
---

<Element
  class={rootClasses}
  data-form-group
  aria-describedby={combinedDescribedBy}
>
  {/* Legend for fieldset mode */}
  {
    fieldsetMode && legend && (
      <legend class={`form-group__legend ${labelClassName}`}>
        {legend}
        {required && (
          <span class="form-group__required" aria-label="required">
            *
          </span>
        )}
        {!required && optionalText && (
          <span class="form-group__optional">
            {optionalText}
          </span>
        )}
      </legend>
    )
  }

  {/* Label section for regular mode */}
  {
    !fieldsetMode && label && (
      <div class={`form-group__label-block ${layout === 'horizontal' ? 'form-group__label-block--horizontal' : ''}`}>
        <label
          class={`form-group__label ${hideLabel ? 'sr-only' : ''} ${labelClassName}`.trim()}
          for={labelFor}
        >
          {label}
          {required && (
            <span class="form-group__required" aria-label="required">
              *
            </span>
          )}
          {!required && optionalText && (
            <span class="form-group__optional">
              {optionalText}
            </span>
          )}
        </label>

        {description && (
          <p id={generatedDescriptionId} class="form-group__description">
            {description}
          </p>
        )}
      </div>
    )
  }

  {/* Content section */}
  <div class={`form-group__field ${layout === 'horizontal' ? 'form-group__field--horizontal' : ''}`}>
    <div class="form-group__controls">
      <slot />

      {/* Help text */}
      {
        helpText && (
          <p id={generatedHelpTextId} class="form-group__help">
            {helpText}
          </p>
        )
      }

      {/* Error message */}
      {
        error && (
          <div
            id={generatedErrorId}
            class="form-group__error"
            role="alert"
            aria-live="assertive"
          >
            <svg
              class="form-group__error-icon"
              fill="currentColor"
              viewBox="0 0 20 20"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z"
                clip-rule="evenodd"
              />
            </svg>
            <p class="form-group__error-text">
              {error}
            </p>
          </div>
        )
      }
    </div>
  </div>
</Element>

<style is:inline>
  .form-group {
    color: #0f172a;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  :where(.dark) .form-group {
    color: #f8fafc;
  }
  .form-group--layout-horizontal {
    gap: 0.5rem;
  }
  @media (min-width: 48rem) {
    .form-group--layout-horizontal {
      flex-direction: row;
      align-items: flex-start;
      gap: 1.5rem;
    }
  }
  .form-group--fieldset {
    border: none;
    padding: 0;
    margin: 0;
  }
  .form-group__legend {
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }
  .form-group__label-block {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  @media (min-width: 48rem) {
    .form-group--layout-horizontal .form-group__label-block {
      width: 12rem;
      flex-shrink: 0;
    }
  }
  .form-group__label {
    font-size: 0.95rem;
    font-weight: 600;
    color: inherit;
  }
  .form-group__description {
    font-size: 0.9rem;
    color: rgba(71, 85, 105, 1);
    margin: 0;
  }
  :where(.dark) .form-group__description {
    color: rgba(203, 213, 225, 1);
  }
  .form-group__field {
    width: 100%;
  }
  .form-group__field--horizontal {
    flex: 1;
    min-width: 0;
  }
  .form-group__controls {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .form-group__help {
    margin: 0;
    font-size: 0.9rem;
    color: rgba(71, 85, 105, 1);
  }
  :where(.dark) .form-group__help {
    color: rgba(203, 213, 225, 1);
  }
  .form-group__error {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    border-radius: 0.85rem;
    background: rgba(254, 226, 226, 0.9);
    border: 1px solid rgba(248, 113, 113, 0.6);
    padding: 0.75rem;
  }
  :where(.dark) .form-group__error {
    background: rgba(127, 29, 29, 0.35);
    border-color: rgba(248, 113, 113, 0.4);
  }
  .form-group__error-icon {
    width: 1rem;
    height: 1rem;
    color: rgba(185, 28, 28, 1);
    flex-shrink: 0;
  }
  .form-group__error-text {
    margin: 0;
    font-size: 0.9rem;
    font-weight: 600;
    color: rgba(185, 28, 28, 1);
  }
  :where(.dark) .form-group__error-text {
    color: rgba(254, 202, 202, 1);
  }
  .form-group__required {
    color: #b91c1c;
    margin-left: 0.25rem;
  }
  :where(.dark) .form-group__required {
    color: #fca5a5;
  }
  .form-group__optional {
    margin-left: 0.5rem;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(148, 163, 184, 1);
  }
  .form-group--size-sm .form-group__controls {
    gap: 0.35rem;
  }
  .form-group--size-lg .form-group__controls {
    gap: 0.75rem;
  }
  @media (prefers-reduced-motion: reduce) {
    .form-group * {
      transition: none !important;
    }
  }
</style>
