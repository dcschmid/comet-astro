---
/**
 * Banner - top-of-page announcement bar
 */
type Variant = 'default' | 'success' | 'warning' | 'danger';

interface Action {
  label: string;
  href: string;
}

interface Props {
  title?: string;
  description?: string;
  variant?: Variant;
  dismissible?: boolean;
  action?: Action;
  icon?: string;
  sticky?: boolean;
  className?: string;
}

const {
  title,
  description,
  variant = 'default',
  dismissible = false,
  action,
  icon,
  sticky = false,
  className = '',
} = Astro.props as Props;

const variants: Variant[] = ['default', 'success', 'warning', 'danger'];
const variantKey = variants.includes(variant) ? variant : 'default';

const id = `banner-${Math.random().toString(36).slice(2, 10)}`;
const rootClasses = [
  'banner',
  `banner--${variantKey}`,
  sticky ? 'banner--sticky' : '',
  className,
]
  .filter(Boolean)
  .join(' ');
---

<section
  id={id}
  class={rootClasses}
  data-banner
  role="status"
>
  <div class="banner__inner">
    <span class="banner__icon" aria-hidden="true">
      {
        icon ||
          (variantKey === 'success'
            ? '✅'
            : variantKey === 'warning'
              ? '⚠️'
              : variantKey === 'danger'
                ? '⛔'
                : '🔔')
      }
    </span>
    <div class="banner__body">
      {
        title && (
          <h2 class="banner__title">
            {title}
          </h2>
        )
      }
      {
        description && (
          <p class="banner__description">{description}</p>
        )
      }
      <slot />
    </div>
    {
      action && (
        <a
          href={action.href}
          class="banner__action"
        >
          {action.label}
          <span aria-hidden="true">→</span>
        </a>
      )
    }
    {
      dismissible && (
        <button
          type="button"
          class="banner__dismiss"
          data-banner-close
          aria-label="Close banner"
        >
          ×
        </button>
      )
    }
  </div>
</section>

<script is:inline>
  (() => {
    const script = document.currentScript;
    if (!(script instanceof HTMLScriptElement)) return;
    const root = script.previousElementSibling;
    if (!(root instanceof HTMLElement)) return;
    const closeButton = root.querySelector('[data-banner-close]');
    if (!(closeButton instanceof HTMLElement)) return;
    const prefersReducedMotion = window.matchMedia?.(
      '(prefers-reduced-motion: reduce)'
    );
    closeButton.addEventListener('click', () => {
      if (prefersReducedMotion?.matches) {
        root.remove();
        return;
      }
      root.style.animation = 'fadeOut 220ms ease forwards';
      window.setTimeout(() => root.remove(), 240);
    });
  })();
</script>

<style is:inline>
  .banner {
    --banner-bg: #0f172a;
    --banner-border: rgba(148, 163, 184, 0.35);
    --banner-text: #f8fafc;
    --banner-icon: #cbd5f5;
    --banner-action-bg: #f8fafc;
    --banner-action-text: #0f172a;
    --banner-action-border: transparent;
    --banner-dismiss-border: rgba(148, 163, 184, 0.5);
    --banner-dismiss-text: #f8fafc;
    --banner-dismiss-hover: rgba(248, 250, 252, 0.15);
    position: relative;
    width: 100%;
    border-bottom: 1px solid var(--banner-border);
    background: var(--banner-bg);
    color: var(--banner-text);
    box-shadow: 0 20px 50px rgba(2, 6, 23, 0.35);
    backdrop-filter: blur(12px);
    isolation: isolate;
  }

  .banner--sticky {
    position: sticky;
    top: 0;
    z-index: 40;
  }

  .banner__inner {
    margin: 0 auto;
    padding: 1rem 1.5rem;
    max-width: 72rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .banner__icon {
    font-size: 2rem;
    color: var(--banner-icon);
  }

  .banner__body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
  }

  .banner__title {
    font-size: 1rem;
    font-weight: 600;
    margin: 0;
    color: var(--banner-text);
  }

  .banner__description {
    margin: 0;
    font-size: 0.925rem;
    color: var(--banner-text);
    opacity: 0.9;
  }

  .banner__action {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border-radius: 999px;
    padding: 0.5rem 1.2rem;
    background: var(--banner-action-bg);
    color: var(--banner-action-text);
    border: 1px solid var(--banner-action-border);
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition:
      background-color 0.2s ease,
      border-color 0.2s ease,
      transform 0.2s ease;
  }

  .banner__action:focus-visible,
  .banner__dismiss:focus-visible {
    outline: 3px solid rgba(255, 255, 255, 0.7);
    outline-offset: 2px;
  }

  .banner__action:hover {
    transform: translateY(-1px);
  }

  .banner__dismiss {
    margin-left: 0.5rem;
    border-radius: 999px;
    border: 1px solid var(--banner-dismiss-border);
    background: transparent;
    color: var(--banner-dismiss-text);
    width: 2.5rem;
    height: 2.5rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    transition: background-color 0.2s ease;
  }

  .banner__dismiss:hover {
    background: var(--banner-dismiss-hover);
  }

  @media (max-width: 768px) {
    .banner__inner {
      flex-direction: column;
      align-items: flex-start;
      text-align: left;
    }

    .banner__action {
      width: 100%;
      justify-content: center;
    }

    .banner__dismiss {
      align-self: flex-end;
      margin-left: 0;
    }
  }

  .banner--default {
    --banner-bg: #0f172a;
    --banner-border: rgba(148, 163, 184, 0.35);
    --banner-text: #f8fafc;
    --banner-icon: #cbd5f5;
    --banner-action-bg: #f8fafc;
    --banner-action-text: #0f172a;
    --banner-dismiss-border: rgba(148, 163, 184, 0.5);
    --banner-dismiss-text: #f8fafc;
    --banner-dismiss-hover: rgba(148, 163, 184, 0.2);
  }

  .banner--success {
    --banner-bg: #022c22;
    --banner-border: rgba(16, 185, 129, 0.4);
    --banner-text: #d1fae5;
    --banner-icon: #6ee7b7;
    --banner-action-bg: #d1fae5;
    --banner-action-text: #064e3b;
    --banner-dismiss-border: rgba(16, 185, 129, 0.45);
    --banner-dismiss-text: #d1fae5;
    --banner-dismiss-hover: rgba(20, 83, 45, 0.55);
  }

  .banner--warning {
    --banner-bg: #451a03;
    --banner-border: rgba(251, 191, 36, 0.45);
    --banner-text: #fde68a;
    --banner-icon: #fcd34d;
    --banner-action-bg: #fef3c7;
    --banner-action-text: #78350f;
    --banner-dismiss-border: rgba(251, 191, 36, 0.45);
    --banner-dismiss-text: #fde68a;
    --banner-dismiss-hover: rgba(120, 53, 15, 0.45);
  }

  .banner--danger {
    --banner-bg: #450a0a;
    --banner-border: rgba(248, 113, 113, 0.4);
    --banner-text: #fee2e2;
    --banner-icon: #fca5a5;
    --banner-action-bg: #fee2e2;
    --banner-action-text: #7f1d1d;
    --banner-dismiss-border: rgba(248, 113, 113, 0.45);
    --banner-dismiss-text: #fee2e2;
    --banner-dismiss-hover: rgba(127, 29, 29, 0.45);
  }

  @keyframes fadeOut {
    to {
      opacity: 0;
      transform: translateY(-8px);
    }
  }
</style>
