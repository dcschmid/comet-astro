---
interface Props {
  category?: string;
  title?: string;
  description?: string;
  href?: string;
  image?: string;
  alt?: string;
  height?: number | string;
  rounded?: boolean;
  className?: string;
  ariaLabel?: string;
  overlayStrength?: 'soft' | 'medium' | 'strong';
  size?: 'sm' | 'md' | 'lg';
  headingLevel?: 2 | 3 | 4 | 5 | 6;
  interactive?: boolean;
}

const {
  category,
  title,
  description,
  href,
  image,
  alt,
  height,
  rounded = true,
  className = '',
  ariaLabel,
  overlayStrength = 'medium',
  size = 'md',
  headingLevel = 3,
  interactive = true,
} = Astro.props as Props;

const displayTitle = title ?? category ?? 'Category';
const displayCategory = category ?? '';
const resolvedAlt = alt ?? `${displayTitle} preview`;

const key = displayTitle.trim().toLowerCase();
const gradientTone = key.includes('rock')
  ? 'purple'
  : key.includes('pop')
    ? 'blue'
    : key.includes('jazz')
      ? 'amber'
      : key.includes('hip') || key.includes('rap')
        ? 'emerald'
        : key.includes('classical')
          ? 'indigo'
          : 'slate';

const sizeHeights: Record<string, string> = {
  sm: '10rem',
  md: '14rem',
  lg: '18rem',
};
const resolvedHeight = height || sizeHeights[size] || sizeHeights.md;

const overlayKey =
  overlayStrength === 'soft'
    ? 'soft'
    : overlayStrength === 'strong'
      ? 'strong'
      : 'medium';

const label = ariaLabel || resolvedAlt;
const descId =
  href && description
    ? `${displayTitle
        .trim()
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, '-')}-desc`
    : undefined;

const headingClass = 'category-image__title';
const Tag = href ? 'a' : 'div';
const classes = [
  'category-image',
  rounded ? 'category-image--rounded' : '',
  interactive ? 'category-image--interactive' : '',
  `category-image--gradient-${gradientTone}`,
  `category-image--overlay-${overlayKey}`,
  className,
]
  .filter(Boolean)
  .join(' ');
---

<Tag
  class={classes}
  href={href}
  aria-label={href ? label : ariaLabel || undefined}
  aria-describedby={href ? descId : undefined}
>
  <div class="category-image__media" style={`height:${resolvedHeight}`}>
    {image ? (
      <img
        src={image}
        alt={resolvedAlt}
        class="category-image__image"
        loading="lazy"
        decoding="async"
      />
    ) : (
      <div class="category-image__gradient" role="img" aria-label={resolvedAlt}>
        <span class="category-image__gradient-text">{displayTitle}</span>
      </div>
    )}
    <div class="category-image__overlay" aria-hidden="true" />
    <div class="category-image__content">
      {displayCategory && (
        <span class="category-image__category">{displayCategory}</span>
      )}
      {headingLevel === 2 && <h2 class={headingClass}>{displayTitle}</h2>}
      {headingLevel === 3 && <h3 class={headingClass}>{displayTitle}</h3>}
      {headingLevel === 4 && <h4 class={headingClass}>{displayTitle}</h4>}
      {headingLevel === 5 && <h5 class={headingClass}>{displayTitle}</h5>}
      {headingLevel === 6 && <h6 class={headingClass}>{displayTitle}</h6>}
      {description && (
        <span
          id={href ? descId : undefined}
          class="category-image__description"
        >
          {description}
        </span>
      )}
    </div>
  </div>
</Tag>

<style is:inline>
  .category-image {
    position: relative;
    display: block;
    overflow: hidden;
    border: 1px solid rgba(148, 163, 184, 0.35);
    background: rgba(15, 23, 42, 0.85);
    box-shadow: 0 20px 45px rgba(2, 6, 23, 0.4);
  }

  .category-image--rounded {
    border-radius: 1.5rem;
  }

  .category-image:not(.category-image--rounded) {
    border-radius: 1rem;
  }

  .category-image--interactive {
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .category-image--interactive:hover,
  .category-image--interactive:focus-visible {
    transform: translateY(-2px);
    box-shadow: 0 25px 55px rgba(2, 6, 23, 0.45);
  }

  .category-image--interactive:focus-visible {
    outline: 3px solid rgba(59, 130, 246, 0.5);
    outline-offset: 3px;
  }

  .category-image__media {
    position: relative;
    width: 100%;
  }

  .category-image__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .category-image--interactive:hover .category-image__image {
    transform: scale(1.03);
  }

  .category-image__gradient {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #f8fafc;
  }

  .category-image__gradient-text {
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  .category-image__overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(
      180deg,
      rgba(2, 6, 23, 0) 0%,
      rgba(2, 6, 23, 0.8) 85%,
      rgba(2, 6, 23, 0.95) 100%
    );
  }

  .category-image__content {
    position: absolute;
    inset: auto 0 0 0;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    color: #f8fafc;
  }

  .category-image__category {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(248, 250, 252, 0.75);
  }

  .category-image__title {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 600;
    line-height: 1.25;
  }

  .category-image__description {
    font-size: 0.85rem;
    color: rgba(248, 250, 252, 0.85);
  }

  .category-image--gradient-purple .category-image__gradient {
    background: linear-gradient(135deg, #6d28d9, #db2777);
  }

  .category-image--gradient-blue .category-image__gradient {
    background: linear-gradient(135deg, #1d4ed8, #0ea5e9);
  }

  .category-image--gradient-amber .category-image__gradient {
    background: linear-gradient(135deg, #d97706, #f97316);
  }

  .category-image--gradient-emerald .category-image__gradient {
    background: linear-gradient(135deg, #047857, #0d9488);
  }

  .category-image--gradient-indigo .category-image__gradient {
    background: linear-gradient(135deg, #3730a3, #2563eb);
  }

  .category-image--gradient-slate .category-image__gradient {
    background: linear-gradient(135deg, #475569, #0f172a);
  }

  .category-image--overlay-soft .category-image__overlay {
    background: linear-gradient(
      180deg,
      rgba(2, 6, 23, 0) 0%,
      rgba(2, 6, 23, 0.5) 70%,
      rgba(2, 6, 23, 0.75) 100%
    );
  }

  .category-image--overlay-strong .category-image__overlay {
    background: linear-gradient(
      180deg,
      rgba(2, 6, 23, 0) 0%,
      rgba(2, 6, 23, 0.85) 70%,
      rgba(2, 6, 23, 0.98) 100%
    );
  }
</style>
