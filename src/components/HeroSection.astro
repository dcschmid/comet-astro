---
/**
 * HeroSection - WCAG AAA compliant hero component with enhanced accessibility and responsive design
 * Enhanced with semantic HTML, proper contrast ratios, and flexible layout options
 */
import ButtonLink from './ButtonLink.astro';

interface Action {
  href: string;
  label: string;
  target?: '_blank' | '_self' | '_parent' | '_top';
  variant?: 'primary' | 'secondary';
}

interface Props {
  /** Main headline text */
  title: string;
  /** Supporting subtitle text */
  subtitle?: string;
  /** Primary call-to-action */
  primary?: Action;
  /** Secondary call-to-action */
  secondary?: Action;
  /** Additional CSS classes */
  className?: string;
  /** Visual theme variant */
  variant?: 'default' | 'gradient' | 'minimal' | 'dark';
  /** Content alignment */
  align?: 'left' | 'center' | 'right';
  /** Size variant */
  size?: 'sm' | 'md' | 'lg' | 'xl';
  /** Background image URL */
  backgroundImage?: string;
  /** Whether to show background pattern */
  showPattern?: boolean;
  /** ARIA label for the section */
  ariaLabel?: string;
  /** Custom heading level for SEO */
  headingLevel?: 'h1' | 'h2' | 'h3';
}

const {
  title,
  subtitle,
  primary,
  secondary,
  className = '',
  variant = 'default',
  align = 'center',
  size = 'lg',
  backgroundImage,
  showPattern = true,
  ariaLabel,
  headingLevel = 'h1',
} = Astro.props as Props;

const variantClasses = {
  default: 'hero-section--variant-default',
  gradient: 'hero-section--variant-gradient',
  minimal: 'hero-section--variant-minimal',
  dark: 'hero-section--variant-dark',
} as const;

const sizeClasses = {
  sm: 'hero-section--size-sm',
  md: 'hero-section--size-md',
  lg: 'hero-section--size-lg',
  xl: 'hero-section--size-xl',
} as const;

const backgroundClass = backgroundImage ? 'hero-section--has-background' : '';

const sectionClasses = [
  'hero-section',
  variantClasses[variant],
  sizeClasses[size],
  backgroundClass,
  className,
]
  .filter(Boolean)
  .join(' ');

const contentClasses = [
  'hero-section__content',
  `hero-section__content--align-${align}`,
].join(' ');

const headingClasses = [
  'hero-section__title',
  `hero-section__title--size-${size}`,
].join(' ');

const subtitleClasses = [
  'hero-section__subtitle',
  `hero-section__subtitle--size-${size}`,
  `hero-section__subtitle--align-${align}`,
].join(' ');

const actionsClasses = [
  'hero-section__actions',
  `hero-section__actions--align-${align}`,
].join(' ');

// Dynamic heading component
const HeadingTag = headingLevel;
---

<section
  class={sectionClasses}
  style={backgroundImage
    ? `background-image: url(${backgroundImage})`
    : undefined}
  aria-label={ariaLabel}
  role="banner"
>
  {showPattern && <div class="hero-section__pattern" aria-hidden="true" />}

  <div class={contentClasses}>
    <HeadingTag class={headingClasses}>
      {title}
    </HeadingTag>

    {
      subtitle && (
        <p class={subtitleClasses}>
          {subtitle}
        </p>
      )
    }

    {
      (primary || secondary) && (
        <div class={actionsClasses}>
          {primary && (
            <ButtonLink
              href={primary.href}
              label={primary.label}
              variant={primary.variant || 'primary'}
              target={primary.target || '_self'}
            />
          )}
          {secondary && (
            <ButtonLink
              href={secondary.href}
              label={secondary.label}
              variant={secondary.variant || 'secondary'}
              target={secondary.target || '_self'}
            />
          )}
        </div>
      )
    }
  </div>
</section>

<style is:inline>
  .hero-section {
    position: relative;
    overflow: hidden;
    border-radius: 1.5rem;
    border: 1px solid rgba(148, 163, 184, 0.4);
    box-shadow: 0 30px 55px rgba(15, 23, 42, 0.15);
    background-color: #ffffff;
    color: #0f172a;
  }

  .hero-section--has-background {
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .hero-section--variant-default {
    background-image: linear-gradient(
      135deg,
      rgba(219, 234, 254, 0.8),
      #ffffff,
      rgba(233, 213, 255, 0.8)
    );
    border-color: rgba(148, 163, 184, 0.4);
  }

  .hero-section--variant-gradient {
    background-image: linear-gradient(
      135deg,
      rgba(199, 210, 254, 0.85),
      #ffffff,
      rgba(191, 219, 254, 0.85)
    );
    border-color: rgba(165, 180, 252, 0.5);
  }

  .hero-section--variant-minimal {
    background-color: #ffffff;
    border-color: rgba(226, 232, 240, 1);
  }

  .hero-section--variant-dark {
    background-color: #0f172a;
    border-color: rgba(71, 85, 105, 0.8);
    color: #f8fafc;
  }

  :where(.dark) .hero-section--variant-default {
    background-image: linear-gradient(
      135deg,
      rgba(15, 23, 42, 0.95),
      rgba(2, 6, 23, 0.98),
      rgba(15, 23, 42, 0.95)
    );
    border-color: rgba(71, 85, 105, 0.6);
  }

  :where(.dark) .hero-section--variant-gradient {
    background-image: linear-gradient(
      135deg,
      rgba(76, 106, 179, 0.85),
      rgba(15, 23, 42, 0.95),
      rgba(15, 118, 110, 0.85)
    );
    border-color: rgba(99, 102, 241, 0.6);
  }

  :where(.dark) .hero-section--variant-minimal {
    background-color: #020617;
    border-color: rgba(30, 41, 59, 0.9);
  }

  .hero-section--size-sm {
    padding: 1.5rem;
  }

  .hero-section--size-md {
    padding: 2rem;
  }

  .hero-section--size-lg {
    padding: 2.5rem;
  }

  .hero-section--size-xl {
    padding: 3rem;
  }

  @media (min-width: 640px) {
    .hero-section--size-sm {
      padding: 2rem;
    }

    .hero-section--size-md {
      padding: 3rem;
    }

    .hero-section--size-lg {
      padding: 4rem;
    }

    .hero-section--size-xl {
      padding: 5rem;
    }
  }

  @media (min-width: 1024px) {
    .hero-section--size-lg {
      padding: 5rem;
    }

    .hero-section--size-xl {
      padding: 6rem;
    }
  }

  .hero-section__pattern {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 0.4;
    background-image: url('data:image/svg+xml,%3Csvg width%3D%2260%22 height%3D%2260%22 viewBox%3D%220 0 60 60%22 xmlns%3D%22http://www.w3.org/2000/svg%22%3E%3Cg fill%3D%22none%22 fill-rule%3D%22evenodd%22%3E%3Cg fill%3D%22%23000%22 fill-opacity%3D%220.02%22%3E%3Ccircle cx%3D%2230%22 cy%3D%2230%22 r%3D%222%22/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');
  }

  :where(.dark) .hero-section__pattern {
    opacity: 0.2;
  }

  .hero-section__content {
    position: relative;
    z-index: 1;
    max-width: 56rem;
  }

  .hero-section__content--align-left {
    margin-left: 0;
    margin-right: auto;
    text-align: left;
  }

  .hero-section__content--align-center {
    margin-left: auto;
    margin-right: auto;
    text-align: center;
  }

  .hero-section__content--align-right {
    margin-left: auto;
    margin-right: 0;
    text-align: right;
  }

  .hero-section__title {
    margin-bottom: 1rem;
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
    text-wrap: balance;
    color: #0f172a;
  }

  :where(.dark) .hero-section__title,
  .hero-section--variant-dark .hero-section__title {
    color: #f8fafc;
  }

  .hero-section__title--size-sm {
    font-size: 1.875rem;
  }

  @media (min-width: 640px) {
    .hero-section__title--size-sm {
      font-size: 2.25rem;
    }
  }

  @media (min-width: 768px) {
    .hero-section__title--size-sm {
      font-size: 3rem;
    }
  }

  .hero-section__title--size-md {
    font-size: 2.25rem;
  }

  @media (min-width: 640px) {
    .hero-section__title--size-md {
      font-size: 3rem;
    }
  }

  @media (min-width: 768px) {
    .hero-section__title--size-md {
      font-size: 3.75rem;
    }
  }

  .hero-section__title--size-lg {
    font-size: 3rem;
  }

  @media (min-width: 640px) {
    .hero-section__title--size-lg {
      font-size: 3.75rem;
    }
  }

  @media (min-width: 768px) {
    .hero-section__title--size-lg {
      font-size: 4.5rem;
    }
  }

  @media (min-width: 1024px) {
    .hero-section__title--size-lg {
      font-size: 6rem;
    }
  }

  .hero-section__title--size-xl {
    font-size: 3.75rem;
  }

  @media (min-width: 640px) {
    .hero-section__title--size-xl {
      font-size: 4.5rem;
    }
  }

  @media (min-width: 768px) {
    .hero-section__title--size-xl {
      font-size: 6rem;
    }
  }

  @media (min-width: 1024px) {
    .hero-section__title--size-xl {
      font-size: 8rem;
    }
  }

  .hero-section__subtitle {
    margin-bottom: 2rem;
    max-width: 48rem;
    line-height: 1.6;
    color: #475569;
  }

  :where(.dark) .hero-section__subtitle,
  .hero-section--variant-dark .hero-section__subtitle {
    color: #cbd5f5;
  }

  .hero-section__subtitle--size-sm {
    font-size: 1rem;
  }

  @media (min-width: 640px) {
    .hero-section__subtitle--size-sm {
      font-size: 1.125rem;
    }
  }

  .hero-section__subtitle--size-md {
    font-size: 1.125rem;
  }

  @media (min-width: 640px) {
    .hero-section__subtitle--size-md {
      font-size: 1.25rem;
    }
  }

  .hero-section__subtitle--size-lg {
    font-size: 1.25rem;
  }

  @media (min-width: 640px) {
    .hero-section__subtitle--size-lg {
      font-size: 1.5rem;
    }
  }

  .hero-section__subtitle--size-xl {
    font-size: 1.5rem;
  }

  @media (min-width: 640px) {
    .hero-section__subtitle--size-xl {
      font-size: 1.875rem;
    }
  }

  .hero-section__subtitle--align-left {
    margin-left: 0;
    margin-right: auto;
  }

  .hero-section__subtitle--align-center {
    margin-left: auto;
    margin-right: auto;
  }

  .hero-section__subtitle--align-right {
    margin-left: auto;
    margin-right: 0;
  }

  .hero-section__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
  }

  .hero-section__actions--align-left {
    justify-content: flex-start;
  }

  .hero-section__actions--align-center {
    justify-content: center;
  }

  .hero-section__actions--align-right {
    justify-content: flex-end;
  }
</style>
