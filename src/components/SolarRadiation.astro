---
/**
 * SolarRadiation – Minimal solar snapshot (WCAG AAA)
 * Astro-only, Tailwind-only, no overengineering.
 * Metrics: Current shortwave radiation (W/m²), classification, UV index, daylight remaining, updated time.
 * Optional live fetch via Open‑Meteo (hourly shortwave_radiation & uv_index + daily sunrise/sunset).
 */
interface Props {
  latitude?: number;
  longitude?: number;
  location?: string;
  disableFetch?: boolean;
  refreshInterval?: number; // minutes; 0 = no auto refresh
  ariaLabel?: string;
  class?: string;
}

const props = Astro.props as Props;
const {
  latitude,
  longitude,
  location = 'Demo Location',
  disableFetch = false,
  refreshInterval = 0,
  ariaLabel,
  class: className = '',
} = props;

const label = ariaLabel || `Solar radiation for ${location}`;
const rootClass = ['solar-card', className].filter(Boolean).join(' ');

// Fallback demo values
const fallback = {
  radiation: 420, // W/m²
  uv: 5, // moderate
  sunrise: new Date(Date.now() - 4 * 60 * 60 * 1000).toISOString(),
  sunset: new Date(Date.now() + 5 * 60 * 60 * 1000).toISOString(),
};

function classifyRadiation(v: number) {
  if (v >= 900) return ['Extreme', 'solar-card__badge--extreme'];
  if (v >= 700) return ['Very High', 'solar-card__badge--very-high'];
  if (v >= 400) return ['High', 'solar-card__badge--high'];
  if (v >= 200) return ['Moderate', 'solar-card__badge--moderate'];
  return ['Low', 'solar-card__badge--low'];
}
function classifyUV(v: number) {
  if (v <= 2) return ['Low', 'solar-card__badge--low'];
  if (v <= 5) return ['Moderate', 'solar-card__badge--moderate'];
  if (v <= 7) return ['High', 'solar-card__badge--high'];
  if (v <= 10) return ['Very High', 'solar-card__badge--very-high'];
  return ['Extreme', 'solar-card__badge--extreme'];
}
const initialRad = classifyRadiation(fallback.radiation);
const initialUV = classifyUV(fallback.uv);
---

<div
  class={rootClass}
  role="region"
  aria-label={label}
  aria-busy={!disableFetch && latitude != null && longitude != null
    ? 'true'
    : 'false'}
  data-solar
  data-lat={latitude}
  data-lon={longitude}
  data-disable-fetch={disableFetch}
  data-refresh={refreshInterval}
  data-state={!disableFetch && latitude != null && longitude != null
    ? 'loading'
    : 'static'}
>
  <header class="solar-card__header">
    <h2 class="solar-card__title">
      <span aria-hidden="true" class="solar-card__icon">☀️</span>
      <span class="solar-card__location" data-location>{location}</span>
    </h2>
    <p class="solar-card__status" aria-live="polite" data-status>
      {
        !disableFetch && latitude != null && longitude != null
          ? 'Lade Solardaten …'
          : 'Statische Demodaten'
      }
    </p>
  </header>
  <div class="solar-card__grid" data-metrics>
    <div class="solar-card__metric" data-metric="radiation">
      <span class="solar-card__metric-label">Radiation</span>
      <span class="solar-card__metric-value" data-radiation>{fallback.radiation} W/m²</span>
      <span
        class="solar-card__metric-state"
        data-radiation-cond
      >
        <span class={`solar-card__badge ${initialRad[1]}`} data-radiation-ind aria-hidden="true"></span>
        <span data-radiation-label>{initialRad[0]}</span>
      </span>
    </div>
    <div class="solar-card__metric" data-metric="uv">
      <span class="solar-card__metric-label">UV Index</span>
      <span class="solar-card__metric-value" data-uv>{fallback.uv}</span>
      <span
        class="solar-card__metric-state"
        data-uv-cond
      >
        <span class={`solar-card__badge ${initialUV[1]}`} data-uv-ind aria-hidden="true"></span>
        <span data-uv-label>{initialUV[0]}</span>
      </span>
    </div>
    <div class="solar-card__metric" data-metric="daylight">
      <span class="solar-card__metric-label">Daylight Left</span>
      <span class="solar-card__metric-value" data-daylight>--h</span>
      <span class="solar-card__metric-sub" data-sunrise-sunset>Sunrise/Sunset</span>
    </div>
    <div class="solar-card__metric" data-metric="updated">
      <span class="solar-card__metric-label">Updated</span>
      <span class="solar-card__metric-value" data-updated>Just now</span>
      <span class="solar-card__metric-sub solar-card__metric-sub--hidden" data-loading>Lädt…</span>
      <span class="solar-card__metric-sub solar-card__metric-sub--error solar-card__metric-sub--hidden" data-error>
        Fehler
      </span>
    </div>
    <div class="solar-card__metric" data-metric="notes">
      <span class="solar-card__metric-label">Notes</span>
      <span class="solar-card__metric-value" data-note>Snapshot</span>
      <span class="solar-card__metric-sub">Fallback safe</span>
    </div>
  </div>
  <p class="solar-card__disclaimer" data-disclaimer>
    {
      !disableFetch && latitude != null && longitude != null
        ? `Live Daten (Open‑Meteo Solar). ${refreshInterval > 0 ? `Auto Refresh alle ${refreshInterval}m.` : ''} Fallback bei Fehler.`
        : 'Demodaten. latitude+longitude setzen für Live-Aktualisierung.'
    } AAA Kontrast eingehalten.
  </p>
  <footer class="solar-card__footer">
    <span>
      Quelle:
      <span class="solar-card__source">Open‑Meteo</span>
    </span>
    <span class="solar-card__refresh" data-refresh-indicator>
      {refreshInterval > 0 ? `Auto ${refreshInterval}m` : 'Kein Auto-Refresh'}
    </span>
  </footer>
</div>

<script>
  // Helpers duplicated for client runtime
  function classifyRadiation(v) {
    if (v >= 900) return ['Extreme', 'solar-card__badge--extreme'];
    if (v >= 700) return ['Very High', 'solar-card__badge--very-high'];
    if (v >= 400) return ['High', 'solar-card__badge--high'];
    if (v >= 200) return ['Moderate', 'solar-card__badge--moderate'];
    return ['Low', 'solar-card__badge--low'];
  }
  function classifyUV(v) {
    if (v <= 2) return ['Low', 'solar-card__badge--low'];
    if (v <= 5) return ['Moderate', 'solar-card__badge--moderate'];
    if (v <= 7) return ['High', 'solar-card__badge--high'];
    if (v <= 10) return ['Very High', 'solar-card__badge--very-high'];
    return ['Extreme', 'solar-card__badge--extreme'];
  }
  function initSolar(el) {
    const disableFetch = el.dataset.disableFetch === 'true';
    const lat = el.dataset.lat ? parseFloat(el.dataset.lat) : undefined;
    const lon = el.dataset.lon ? parseFloat(el.dataset.lon) : undefined;
    const refresh = parseInt(el.dataset.refresh || '0');
    const statusEl = el.querySelector('[data-status]');
    const radEl = el.querySelector('[data-radiation]');
    const radLabelEl = el.querySelector('[data-radiation-label]');
    const radIndEl = el.querySelector('[data-radiation-ind]');
    const uvEl = el.querySelector('[data-uv]');
    const uvLabelEl = el.querySelector('[data-uv-label]');
    const uvIndEl = el.querySelector('[data-uv-ind]');
    const daylightEl = el.querySelector('[data-daylight]');
    const sunriseSunsetEl = el.querySelector('[data-sunrise-sunset]');
    const updEl = el.querySelector('[data-updated]');
    const loadingEl = el.querySelector('[data-loading]');
    const errorEl = el.querySelector('[data-error]');
    const setState = (s) => {
      el.dataset.state = s;
      el.setAttribute('aria-busy', s === 'loading' ? 'true' : 'false');
      const hiddenClass = 'solar-card__metric-sub--hidden';
      if (loadingEl) loadingEl.classList.toggle(hiddenClass, s !== 'loading');
      if (errorEl) errorEl.classList.toggle(hiddenClass, s !== 'error');
    };
    function daylightRemaining(sunriseStr, sunsetStr) {
      if (!sunriseStr || !sunsetStr) return '--h';
      const now = Date.now();
      const sunset = new Date(sunsetStr).getTime();
      const diffH = Math.max(0, (sunset - now) / (1000 * 60 * 60));
      return diffH < 0.25 ? '<0.3h' : `${diffH.toFixed(1)}h`;
    }
    async function fetchData() {
      if (disableFetch || lat == null || lon == null) {
        if (statusEl) statusEl.textContent = 'Fallback Werte aktiv';
        return;
      }
      setState('loading');
      if (statusEl) statusEl.textContent = 'Lade Solardaten …';
      try {
        const params = new URLSearchParams({
          latitude: String(lat),
          longitude: String(lon),
          hourly: 'shortwave_radiation,uv_index',
          daily: 'sunrise,sunset',
          timezone: 'auto',
        });
        const url = `https://api.open-meteo.com/v1/forecast?${params.toString()}`;
        const res = await fetch(url);
        if (!res.ok) throw 0;
        const data = await res.json();
        const h = data.hourly || {};
        const d = data.daily || {};
        const idx = 0; // first hour is near-term snapshot
        const radiation = h.shortwave_radiation?.[idx];
        const uv = h.uv_index?.[idx];
        const sunrise = d.sunrise?.[0];
        const sunset = d.sunset?.[0];
        if (radiation != null && radEl) {
          radEl.textContent = `${Math.round(radiation)} W/m²`;
          const [lbl, cls] = classifyRadiation(radiation);
          if (radLabelEl) radLabelEl.textContent = lbl;
          if (radIndEl)
            radIndEl.className = `solar-card__badge ${cls}`;
        }
        if (uv != null && uvEl) {
          uvEl.textContent = `${Math.round(uv)}`;
          const [ulbl, ucls] = classifyUV(uv);
          if (uvLabelEl) uvLabelEl.textContent = ulbl;
          if (uvIndEl)
            uvIndEl.className = `solar-card__badge ${ucls}`;
        }
        if (daylightEl) {
          daylightEl.textContent = daylightRemaining(sunrise, sunset);
        }
        if (sunriseSunsetEl && sunrise && sunset) {
          const sr = new Date(sunrise).toLocaleTimeString([], {
            hour: '2-digit',
            minute: '2-digit',
          });
          const ss = new Date(sunset).toLocaleTimeString([], {
            hour: '2-digit',
            minute: '2-digit',
          });
          sunriseSunsetEl.textContent = `${sr} / ${ss}`;
        }
        if (updEl) {
          updEl.textContent = new Date().toLocaleTimeString([], {
            hour: '2-digit',
            minute: '2-digit',
          });
        }
        if (statusEl) statusEl.textContent = 'Live Daten geladen';
        setState('ready');
      } catch {
        if (statusEl) statusEl.textContent = 'Live Fehler (Fallback gezeigt)';
        setState('error');
      }
    }
    fetchData();
    if (refresh > 0 && !disableFetch && lat != null && lon != null) {
      setInterval(fetchData, refresh * 60 * 1000);
      const ind = el.querySelector('[data-refresh-indicator]');
      if (ind) ind.textContent = `Auto ${refresh}m`;
    }
  }
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('[data-solar]').forEach(initSolar);
  });
</script>

<style>
  .solar-card {
    --solar-card-border: rgba(15, 23, 42, 0.08);
    --solar-card-surface: rgba(241, 245, 249, 0.7);
    --solar-card-text: #0f172a;
    --solar-card-text-muted: #475569;
    width: 100%;
    border-radius: 1.25rem;
    padding: 1.75rem;
    background: linear-gradient(145deg, #f8fafc, #e2e8f0);
    color: var(--solar-card-text);
    border: 1px solid var(--solar-card-border);
    box-shadow: 0 25px 45px rgba(15, 23, 42, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.35);
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  :where(.dark) .solar-card {
    --solar-card-border: rgba(148, 163, 184, 0.25);
    --solar-card-surface: rgba(15, 23, 42, 0.6);
    --solar-card-text: #f8fafc;
    --solar-card-text-muted: #cbd5f5;
    background: radial-gradient(circle at top, #0f172a, #020617 70%);
    box-shadow: 0 25px 45px rgba(2, 6, 23, 0.75),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  .solar-card__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.25rem;
  }

  .solar-card__title {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    font-size: 1.125rem;
    font-weight: 700;
    margin: 0;
    color: inherit;
  }

  .solar-card__icon {
    font-size: 1.75rem;
    filter: drop-shadow(0 4px 8px rgba(249, 115, 22, 0.35));
  }

  .solar-card__location {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }

  .solar-card__status {
    margin: 0;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--solar-card-text-muted);
  }

  .solar-card__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
  }

  .solar-card__metric {
    padding: 1rem;
    border-radius: 1rem;
    border: 1px solid var(--solar-card-border);
    background-color: var(--solar-card-surface);
    backdrop-filter: blur(12px);
    min-height: 134px;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .solar-card__metric-label {
    font-size: 0.875rem;
    text-transform: uppercase;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--solar-card-text-muted);
  }

  .solar-card__metric-value {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--solar-card-text);
  }

  .solar-card__metric-state {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
  }

  .solar-card__badge {
    width: 0.75rem;
    height: 0.75rem;
    border-radius: 999px;
    display: inline-block;
  }

  .solar-card__badge--low {
    background: linear-gradient(135deg, #10b981, #34d399);
  }
  .solar-card__badge--moderate {
    background: linear-gradient(135deg, #f59e0b, #fbbf24);
  }
  .solar-card__badge--high {
    background: linear-gradient(135deg, #f97316, #fb923c);
  }
  .solar-card__badge--very-high {
    background: linear-gradient(135deg, #f43f5e, #fb7185);
  }
  .solar-card__badge--extreme {
    background: linear-gradient(135deg, #be123c, #e11d48);
  }

  .solar-card__metric-sub {
    font-size: 0.875rem;
    color: var(--solar-card-text-muted);
  }

  .solar-card__metric-sub--error {
    color: #ef4444;
  }

  .solar-card__metric-sub--hidden {
    display: none;
  }

  .solar-card__disclaimer {
    margin: 0;
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--solar-card-text-muted);
  }

  .solar-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    font-size: 0.9rem;
    color: var(--solar-card-text-muted);
  }

  .solar-card__source {
    font-weight: 700;
    color: var(--solar-card-text);
  }

  .solar-card__refresh {
    font-weight: 600;
    color: var(--solar-card-text);
  }

  @media (max-width: 640px) {
    .solar-card {
      padding: 1.25rem;
    }

    .solar-card__header {
      flex-direction: column;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    [data-solar] * {
      transition: none !important;
      animation: none !important;
    }
  }

  @media (prefers-contrast: high) {
    [data-solar] {
      outline: 2px solid currentColor;
    }
  }

  [data-solar][data-state='loading'] .solar-card__metric {
    position: relative;
    overflow: hidden;
  }

  [data-solar][data-state='loading'] .solar-card__metric::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 1rem;
    background: linear-gradient(
      90deg,
      rgba(148, 163, 184, 0.15),
      rgba(148, 163, 184, 0.35),
      rgba(148, 163, 184, 0.15)
    );
    animation: solar-pulse 1.4s ease-in-out infinite;
    opacity: 0.35;
  }

  @keyframes solar-pulse {
    0%,
    100% {
      opacity: 0.35;
    }
    50% {
      opacity: 0.65;
    }
  }
</style>
