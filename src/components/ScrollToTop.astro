---
/**
 * ScrollToTop - Accessible scroll-to-top button with WCAG AAA compliance
 */
interface Props {
  /** Scroll threshold in pixels before button appears */
  threshold?: number;
  /** Position of the button on screen */
  position?:
    | 'bottom-right'
    | 'bottom-left'
    | 'bottom-center'
    | 'top-right'
    | 'top-left';
  /** Enable smooth scrolling animation */
  smooth?: boolean;
  /** Visual variant of the button */
  variant?: 'default' | 'minimal' | 'ghost' | 'solid';
  /** Size of the button */
  size?: 'sm' | 'md' | 'lg';
  /** Custom label for accessibility */
  label?: string;
  /** Icon to display (default is arrow up) */
  icon?: 'arrow' | 'chevron' | 'caret';
  /** Show progress indicator */
  showProgress?: boolean;
  /** Custom offset from edges */
  offset?: number;
  /** Whether button is disabled */
  disabled?: boolean;
  /** Additional CSS classes */
  class?: string;
}

const {
  threshold = 300,
  position = 'bottom-right',
  smooth = true,
  variant = 'default',
  size = 'md',
  label = 'Scroll to top',
  icon = 'arrow',
  showProgress = false,
  offset = 32,
  disabled = false,
  class: className = '',
} = Astro.props;

const rootClasses = [
  'scroll-top',
  `scroll-top--variant-${variant}`,
  `scroll-top--size-${size}`,
  `scroll-top--position-${position}`,
  showProgress ? 'scroll-top--with-progress' : '',
  disabled ? 'scroll-top--disabled' : '',
  className,
]
  .filter(Boolean)
  .join(' ');

const iconClasses = [
  'scroll-top__icon',
  showProgress ? 'scroll-top__icon--small' : '',
]
  .filter(Boolean)
  .join(' ');

const wrapperStyle = `--scroll-top-offset: ${offset}px`;

// Icon variants
const iconMap = {
  arrow: '↑',
  chevron: '⌃',
  caret: '▲',
};

---

<button
  type="button"
  class={rootClasses}
  style={wrapperStyle}
  data-scroll-top
  data-threshold={threshold}
  data-smooth={smooth}
  data-show-progress={showProgress}
  aria-label={label}
  aria-hidden="true"
  tabindex="-1"
  disabled={disabled}
  data-testid="scroll-to-top"
>
  {
    showProgress && (
      <div
        class="scroll-top__progress"
        data-progress-ring
        style="background: conic-gradient(from 0deg, currentColor 0%, transparent 0%)"
      />
    )
  }
  <span class={iconClasses}>{iconMap[icon]}</span>
</button>

<style is:inline>
  .scroll-top {
    position: fixed;
    z-index: 50;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    border: 1px solid transparent;
    transition: opacity 0.3s ease, transform 0.3s ease, visibility 0.3s ease;
    opacity: 0;
    visibility: hidden;
    transform: translateY(0.5rem);
    background-color: #2563eb;
    color: #f8fafc;
    box-shadow: 0 15px 30px rgba(37, 99, 235, 0.35);
    width: 3rem;
    height: 3rem;
    font-size: 1.125rem;
    cursor: pointer;
  }

  .scroll-top--visible {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .scroll-top--size-sm {
    width: 2.5rem;
    height: 2.5rem;
    font-size: 1rem;
  }

  .scroll-top--size-lg {
    width: 3.5rem;
    height: 3.5rem;
    font-size: 1.35rem;
  }

  .scroll-top--position-bottom-right {
    right: var(--scroll-top-offset, 2rem);
    bottom: var(--scroll-top-offset, 2rem);
  }

  .scroll-top--position-bottom-left {
    left: var(--scroll-top-offset, 2rem);
    bottom: var(--scroll-top-offset, 2rem);
  }

  .scroll-top--position-top-right {
    right: var(--scroll-top-offset, 2rem);
    top: var(--scroll-top-offset, 2rem);
  }

  .scroll-top--position-top-left {
    left: var(--scroll-top-offset, 2rem);
    top: var(--scroll-top-offset, 2rem);
  }

  .scroll-top--position-bottom-center {
    left: 50%;
    bottom: var(--scroll-top-offset, 2rem);
    transform: translate(-50%, 0.5rem);
  }

  .scroll-top--visible.scroll-top--position-bottom-center {
    transform: translate(-50%, 0);
  }

  .scroll-top--variant-default {
    background-color: #2563eb;
    border-color: #1d4ed8;
    color: #f8fafc;
  }

  .scroll-top--variant-minimal {
    background-color: #f1f5f9;
    border-color: #cbd5f5;
    color: #0f172a;
    box-shadow: 0 12px 25px rgba(15, 23, 42, 0.1);
  }

  .scroll-top--variant-ghost {
    background-color: rgba(255, 255, 255, 0.85);
    border-color: rgba(148, 163, 184, 0.4);
    color: #0f172a;
    backdrop-filter: blur(8px);
    box-shadow: 0 10px 20px rgba(15, 23, 42, 0.15);
  }

  .scroll-top--variant-solid {
    background-color: #0f172a;
    border-color: #0f172a;
    color: #f8fafc;
    box-shadow: 0 20px 40px rgba(15, 23, 42, 0.4);
  }

  .scroll-top--variant-default:hover:not(.scroll-top--disabled),
  .scroll-top--variant-default:focus-visible {
    background-color: #1d4ed8;
  }

  .scroll-top--variant-minimal:hover:not(.scroll-top--disabled),
  .scroll-top--variant-minimal:focus-visible {
    background-color: #e2e8f0;
  }

  .scroll-top--variant-ghost:hover:not(.scroll-top--disabled),
  .scroll-top--variant-ghost:focus-visible {
    background-color: rgba(255, 255, 255, 1);
  }

  .scroll-top--variant-solid:hover:not(.scroll-top--disabled),
  .scroll-top--variant-solid:focus-visible {
    background-color: #1f2937;
  }

  .scroll-top:focus-visible {
    outline: 2px solid #3b82f6;
    outline-offset: 3px;
  }

  .scroll-top--disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .scroll-top__progress {
    position: absolute;
    inset: 0;
    border-radius: 999px;
    border: 2px solid transparent;
    transition: background 150ms ease;
  }

  .scroll-top__icon {
    font-weight: 700;
    position: relative;
    z-index: 1;
  }

  .scroll-top__icon--small {
    font-size: 0.85rem;
  }

  .scroll-top--with-progress .scroll-top__icon {
    mix-blend-mode: difference;
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-top,
    .scroll-top__progress {
      transition-duration: 0s;
    }
  }

  @media (prefers-contrast: high) {
    .scroll-top {
      border-width: 2px;
    }
  }

  :where(.dark) .scroll-top--variant-default {
    background-color: #3b82f6;
    border-color: #2563eb;
    color: #0f172a;
  }

  :where(.dark) .scroll-top--variant-minimal {
    background-color: #1f2937;
    border-color: #475569;
    color: #f8fafc;
  }

  :where(.dark) .scroll-top--variant-ghost {
    background-color: rgba(15, 23, 42, 0.8);
    border-color: rgba(148, 163, 184, 0.35);
    color: #f8fafc;
  }

  :where(.dark) .scroll-top--variant-solid {
    background-color: #f8fafc;
    border-color: #f8fafc;
    color: #0f172a;
  }
</style>

<script is:inline>
  (function setupScrollToTop() {
    const buttons = document.querySelectorAll('[data-scroll-top]');

    buttons.forEach((button) => {
      if (!(button instanceof HTMLElement)) return;

      const threshold = parseInt(
        button.getAttribute('data-threshold') || '300'
      );
      const smooth = button.getAttribute('data-smooth') === 'true';
      const showProgress = button.getAttribute('data-show-progress') === 'true';
      const progressRing = button.querySelector('[data-progress-ring]');
      const reduceMotion = window.matchMedia(
        '(prefers-reduced-motion: reduce)'
      );

      const setVisibility = (visible) => {
        button.classList.toggle('scroll-top--visible', visible);
        button.setAttribute('aria-hidden', visible ? 'false' : 'true');
        button.tabIndex = visible ? 0 : -1;
      };

      const updateProgress = () => {
        if (!showProgress || !progressRing) return;

        const scrollTop =
          window.pageYOffset || document.documentElement.scrollTop;
        const docHeight =
          document.documentElement.scrollHeight - window.innerHeight;
        const scrollPercent = (scrollTop / docHeight) * 100;

        const clampedPercent = Math.min(Math.max(scrollPercent, 0), 100);
        progressRing.style.background = `conic-gradient(from 0deg, currentColor ${clampedPercent}%, transparent ${clampedPercent}%)`;
      };

      const checkScroll = () => {
        const scrollY =
          window.pageYOffset || document.documentElement.scrollTop;

        if (scrollY > threshold) {
          setVisibility(true);
          updateProgress();
        } else {
          setVisibility(false);
        }
      };

      const scrollToTop = () => {
        const targetPosition = 0;
        const startPosition =
          window.pageYOffset || document.documentElement.scrollTop;
        const distance = targetPosition - startPosition;
        const duration = smooth && !reduceMotion.matches ? 800 : 0;

        if (duration === 0) {
          window.scrollTo(0, 0);
          return;
        }

        let start = null;

        const step = (timestamp) => {
          if (!start) start = timestamp;
          const progress = timestamp - start;
          const progressPercent = Math.min(progress / duration, 1);

          // Easing function for smooth animation
          const easeOutCubic = 1 - Math.pow(1 - progressPercent, 3);

          window.scrollTo(0, startPosition + distance * easeOutCubic);

          if (progress < duration) {
            requestAnimationFrame(step);
          }
        };

        requestAnimationFrame(step);
      };

      // Event listeners
      button.addEventListener('click', (event) => {
        event.preventDefault();
        scrollToTop();

        // Announce to screen readers
        const announcement = document.createElement('div');
        announcement.setAttribute('aria-live', 'polite');
        announcement.setAttribute('aria-atomic', 'true');
        announcement.className = 'sr-only';
        announcement.textContent = 'Scrolled to top of page';
        document.body.appendChild(announcement);

        setTimeout(() => {
          document.body.removeChild(announcement);
        }, 1000);
      });

      // Keyboard support
      button.addEventListener('keydown', (event) => {
        if (event.key === 'Enter' || event.key === ' ') {
          event.preventDefault();
          scrollToTop();
        }
      });

      // Throttled scroll listener for better performance
      let ticking = false;
      const throttledScroll = () => {
        if (!ticking) {
          requestAnimationFrame(() => {
            checkScroll();
            ticking = false;
          });
          ticking = true;
        }
      };

      window.addEventListener('scroll', throttledScroll, { passive: true });

      // Check initial state
      checkScroll();

      // Handle resize for responsive behavior
      window.addEventListener(
        'resize',
        () => {
          checkScroll();
        },
        { passive: true }
      );
    });
  })();
</script>
