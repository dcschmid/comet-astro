---

interface Props {
  name: string;
  value: string;
  label?: string;
  checked?: boolean;
  disabled?: boolean;
  required?: boolean;
  error?: boolean;
  variant?: 'default' | 'success' | 'warning' | 'error' | 'minimal';
  size?: 'sm' | 'md' | 'lg';
  labelPosition?: 'right' | 'left';
  description?: string;
  id?: string;
  ariaLabel?: string;
  ariaDescribedBy?: string;
  class?: string;
}

const {
  name,
  value,
  label,
  checked = false,
  disabled = false,
  required = false,
  error = false,
  variant = 'default',
  size = 'md',
  labelPosition = 'right',
  description,
  id = `radio-${name}-${value}`,
  ariaLabel,
  ariaDescribedBy,
  class: className = '',
} = Astro.props;

const rootClasses = [
  'radio',
  `radio--variant-${variant}`,
  `radio--size-${size}`,
  labelPosition === 'left' ? 'radio--reverse' : '',
  error ? 'radio--error' : '',
  disabled ? 'radio--disabled' : '',
  className,
]
  .filter(Boolean)
  .join(' ');

const descriptionId = description ? `${id}-description` : undefined;
const finalAriaDescribedBy =
  [ariaDescribedBy, descriptionId].filter(Boolean).join(' ') || undefined;
---

<div class={rootClasses}>
  <input
    type="radio"
    {id}
    {name}
    {value}
    {checked}
    {disabled}
    {required}
    aria-label={ariaLabel}
    aria-describedby={finalAriaDescribedBy}
    aria-invalid={error ? 'true' : undefined}
    class="radio__input"
  />

  {
    (label || description) && (
      <div class="radio__text">
        {label && (
          <label for={id} class="radio__label">
            {label}
            {required && <span class="radio__required">*</span>}
          </label>
        )}

        {description && (
          <div id={descriptionId} class="radio__description">
            {description}
          </div>
        )}
      </div>
    )
  }
</div>

<style>
  .radio {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .radio--reverse {
    flex-direction: row-reverse;
  }

  .radio__input {
    margin-top: 0.25rem;
    width: 1.2rem;
    height: 1.2rem;
    border: 2px solid rgba(148, 163, 184, 0.8);
    border-radius: 999px;
    background-color: #ffffff;
    accent-color: #2563eb;
    cursor: pointer;
  }

  .radio--size-sm .radio__input {
    width: 1rem;
    height: 1rem;
  }

  .radio--size-lg .radio__input {
    width: 1.35rem;
    height: 1.35rem;
  }

  .radio--variant-success .radio__input {
    accent-color: #16a34a;
    border-color: rgba(16, 185, 129, 0.7);
  }

  .radio--variant-warning .radio__input {
    accent-color: #d97706;
    border-color: rgba(234, 179, 8, 0.8);
  }

  .radio--variant-error .radio__input {
    accent-color: #dc2626;
    border-color: rgba(239, 68, 68, 0.8);
  }

  .radio--variant-minimal .radio__input {
    border-color: rgba(148, 163, 184, 0.5);
  }

  .radio__text {
    flex: 1;
    min-width: 0;
  }

  .radio__label {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-weight: 600;
    color: #0f172a;
    cursor: pointer;
  }

  .radio__required {
    color: #dc2626;
  }

  .radio__description {
    margin-top: 0.35rem;
    font-size: 0.85rem;
    color: #475569;
  }

  .radio--size-sm .radio__label {
    font-size: 0.9rem;
  }

  .radio--size-lg .radio__label {
    font-size: 1rem;
  }

  .radio--disabled .radio__label,
  .radio--disabled .radio__description {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .radio--disabled .radio__input {
    cursor: not-allowed;
  }

  .radio--error .radio__label,
  .radio--error .radio__description {
    color: #dc2626;
  }

  :where(.dark) .radio__input {
    background-color: #0f172a;
    border-color: rgba(148, 163, 184, 0.5);
  }

  :where(.dark) .radio__label {
    color: #f8fafc;
  }

  :where(.dark) .radio__description {
    color: #cbd5f5;
  }
</style>
