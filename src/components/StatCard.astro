---
interface Props {
  label: string;
  value: string | number;
  icon?: string;
  trend?: number;
  trendLabel?: string;
  variant?: 'default' | 'gradient' | 'bordered' | 'elevated';
  size?: 'sm' | 'md' | 'lg';
  as?: 'div' | 'article' | 'section';
  role?: string;
  ariaLabel?: string;
  ariaLabelledby?: string;
  debug?: boolean;
  class?: string;
}

const {
  label,
  value,
  icon,
  trend,
  trendLabel,
  variant = 'default',
  size = 'md',
  as: Element = 'div',
  role,
  ariaLabel,
  ariaLabelledby,
  debug = false,
  class: className = '',
} = Astro.props as Props;

const trendState =
  trend === undefined
    ? undefined
    : trend > 0
      ? 'positive'
      : trend < 0
        ? 'negative'
        : 'neutral';

const rootClasses = [
  'stat-card',
  `stat-card--variant-${variant}`,
  `stat-card--size-${size}`,
  debug ? 'stat-card--debug' : '',
  className,
]
  .filter(Boolean)
  .join(' ');

const trendClasses = [
  'stat-card__trend',
  trendState ? `stat-card__trend--${trendState}` : '',
]
  .filter(Boolean)
  .join(' ');

const debugInfo = debug ? `${variant} ${size}` : undefined;
const labelId = `stat-label-${Math.random().toString(36).slice(2, 9)}`;
const valueId = `stat-value-${Math.random().toString(36).slice(2, 9)}`;

const trendAbsValue =
  trend !== undefined ? Math.abs(trend).toLocaleString() : undefined;

const trendAriaLabel =
  trend === undefined
    ? undefined
    : `Trend: ${trendState === 'positive' ? 'positive' : trendState === 'negative' ? 'negative' : 'neutral'} ${trendAbsValue}%`;
---

<Element
  class={rootClasses}
  role={role}
  aria-label={ariaLabel}
  aria-labelledby={ariaLabelledby || `${labelId} ${valueId}`}
  data-debug-info={debugInfo}
>
  <div class="stat-card__header">
    <p id={labelId} class="stat-card__label">
      {label}
    </p>
    {
      icon && (
        <span class="stat-card__icon" aria-hidden="true">
          {icon}
        </span>
      )
    }
  </div>

  <div class="stat-card__value-wrapper">
    <p id={valueId} class="stat-card__value">
      {value}
    </p>
  </div>

  {
    (trend !== undefined || trendLabel) && (
      <div class="stat-card__trend-row">
        {trend !== undefined && (
          <span class={trendClasses} aria-label={trendAriaLabel}>
            <span class="stat-card__trend-symbol" aria-hidden="true">
              {trendState === 'positive' && '↗'}
              {trendState === 'negative' && '↘'}
              {trendState === 'neutral' && '→'}
            </span>
            <span class="stat-card__trend-value">{trendAbsValue}%</span>
          </span>
        )}
        {trendLabel && (
          <span class="stat-card__trend-label">
            {trendLabel}
          </span>
        )}
      </div>
    )
  }
</Element>

<style>
  .stat-card {
    --stat-card-padding: 1.5rem;
    --stat-card-radius: 1.25rem;
    --stat-card-label-size: 0.85rem;
    --stat-card-value-size: 2.5rem;
    --stat-card-icon-size: 1.75rem;
    --stat-card-trend-size: 0.9rem;
    --stat-card-border: rgba(226, 232, 240, 1);
    --stat-card-background: #fff;
    --stat-card-shadow: 0 20px 45px rgba(15, 23, 42, 0.08);
    --stat-card-text: #0f172a;
    --stat-card-muted: #475569;
    border: 1px solid var(--stat-card-border);
    border-radius: var(--stat-card-radius);
    padding: var(--stat-card-padding);
    background: var(--stat-card-background);
    box-shadow: var(--stat-card-shadow);
    color: var(--stat-card-text);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: background 0.2s ease, border-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  :where(.dark) .stat-card {
    --stat-card-border: rgba(71, 85, 105, 1);
    --stat-card-background: #0f172a;
    --stat-card-shadow: 0 15px 30px rgba(2, 8, 23, 0.75);
    --stat-card-text: #f8fafc;
    --stat-card-muted: #cbd5f5;
  }

  .stat-card--variant-default {
    --stat-card-border: rgba(226, 232, 240, 1);
    --stat-card-background: #fff;
    --stat-card-shadow: 0 12px 24px rgba(148, 163, 184, 0.2);
  }

  :where(.dark) .stat-card--variant-default {
    --stat-card-border: rgba(51, 65, 85, 1);
    --stat-card-background: #0f172a;
    --stat-card-shadow: 0 20px 40px rgba(2, 6, 23, 0.85);
  }

  .stat-card--variant-gradient {
    --stat-card-border: rgba(191, 219, 254, 1);
    --stat-card-background: linear-gradient(
      135deg,
      rgba(219, 234, 254, 0.95),
      rgba(224, 231, 255, 0.95),
      rgba(238, 242, 255, 0.95)
    );
    --stat-card-shadow: 0 25px 35px rgba(99, 102, 241, 0.2);
  }

  :where(.dark) .stat-card--variant-gradient {
    --stat-card-border: rgba(37, 99, 235, 0.6);
    --stat-card-background: linear-gradient(
      135deg,
      rgba(15, 23, 42, 0.95),
      rgba(30, 27, 75, 0.95),
      rgba(8, 47, 73, 0.95)
    );
    --stat-card-shadow: 0 30px 40px rgba(5, 17, 43, 0.8);
  }

  .stat-card--variant-bordered {
    --stat-card-border: rgba(148, 163, 184, 1);
    --stat-card-background: #fff;
    --stat-card-shadow: 0 10px 20px rgba(15, 23, 42, 0.05);
    border-width: 2px;
  }

  :where(.dark) .stat-card--variant-bordered {
    --stat-card-border: rgba(71, 85, 105, 1);
    --stat-card-background: #020617;
  }

  .stat-card--variant-elevated {
    --stat-card-border: rgba(226, 232, 240, 0.8);
    --stat-card-background: #fff;
    --stat-card-shadow: 0 30px 45px rgba(15, 23, 42, 0.25);
  }

  :where(.dark) .stat-card--variant-elevated {
    --stat-card-border: rgba(71, 85, 105, 0.8);
    --stat-card-background: #0f172a;
    --stat-card-shadow: 0 30px 45px rgba(2, 6, 23, 0.85);
  }

  .stat-card--size-sm {
    --stat-card-padding: 1rem;
    --stat-card-radius: 0.85rem;
    --stat-card-label-size: 0.75rem;
    --stat-card-value-size: 1.75rem;
    --stat-card-icon-size: 1.25rem;
    --stat-card-trend-size: 0.75rem;
  }

  .stat-card--size-md {
    --stat-card-padding: 1.5rem;
    --stat-card-radius: 1.25rem;
    --stat-card-label-size: 0.85rem;
    --stat-card-value-size: 2.5rem;
    --stat-card-icon-size: 1.75rem;
    --stat-card-trend-size: 0.9rem;
  }

  .stat-card--size-lg {
    --stat-card-padding: 2rem;
    --stat-card-radius: 1.75rem;
    --stat-card-label-size: 1rem;
    --stat-card-value-size: 3rem;
    --stat-card-icon-size: 2.25rem;
    --stat-card-trend-size: 1rem;
  }

  .stat-card__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .stat-card__label {
    margin: 0;
    font-size: var(--stat-card-label-size);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--stat-card-muted);
  }

  .stat-card__icon {
    font-size: var(--stat-card-icon-size);
    line-height: 1;
    color: var(--stat-card-muted);
  }

  .stat-card__value-wrapper {
    margin-block-start: 0.25rem;
  }

  .stat-card__value {
    margin: 0;
    font-size: var(--stat-card-value-size);
    font-weight: 700;
    color: var(--stat-card-text);
    line-height: 1.1;
  }

  .stat-card__trend-row {
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .stat-card__trend {
    display: inline-flex;
    align-items: center;
    font-size: var(--stat-card-trend-size);
    font-weight: 600;
    color: var(--stat-card-muted);
    gap: 0.35rem;
  }

  .stat-card__trend-symbol {
    font-size: var(--stat-card-trend-size);
  }

  .stat-card__trend-value {
    font-variant-numeric: tabular-nums;
  }

  .stat-card__trend--positive {
    color: #065f46;
  }

  :where(.dark) .stat-card__trend--positive {
    color: #6ee7b7;
  }

  .stat-card__trend--negative {
    color: #b91c1c;
  }

  :where(.dark) .stat-card__trend--negative {
    color: #fca5a5;
  }

  .stat-card__trend--neutral {
    color: var(--stat-card-muted);
  }

  .stat-card__trend-label {
    font-size: var(--stat-card-trend-size);
    color: var(--stat-card-muted);
    font-weight: 500;
  }

  .stat-card:focus-within {
    outline: 2px solid transparent;
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.4);
  }

  :where(.dark) .stat-card:focus-within {
    box-shadow: 0 0 0 3px rgba(96, 165, 250, 0.4);
  }

  .stat-card--debug {
    outline: 2px dashed rgba(255, 0, 255, 0.5);
    outline-offset: 2px;
    position: relative;
  }

  .stat-card--debug::after {
    content: attr(data-debug-info);
    position: absolute;
    top: -1.75rem;
    left: 0;
    background: rgba(255, 255, 255, 0.95);
    color: #db2777;
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
    font-size: 0.75rem;
    font-family: monospace;
    pointer-events: none;
  }

  :where(.dark) .stat-card--debug::after {
    background: rgba(2, 6, 23, 0.9);
    color: #f472b6;
  }

  @media (prefers-reduced-motion: reduce) {
    .stat-card {
      transition: none !important;
    }
  }

  @media (prefers-contrast: high) {
    .stat-card {
      --stat-card-border: currentColor;
      --stat-card-shadow: none;
    }

    .stat-card__label,
    .stat-card__trend,
    .stat-card__trend-label {
      color: currentColor;
    }
  }
</style>
