---
interface Props {
  id: string;
  title?: string;
  position?: 'left' | 'right';
  size?: 'sm' | 'md' | 'lg' | 'full';
  dismissible?: boolean;
  className?: string;
}

const {
  id,
  title,
  position = 'right',
  size = 'md',
  dismissible = true,
  className = '',
} = Astro.props;

const panelClasses = [
  'drawer__panel',
  `drawer__panel--${position}`,
  `drawer__panel--size-${size}`,
  className,
]
  .filter(Boolean)
  .join(' ');
---

<div
  id={id}
  class="drawer"
  data-drawer
  aria-hidden="true"
>
  <div class="drawer__backdrop" data-drawer-backdrop></div>

  <div
    class={panelClasses}
    data-drawer-panel
    data-position={position}
    role="dialog"
    aria-modal="true"
    aria-labelledby={title ? `${id}-title` : undefined}
  >
    <div class="drawer__content">
      {
        (title || dismissible) && (
          <header class="drawer__header">
            {title && (
              <h2 id={`${id}-title`} class="drawer__title">
                {title}
              </h2>
            )}
            {dismissible && (
              <button
                type="button"
                class="drawer__close"
                data-drawer-close
                aria-label="Close drawer"
              >
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  aria-hidden="true"
                >
                  <path d="M18 6L6 18M6 6l12 12" />
                </svg>
              </button>
            )}
          </header>
        )
      }

      <div class="drawer__body">
        <slot />
      </div>

      <footer class="drawer__footer">
        <div class="drawer__actions">
          <slot name="actions">
            {
              dismissible && (
                <button
                  type="button"
                  class="drawer__button"
                  data-drawer-close
                >
                  Close
                </button>
              )
            }
          </slot>
        </div>
      </footer>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    const drawers = Array.from(
      document.querySelectorAll('[data-drawer]')
    ).filter((el) => el instanceof HTMLElement);
    if (!drawers.length) return;

    const lastFocusMap = new WeakMap();
    const ROOT_VISIBLE_CLASS = 'drawer--visible';
    const BACKDROP_VISIBLE_CLASS = 'drawer__backdrop--visible';
    const PANEL_OPEN_CLASS = 'drawer__panel--open';
    const TRANSITION_DURATION = 300;

    const getFocusableChildren = (container) =>
      Array.from(
        container.querySelectorAll(
          'a[href], button:not([disabled]), textarea, input, select, [tabindex]'
        )
      ).filter(
        (el) =>
          el instanceof HTMLElement &&
          el.tabIndex !== -1 &&
          !el.hasAttribute('disabled')
      );

    const closeDrawer = (drawer) => {
      if (!drawer) return;
      const backdrop = drawer.querySelector('[data-drawer-backdrop]');
      const panel = drawer.querySelector('[data-drawer-panel]');
      if (backdrop instanceof HTMLElement) {
        backdrop.classList.remove(BACKDROP_VISIBLE_CLASS);
      }
      if (panel instanceof HTMLElement) {
        panel.classList.remove(PANEL_OPEN_CLASS);
      }
      drawer.setAttribute('aria-hidden', 'true');
      window.setTimeout(() => {
        drawer.classList.remove(ROOT_VISIBLE_CLASS);
      }, TRANSITION_DURATION);
      const last = lastFocusMap.get(drawer);
      if (last instanceof HTMLElement) {
        last.focus({ preventScroll: true });
      }
      if (!document.querySelector('[data-drawer][aria-hidden="false"]')) {
        document.body.style.removeProperty('overflow');
      }
    };

    drawers.forEach((drawer) => {
      const backdrop = drawer.querySelector('[data-drawer-backdrop]');
      const panel = drawer.querySelector('[data-drawer-panel]');
      const closeButtons = drawer.querySelectorAll('[data-drawer-close]');

      closeButtons.forEach((button) => {
        button.addEventListener('click', () => closeDrawer(drawer));
      });

      if (backdrop instanceof HTMLElement) {
        backdrop.addEventListener('click', () => closeDrawer(drawer));
      }

      drawer.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          event.preventDefault();
          closeDrawer(drawer);
        } else if (event.key === 'Tab' && panel instanceof HTMLElement) {
          const focusable = getFocusableChildren(panel);
          if (!focusable.length) return;
          const first = focusable[0];
          const last = focusable[focusable.length - 1];
          if (event.shiftKey && document.activeElement === first) {
            event.preventDefault();
            last.focus({ preventScroll: true });
          } else if (!event.shiftKey && document.activeElement === last) {
            event.preventDefault();
            first.focus({ preventScroll: true });
          }
        }
      });
    });

    const openDrawer = (drawer) => {
      if (!drawer) return;
      const backdrop = drawer.querySelector('[data-drawer-backdrop]');
      const panel = drawer.querySelector('[data-drawer-panel]');
      if (!(panel instanceof HTMLElement)) return;
      lastFocusMap.set(
        drawer,
        document.activeElement instanceof HTMLElement
          ? document.activeElement
          : null
      );
      drawer.classList.add(ROOT_VISIBLE_CLASS);
      requestAnimationFrame(() => {
        if (backdrop instanceof HTMLElement) {
          backdrop.classList.add(BACKDROP_VISIBLE_CLASS);
        }
        panel.classList.add(PANEL_OPEN_CLASS);
      });
      drawer.setAttribute('aria-hidden', 'false');
      document.body.style.setProperty('overflow', 'hidden');
      const focusable = getFocusableChildren(panel);
      (focusable[0] || panel).focus({ preventScroll: true });
    };

    document.addEventListener('click', (event) => {
      const trigger =
        event.target instanceof HTMLElement
          ? event.target.closest('[data-drawer-trigger]')
          : null;
      if (!trigger) return;
      const targetId = trigger.getAttribute('data-drawer-trigger');
      if (!targetId) return;
      const drawer = document.getElementById(targetId);
      if (!(drawer instanceof HTMLElement)) return;
      openDrawer(drawer);
    });
  })();
</script>

<style is:inline>
  .drawer {
    position: fixed;
    inset: 0;
    z-index: 50;
    width: 100%;
    height: 100%;
    pointer-events: none;
    visibility: hidden;
  }
  .drawer--visible {
    pointer-events: auto;
    visibility: visible;
  }
  .drawer__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(2, 6, 23, 0.8);
    opacity: 0;
    transition: opacity 0.25s ease;
    backdrop-filter: blur(2px);
  }
  .drawer__backdrop--visible {
    opacity: 1;
  }
  .drawer__panel {
    --drawer-panel-width: 24rem;
    position: absolute;
    top: 0;
    height: 100%;
    width: min(100%, var(--drawer-panel-width));
    background: var(--drawer-bg, #ffffff);
    color: var(--drawer-text, #0f172a);
    border: 1px solid var(--drawer-border, rgba(15, 23, 42, 0.08));
    box-shadow: 0 25px 80px rgba(15, 23, 42, 0.25);
    transform: translateX(100%);
    transition: transform 0.3s ease;
    display: flex;
    flex-direction: column;
  }
  .drawer__panel--left {
    left: 0;
    transform: translateX(-100%);
    border-right-width: 2px;
  }
  .drawer__panel--right {
    right: 0;
    transform: translateX(100%);
    border-left-width: 2px;
  }
  .drawer__panel--open {
    transform: translateX(0);
  }
  .drawer__panel--size-sm {
    --drawer-panel-width: 20rem;
  }
  .drawer__panel--size-md {
    --drawer-panel-width: 24rem;
  }
  .drawer__panel--size-lg {
    --drawer-panel-width: 30rem;
  }
  .drawer__panel--size-full {
    --drawer-panel-width: clamp(22rem, 80vw, 60rem);
  }
  :where(.dark) .drawer__panel {
    --drawer-bg: #0f172a;
    --drawer-text: #f8fafc;
    --drawer-border: rgba(148, 163, 184, 0.4);
    box-shadow: 0 30px 80px rgba(2, 6, 23, 0.75);
  }
  .drawer__content {
    display: flex;
    flex-direction: column;
    height: 100%;
  }
  .drawer__header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    justify-content: space-between;
    padding: 1rem 1.5rem;
    border-bottom: 1px solid var(--drawer-border, rgba(15, 23, 42, 0.08));
    background: rgba(15, 23, 42, 0.03);
  }
  :where(.dark) .drawer__header {
    background: rgba(148, 163, 184, 0.12);
  }
  .drawer__title {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 600;
    color: inherit;
  }
  .drawer__close {
    border: 1px solid transparent;
    border-radius: 999px;
    width: 2.5rem;
    height: 2.5rem;
    background: rgba(255, 255, 255, 0.9);
    color: inherit;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition:
      background-color 0.2s ease,
      border-color 0.2s ease,
      color 0.2s ease;
  }
  .drawer__close:hover {
    background: rgba(37, 99, 235, 0.1);
  }
  .drawer__close:focus-visible {
    outline: 2px solid rgba(37, 99, 235, 0.7);
    outline-offset: 2px;
  }
  :where(.dark) .drawer__close {
    background: rgba(15, 23, 42, 0.75);
  }
  .drawer__body {
    flex: 1;
    padding: 1.5rem;
    overflow-y: auto;
    font-size: 0.95rem;
    line-height: 1.6;
  }
  .drawer__footer {
    border-top: 1px solid var(--drawer-border, rgba(15, 23, 42, 0.08));
    background: rgba(15, 23, 42, 0.02);
    padding: 1rem 1.5rem;
  }
  :where(.dark) .drawer__footer {
    background: rgba(148, 163, 184, 0.08);
  }
  .drawer__actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  @media (min-width: 640px) {
    .drawer__actions {
      flex-direction: row;
      justify-content: flex-end;
      align-items: center;
    }
  }
  .drawer__button {
    border-radius: 0.85rem;
    border: 1px solid var(--drawer-border, rgba(15, 23, 42, 0.08));
    background: var(--drawer-bg, #ffffff);
    padding: 0.65rem 1.5rem;
    font-weight: 600;
    color: inherit;
    cursor: pointer;
    transition:
      background-color 0.2s ease,
      border-color 0.2s ease,
      color 0.2s ease;
  }
  .drawer__button:hover {
    border-color: rgba(37, 99, 235, 0.7);
    background: rgba(37, 99, 235, 0.08);
  }
  .drawer__button:focus-visible {
    outline: 2px solid rgba(37, 99, 235, 0.7);
    outline-offset: 2px;
  }
  @media (prefers-reduced-motion: reduce) {
    .drawer__panel,
    .drawer__backdrop,
    .drawer__close,
    .drawer__button {
      transition: none;
    }
  }
</style>
