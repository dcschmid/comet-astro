---
interface Tab {
  id: string;
  label: string;
  content?: string;
  disabled?: boolean;
  icon?: string;
  badge?: string | number;
}

type TabSize = 'sm' | 'md' | 'lg';
type TabVariant = 'default' | 'minimal' | 'pills' | 'cards';
type TabOrientation = 'horizontal' | 'vertical';

interface Props {
  tabs: Tab[];
  activeId?: string;
  className?: string;
  size?: TabSize;
  variant?: TabVariant;
  orientation?: TabOrientation;
  centered?: boolean;
  fullWidth?: boolean;
  destroyInactive?: boolean;
  ariaLabel?: string;
}

const {
  tabs = [],
  activeId = tabs.find((tab) => !tab.disabled)?.id || tabs[0]?.id,
  className = '',
  size = 'md',
  variant = 'default',
  orientation = 'horizontal',
  centered = false,
  fullWidth = false,
  destroyInactive = false,
  ariaLabel = 'Tabs',
} = Astro.props as Props;

const enabledTabs = tabs.filter((tab) => !tab.disabled);
const validActiveId =
  activeId && tabs.some((tab) => tab.id === activeId && !tab.disabled)
    ? activeId
    : enabledTabs[0]?.id;

const tabsId = `tabs-${Math.random().toString(36).slice(2, 9)}`;
const getTabId = (id: string) => `${tabsId}-tab-${id}`;
const getPanelId = (id: string) => `${tabsId}-panel-${id}`;

const rootClasses = [
  'tabs',
  `tabs--size-${size}`,
  `tabs--variant-${variant}`,
  `tabs--orientation-${orientation}`,
  centered ? 'tabs--centered' : '',
  fullWidth ? 'tabs--full' : '',
  className,
]
  .filter(Boolean)
  .join(' ');

const hasBadge = (tab: Tab) => tab.badge !== undefined && tab.badge !== null && tab.badge !== '';
---

<div id={tabsId} class={rootClasses} data-auto-activate="true">
  <div
    role="tablist"
    aria-label={ariaLabel}
    aria-orientation={orientation}
    class="tabs__list"
  >
    {tabs.map((tab) => {
      const isActive = tab.id === validActiveId;
      return (
        <button
          type="button"
          role="tab"
          id={getTabId(tab.id)}
          data-tab-id={tab.id}
          aria-selected={isActive}
          aria-controls={getPanelId(tab.id)}
          aria-disabled={tab.disabled}
          tabindex={isActive ? 0 : -1}
          disabled={tab.disabled}
          class={[
            'tabs__tab',
            tab.disabled ? 'tabs__tab--disabled' : '',
            isActive ? 'tabs__tab--active' : '',
            tab.icon ? 'tabs__tab--with-icon' : '',
            hasBadge(tab) ? 'tabs__tab--with-badge' : '',
          ]
            .filter(Boolean)
            .join(' ')}
          title={tab.disabled ? `${tab.label} (disabled)` : tab.label}
        >
          {tab.icon && (
            <span class="tabs__icon" aria-hidden="true" set:html={tab.icon} />
          )}
          <span class="tabs__label">{tab.label}</span>
          {tab.badge && (
            <span class="tabs__badge" aria-label={`${tab.badge} notifications`}>
              {tab.badge}
            </span>
          )}
        </button>
      );
    })}
  </div>

  <div class="tabs__panels">
    {tabs.map((tab) => {
      const isActive = tab.id === validActiveId;
      if (!destroyInactive || isActive) {
        return (
          <div
            role="tabpanel"
            id={getPanelId(tab.id)}
            data-panel-id={tab.id}
            aria-labelledby={getTabId(tab.id)}
            aria-hidden={!isActive}
            tabindex={isActive ? 0 : -1}
            class={['tabs__panel', isActive ? 'tabs__panel--active' : 'tabs__panel--hidden']
              .filter(Boolean)
              .join(' ')}
          >
            {tab.content ? (
              <div set:html={tab.content} />
            ) : (
              <div class="tabs__empty">No content provided for this tab</div>
            )}
          </div>
        );
      }
      return null;
    })}

    {tabs.length === 0 && (
      <div class="tabs__empty tabs__empty--global" role="status" aria-live="polite">
        No tabs available
      </div>
    )}
  </div>
</div>

<script
  is:inline
  define:vars={{ tabsId, destroyInactive }}
>
  (function () {
    const root = document.getElementById(tabsId);
    if (!root) return;

    const tablist = root.querySelector('.tabs__list');
    const tabs = Array.from(root.querySelectorAll('.tabs__tab'));
    const panels = Array.from(root.querySelectorAll('.tabs__panel'));

    if (!tablist || !tabs.length || !panels.length) return;

    const setActive = (targetId, focus) => {
      tabs.forEach((tab) => {
        const tabId = tab.dataset.tabId;
        const isActive = tabId === targetId;
        tab.setAttribute('aria-selected', String(isActive));
        tab.tabIndex = isActive ? 0 : -1;
        tab.classList.toggle('tabs__tab--active', isActive);
        if (focus && isActive) tab.focus();
      });

      panels.forEach((panel) => {
        const panelId = panel.dataset.panelId;
        const isActive = panelId === targetId;
        panel.setAttribute('aria-hidden', String(!isActive));
        panel.tabIndex = isActive ? 0 : -1;
        panel.classList.toggle('tabs__panel--active', isActive);
        panel.classList.toggle('tabs__panel--hidden', !isActive);
        if (destroyInactive && !isActive) {
          panel.classList.add('tabs__panel--destroyed');
        } else {
          panel.classList.remove('tabs__panel--destroyed');
        }
      });

      const activeTab = tabs.find((tab) => tab.dataset.tabId === targetId);
      if (activeTab) {
        const liveRegion = document.createElement('div');
        liveRegion.className = 'sr-only';
        liveRegion.setAttribute('aria-live', 'polite');
        liveRegion.setAttribute('aria-atomic', 'true');
        liveRegion.textContent = `Switched to ${activeTab.textContent?.trim()} tab`;
        document.body.appendChild(liveRegion);
        setTimeout(() => liveRegion.remove(), 1000);
      }
    };

    const moveFocus = (currentIndex, direction) => {
      const enabledTabs = tabs.filter((tab) => !tab.disabled);
      if (!enabledTabs.length) return;
      let nextIndex = currentIndex;
      if (direction === 'next') {
        nextIndex = (currentIndex + 1) % enabledTabs.length;
      } else if (direction === 'previous') {
        nextIndex = (currentIndex - 1 + enabledTabs.length) % enabledTabs.length;
      } else if (direction === 'first') {
        nextIndex = 0;
      } else if (direction === 'last') {
        nextIndex = enabledTabs.length - 1;
      }
      const nextTab = enabledTabs[nextIndex];
      const targetId = nextTab?.dataset.tabId;
      if (targetId) setActive(targetId, true);
    };

    tabs.forEach((tab) => {
      tab.addEventListener('click', (event) => {
        event.preventDefault();
        if (!tab.disabled) {
          const tabId = tab.dataset.tabId;
          if (tabId) setActive(tabId, true);
        }
      });

      tab.addEventListener('keydown', (event) => {
        const enabledTabs = tabs.filter((t) => !t.disabled);
        const currentIndex = enabledTabs.findIndex((t) => t === tab);

        switch (event.key) {
          case 'ArrowRight':
          case 'ArrowDown':
            event.preventDefault();
            moveFocus(currentIndex, 'next');
            break;
          case 'ArrowLeft':
          case 'ArrowUp':
            event.preventDefault();
            moveFocus(currentIndex, 'previous');
            break;
          case 'Home':
            event.preventDefault();
            moveFocus(0, 'first');
            break;
          case 'End':
            event.preventDefault();
            moveFocus(enabledTabs.length - 1, 'last');
            break;
        }
      });
    });

    panels.forEach((panel) => {
      panel.addEventListener('keydown', (event) => {
        if (event.ctrlKey && (event.key === 'PageUp' || event.key === 'PageDown')) {
          event.preventDefault();
          const activeTab = tabs.find((tab) => tab.getAttribute('aria-selected') === 'true');
          if (!activeTab) return;
          const enabledTabs = tabs.filter((t) => !t.disabled);
          const currentIndex = enabledTabs.findIndex((t) => t === activeTab);
          moveFocus(currentIndex, event.key === 'PageUp' ? 'previous' : 'next');
        }
      });
    });

    const observer = new MutationObserver(() => {
      const activeTab = tabs.find((tab) => tab.getAttribute('aria-selected') === 'true');
      if (activeTab?.dataset.tabId) {
        setActive(activeTab.dataset.tabId);
      }
    });

    tabs.forEach((tab) => {
      observer.observe(tab, { attributes: true, attributeFilter: ['aria-selected', 'disabled'] });
    });

    window.addEventListener('beforeunload', () => observer.disconnect());

    const initialActive = tabs.find((tab) => tab.getAttribute('aria-selected') === 'true');
    if (initialActive?.dataset.tabId) setActive(initialActive.dataset.tabId);
  })();
</script>

<style>
  .tabs {
    --tabs-gap: 0.5rem;
    --tabs-padding: 0.75rem;
    --tabs-font-size: 0.95rem;
    --tabs-panel-gap: 1rem;
    --tabs-tab-bg: transparent;
    --tabs-tab-border: transparent;
    --tabs-color: #0f172a;
    --tabs-muted: #475569;
    --tabs-hover-bg: rgba(59, 130, 246, 0.08);
    --tabs-active-bg: rgba(59, 130, 246, 0.1);
    --tabs-active-border: #2563eb;
    width: 100%;
    color: var(--tabs-color);
    display: flex;
    flex-direction: column;
    gap: var(--tabs-panel-gap);
  }

  :where(.dark) .tabs {
    --tabs-color: #f8fafc;
    --tabs-muted: #cbd5f5;
    --tabs-hover-bg: rgba(148, 163, 184, 0.15);
    --tabs-active-bg: rgba(59, 130, 246, 0.25);
    --tabs-active-border: #60a5fa;
  }

  .tabs--orientation-vertical {
    flex-direction: row;
    gap: 1.5rem;
  }

  .tabs--size-sm {
    --tabs-gap: 0.4rem;
    --tabs-padding: 0.5rem;
    --tabs-font-size: 0.85rem;
  }

  .tabs--size-lg {
    --tabs-gap: 0.75rem;
    --tabs-padding: 0.9rem;
    --tabs-font-size: 1rem;
  }

  .tabs__list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--tabs-gap);
  }

  .tabs--orientation-vertical .tabs__list {
    flex-direction: column;
    min-width: 220px;
    flex-shrink: 0;
  }

  .tabs__tab {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: var(--tabs-padding);
    border-radius: 0.8rem;
    border: 2px solid var(--tabs-tab-border);
    background: var(--tabs-tab-bg);
    color: inherit;
    font-size: var(--tabs-font-size);
    font-weight: 600;
    cursor: pointer;
    min-height: 2.5rem;
    transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }

  .tabs--variant-default .tabs__list {
    border-bottom: 1px solid rgba(148, 163, 184, 0.35);
    padding-bottom: 0.25rem;
  }

  .tabs--variant-default .tabs__tab {
    border-radius: 0;
    border-width: 0 0 3px 0;
    border-color: transparent;
  }

  .tabs--variant-minimal .tabs__tab {
    border: none;
    border-radius: 0.65rem;
  }

  .tabs--variant-minimal .tabs__tab--active {
    background: rgba(37, 99, 235, 0.1);
  }

  .tabs--variant-pills .tabs__tab {
    border: none;
    border-radius: 0.75rem;
    background: transparent;
  }

  .tabs--variant-pills .tabs__tab--active {
    background: #fff;
    color: var(--tabs-color);
  }

  :where(.dark) .tabs--variant-pills .tabs__tab--active {
    background: rgba(15, 23, 42, 0.8);
  }

  .tabs--variant-cards .tabs__tab {
    border-radius: 1rem;
    border-width: 2px;
    background: #fff;
  }

  :where(.dark) .tabs--variant-cards .tabs__tab {
    background: #0f172a;
  }

  .tabs--variant-cards .tabs__tab--active {
    background: var(--tabs-active-border);
    color: #fff;
    border-color: var(--tabs-active-border);
    box-shadow: 0 15px 30px rgba(37, 99, 235, 0.2);
  }

  :where(.dark) .tabs--variant-cards .tabs__tab--active {
    color: #0f172a;
  }

  .tabs__tab:hover {
    background: var(--tabs-hover-bg);
  }

  .tabs__tab:focus-visible {
    outline: 2px solid rgba(59, 130, 246, 0.4);
    outline-offset: 2px;
  }

  .tabs__tab--active {
    background: var(--tabs-active-bg);
    border-color: var(--tabs-active-border);
    color: var(--tabs-active-border);
  }

  .tabs__tab--disabled {
    color: var(--tabs-muted);
    cursor: not-allowed;
    opacity: 0.6;
  }

  .tabs__tab--with-icon .tabs__icon {
    display: inline-flex;
    width: 1.1em;
    height: 1.1em;
  }

  .tabs__label {
    flex: 1;
    min-width: 0;
    text-align: left;
  }

  .tabs__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.35rem;
    height: 1.35rem;
    padding: 0 0.35rem;
    border-radius: 999px;
    background: rgba(148, 163, 184, 0.25);
    font-size: 0.75rem;
  }

  .tabs__panels {
    flex: 1;
  }

  .tabs--variant-default .tabs__panel,
  .tabs--variant-pills .tabs__panel,
  .tabs--variant-cards .tabs__panel {
    border: 1px solid rgba(148, 163, 184, 0.35);
    border-radius: 1rem;
    padding: 1.25rem;
    background: #fff;
    box-shadow: 0 12px 30px rgba(15, 23, 42, 0.08);
  }

  :where(.dark) .tabs--variant-default .tabs__panel,
  :where(.dark) .tabs--variant-pills .tabs__panel,
  :where(.dark) .tabs--variant-cards .tabs__panel {
    background: #0f172a;
    border-color: rgba(71, 85, 105, 0.6);
  }

  .tabs--variant-minimal .tabs__panel {
    padding: 0.25rem 0;
  }

  .tabs__panel {
    display: none;
    outline: none;
  }

  .tabs__panel:focus-visible {
    outline: 2px solid rgba(59, 130, 246, 0.4);
    outline-offset: 4px;
  }

  .tabs__panel--active {
    display: block;
  }

  .tabs__panel--hidden {
    display: none;
  }

  .tabs__panel--destroyed {
    display: none;
  }

  .tabs__empty {
    font-style: italic;
    color: var(--tabs-muted);
    line-height: 1.5;
  }

  .tabs__empty--global {
    text-align: center;
    padding: 1rem 0;
  }

  .tabs--variant-pills .tabs__list {
    background: rgba(226, 232, 240, 0.5);
    border-radius: 1rem;
    padding: 0.4rem;
  }

  .tabs--variant-cards .tabs__tab {
    border-radius: 1rem;
    border-width: 2px;
  }

  .tabs--centered .tabs__list {
    justify-content: center;
  }

  .tabs--full .tabs__list .tabs__tab {
    flex: 1;
  }

  @media (prefers-contrast: high) {
    .tabs__tab {
      border-color: currentColor;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tabs * {
      animation: none !important;
      transition: none !important;
    }
  }
</style>
