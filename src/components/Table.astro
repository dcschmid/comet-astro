---
import type { Column } from './Table.types';

interface Props {
  columns: Column[];
  data: Record<string, any>[];
  striped?: boolean;
  hoverable?: boolean;
  bordered?: boolean;
  compact?: boolean;
  size?: 'sm' | 'md' | 'lg';
  variant?: 'default' | 'minimal' | 'elevated' | 'bordered';
  caption?: string;
  captionSrOnly?: boolean;
  responsive?: boolean;
  loading?: boolean;
  emptyMessage?: string;
  ariaLabel?: string;
  ariaDescribedby?: string;
  debug?: boolean;
  class?: string;
}

const {
  columns,
  data,
  striped = false,
  hoverable = true,
  bordered = false,
  compact = false,
  size = 'md',
  variant = 'default',
  caption,
  captionSrOnly = false,
  responsive = true,
  loading = false,
  emptyMessage = 'No data available',
  ariaLabel,
  ariaDescribedby,
  debug = false,
  class: className = '',
} = Astro.props as Props;

const sizeTokens = {
  sm: {
    font: 'var(--table-font-size-sm)',
    cellPadding: 'var(--table-cell-padding-sm)',
    captionPadding: 'var(--table-caption-padding-sm)',
  },
  md: {
    font: 'var(--table-font-size-md)',
    cellPadding: 'var(--table-cell-padding-md)',
    captionPadding: 'var(--table-caption-padding-md)',
  },
  lg: {
    font: 'var(--table-font-size-lg)',
    cellPadding: 'var(--table-cell-padding-lg)',
    captionPadding: 'var(--table-caption-padding-lg)',
  },
};

const rootClasses = [
  'table',
  `table--size-${size}`,
  `table--variant-${variant}`,
  striped ? 'table--striped' : '',
  hoverable ? 'table--hoverable' : '',
  bordered ? 'table--bordered' : '',
  compact ? 'table--compact' : '',
  responsive ? 'table--responsive' : '',
  loading ? 'table--loading' : '',
  debug ? 'table--debug' : '',
  className,
]
  .filter(Boolean)
  .join(' ');

const captionId = caption ? `table-caption-${Math.random().toString(36).slice(2, 9)}` : undefined;
const debugInfo = debug ? `${size} ${variant} ${data.length} rows` : undefined;
---

<div class={rootClasses} data-debug-info={debugInfo}>
  {loading && (
    <div class="table__loader" aria-hidden="true">
      <div class="table__spinner" role="status" aria-label="Loading data">
        <svg class="table__spinner-icon" viewBox="0 0 24 24">
          <circle class="table__spinner-track" cx="12" cy="12" r="10" stroke-width="4" />
          <path class="table__spinner-indicator" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z" />
        </svg>
        <span>Loading…</span>
      </div>
    </div>
  )}

  <table
    class="table__element"
    aria-label={ariaLabel}
    aria-describedby={ariaDescribedby || captionId}
  >
    {caption && (
      <caption
        id={captionId}
        class={[
          'table__caption',
          captionSrOnly ? 'table__caption--sr-only' : '',
        ]
          .filter(Boolean)
          .join(' ')}
      >
        {caption}
      </caption>
    )}

    <thead class="table__head">
      <tr class="table__row table__row--head">
        {columns.map((col) => (
          <th
            scope="col"
            class={[
              'table__cell table__cell--head',
              `table__cell--align-${col.align || 'left'}`,
              col.sticky ? 'table__cell--sticky' : '',
            ]
              .filter(Boolean)
              .join(' ')}
            style={col.width ? `width: ${col.width}` : undefined}
            aria-sort={col.sortable ? 'none' : undefined}
          >
            {col.sortable ? (
              <button type="button" class="table__sort-button" aria-label={`Sort by ${col.label}`}>
                <span>{col.label}</span>
                <span class="table__sort-icon" aria-hidden="true">↕</span>
              </button>
            ) : (
              col.label
            )}
          </th>
        ))}
      </tr>
    </thead>

    <tbody class="table__body">
      {data.length === 0 ? (
        <tr class="table__row">
          <td colspan={columns.length} class="table__cell table__cell--empty">
            {emptyMessage}
          </td>
        </tr>
      ) : (
        data.map((row, rowIndex) => (
          <tr
            class={[
              'table__row',
              striped && rowIndex % 2 === 1 ? 'table__row--striped' : '',
            ]
              .filter(Boolean)
              .join(' ')}
          >
            {columns.map((col) => (
              <td
                class={[
                  'table__cell',
                  `table__cell--align-${col.align || 'left'}`,
                  col.sticky ? 'table__cell--sticky' : '',
                ]
                  .filter(Boolean)
                  .join(' ')}
                data-column={col.key}
                set:html={row[col.key]}
              />
            ))}
          </tr>
        ))
      )}
    </tbody>
  </table>
</div>

<style>
  .table {
    --table-font-size-sm: 0.875rem;
    --table-font-size-md: 0.95rem;
    --table-font-size-lg: 1rem;
    --table-cell-padding-sm: 0.35rem 0.75rem;
    --table-cell-padding-md: 0.75rem 1rem;
    --table-cell-padding-lg: 1rem 1.5rem;
    --table-caption-padding-sm: 0.5rem;
    --table-caption-padding-md: 0.75rem;
    --table-caption-padding-lg: 1rem;
    --table-border-color: rgba(148, 163, 184, 0.7);
    --table-header-bg: #f1f5f9;
    --table-header-color: #0f172a;
    --table-body-color: #1f2937;
    --table-row-hover: rgba(59, 130, 246, 0.08);
    --table-row-striped: rgba(226, 232, 240, 0.5);
    --table-background: #fff;
    --table-shadow: 0 12px 35px rgba(15, 23, 42, 0.08);
    position: relative;
    border-radius: 1rem;
    border: 1px solid var(--table-border-color);
    background: var(--table-background);
    color: var(--table-body-color);
    font-size: var(--table-font-size-md);
    overflow: hidden;
  }

  :where(.dark) .table {
    --table-border-color: rgba(71, 85, 105, 0.6);
    --table-header-bg: rgba(15, 23, 42, 0.65);
    --table-header-color: #f8fafc;
    --table-body-color: #e2e8f0;
    --table-row-hover: rgba(59, 130, 246, 0.2);
    --table-row-striped: rgba(30, 41, 59, 0.7);
    --table-background: #0f172a;
    --table-shadow: 0 30px 60px rgba(2, 6, 23, 0.75);
  }

  .table--variant-minimal {
    border-color: transparent;
    background: transparent;
    box-shadow: none;
  }

  .table--variant-elevated {
    border-color: rgba(148, 163, 184, 0.5);
    box-shadow: var(--table-shadow);
  }

  .table--variant-bordered {
    border-width: 2px;
    border-color: rgba(15, 23, 42, 0.35);
  }

  .table--size-sm {
    font-size: var(--table-font-size-sm);
  }

  .table--size-lg {
    font-size: var(--table-font-size-lg);
  }

  .table--responsive {
    overflow-x: auto;
  }

  .table__element {
    width: 100%;
    border-collapse: collapse;
  }

  .table__caption {
    padding: var(--table-caption-padding-md);
    font-weight: 600;
    color: var(--table-body-color);
    text-align: left;
  }

  .table--size-sm .table__caption {
    padding: var(--table-caption-padding-sm);
  }

  .table--size-lg .table__caption {
    padding: var(--table-caption-padding-lg);
  }

  .table__caption--sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
  }

  .table__head {
    background: var(--table-header-bg);
    color: var(--table-header-color);
  }

  .table__row {
    transition: background 0.15s ease;
  }

  .table--hoverable .table__row:hover {
    background: var(--table-row-hover);
  }

  .table--striped .table__row--striped {
    background: var(--table-row-striped);
  }

  .table__row--head {
    border-bottom: 1px solid var(--table-border-color);
  }

  .table__body {
    color: var(--table-body-color);
  }

  .table__cell {
    padding: var(--table-cell-padding-md);
    border-bottom: 1px solid rgba(148, 163, 184, 0.35);
    vertical-align: top;
  }

  .table--size-sm .table__cell {
    padding: var(--table-cell-padding-sm);
  }

  .table--size-lg .table__cell {
    padding: var(--table-cell-padding-lg);
  }

  .table__cell--head {
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .table--bordered .table__cell {
    border-right: 1px solid rgba(148, 163, 184, 0.35);
  }

  .table__cell:last-child {
    border-right: none;
  }

  .table__cell--align-center {
    text-align: center;
  }

  .table__cell--align-right {
    text-align: right;
  }

  .table__cell--sticky {
    position: sticky;
    left: 0;
    background: inherit;
    z-index: 5;
  }

  .table__cell--empty {
    text-align: center;
    font-style: italic;
    color: rgba(100, 116, 139, 0.9);
  }

  .table__sort-button {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    border: none;
    background: transparent;
    color: inherit;
    font-weight: inherit;
    text-transform: inherit;
    cursor: pointer;
    padding: 0.15rem 0.25rem;
    border-radius: 0.5rem;
    transition: background 0.2s ease;
  }

  .table__sort-button:focus-visible {
    outline: 2px solid rgba(59, 130, 246, 0.4);
    outline-offset: 2px;
  }

  .table__sort-button:hover {
    background: rgba(59, 130, 246, 0.08);
  }

  .table__sort-icon {
    font-size: 0.75em;
    opacity: 0.6;
  }

  .table__loader {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(248, 250, 252, 0.85);
    z-index: 10;
    border-radius: inherit;
  }

  :where(.dark) .table__loader {
    background: rgba(15, 23, 42, 0.75);
  }

  .table__spinner {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--table-body-color);
    font-weight: 600;
  }

  .table__spinner-icon {
    width: 1.5rem;
    height: 1.5rem;
    animation: table-spin 1s linear infinite;
  }

  .table__spinner-track {
    fill: none;
    stroke: currentColor;
    opacity: 0.2;
  }

  .table__spinner-indicator {
    fill: currentColor;
    opacity: 0.6;
  }

  @keyframes table-spin {
    to {
      transform: rotate(360deg);
    }
  }

  .table--loading .table__element {
    opacity: 0.45;
  }

  .table--debug {
    outline: 2px dashed rgba(244, 114, 182, 0.8);
    outline-offset: 3px;
  }

  .table--debug::after {
    content: attr(data-debug-info);
    position: absolute;
    top: -1.5rem;
    left: 0;
    background: rgba(255, 255, 255, 0.95);
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
    font-size: 0.75rem;
    color: #db2777;
    font-family: monospace;
  }

  :where(.dark) .table--debug::after {
    background: rgba(15, 23, 42, 0.95);
    color: #f472b6;
  }

  @media (prefers-contrast: high) {
    .table,
    .table__cell,
    .table__caption,
    .table__sort-button {
      color: currentColor;
      border-color: currentColor;
    }

    .table__loader {
      background: rgba(255, 255, 255, 0.4);
    }

    :where(.dark) .table__loader {
      background: rgba(0, 0, 0, 0.6);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .table *,
    .table__spinner-icon {
      transition: none !important;
      animation: none !important;
    }
  }
</style>
