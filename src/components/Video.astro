---
interface Props {
  src: string;
  poster?: string;
  autoplay?: boolean;
  loop?: boolean;
  muted?: boolean;
  controls?: boolean;
  playsInline?: boolean;
  preload?: 'none' | 'metadata' | 'auto';
  variant?: 'default' | 'inline' | 'featured' | 'minimal';
  size?: 'sm' | 'md' | 'lg' | 'xl';
  aspectRatio?: '16/9' | '4/3' | '1/1' | '21/9' | '9/16' | 'auto';
  rounded?: boolean;
  title?: string;
  description?: string;
  caption?: string;
  ariaLabel?: string;
  loading?: boolean;
  error?: string;
  responsive?: boolean;
  maxWidth?: string;
  className?: string;
}

const {
  src,
  poster,
  autoplay = false,
  loop = false,
  muted = false,
  controls = true,
  playsInline = true,
  preload = 'metadata',
  variant = 'default',
  size = 'md',
  aspectRatio = '16/9',
  rounded = true,
  title,
  description,
  caption,
  ariaLabel,
  loading = false,
  error,
  responsive = true,
  maxWidth,
  className = '',
} = Astro.props as Props;

const videoId = `video-${Math.random().toString(36).slice(2, 9)}`;

const rootClasses = [
  'video',
  `video--variant-${variant}`,
  `video--size-${size}`,
  rounded ? 'video--rounded' : '',
  responsive ? 'video--responsive' : '',
  loading ? 'video--loading' : '',
  error ? 'video--error' : '',
  className,
]
  .filter(Boolean)
  .join(' ');

const videoWrapperClasses = [
  'video__media',
  aspectRatio !== 'auto' ? `video__media--ratio-${aspectRatio.replace('/', '-')}` : '',
  variant === 'inline' ? 'video__media--inline' : '',
].filter(Boolean).join(' ');
---

<figure
  class={rootClasses}
  style={maxWidth ? `max-width: ${maxWidth}` : undefined}
  data-video-variant={variant}
  data-video-size={size}
>
  {description && (
    <div id={`${videoId}-description`} class="video__sr">
      {description}
    </div>
  )}

  <div class={videoWrapperClasses}>
    {loading && (
      <div class="video__loading" aria-hidden="true">
        <div class="video__spinner" />
        <span class="video__loading-text">Loading video...</span>
      </div>
    )}

    {error && (
      <div class="video__error" role="alert" aria-live="polite">
        <span class="video__error-title">Video not available</span>
        <p class="video__error-text">{error}</p>
      </div>
    )}

    {!loading && !error && (
      <video
        id={videoId}
        class="video__element"
        src={src}
        poster={poster}
        autoplay={autoplay}
        loop={loop}
        muted={muted}
        controls={controls}
        playsinline={playsInline}
        preload={preload}
        aria-label={ariaLabel || title}
        aria-describedby={description ? `${videoId}-description` : undefined}
        title={title}
      >
        <slot name="fallback">
          <div class="video__fallback">
            <span>Ihr Browser unterstützt das Video-Element nicht.</span>
          </div>
        </slot>
      </video>
    )}
  </div>

  {(caption || Astro.slots.has('caption')) && (
    <figcaption id={`${videoId}-caption`} class="video__caption">
      <slot name="caption">{caption}</slot>
    </figcaption>
  )}

  <slot name="overlay" />
</figure>

<style>
  .video {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    border: 1px solid rgba(148, 163, 184, 0.5);
    background: rgba(255, 255, 255, 0.95);
    padding: 1rem;
    box-shadow: 0 12px 30px rgba(15, 23, 42, 0.1);
  }

  :where(.dark) .video {
    background: rgba(2, 6, 23, 0.9);
    border-color: rgba(71, 85, 105, 0.6);
  }

  .video--rounded {
    border-radius: 1.5rem;
  }

  .video--size-sm {
    max-width: 20rem;
    padding: 0.75rem;
  }

  .video--size-lg {
    max-width: 52rem;
    padding: 1.25rem;
  }

  .video--size-xl {
    max-width: 64rem;
    padding: 1.5rem;
  }

  .video--variant-inline {
    padding: 0;
    border: none;
    box-shadow: none;
  }

  .video__media {
    position: relative;
    overflow: hidden;
    background: #0f172a;
    border-radius: 1rem;
  }

  .video__media--inline {
    border-radius: 1.5rem;
  }

  .video__media--ratio-16-9 {
    aspect-ratio: 16 / 9;
  }

  .video__media--ratio-4-3 {
    aspect-ratio: 4 / 3;
  }

  .video__media--ratio-1-1 {
    aspect-ratio: 1 / 1;
  }

  .video__media--ratio-21-9 {
    aspect-ratio: 21 / 9;
  }

  .video__media--ratio-9-16 {
    aspect-ratio: 9 / 16;
  }

  .video__element {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .video__loading,
  .video__error {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 1rem;
    gap: 0.5rem;
    text-align: center;
  }

  .video__loading {
    background: rgba(248, 250, 252, 0.9);
  }

  :where(.dark) .video__loading {
    background: rgba(15, 23, 42, 0.9);
  }

  .video__spinner {
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 999px;
    border: 2px solid rgba(148, 163, 184, 0.6);
    border-top-color: rgba(59, 130, 246, 0.9);
    animation: spin 1s linear infinite;
  }

  .video__loading-text {
    font-size: 0.875rem;
    color: rgba(71, 85, 105, 0.9);
  }

  .video__error {
    background: rgba(248, 250, 252, 0.95);
    color: #0f172a;
  }

  :where(.dark) .video__error {
    background: rgba(15, 23, 42, 0.95);
    color: #f8fafc;
  }

  .video__error-title {
    font-size: 0.95rem;
    font-weight: 600;
  }

  .video__caption {
    font-size: 0.9rem;
    color: rgba(71, 85, 105, 0.9);
    line-height: 1.5;
  }

  :where(.dark) .video__caption {
    color: rgba(203, 213, 225, 0.85);
  }

  .video__fallback {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
    background: rgba(248, 250, 252, 0.95);
    color: rgba(71, 85, 105, 0.9);
  }

  :where(.dark) .video__fallback {
    background: rgba(15, 23, 42, 0.95);
    color: rgba(203, 213, 225, 0.9);
  }

  .video__sr {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  @media (prefers-contrast: high) {
    .video {
      border-width: 2px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .video,
    .video__element {
      transition: none !important;
    }
  }
</style>
