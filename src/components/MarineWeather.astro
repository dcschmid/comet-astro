---
/**
 * MarineWeather – Minimal marine snapshot (WCAG AAA)
 * Tailwind utilities only; Astro only. No overengineering.
 * Shows: Wave Height, Sea Temp, Wind Speed, Condition + Updated time.
 * Optional live fetch (Open‑Meteo Marine API) via latitude + longitude, else fallback demo values.
 */

interface Props {
  latitude?: number;
  longitude?: number;
  location?: string;
  disableFetch?: boolean;
  refreshInterval?: number; // minutes; 0 = no auto refresh
  ariaLabel?: string;
  class?: string;
}

const props = Astro.props as Props;
const {
  latitude,
  longitude,
  location = 'Demo Marine Location',
  disableFetch = false,
  refreshInterval = 0,
  ariaLabel,
  class: className = '',
} = props;

const label = ariaLabel || `Marine weather for ${location}`;
const baseClasses = ['marine-weather', className].filter(Boolean).join(' ');
const metricCardClass = (type?: string) =>
  ['marine-weather__metric-card', type && `marine-weather__metric-card--${type}`]
    .filter(Boolean)
    .join(' ');

// Fallback demo values
const fallback = {
  waveHeight: 0.8, // m
  seaTemp: 18.4, // °C
  windSpeed: 12, // km/h
  windDirection: 135, // degrees
  updated: new Date().toISOString(),
};

function dirText(deg: number) {
  const dirs = [
    'N',
    'NNE',
    'NE',
    'ENE',
    'E',
    'ESE',
    'SE',
    'SSE',
    'S',
    'SSW',
    'SW',
    'WSW',
    'W',
    'WNW',
    'NW',
    'NNW',
  ];
  return dirs[Math.round(deg / 22.5) % 16];
}
function waveClass(h: number) {
  if (h >= 3) return ['Extreme', 'extreme'];
  if (h >= 2) return ['Rough', 'rough'];
  if (h >= 1) return ['Moderate', 'moderate'];
  if (h >= 0.5) return ['Calm', 'calm'];
  return ['Flat', 'flat'];
}
const initialWave = waveClass(fallback.waveHeight);
---

<div
  class={baseClasses}
  role="region"
  aria-label={label}
  aria-busy={!disableFetch && latitude != null && longitude != null
    ? 'true'
    : 'false'}
  data-marine
  data-lat={latitude}
  data-lon={longitude}
  data-disable-fetch={disableFetch}
  data-refresh={refreshInterval}
  data-state={!disableFetch && latitude != null && longitude != null
    ? 'loading'
    : 'static'}
>
  <header
    class="marine-weather__header"
  >
    <h2
      class="marine-weather__title"
    >
      <span aria-hidden="true" class="marine-weather__title-icon">🌊</span>
      <span class="marine-weather__location" data-location>{location}</span>
    </h2>
    <p
      class="marine-weather__status-text"
      aria-live="polite"
      data-status
    >
      {
        !disableFetch && latitude != null && longitude != null
          ? 'Lade Marinedaten …'
          : 'Statische Demodaten'
      }
    </p>
  </header>
  <div class="marine-weather__metrics" data-metrics>
    <div class={metricCardClass('wave')} data-metric="wave">
      <span class="marine-weather__metric-label">Wave Height</span>
      <span class="marine-weather__metric-value" data-wave>{fallback.waveHeight.toFixed(1)} m</span>
      <span
        class="marine-weather__wave-state"
        data-wave-cond
      >
        <span
          class={`marine-weather__wave-indicator marine-weather__wave-indicator--${initialWave[1]}`}
          data-wave-ind
          aria-hidden="true"></span>
        <span data-wave-label>{initialWave[0]}</span>
      </span>
    </div>
    <div class={metricCardClass('temp')} data-metric="temp">
      <span class="marine-weather__metric-label">Sea Temp</span>
      <span class="marine-weather__metric-value" data-sea-temp>{fallback.seaTemp.toFixed(1)}°C</span
      >
      <span class="marine-weather__metric-subtitle" data-sea-temp-desc>Comfortable</span>
    </div>
    <div class={metricCardClass('wind')} data-metric="wind">
      <span class="marine-weather__metric-label">Wind</span>
      <span class="marine-weather__metric-value" data-wind>{fallback.windSpeed} km/h</span>
      <span class="marine-weather__metric-subtitle" data-wind-dir>{dirText(fallback.windDirection)}</span
      >
    </div>
    <div class={metricCardClass('condition')} data-metric="condition">
      <span class="marine-weather__metric-label">Condition</span>
      <span class="marine-weather__metric-value" data-condition>Stable</span>
      <span class="marine-weather__metric-subtitle">Snapshot</span>
    </div>
    <div class={metricCardClass('updated')} data-metric="updated">
      <span class="marine-weather__metric-label">Updated</span>
      <span class="marine-weather__metric-value" data-updated>Just now</span>
      <span
        class="marine-weather__status-flag marine-weather__status-flag--loading hidden"
        data-loading>Lädt…</span
      >
      <span
        class="marine-weather__status-flag marine-weather__status-flag--error hidden"
        data-error>Fehler</span
      >
    </div>
  </div>
  <p
    class="marine-weather__disclaimer"
    data-disclaimer
  >
    {
      !disableFetch && latitude != null && longitude != null
        ? `Live Daten (Open‑Meteo Marine).${refreshInterval > 0 ? ` Auto Refresh alle ${refreshInterval}m.` : ''} Fallback bei Fehler.`
        : 'Demodaten. latitude+longitude setzen für Live-Aktualisierung.'
    } AAA Kontrast eingehalten.
  </p>
  <footer
    class="marine-weather__footer"
  >
    <span
      >Quelle: <span class="marine-weather__source-link"
        >Open‑Meteo</span
      ></span
    >
    <span class="marine-weather__refresh" data-refresh-indicator
      >{
        refreshInterval > 0 ? `Auto ${refreshInterval}m` : 'Kein Auto-Refresh'
      }</span
    >
  </footer>
</div>

<script>
  // Client-side copies of helpers (frontmatter scope not available in browser runtime)
  function dirText(deg) {
    const dirs = [
      'N',
      'NNE',
      'NE',
      'ENE',
      'E',
      'ESE',
      'SE',
      'SSE',
      'S',
      'SSW',
      'SW',
      'WSW',
      'W',
      'WNW',
      'NW',
      'NNW',
    ];
    return dirs[Math.round(deg / 22.5) % 16];
  }
  function waveClass(h) {
    if (h >= 3) return ['Extreme', 'extreme'];
    if (h >= 2) return ['Rough', 'rough'];
    if (h >= 1) return ['Moderate', 'moderate'];
    if (h >= 0.5) return ['Calm', 'calm'];
    return ['Flat', 'flat'];
  }
  function initMarine(el) {
    const disableFetch = el.dataset.disableFetch === 'true';
    const lat = el.dataset.lat ? parseFloat(el.dataset.lat) : undefined;
    const lon = el.dataset.lon ? parseFloat(el.dataset.lon) : undefined;
    const refresh = parseInt(el.dataset.refresh || '0');
    const statusEl = el.querySelector('[data-status]');
    const waveEl = el.querySelector('[data-wave]');
    const waveLabelEl = el.querySelector('[data-wave-label]');
    const waveIndEl = el.querySelector('[data-wave-ind]');
    const seaTempEl = el.querySelector('[data-sea-temp]');
    const seaTempDescEl = el.querySelector('[data-sea-temp-desc]');
    const windEl = el.querySelector('[data-wind]');
    const windDirEl = el.querySelector('[data-wind-dir]');
    const condEl = el.querySelector('[data-condition]');
    const updEl = el.querySelector('[data-updated]');
    const loadingEl = el.querySelector('[data-loading]');
    const errorEl = el.querySelector('[data-error]');
    const setState = (s) => {
      el.dataset.state = s;
      el.setAttribute('aria-busy', s === 'loading' ? 'true' : 'false');
      if (loadingEl) loadingEl.classList.toggle('hidden', s !== 'loading');
      if (errorEl) errorEl.classList.toggle('hidden', s !== 'error');
    };
    function comfort(t) {
      if (t < 10) return 'Very Cold';
      if (t < 15) return 'Cold';
      if (t < 20) return 'Cool';
      if (t < 25) return 'Comfortable';
      if (t < 30) return 'Warm';
      return 'Hot';
    }
    async function fetchData() {
      if (disableFetch || lat == null || lon == null) {
        if (statusEl) statusEl.textContent = 'Fallback Werte aktiv';
        return;
      }
      setState('loading');
      if (statusEl) statusEl.textContent = 'Lade Marinedaten …';
      try {
        const params = new URLSearchParams({
          latitude: String(lat),
          longitude: String(lon),
          current:
            'wave_height,wave_direction,sea_surface_temperature,wind_speed_10m,wind_direction_10m',
          timezone: 'auto',
        });
        const url = `https://marine-api.open-meteo.com/v1/marine?${params.toString()}`;
        const res = await fetch(url);
        if (!res.ok) throw 0;
        const data = await res.json();
        const cur = data.current || {};
        const wave = cur.wave_height;
        // waveDir reserved for future directional display (not shown in minimal variant)
        const seaT = cur.sea_surface_temperature;
        const windSp = cur.wind_speed_10m;
        const windDir = cur.wind_direction_10m;
        if (wave != null && waveEl) {
          waveEl.textContent = `${wave.toFixed(1)} m`;
          const [lbl, cls] =
            typeof waveClass === 'function'
              ? waveClass(wave)
              : ['Wave', 'calm'];
          if (waveLabelEl) waveLabelEl.textContent = lbl;
          if (waveIndEl)
            waveIndEl.className = `marine-weather__wave-indicator marine-weather__wave-indicator--${cls}`;
        }
        if (seaT != null && seaTempEl) {
          seaTempEl.textContent = `${seaT.toFixed(1)}°C`;
          if (seaTempDescEl) seaTempDescEl.textContent = comfort(seaT);
        }
        if (windSp != null && windEl) {
          windEl.textContent = `${Math.round(windSp)} km/h`;
        }
        if (windDir != null && windDirEl) {
          windDirEl.textContent =
            typeof dirText === 'function' ? dirText(windDir) : 'N';
        }
        if (condEl) {
          condEl.textContent = 'Live';
        }
        if (updEl) {
          updEl.textContent = new Date().toLocaleTimeString([], {
            hour: '2-digit',
            minute: '2-digit',
          });
        }
        if (statusEl) statusEl.textContent = 'Live Daten geladen';
        setState('ready');
      } catch {
        if (statusEl) statusEl.textContent = 'Live Fehler (Fallback angezeigt)';
        setState('error');
      }
    }
    fetchData();
    if (refresh > 0 && !disableFetch && lat != null && lon != null) {
      setInterval(fetchData, refresh * 60 * 1000);
      const ind = el.querySelector('[data-refresh-indicator]');
      if (ind) ind.textContent = `Auto ${refresh}m`;
    }
  }
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('[data-marine]').forEach(initMarine);
  });
</script>

<style>
  .marine-weather {
    border: 1px solid #cbd5f5;
    border-radius: 1.5rem;
    background-color: #ffffff;
    color: #0f172a;
    box-shadow: 0 12px 30px rgba(15, 23, 42, 0.08);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .marine-weather {
      padding: 2rem;
    }
  }

  .marine-weather__header {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  @media (min-width: 768px) {
    .marine-weather__header {
      flex-direction: row;
      align-items: flex-start;
      justify-content: space-between;
    }
  }

  .marine-weather__title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0;
    font-size: 1.375rem;
    font-weight: 700;
    color: inherit;
  }

  .marine-weather__title-icon {
    font-size: 2rem;
    line-height: 1;
  }

  .marine-weather__location {
    display: inline-block;
    max-width: 100%;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .marine-weather__status-text {
    font-size: 0.8125rem;
    font-weight: 500;
    color: #475569;
  }

  .marine-weather__metrics {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .marine-weather__metrics {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1.25rem;
    }
  }

  @media (min-width: 1024px) {
    .marine-weather__metrics {
      grid-template-columns: repeat(5, minmax(0, 1fr));
    }
  }

  .marine-weather__metric-card {
    border-radius: 0.85rem;
    border: 1px solid #e2e8f0;
    background-color: rgba(248, 250, 252, 0.85);
    padding: 0.85rem;
    min-height: 86px;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  @media (min-width: 768px) {
    .marine-weather__metric-card {
      padding-block: 1rem;
    }
  }

  .marine-weather__metric-label {
    font-size: 0.625rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 600;
    color: #475569;
  }

  .marine-weather__metric-value {
    font-size: 1rem;
    font-weight: 700;
    color: #0f172a;
  }

  @media (min-width: 768px) {
    .marine-weather__metric-value {
      font-size: 1.125rem;
    }
  }

  .marine-weather__metric-subtitle {
    font-size: 0.7rem;
    font-weight: 500;
    color: #475569;
  }

  .marine-weather__wave-state {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.7rem;
    font-weight: 600;
    color: #0f172a;
  }

  .marine-weather__wave-indicator {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 999px;
    background-color: #10b981;
  }

  .marine-weather__wave-indicator--flat {
    background-color: #34d399;
  }

  .marine-weather__wave-indicator--calm {
    background-color: #10b981;
  }

  .marine-weather__wave-indicator--moderate {
    background-color: #f59e0b;
  }

  .marine-weather__wave-indicator--rough {
    background-color: #f97316;
  }

  .marine-weather__wave-indicator--extreme {
    background-color: #f43f5e;
  }

  .marine-weather__status-flag {
    font-size: 0.7rem;
    font-weight: 600;
  }

  .marine-weather__status-flag--loading {
    color: #b45309;
  }

  .marine-weather__status-flag--error {
    color: #be123c;
  }

  .marine-weather__disclaimer {
    margin-top: 0.5rem;
    font-size: 0.7rem;
    line-height: 1.4;
    color: #475569;
  }

  .marine-weather__footer {
    border-top: 1px solid #e2e8f0;
    padding-top: 1rem;
    margin-top: 0.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    font-size: 0.75rem;
    color: #475569;
    align-items: center;
  }

  .marine-weather__source-link {
    color: #0f172a;
    text-decoration: underline;
    text-decoration-thickness: 1px;
  }

  .marine-weather__refresh {
    margin-left: auto;
    font-weight: 600;
    color: #0f172a;
  }

  :where(.dark) .marine-weather {
    background-color: #0f172a;
    border-color: #334155;
    color: #f1f5f9;
  }

  :where(.dark) .marine-weather__metric-card {
    border-color: #1e293b;
    background-color: rgba(30, 41, 59, 0.75);
  }

  :where(.dark) .marine-weather__metric-label,
  :where(.dark) .marine-weather__metric-subtitle,
  :where(.dark) .marine-weather__status-text,
  :where(.dark) .marine-weather__disclaimer,
  :where(.dark) .marine-weather__footer {
    color: #cbd5f5;
  }

  :where(.dark) .marine-weather__metric-value,
  :where(.dark) .marine-weather__wave-state,
  :where(.dark) .marine-weather__source-link,
  :where(.dark) .marine-weather__refresh {
    color: #f8fafc;
  }

  :where(.dark) .marine-weather__wave-indicator--flat {
    background-color: #86efac;
  }

  :where(.dark) .marine-weather__wave-indicator--calm {
    background-color: #4ade80;
  }

  :where(.dark) .marine-weather__wave-indicator--moderate {
    background-color: #facc15;
  }

  :where(.dark) .marine-weather__wave-indicator--rough {
    background-color: #fb923c;
  }

  :where(.dark) .marine-weather__wave-indicator--extreme {
    background-color: #fb7185;
  }

  @media (prefers-reduced-motion: reduce) {
    [data-marine] * {
      transition: none !important;
      animation: none !important;
    }
  }

  @media (prefers-contrast: high) {
    [data-marine] {
      outline: 2px solid currentColor;
    }
  }

  [data-marine][data-state='loading'] [data-metric] {
    position: relative;
  }

  [data-marine][data-state='loading'] [data-metric]::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 0.85rem;
    background: linear-gradient(
      90deg,
      rgba(148, 163, 184, 0.15),
      rgba(148, 163, 184, 0.35),
      rgba(148, 163, 184, 0.15)
    );
    animation: marine-pulse 1.4s ease-in-out infinite;
    opacity: 0.35;
  }

  @keyframes marine-pulse {
    0%,
    100% {
      opacity: 0.35;
    }
    50% {
      opacity: 0.65;
    }
  }
</style>
