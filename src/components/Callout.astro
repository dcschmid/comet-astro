---
interface Props {
  variant?: 'info' | 'success' | 'warning' | 'error' | 'note';
  title?: string;
  icon?: string;
  className?: string;
}

const { variant = 'info', title, icon, className = '' } = Astro.props;
const variants = ['info', 'success', 'warning', 'error', 'note'] as const;
type VariantKey = (typeof variants)[number];
const variantKey = variants.includes(variant as VariantKey)
  ? (variant as VariantKey)
  : 'info';

const rootClasses = ['callout', `callout--${variantKey}`, className]
  .filter(Boolean)
  .join(' ');

const defaultIcons: Record<VariantKey, string> = {
  info: 'ℹ️',
  success: '✅',
  warning: '⚠️',
  error: '❌',
  note: '📝',
};

const iconSymbol = icon || defaultIcons[variantKey];
---

<div class={rootClasses} role="note">
  <div class="callout__inner">
    {
      iconSymbol && (
        <div class="callout__icon" aria-hidden="true">
          {iconSymbol}
        </div>
      )
    }
    <div class="callout__content">
      {title && <p class="callout__title">{title}</p>}
      <div class="callout__body">
        <slot />
      </div>
    </div>
  </div>
</div>

<style is:inline>
  .callout {
    --callout-bg: #f8fafc;
    --callout-border: #cbd5f5;
    --callout-text: #0f172a;
    --callout-title: #0f172a;
    --callout-icon: #0f172a;
    --callout-radius: 1.25rem;
    --callout-padding-x: 1.5rem;
    --callout-padding-y: 1.2rem;
    border-radius: var(--callout-radius);
    border: 1px solid var(--callout-border);
    background: var(--callout-bg);
    color: var(--callout-text);
    box-shadow: 0 18px 30px rgba(2, 6, 23, 0.45);
    transition: border-color 0.2s ease, background-color 0.2s ease;
  }

  .callout__inner {
    display: flex;
    gap: 1rem;
    padding: var(--callout-padding-y) var(--callout-padding-x);
  }

  .callout__icon {
    font-size: 2rem;
    line-height: 1;
    flex-shrink: 0;
    color: var(--callout-icon);
  }

  .callout__content {
    flex: 1;
    min-width: 0;
  }

  .callout__title {
    margin: 0 0 0.35rem 0;
    font-size: 1rem;
    font-weight: 600;
    color: var(--callout-title);
  }

  .callout__body {
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--callout-text);
  }

  .callout__body > :where(p) {
    margin-bottom: 0.75rem;
  }

  .callout__body > :where(p:last-child) {
    margin-bottom: 0;
  }

  .callout--info {
    --callout-bg: #dbeafe;
    --callout-border: #60a5fa;
    --callout-text: #0f172a;
    --callout-title: #0c4a6e;
    --callout-icon: #0c4a6e;
  }

  .callout--success {
    --callout-bg: #d1fae5;
    --callout-border: #34d399;
    --callout-text: #064e3b;
    --callout-title: #03543f;
    --callout-icon: #047857;
  }

  .callout--warning {
    --callout-bg: #fef3c7;
    --callout-border: #f59e0b;
    --callout-text: #78350f;
    --callout-title: #92400e;
    --callout-icon: #b45309;
  }

  .callout--error {
    --callout-bg: #fee2e2;
    --callout-border: #ef4444;
    --callout-text: #7f1d1d;
    --callout-title: #991b1b;
    --callout-icon: #b91c1c;
  }

  .callout--note {
    --callout-bg: #ede9fe;
    --callout-border: #a78bfa;
    --callout-text: #312e81;
    --callout-title: #312e81;
    --callout-icon: #4c1d95;
  }

  :where(.dark) .callout {
    --callout-bg: #0f172a;
    --callout-border: rgba(148, 163, 184, 0.35);
    --callout-text: #f8fafc;
    --callout-title: #f8fafc;
    --callout-icon: #e2e8f0;
  }

  :where(.dark) .callout--info {
    --callout-bg: #082f49;
    --callout-border: #38bdf8;
    --callout-text: #e0f2fe;
    --callout-title: #f8fafc;
    --callout-icon: #7dd3fc;
  }

  :where(.dark) .callout--success {
    --callout-bg: #022c22;
    --callout-border: #22c55e;
    --callout-text: #bbf7d0;
    --callout-title: #ecfccb;
    --callout-icon: #34d399;
  }

  :where(.dark) .callout--warning {
    --callout-bg: #451a03;
    --callout-border: #f59e0b;
    --callout-text: #fde68a;
    --callout-title: #fffbeb;
    --callout-icon: #fbbf24;
  }

  :where(.dark) .callout--error {
    --callout-bg: #450a0a;
    --callout-border: #f87171;
    --callout-text: #fecdd3;
    --callout-title: #fee2e2;
    --callout-icon: #fda4af;
  }

  :where(.dark) .callout--note {
    --callout-bg: #1e1b4b;
    --callout-border: #a78bfa;
    --callout-text: #e0e7ff;
    --callout-title: #eef2ff;
    --callout-icon: #c4b5fd;
  }
</style>
