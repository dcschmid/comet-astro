---
/**
 * Alert - status message
 */
interface Props {
  title?: string;
  message?: string;
  variant?:
    | 'info'
    | 'success'
    | 'warning'
    | 'error'
    | 'classic'
    | 'nature'
    | 'warm'
    | 'sky'
    | 'orange';
  dismissible?: boolean;
  dismissLabel?: string;
  className?: string;
}

const {
  title,
  message,
  variant = 'info',
  dismissible = false,
  dismissLabel = 'Dismiss alert',
  className = '',
} = Astro.props as Props;

import Icon from './Icon.astro';

const paletteMap = {
  classic: 'classic',
  nature: 'nature',
  warm: 'warm',
  sky: 'sky',
  orange: 'orange',
  info: 'classic',
  success: 'nature',
  warning: 'warm',
  error: 'orange',
} as const;

const paletteKey = paletteMap[variant] || 'classic';

const rootClasses = [
  'alert',
  `alert--palette-${paletteKey}`,
  dismissible ? 'alert--dismissible' : '',
  className,
]
  .filter(Boolean)
  .join(' ');

const roleMap = {
  classic: { role: 'status', ariaLive: 'polite', label: 'Information' },
  nature: { role: 'status', ariaLive: 'polite', label: 'Success' },
  warm: { role: 'alert', ariaLive: 'assertive', label: 'Warning' },
  sky: { role: 'status', ariaLive: 'polite', label: 'Information' },
  orange: { role: 'alert', ariaLive: 'assertive', label: 'Error' },
  info: { role: 'status', ariaLive: 'polite', label: 'Information' },
  success: { role: 'status', ariaLive: 'polite', label: 'Success' },
  warning: { role: 'alert', ariaLive: 'assertive', label: 'Warning' },
  error: { role: 'alert', ariaLive: 'assertive', label: 'Error' },
} as const;

const iconName = {
  classic: 'info',
  nature: 'check-circle',
  warm: 'exclamation',
  sky: 'info',
  orange: 'x-circle',
  info: 'info',
  success: 'check-circle',
  warning: 'exclamation',
  error: 'x-circle',
} as const;
---

<div
  class={rootClasses}
  role={roleMap[variant].role}
  aria-live={roleMap[variant].ariaLive}
  aria-atomic="true"
  data-variant={variant}
  data-state="open"
  aria-hidden="false"
>
  <div class="alert__inner">
    <div class="alert__icon" aria-hidden="true">
      <Icon
        name={iconName[variant]}
        size="md"
        decorative={false}
        ariaLabel={roleMap[variant].label}
      />
    </div>
    <div class="alert__body">
      <span class="alert__sr-only">{roleMap[variant].label}</span>
      {title && <div class="alert__title">{title}</div>}
      {message && <div class="alert__message">{message}</div>}
      <slot />
    </div>
    {
      dismissible && (
        <button
          type="button"
          class="alert__dismiss"
          data-alert-dismiss
          aria-label={dismissLabel}
        >
          <span aria-hidden="true">×</span>
          <span class="alert__sr-only">{dismissLabel}</span>
        </button>
      )
    }
  </div>
</div>

<script type="module" is:inline>
  const attachDismiss = (alert) => {
    if (!(alert instanceof HTMLElement)) return;
    if (alert.dataset.alertReady === 'true') return;
    const dismissBtn = alert.querySelector('[data-alert-dismiss]');
    if (!(dismissBtn instanceof HTMLElement)) return;
    alert.dataset.state =
      alert.getAttribute('hidden') === 'true' ? 'closed' : 'open';
    dismissBtn.addEventListener(
      'click',
      () => {
        alert.setAttribute('hidden', 'true');
        alert.setAttribute('aria-hidden', 'true');
        alert.dataset.state = 'closed';
        alert.classList.add('alert--closed');
      },
      { passive: true }
    );
    alert.dataset.alertReady = 'true';
  };

  const hydrateAlerts = () => {
    document
      .querySelectorAll('.alert')
      .forEach((alert) => attachDismiss(alert));
  };

  const ready = () => hydrateAlerts();

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', ready, { once: true });
  } else {
    ready();
  }

  document.addEventListener('astro:page-load', hydrateAlerts);
</script>

<style is:inline>
  .alert {
    --alert-bg: #ffffff;
    --alert-border: #e5e7eb;
    --alert-text: #0f172a;
    --alert-muted: #475467;
    --alert-icon: #2563eb;
    --alert-hover-bg: #eff6ff;
    --alert-hover-border: #c7d2fe;
    --alert-focus: #2563eb;
    position: relative;
    display: flex;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    border: 1px solid var(--alert-border);
    border-radius: 1rem;
    background-color: var(--alert-bg);
    color: var(--alert-text);
    box-shadow: 0 12px 24px rgba(15, 23, 42, 0.08);
    transition:
      border-color 0.2s ease,
      background-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .alert:hover {
    border-color: var(--alert-hover-border);
    background-color: var(--alert-hover-bg);
  }

  .alert__inner {
    display: flex;
    gap: 1rem;
    width: 100%;
    align-items: flex-start;
  }

  .alert__icon {
    flex-shrink: 0;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.85);
    color: var(--alert-icon);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: inset 0 1px 3px rgba(15, 23, 42, 0.12);
  }

  :where(.dark) .alert__icon {
    background: rgba(255, 255, 255, 0.1);
  }

  .alert__body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .alert__title {
    font-weight: 600;
    font-size: 1rem;
    color: var(--alert-text);
  }

  .alert__message {
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--alert-muted);
  }

  .alert__dismiss {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 0.75rem;
    border: 1px solid transparent;
    background: transparent;
    color: var(--alert-text);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    cursor: pointer;
    transition:
      border-color 0.2s ease,
      background-color 0.2s ease;
  }

  .alert__dismiss:hover {
    border-color: var(--alert-hover-border);
    background-color: var(--alert-hover-bg);
  }

  .alert__dismiss:focus-visible {
    outline: 2px solid var(--alert-focus);
    outline-offset: 2px;
    border-color: var(--alert-focus);
  }

  .alert__sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .alert--closed {
    display: none;
  }

  :where(.dark) .alert {
    --alert-bg: #0f172a;
    --alert-border: #1f2937;
    --alert-text: #f8fafc;
    --alert-muted: #cbd5f5;
    --alert-hover-bg: #1f2937;
    --alert-hover-border: #334155;
    --alert-focus: #60a5fa;
    box-shadow: 0 16px 32px rgba(2, 6, 23, 0.65);
  }

  .alert--palette-classic {
    --alert-bg: #ffffff;
    --alert-border: #e5e7eb;
    --alert-text: #111827;
    --alert-muted: #4b5563;
    --alert-icon: #2563eb;
    --alert-hover-bg: #eff6ff;
    --alert-hover-border: #60a5fa;
    --alert-focus: #2563eb;
  }

  :where(.dark) .alert--palette-classic {
    --alert-bg: #111827;
    --alert-border: #374151;
    --alert-text: #ffffff;
    --alert-muted: #cbd5f5;
    --alert-icon: #60a5fa;
    --alert-hover-bg: #1f2937;
    --alert-hover-border: #3b82f6;
    --alert-focus: #60a5fa;
  }

  .alert--palette-nature {
    --alert-bg: #fafaf9;
    --alert-border: #e7e5e4;
    --alert-text: #1c1917;
    --alert-muted: #44403c;
    --alert-icon: #059669;
    --alert-hover-bg: #f7f3f9;
    --alert-hover-border: #34d399;
    --alert-focus: #059669;
  }

  :where(.dark) .alert--palette-nature {
    --alert-bg: #0c0a09;
    --alert-border: #292524;
    --alert-text: #f5f5f4;
    --alert-muted: #d6d3d1;
    --alert-icon: #34d399;
    --alert-hover-bg: #181716;
    --alert-hover-border: #10b981;
    --alert-focus: #34d399;
  }

  .alert--palette-warm {
    --alert-bg: #f9fafb;
    --alert-border: #d1d5db;
    --alert-text: #111827;
    --alert-muted: #4b5563;
    --alert-icon: #7c3aed;
    --alert-hover-bg: #faf5ff;
    --alert-hover-border: #a78bfa;
    --alert-focus: #7c3aed;
  }

  :where(.dark) .alert--palette-warm {
    --alert-bg: #030712;
    --alert-border: #374151;
    --alert-text: #f9fafb;
    --alert-muted: #cbd5f5;
    --alert-icon: #a78bfa;
    --alert-hover-bg: #111827;
    --alert-hover-border: #8b5cf6;
    --alert-focus: #a78bfa;
  }

  .alert--palette-sky {
    --alert-bg: #f8fafc;
    --alert-border: #e2e8f0;
    --alert-text: #0f172a;
    --alert-muted: #334155;
    --alert-icon: #0891b2;
    --alert-hover-bg: #ecfeff;
    --alert-hover-border: #22d3ee;
    --alert-focus: #0891b2;
  }

  :where(.dark) .alert--palette-sky {
    --alert-bg: #0f172a;
    --alert-border: #1e293b;
    --alert-text: #f8fafc;
    --alert-muted: #cbd5f5;
    --alert-icon: #67e8f9;
    --alert-hover-bg: #020617;
    --alert-hover-border: #06b6d4;
    --alert-focus: #22d3ee;
  }

  .alert--palette-orange {
    --alert-bg: #fafafa;
    --alert-border: #e4e4e7;
    --alert-text: #18181b;
    --alert-muted: #3f3f46;
    --alert-icon: #f97316;
    --alert-hover-bg: #fff7ed;
    --alert-hover-border: #fb923c;
    --alert-focus: #f97316;
  }

  :where(.dark) .alert--palette-orange {
    --alert-bg: #09090b;
    --alert-border: #27272a;
    --alert-text: #fafafa;
    --alert-muted: #d4d4d8;
    --alert-icon: #fdba74;
    --alert-hover-bg: #18181b;
    --alert-hover-border: #fb923c;
    --alert-focus: #fb923c;
  }
</style>
