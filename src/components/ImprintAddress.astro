---
/**
 * ImprintAddress - WCAG AAA compliant legal address/contact block
 */
interface Props {
  name: string;
  street?: string;
  postalCode?: string;
  city?: string;
  country?: string;
  email?: string;
  phone?: string;
  website?: string;
  vatId?: string;
  register?: string; // e.g., Amtsgericht/Handelsregister-Nr
  size?: 'sm' | 'md' | 'lg';
  layout?: 'compact' | 'default' | 'expanded';
  showLabels?: boolean;
  className?: string;
}

const {
  name,
  street,
  postalCode,
  city,
  country,
  email,
  phone,
  website,
  vatId,
  register,
  size = 'md',
  layout = 'default',
  showLabels = false,
  className = '',
} = Astro.props as Props;

// Enhanced size classes with responsive typography
const sizeClasses = {
  sm: 'imprint-address--size-sm',
  md: 'imprint-address--size-md',
  lg: 'imprint-address--size-lg',
} as const;

const layoutClasses = {
  compact: 'imprint-address--layout-compact',
  default: 'imprint-address--layout-default',
  expanded: 'imprint-address--layout-expanded',
} as const;

const wrapperClasses = [
  'imprint-address',
  sizeClasses[size],
  layoutClasses[layout],
  className,
]
  .filter(Boolean)
  .join(' ');
---

<address
  class={wrapperClasses}
  itemscope
  itemtype="https://schema.org/Organization"
  role="contentinfo"
  aria-label="Organization contact information"
>
  <div itemprop="name" class="imprint-address__name">
    {name}
  </div>

  {
    (street || postalCode || city) && (
      <div
        itemprop="address"
        itemscope
        itemtype="https://schema.org/PostalAddress"
        class="imprint-address__section imprint-address__section--address"
      >
        {showLabels && (
          <div class="imprint-address__label">Address</div>
        )}

        {street && (
          <div itemprop="streetAddress" class="imprint-address__line">
            {street}
          </div>
        )}

        {(postalCode || city) && (
          <div class="imprint-address__line">
            {postalCode && <span itemprop="postalCode">{postalCode}</span>}
            {postalCode && city && ' '}
            {city && <span itemprop="addressLocality">{city}</span>}
          </div>
        )}

        {country && (
          <div itemprop="addressCountry" class="imprint-address__line">
            {country}
          </div>
        )}
      </div>
    )
  }

  <div class="imprint-address__section imprint-address__section--contact">
    {
      showLabels && (email || phone || website) && (
        <div class="imprint-address__label">Contact</div>
      )
    }

    {
      email && (
        <div class="imprint-address__row">
          {showLabels && (
            <span class="imprint-address__row-label">Email:</span>
          )}
          <a
            href={`mailto:${email}`}
            itemprop="email"
            class="imprint-address__link imprint-address__link--break"
            aria-label={`Send email to ${email}`}
          >
            {email}
          </a>
        </div>
      )
    }

    {
      phone && (
        <div class="imprint-address__row">
          {showLabels && (
            <span class="imprint-address__row-label">Phone:</span>
          )}
          <a
            href={`tel:${phone}`}
            itemprop="telephone"
            class="imprint-address__link"
            aria-label={`Call ${phone}`}
          >
            {phone}
          </a>
        </div>
      )
    }

    {
      website && (
        <div class="imprint-address__row">
          {showLabels && (
            <span class="imprint-address__row-label">Website:</span>
          )}
          <a
            href={website}
            target="_blank"
            rel="noopener noreferrer"
            itemprop="url"
            class="imprint-address__link imprint-address__link--break"
            aria-label={`Visit ${website} (opens in new window)`}
          >
            {website}
            <span class="sr-only"> (opens in new window)</span>
          </a>
        </div>
      )
    }
  </div>

  {
    (vatId || register) && (
      <div class="imprint-address__section imprint-address__section--legal">
        {showLabels && (
          <div class="imprint-address__label">
            Legal Information
          </div>
        )}

        {vatId && (
          <div class="imprint-address__line">
            <span class="imprint-address__inline-label">VAT-ID:</span> {vatId}
          </div>
        )}

        {register && (
          <div class="imprint-address__line">
            <span class="imprint-address__inline-label">Register:</span> {register}
          </div>
        )}
      </div>
    )
  }
</address>

<style is:inline>
  .imprint-address {
    display: block;
    color: #1f2937;
    font-size: 0.95rem;
    line-height: 1.65;
  }

  .imprint-address--size-sm {
    font-size: 0.875rem;
  }

  .imprint-address--size-lg {
    font-size: 1rem;
  }

  .imprint-address--layout-compact {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .imprint-address--layout-default {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .imprint-address--layout-expanded {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .imprint-address__name {
    font-size: 1.125em;
    font-weight: 600;
    color: #0f172a;
  }

  .imprint-address--size-sm .imprint-address__name {
    font-size: 1em;
  }

  .imprint-address--size-lg .imprint-address__name {
    font-size: 1.25em;
  }

  .imprint-address__section {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .imprint-address__section--contact {
    margin-top: 0.75rem;
    gap: 0.6rem;
  }

  .imprint-address--layout-compact .imprint-address__section--contact,
  .imprint-address--layout-compact .imprint-address__section--legal {
    margin-top: 0.5rem;
  }

  .imprint-address__section--legal {
    margin-top: 0.75rem;
    gap: 0.35rem;
    color: #475569;
    font-size: 0.85em;
  }

  .imprint-address__label {
    font-weight: 600;
    color: #0f172a;
    margin-bottom: 0.2rem;
  }

  .imprint-address__line {
    color: inherit;
  }

  .imprint-address__row {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .imprint-address__row-label {
    color: #475569;
    font-weight: 500;
    min-width: 3rem;
  }

  .imprint-address__inline-label {
    font-weight: 600;
    color: #1f2937;
  }

  .imprint-address__link {
    color: #1d4ed8;
    text-decoration: none;
    border-radius: 0.25rem;
    padding: 0.05rem 0;
    transition: color 0.2s ease;
    outline: none;
  }

  .imprint-address__link:hover {
    color: #1e40af;
  }

  .imprint-address__link:focus-visible {
    outline: 2px solid #2563eb;
    outline-offset: 2px;
  }

  .imprint-address__link--break {
    word-break: break-all;
  }

  :where(.dark) .imprint-address {
    color: #cbd5f5;
  }

  :where(.dark) .imprint-address__name {
    color: #f8fafc;
  }

  :where(.dark) .imprint-address__section--legal {
    color: #94a3b8;
  }

  :where(.dark) .imprint-address__row-label {
    color: #94a3b8;
  }

  :where(.dark) .imprint-address__inline-label {
    color: #e2e8f0;
  }

  :where(.dark) .imprint-address__link {
    color: #60a5fa;
  }

  :where(.dark) .imprint-address__link:hover {
    color: #bfdbfe;
  }

  :where(.dark) .imprint-address__link:focus-visible {
    outline-color: #60a5fa;
  }
</style>
