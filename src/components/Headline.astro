---
/**
 * Headline - WCAG AAA compliant heading component with enhanced typography and accessibility
 * Enhanced with semantic HTML, proper contrast ratios, and responsive design
 */
interface Props {
  /** Text content for the headline */
  title?: string;
  /** Semantic heading level */
  level?: 'h1' | 'h2' | 'h3' | 'h4' | 'h5' | 'h6';
  /** Additional CSS classes */
  className?: string;
  /** Text size variant with responsive scaling */
  textSize?: 'xs' | 'sm' | 'base' | 'lg' | 'xl' | '2xl' | '3xl' | '4xl';
  /** Text alignment */
  textAlign?: 'left' | 'center' | 'right' | 'justify';
  /** Color variant with WCAG AAA compliance */
  color?: 'default' | 'muted' | 'accent' | 'success' | 'warning' | 'error';
  /** Weight variant */
  weight?: 'normal' | 'medium' | 'semibold' | 'bold' | 'extrabold';
  /** Whether to balance text lines for better readability */
  balance?: boolean;
  /** Maximum width for optimal reading experience */
  maxWidth?: 'none' | 'sm' | 'md' | 'lg' | 'xl' | '2xl' | 'prose';
  /** ARIA level override for accessibility */
  ariaLevel?: number;
  /** Additional ARIA label */
  ariaLabel?: string;
}

const {
  title,
  level = 'h1',
  className = '',
  textSize = 'lg',
  textAlign = 'left',
  color = 'default',
  weight = 'bold',
  balance = true,
  maxWidth = 'none',
  ariaLevel,
  ariaLabel,
} = Astro.props as Props;
const Tag = level;

// BEM class maps for typography system
const sizeClassMap: Record<NonNullable<Props['textSize']>, string> = {
  xs: 'headline--size-xs',
  sm: 'headline--size-sm',
  base: 'headline--size-base',
  lg: 'headline--size-lg',
  xl: 'headline--size-xl',
  '2xl': 'headline--size-2xl',
  '3xl': 'headline--size-3xl',
  '4xl': 'headline--size-4xl',
};

const alignClassMap: Record<NonNullable<Props['textAlign']>, string> = {
  left: 'headline--align-left',
  center: 'headline--align-center',
  right: 'headline--align-right',
  justify: 'headline--align-justify',
};

const colorClassMap: Record<NonNullable<Props['color']>, string> = {
  default: 'headline--color-default',
  muted: 'headline--color-muted',
  accent: 'headline--color-accent',
  success: 'headline--color-success',
  warning: 'headline--color-warning',
  error: 'headline--color-error',
};

const weightClassMap: Record<NonNullable<Props['weight']>, string> = {
  normal: 'headline--weight-normal',
  medium: 'headline--weight-medium',
  semibold: 'headline--weight-semibold',
  bold: 'headline--weight-bold',
  extrabold: 'headline--weight-extrabold',
};

const widthClassMap: Record<NonNullable<Props['maxWidth']>, string> = {
  none: '',
  sm: 'headline--width-sm',
  md: 'headline--width-md',
  lg: 'headline--width-lg',
  xl: 'headline--width-xl',
  '2xl': 'headline--width-2xl',
  prose: 'headline--width-prose',
};

const classes = [
  'headline',
  balance ? 'headline--balanced' : '',
  sizeClassMap[textSize],
  alignClassMap[textAlign],
  colorClassMap[color],
  weightClassMap[weight],
  widthClassMap[maxWidth],
  className,
]
  .filter(Boolean)
  .join(' ');

// Enhanced ARIA attributes
const ariaAttributes = {
  ...(ariaLevel && { 'aria-level': ariaLevel }),
  ...(ariaLabel && { 'aria-label': ariaLabel }),
};
---

<Tag class={classes} {...ariaAttributes}>
  {title || <slot />}
</Tag>

<style is:inline>
  .headline {
    margin: 0;
    display: block;
    line-height: 1.1;
    letter-spacing: -0.015em;
    word-break: break-word;
    overflow-wrap: anywhere;
    hyphens: auto;
  }

  .headline--balanced {
    text-wrap: balance;
  }

  .headline--align-left {
    text-align: left;
    margin-left: 0;
    margin-right: auto;
  }

  .headline--align-center {
    text-align: center;
    margin-left: auto;
    margin-right: auto;
  }

  .headline--align-right {
    text-align: right;
    margin-left: auto;
    margin-right: 0;
  }

  .headline--align-justify {
    text-align: justify;
  }

  .headline--color-default {
    color: #0f172a;
  }

  :where(.dark) .headline--color-default {
    color: #f8fafc;
  }

  .headline--color-muted {
    color: #334155;
  }

  :where(.dark) .headline--color-muted {
    color: #cbd5f5;
  }

  .headline--color-accent {
    color: #1d4ed8;
  }

  :where(.dark) .headline--color-accent {
    color: #bfdbfe;
  }

  .headline--color-success {
    color: #166534;
  }

  :where(.dark) .headline--color-success {
    color: #bbf7d0;
  }

  .headline--color-warning {
    color: #b45309;
  }

  :where(.dark) .headline--color-warning {
    color: #fde68a;
  }

  .headline--color-error {
    color: #b91c1c;
  }

  :where(.dark) .headline--color-error {
    color: #fecaca;
  }

  .headline--weight-normal {
    font-weight: 400;
  }

  .headline--weight-medium {
    font-weight: 500;
  }

  .headline--weight-semibold {
    font-weight: 600;
  }

  .headline--weight-bold {
    font-weight: 700;
  }

  .headline--weight-extrabold {
    font-weight: 800;
  }

  .headline--width-sm {
    max-width: 24rem;
  }

  .headline--width-md {
    max-width: 28rem;
  }

  .headline--width-lg {
    max-width: 32rem;
  }

  .headline--width-xl {
    max-width: 36rem;
  }

  .headline--width-2xl {
    max-width: 42rem;
  }

  .headline--width-prose {
    max-width: 65ch;
  }

  .headline--size-xs {
    font-size: 1rem;
  }

  @media (min-width: 640px) {
    .headline--size-xs {
      font-size: 1.125rem;
    }
  }

  @media (min-width: 768px) {
    .headline--size-xs {
      font-size: 1.25rem;
    }
  }

  .headline--size-sm {
    font-size: 1.125rem;
  }

  @media (min-width: 640px) {
    .headline--size-sm {
      font-size: 1.25rem;
    }
  }

  @media (min-width: 768px) {
    .headline--size-sm {
      font-size: 1.5rem;
    }
  }

  .headline--size-base {
    font-size: 1.25rem;
  }

  @media (min-width: 640px) {
    .headline--size-base {
      font-size: 1.5rem;
    }
  }

  @media (min-width: 768px) {
    .headline--size-base {
      font-size: 1.875rem;
    }
  }

  .headline--size-lg {
    font-size: 1.5rem;
  }

  @media (min-width: 640px) {
    .headline--size-lg {
      font-size: 1.875rem;
    }
  }

  @media (min-width: 768px) {
    .headline--size-lg {
      font-size: 2.25rem;
    }
  }

  @media (min-width: 1024px) {
    .headline--size-lg {
      font-size: 3rem;
    }
  }

  .headline--size-xl {
    font-size: 1.875rem;
  }

  @media (min-width: 640px) {
    .headline--size-xl {
      font-size: 2.25rem;
    }
  }

  @media (min-width: 768px) {
    .headline--size-xl {
      font-size: 3rem;
    }
  }

  @media (min-width: 1024px) {
    .headline--size-xl {
      font-size: 3.75rem;
    }
  }

  .headline--size-2xl {
    font-size: 2.25rem;
  }

  @media (min-width: 640px) {
    .headline--size-2xl {
      font-size: 3rem;
    }
  }

  @media (min-width: 768px) {
    .headline--size-2xl {
      font-size: 3.75rem;
    }
  }

  @media (min-width: 1024px) {
    .headline--size-2xl {
      font-size: 4.5rem;
    }
  }

  .headline--size-3xl {
    font-size: 3rem;
  }

  @media (min-width: 640px) {
    .headline--size-3xl {
      font-size: 3.75rem;
    }
  }

  @media (min-width: 768px) {
    .headline--size-3xl {
      font-size: 4.5rem;
    }
  }

  @media (min-width: 1024px) {
    .headline--size-3xl {
      font-size: 6rem;
    }
  }

  .headline--size-4xl {
    font-size: 3.75rem;
  }

  @media (min-width: 640px) {
    .headline--size-4xl {
      font-size: 4.5rem;
    }
  }

  @media (min-width: 768px) {
    .headline--size-4xl {
      font-size: 6rem;
    }
  }

  @media (min-width: 1024px) {
    .headline--size-4xl {
      font-size: 8rem;
    }
  }
</style>
