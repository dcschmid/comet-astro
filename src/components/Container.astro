---
/**
 * Container - responsive max-width wrapper for content layout
 */
interface Props {
  size?: 'sm' | 'md' | 'lg' | 'xl' | 'full';
  className?: string;
  as?: 'div' | 'main' | 'section' | 'article' | 'aside' | 'header' | 'footer';
  id?: string;
}

const { size = 'lg', className = '', as: Element = 'div', id } = Astro.props;

const baseClasses = ['container', `container--${size}`, className]
  .filter(Boolean)
  .join(' ');
---

<Element class={baseClasses} id={id}>
  <slot />
</Element>

<style is:inline>
  .container {
    width: 100%;
    margin-left: auto;
    margin-right: auto;
    padding-left: 1rem;
    padding-right: 1rem;
  }

  @media (min-width: 640px) {
    .container {
      padding-left: 1.5rem;
      padding-right: 1.5rem;
    }
  }

  @media (min-width: 1024px) {
    .container {
      padding-left: 2rem;
      padding-right: 2rem;
    }
  }

  .container--sm {
    max-width: 42rem;
  }
  .container--md {
    max-width: 56rem;
  }
  .container--lg {
    max-width: 72rem;
  }
  .container--xl {
    max-width: 80rem;
  }
  .container--full {
    max-width: 100%;
  }
</style>
