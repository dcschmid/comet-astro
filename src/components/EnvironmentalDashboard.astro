---
/**
 * EnvironmentalDashboard – Minimal environmental snapshot.
 * WCAG AAA (light & dark), Astro-only, Tailwind-only.
 * Metrics: Temperature, Humidity, optional Wind, optional AQI & PM2.5, Updated time.
 * Live fetch (Open‑Meteo) only if latitude & longitude provided; else static fallback.
 */
const {
  latitude,
  longitude,
  location = 'Demo Location',
  unit = 'c',
  showAirQuality = true,
  showWind = true,
  refreshInterval = 0,
  disableFetch = false,
  ariaLabel,
  class: className = '',
} = Astro.props;

const fallback = {
  temperatureC: 18.2,
  humidity: 55,
  windKph: 12,
  windDir: 'NW',
  condition: 'Partly cloudy',
  isDay: true,
  aqi: 34,
  pm25: 5.8,
};

const label = ariaLabel || `Environmental conditions for ${location}`;
const tempDisplay =
  unit === 'c'
    ? `${Math.round(fallback.temperatureC)}°C`
    : `${Math.round((fallback.temperatureC * 9) / 5 + 32)}°F`;

const rootClasses = ['env-dashboard', className].filter(Boolean).join(' ');
---

<div
  class={rootClasses}
  role="region"
  aria-label={label}
  aria-busy={latitude && longitude && !disableFetch ? 'true' : 'false'}
  data-env-dashboard
  data-unit={unit}
  data-refresh={refreshInterval}
  data-lat={latitude}
  data-lon={longitude}
  data-disable-fetch={disableFetch}
  data-state={latitude && longitude && !disableFetch ? 'loading' : 'static'}
>
  <header class="env-dashboard__header">
    <h2 class="env-dashboard__title">
      <span aria-hidden="true" class="env-dashboard__title-icon">🌍</span>
      <span class="env-dashboard__location" data-location>{location}</span>
    </h2>
    <p class="env-dashboard__status" aria-live="polite" data-status>
      {
        latitude && longitude && !disableFetch
          ? 'Loading live environmental data…'
          : 'Static demo data'
      }
    </p>
  </header>

  <div class="env-dashboard__metrics" data-metrics>
    <div class="env-dashboard__metric" data-metric="temperature">
      <span class="env-dashboard__metric-label">Temperature</span>
      <span class="env-dashboard__metric-value" data-temp>{tempDisplay}</span>
      <span class="env-dashboard__metric-subtext" data-condition
        >{fallback.condition}</span
      >
    </div>
    <div class="env-dashboard__metric" data-metric="humidity">
      <span class="env-dashboard__metric-label">Humidity</span>
      <span class="env-dashboard__metric-value" data-humidity
        >{fallback.humidity}%</span
      >
      <span class="env-dashboard__metric-subtext" data-daynight
        >{fallback.isDay ? 'Daytime' : 'Night'}</span
      >
    </div>
    {
      showWind && (
        <div class="env-dashboard__metric" data-metric="wind">
          <>
            <span class="env-dashboard__metric-label">Wind</span>
            <span class="env-dashboard__metric-value" data-wind>
              {fallback.windKph} km/h
            </span>
            <span class="env-dashboard__metric-subtext" data-winddir>
              {fallback.windDir}
            </span>
          </>
        </div>
      )
    }
    {
      showAirQuality && (
        <div class="env-dashboard__metric" data-metric="aqi">
          <>
            <span class="env-dashboard__metric-label">AQI</span>
            <span class="env-dashboard__metric-value" data-aqi>
              {fallback.aqi}
            </span>
            <span class="env-dashboard__metric-subtext" data-aqi-cat>
              Good
            </span>
          </>
        </div>
      )
    }
    {
      showAirQuality && (
        <div class="env-dashboard__metric" data-metric="pm25">
          <>
            <span class="env-dashboard__metric-label">PM2.5</span>
            <span class="env-dashboard__metric-value" data-pm25>
              {fallback.pm25}
            </span>
            <span class="env-dashboard__metric-subtext">µg/m³</span>
          </>
        </div>
      )
    }
    <div class="env-dashboard__metric" data-metric="updated">
      <span class="env-dashboard__metric-label">Updated</span>
      <span class="env-dashboard__metric-value" data-updated>Just now</span>
      <span
        class="env-dashboard__status-tag env-dashboard__status-tag--loading"
        data-loading
        >Loading…</span
      >
      <span
        class="env-dashboard__status-tag env-dashboard__status-tag--error"
        data-error
        >Error</span
      >
    </div>
  </div>

  <p class="env-dashboard__disclaimer" data-disclaimer>
    {
      latitude && longitude && !disableFetch
        ? 'Live Open‑Meteo data (weather + air quality). Fallback values retained on failure.'
        : 'Demo fallback data. Add latitude & longitude to enable live fetch.'
    } AAA contrast maintained.
  </p>

  <footer class="env-dashboard__footer">
    <span class="env-dashboard__source"
      >Source:
      <a href="https://open-meteo.com" class="env-dashboard__link"
        >Open‑Meteo</a
      ></span
    >
    <span class="env-dashboard__refresh" data-refresh-indicator
      >{
        refreshInterval > 0 ? `Auto ${refreshInterval}m` : 'No auto refresh'
      }</span
    >
  </footer>
</div>

<script>
  const codeToCondition = (code) =>
    ({
      0: 'Clear',
      1: 'Mainly clear',
      2: 'Partly cloudy',
      3: 'Overcast',
      45: 'Fog',
      48: 'Fog',
      51: 'Drizzle',
      53: 'Drizzle',
      55: 'Drizzle',
      61: 'Rain',
      63: 'Rain',
      65: 'Rain',
      71: 'Snow',
      73: 'Snow',
      75: 'Snow',
      80: 'Rain showers',
      81: 'Rain showers',
      82: 'Rain showers',
      95: 'Thunderstorm',
      96: 'Thunderstorm',
      99: 'Thunderstorm',
    })[code] || 'Unknown';

  function initEnvDashboard(el) {
    const lat = parseFloat(el.dataset.lat);
    const lon = parseFloat(el.dataset.lon);
    const unit = el.dataset.unit || 'c';
    const refresh = parseInt(el.dataset.refresh || '0');
    const disableFetch = el.dataset.disableFetch === 'true';
    const canFetch = !!lat && !!lon && !disableFetch;

    const qs = (sel) => el.querySelector(sel);
    const tempEl = qs('[data-temp]');
    const condEl = qs('[data-condition]');
    const humEl = qs('[data-humidity]');
    const windEl = qs('[data-wind]');
    const windDirEl = qs('[data-winddir]');
    const dayNightEl = qs('[data-daynight]');
    const aqiEl = qs('[data-aqi]');
    const aqiCatEl = qs('[data-aqi-cat]');
    const pm25El = qs('[data-pm25]');
    const updEl = qs('[data-updated]');
    const statusEl = qs('[data-status]');
    const loadingEl = qs('[data-loading]');
    const errorEl = qs('[data-error]');

    const classifyAQI = (v) =>
      v <= 50
        ? 'Good'
        : v <= 100
          ? 'Moderate'
          : v <= 150
            ? 'USG'
            : v <= 200
              ? 'Unhealthy'
              : v <= 300
                ? 'Very Unhealthy'
                : 'Hazardous';
    const LOADING_CLASS = 'env-dashboard--loading';
    const STATUS_VISIBLE_CLASS = 'env-dashboard__status-tag--visible';

    const setState = (s) => {
      el.dataset.state = s;
      el.setAttribute('aria-busy', s === 'loading' ? 'true' : 'false');
      el.classList.toggle(LOADING_CLASS, s === 'loading');
      if (loadingEl)
        loadingEl.classList.toggle(STATUS_VISIBLE_CLASS, s === 'loading');
      if (errorEl)
        errorEl.classList.toggle(STATUS_VISIBLE_CLASS, s === 'error');
    };

    async function fetchData() {
      if (!canFetch) return;
      setState('loading');
      if (statusEl) statusEl.textContent = 'Loading live environmental data…';
      try {
        const wRes = await fetch(
          `https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}&current=temperature_2m,relative_humidity_2m,wind_speed_10m,wind_direction_10m,weather_code,is_day&timezone=auto`
        );
        if (!wRes.ok) throw 0;
        const wData = await wRes.json();
        const cur = wData.current;
        if (cur) {
          const condition = codeToCondition(cur.weather_code);
          const cTemp = Math.round(cur.temperature_2m);
          const fTemp = Math.round((cTemp * 9) / 5 + 32);
          const tDisp = unit === 'f' ? `${fTemp}°F` : `${cTemp}°C`;
          if (tempEl) tempEl.textContent = tDisp;
          if (condEl) condEl.textContent = condition;
          if (humEl) humEl.textContent = `${cur.relative_humidity_2m}%`;
          if (dayNightEl)
            dayNightEl.textContent = cur.is_day ? 'Daytime' : 'Night';
          if (windEl)
            windEl.textContent = `${Math.round(cur.wind_speed_10m)} km/h`;
          if (windDirEl) {
            const dirs = [
              'N',
              'NNE',
              'NE',
              'ENE',
              'E',
              'ESE',
              'SE',
              'SSE',
              'S',
              'SSW',
              'SW',
              'WSW',
              'W',
              'WNW',
              'NW',
              'NNW',
            ];
            windDirEl.textContent =
              dirs[Math.round(cur.wind_direction_10m / 22.5) % 16];
          }
        }
        if (aqiEl || pm25El) {
          const aqRes = await fetch(
            `https://air-quality-api.open-meteo.com/v1/air-quality?latitude=${lat}&longitude=${lon}&hourly=us_aqi,pm2_5&timezone=auto`
          );
          if (aqRes.ok) {
            const aq = await aqRes.json();
            const idx = aq.hourly?.time?.length
              ? aq.hourly.time.indexOf(aq.current?.time)
              : 0;
            const aqiVal = aq.hourly?.us_aqi?.[idx] ?? aq.hourly?.us_aqi?.[0];
            const pmVal = aq.hourly?.pm2_5?.[idx] ?? aq.hourly?.pm2_5?.[0];
            if (typeof aqiVal === 'number' && aqiEl) aqiEl.textContent = aqiVal;
            if (typeof aqiVal === 'number' && aqiCatEl)
              aqiCatEl.textContent = classifyAQI(aqiVal);
            if (typeof pmVal === 'number' && pm25El)
              pm25El.textContent = pmVal.toFixed(1);
          }
        }
        if (updEl) {
          updEl.textContent = new Date().toLocaleTimeString([], {
            hour: '2-digit',
            minute: '2-digit',
          });
        }
        if (statusEl) statusEl.textContent = 'Live data loaded';
        setState('ready');
      } catch {
        if (statusEl)
          statusEl.textContent = 'Live update failed (fallback shown)';
        setState('error');
      }
    }

    fetchData();
    if (refresh > 0 && canFetch) setInterval(fetchData, refresh * 60 * 1000);
  }

  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('[data-env-dashboard]').forEach(initEnvDashboard);
  });
</script>

<style is:inline>
  .env-dashboard {
    --env-bg: #ffffff;
    --env-border: rgba(15, 23, 42, 0.1);
    --env-heading: #0f172a;
    --env-subtext: #475569;
    --env-card-bg: rgba(248, 250, 252, 0.9);
    --env-card-border: rgba(15, 23, 42, 0.08);
    --env-card-text: #0f172a;
    --env-card-muted: #475569;
    --env-accent: #2563eb;
    width: 100%;
    border-radius: 1.75rem;
    border: 1px solid var(--env-border);
    background: var(--env-bg);
    box-shadow: 0 25px 60px rgba(15, 23, 42, 0.08);
    padding: clamp(1.5rem, 4vw, 2.5rem);
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  :where(.dark) .env-dashboard {
    --env-bg: #0f172a;
    --env-border: rgba(148, 163, 184, 0.4);
    --env-heading: #f8fafc;
    --env-subtext: #cbd5f5;
    --env-card-bg: rgba(15, 23, 42, 0.65);
    --env-card-border: rgba(148, 163, 184, 0.3);
    --env-card-text: #f8fafc;
    --env-card-muted: #cbd5f5;
    --env-accent: #60a5fa;
    box-shadow: 0 30px 70px rgba(2, 6, 23, 0.6);
  }
  .env-dashboard__header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  @media (min-width: 48rem) {
    .env-dashboard__header {
      flex-direction: row;
      align-items: flex-start;
      justify-content: space-between;
    }
  }
  .env-dashboard__title {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: clamp(1.3rem, 3vw, 1.8rem);
    font-weight: 700;
    color: var(--env-heading);
    margin: 0;
  }
  .env-dashboard__title-icon {
    font-size: 2rem;
  }
  .env-dashboard__location {
    min-width: 0;
    display: inline-flex;
    max-width: 100%;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .env-dashboard__status {
    margin: 0;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--env-subtext);
  }
  .env-dashboard__metrics {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }
  @media (min-width: 40rem) {
    .env-dashboard__metrics {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
  @media (min-width: 72rem) {
    .env-dashboard__metrics {
      grid-template-columns: repeat(6, minmax(0, 1fr));
    }
  }
  .env-dashboard__metric {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    border-radius: 1rem;
    border: 1px solid var(--env-card-border);
    background: var(--env-card-bg);
    padding: 0.9rem 1rem;
    min-height: 5rem;
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.03);
  }
  .env-dashboard__metric-label {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--env-card-muted);
  }
  .env-dashboard__metric-value {
    font-size: clamp(1rem, 2vw, 1.25rem);
    font-weight: 700;
    color: var(--env-card-text);
  }
  .env-dashboard__metric-subtext {
    font-size: 0.75rem;
    color: var(--env-card-muted);
  }
  .env-dashboard__status-tag {
    display: none;
    font-size: 0.75rem;
    font-weight: 600;
  }
  .env-dashboard__status-tag--loading {
    color: #b45309;
  }
  .env-dashboard__status-tag--error {
    color: #b91c1c;
  }
  .env-dashboard__status-tag--visible {
    display: inline;
  }
  .env-dashboard__disclaimer {
    margin: 0;
    font-size: 0.75rem;
    color: var(--env-subtext);
  }
  .env-dashboard__footer {
    border-top: 1px solid var(--env-border);
    padding-top: 1rem;
    margin-top: 0.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-size: 0.75rem;
    color: var(--env-subtext);
  }
  .env-dashboard__source {
    display: inline-flex;
    gap: 0.25rem;
    align-items: center;
  }
  .env-dashboard__link {
    color: var(--env-heading);
    text-decoration: underline;
  }
  .env-dashboard__refresh {
    margin-left: auto;
    font-weight: 600;
  }
  .env-dashboard--loading .env-dashboard__metric::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 1rem;
    background: linear-gradient(
      90deg,
      rgba(148, 163, 184, 0.15),
      rgba(148, 163, 184, 0.35),
      rgba(148, 163, 184, 0.15)
    );
    animation: env-dashboard-pulse 1.4s ease-in-out infinite;
    opacity: 0.4;
  }
  @keyframes env-dashboard-pulse {
    0%,
    100% {
      opacity: 0.35;
    }
    50% {
      opacity: 0.65;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .env-dashboard__metric::after,
    .env-dashboard__status,
    .env-dashboard__metric,
    .env-dashboard__button {
      transition: none !important;
      animation: none !important;
    }
  }
  @media (prefers-contrast: high) {
    .env-dashboard {
      outline: 2px solid currentColor;
      outline-offset: 4px;
    }
  }
</style>
