---
interface Props {
  name: string;
  label?: string;
  checked?: boolean;
  disabled?: boolean;
  size?: 'xs' | 'sm' | 'md' | 'lg' | 'xl';
  variant?: 'default' | 'success' | 'warning' | 'danger' | 'info';
  labelPosition?: 'left' | 'right';
  description?: string;
  loading?: boolean;
  ariaLabel?: string;
  ariaDescribedby?: string;
  debug?: boolean;
  id?: string;
  class?: string;
}

const {
  name,
  label,
  checked = false,
  disabled = false,
  size = 'md',
  variant = 'default',
  labelPosition = 'right',
  description,
  loading = false,
  ariaLabel,
  ariaDescribedby,
  debug = false,
  id = name,
  class: className = '',
} = Astro.props as Props;

const rootClasses = [
  'switch',
  `switch--size-${size}`,
  `switch--variant-${variant}`,
  `switch--label-${labelPosition}`,
  disabled ? 'switch--disabled' : '',
  loading ? 'switch--loading' : '',
  debug ? 'switch--debug' : '',
  className,
]
  .filter(Boolean)
  .join(' ');

const controlClasses = [
  'switch__control',
  disabled ? 'switch__control--disabled' : '',
].join(' ');

const thumbClasses = [
  'switch__thumb',
  loading ? 'switch__thumb--loading' : '',
].join(' ');

const hasText = Boolean(label || description);
const textWrapperClasses = 'switch__text';

const labelClasses = ['switch__label', disabled ? 'switch__label--disabled' : '']
  .filter(Boolean)
  .join(' ');

const descriptionClasses = [
  'switch__description',
  disabled ? 'switch__description--disabled' : '',
]
  .filter(Boolean)
  .join(' ');

const labelId = label ? `${id}-label` : undefined;
const descriptionId = description ? `${id}-description` : undefined;
const describedBy =
  [ariaDescribedby, descriptionId].filter(Boolean).join(' ') || undefined;
const debugInfo = debug ? `${size} ${variant} ${checked ? 'on' : 'off'}` : undefined;
---

<div class={rootClasses} data-debug-info={debugInfo}>
  <label class={controlClasses}>
    <input
      type="checkbox"
      class="switch__input"
      id={id}
      name={name}
      checked={checked}
      disabled={disabled}
      aria-label={ariaLabel}
      aria-labelledby={labelId}
      aria-describedby={describedBy}
    />
    <span class="switch__track" aria-hidden="true">
      <span class={thumbClasses}>
        {
          loading && (
            <svg
              class="switch__spinner"
              viewBox="0 0 24 24"
              role="img"
              aria-hidden="true"
            >
              <circle
                class="switch__spinner-track"
                cx="12"
                cy="12"
                r="10"
                stroke-width="4"
              />
              <path
                class="switch__spinner-indicator"
                d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
              />
            </svg>
          )
        }
      </span>
    </span>
  </label>

  {
    hasText && (
      <div class={textWrapperClasses}>
        {label && (
          <label for={id} id={labelId} class={labelClasses}>
            {label}
          </label>
        )}
        {description && (
          <p id={descriptionId} class={descriptionClasses}>
            {description}
          </p>
        )}
      </div>
    )
  }
</div>

<style>
  .switch {
    --switch-track-width: 2.75rem;
    --switch-track-height: 1.5rem;
    --switch-thumb-size: 1.25rem;
    --switch-thumb-offset: 0.125rem;
    --switch-gap: 0.75rem;
    --switch-label-size: 0.95rem;
    --switch-description-size: 0.85rem;
    --switch-active-bg: #2563eb;
    --switch-active-border: #2563eb;
    --switch-focus-ring: rgba(59, 130, 246, 0.45);
    --switch-active-shadow: rgba(59, 130, 246, 0.15);
    --switch-inactive-bg: #cbd5f5;
    --switch-inactive-border: #94a3b8;
    --switch-thumb-color: #fff;
    --switch-thumb-border: #e2e8f0;
    display: inline-flex;
    align-items: flex-start;
    gap: var(--switch-gap);
  }

  .switch--label-left {
    flex-direction: row-reverse;
  }

  .switch--disabled {
    opacity: 0.7;
  }

  .switch__control {
    position: relative;
    display: inline-flex;
    width: var(--switch-track-width);
    height: var(--switch-track-height);
    cursor: pointer;
  }

  .switch__control--disabled {
    cursor: not-allowed;
  }

  .switch__input {
    position: absolute;
    inset: 0;
    opacity: 0;
    width: 100%;
    height: 100%;
    margin: 0;
    cursor: inherit;
  }

  .switch__track {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 999px;
    border: 2px solid var(--switch-inactive-border);
    background: var(--switch-inactive-bg);
    transition: background 0.25s ease, border-color 0.25s ease,
      box-shadow 0.25s ease;
  }

  .switch__track::after {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: inherit;
    border: 2px solid transparent;
    transition: border-color 0.2s ease;
    pointer-events: none;
  }

  .switch__thumb {
    position: absolute;
    width: var(--switch-thumb-size);
    height: var(--switch-thumb-size);
    border-radius: 999px;
    background: var(--switch-thumb-color);
    border: 1px solid var(--switch-thumb-border);
    top: 50%;
    left: var(--switch-thumb-offset);
    transform: translate(0, -50%);
    box-shadow: 0 4px 10px rgba(15, 23, 42, 0.15);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.25s ease, border-color 0.25s ease,
      background 0.25s ease;
    color: var(--switch-active-border);
  }

  .switch__thumb--loading {
    animation: switch-thumb-pulse 1s ease-in-out infinite;
  }

  .switch__spinner {
    width: 100%;
    height: 100%;
  }

  .switch__spinner-track {
    fill: none;
    stroke: currentColor;
    opacity: 0.25;
  }

  .switch__spinner-indicator {
    fill: currentColor;
    opacity: 0.65;
  }

  .switch__text {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
  }

  .switch__label {
    font-size: var(--switch-label-size);
    font-weight: 600;
    color: #0f172a;
    cursor: pointer;
  }

  :where(.dark) .switch__label {
    color: #f8fafc;
  }

  .switch__label--disabled {
    cursor: not-allowed;
  }

  .switch__description {
    font-size: var(--switch-description-size);
    color: #475569;
    margin: 0;
  }

  :where(.dark) .switch__description {
    color: #cbd5f5;
  }

  .switch__description--disabled {
    color: #94a3b8;
  }

  .switch__input:checked + .switch__track {
    background: var(--switch-active-bg);
    border-color: var(--switch-active-border);
    box-shadow: 0 0 0 4px var(--switch-active-shadow);
  }

  .switch__input:checked + .switch__track .switch__thumb {
    transform: translate(
        calc(var(--switch-track-width) - var(--switch-thumb-size) -
            (var(--switch-thumb-offset) * 2)),
        -50%
      );
    border-color: var(--switch-active-border);
  }

  .switch__input:focus-visible + .switch__track::after {
    border-color: var(--switch-focus-ring);
  }

  .switch--variant-success {
    --switch-active-bg: #15803d;
    --switch-active-border: #15803d;
    --switch-focus-ring: rgba(34, 197, 94, 0.45);
    --switch-active-shadow: rgba(34, 197, 94, 0.25);
  }

  .switch--variant-warning {
    --switch-active-bg: #d97706;
    --switch-active-border: #d97706;
    --switch-focus-ring: rgba(245, 158, 11, 0.5);
    --switch-active-shadow: rgba(245, 158, 11, 0.25);
  }

  .switch--variant-danger {
    --switch-active-bg: #b91c1c;
    --switch-active-border: #b91c1c;
    --switch-focus-ring: rgba(248, 113, 113, 0.4);
    --switch-active-shadow: rgba(248, 113, 113, 0.25);
  }

  .switch--variant-info {
    --switch-active-bg: #0891b2;
    --switch-active-border: #0891b2;
    --switch-focus-ring: rgba(6, 182, 212, 0.45);
    --switch-active-shadow: rgba(6, 182, 212, 0.25);
  }

  :where(.dark) .switch {
    --switch-inactive-bg: #1e293b;
    --switch-inactive-border: #475569;
    --switch-thumb-color: #0f172a;
    --switch-thumb-border: #334155;
  }

  .switch--disabled .switch__control,
  .switch--disabled .switch__label {
    cursor: not-allowed;
  }

  .switch--size-xs {
    --switch-track-width: 1.5rem;
    --switch-track-height: 0.75rem;
    --switch-thumb-size: 0.55rem;
    --switch-gap: 0.5rem;
    --switch-label-size: 0.75rem;
    --switch-description-size: 0.7rem;
  }

  .switch--size-sm {
    --switch-track-width: 2rem;
    --switch-track-height: 1rem;
    --switch-thumb-size: 0.85rem;
    --switch-gap: 0.6rem;
    --switch-label-size: 0.85rem;
    --switch-description-size: 0.75rem;
  }

  .switch--size-md {
    --switch-track-width: 2.75rem;
    --switch-track-height: 1.5rem;
    --switch-thumb-size: 1.1rem;
    --switch-gap: 0.75rem;
    --switch-label-size: 0.95rem;
    --switch-description-size: 0.85rem;
  }

  .switch--size-lg {
    --switch-track-width: 3.5rem;
    --switch-track-height: 1.75rem;
    --switch-thumb-size: 1.35rem;
    --switch-gap: 0.85rem;
    --switch-label-size: 1rem;
    --switch-description-size: 0.9rem;
  }

  .switch--size-xl {
    --switch-track-width: 4rem;
    --switch-track-height: 2rem;
    --switch-thumb-size: 1.6rem;
    --switch-gap: 1rem;
    --switch-label-size: 1.1rem;
    --switch-description-size: 1rem;
  }

  .switch--debug {
    outline: 2px dashed rgba(14, 165, 233, 0.8);
    outline-offset: 2px;
    position: relative;
  }

  .switch--debug::after {
    content: attr(data-debug-info);
    position: absolute;
    top: -1.5rem;
    left: 0;
    font-size: 0.75rem;
    color: #0ea5e9;
    background: rgba(255, 255, 255, 0.95);
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
    font-family: monospace;
  }

  :where(.dark) .switch--debug::after {
    background: rgba(15, 23, 42, 0.95);
    color: #bae6fd;
  }

  @keyframes switch-thumb-pulse {
    0%,
    100% {
      opacity: 1;
      box-shadow: 0 4px 10px rgba(15, 23, 42, 0.15);
    }
    50% {
      opacity: 0.75;
      box-shadow: 0 6px 12px rgba(15, 23, 42, 0.25);
    }
  }

  @media (prefers-contrast: high) {
    .switch__track {
      border-color: currentColor;
      background: transparent;
    }

    .switch__input:checked + .switch__track {
      background: currentColor;
      border-color: currentColor;
    }

    .switch__thumb {
      border-color: currentColor;
      background: #fff;
    }

    .switch__label,
    .switch__description {
      color: currentColor;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .switch * {
      animation: none !important;
      transition: none !important;
    }
  }
</style>
