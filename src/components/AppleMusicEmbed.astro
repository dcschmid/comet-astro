---
import LoadingSpinner from './LoadingSpinner.astro';

/**
 * AppleMusicEmbed - WCAG AAA compliant Apple Music and Podcasts embed
 * Provides accessible Apple media integration with proper loading states and error handling
 */
interface Props {
  /** Apple Music or Podcasts URL */
  url: string;
  /** Type of Apple content */
  type?: 'song' | 'album' | 'playlist' | 'podcast' | 'episode' | 'auto';
  /** Visual theme variant */
  variant?: 'default' | 'minimal' | 'card';
  /** Show loading state */
  showLoading?: boolean;
  /** Accessible title for screen readers */
  title?: string;
  /** CSS class for styling */
  class?: string;
  /** Allow fullscreen playback */
  allowFullscreen?: boolean;
  /** ARIA label for accessibility */
  ariaLabel?: string;
  /** Additional iframe attributes */
  [key: string]: any;
}

const {
  url,
  type = 'auto',
  showLoading = true,
  autoHeight = true,
  title,
  class: className = '',
  allowFullscreen = true,
  ariaLabel,
  ...props
} = Astro.props;

const variantOptions = ['default', 'minimal', 'card'] as const;
type Variant = (typeof variantOptions)[number];
const variantKey = variantOptions.includes(
  (props.variant as Variant) || 'default'
)
  ? (props.variant as Variant)
  : 'default';

// Build Apple Music/Podcasts embed URL
const buildAppleEmbedUrl = (): string => {
  try {
    const target = new URL(url);

    // If already an embed URL, return as-is
    if (target.hostname.startsWith('embed.')) {
      return target.toString();
    }

    // Convert Apple Music URLs to embed format
    if (target.hostname.endsWith('music.apple.com')) {
      target.hostname = 'embed.music.apple.com';
      return target.toString();
    }

    // Convert Apple Podcasts URLs to embed format
    if (target.hostname.endsWith('podcasts.apple.com')) {
      target.hostname = 'embed.podcasts.apple.com';
      return target.toString();
    }

    // Return original URL if not a recognized Apple domain
    return target.toString();
  } catch (error) {
    console.warn('Failed to parse Apple URL:', error);
    return url;
  }
};

// Determine content type and appropriate aspect ratio
const getAppleContentType = (): string => {
  if (type !== 'auto') return type;

  try {
    const target = new URL(url);

    // Check for podcasts domain
    if (target.hostname.includes('podcasts.apple.com')) {
      return target.pathname.includes('/episode/') ? 'episode' : 'podcast';
    }

    // Check for music domain patterns
    if (target.hostname.includes('music.apple.com')) {
      const path = target.pathname;
      const hasTrackParam = target.searchParams.has('i');

      if (
        path.includes('/song/') ||
        path.includes('/track/') ||
        hasTrackParam
      ) {
        return 'song';
      }
      if (path.includes('/album/')) {
        return 'album';
      }
      if (path.includes('/playlist/')) {
        return 'playlist';
      }
    }

    return 'album'; // Default fallback
  } catch {
    return 'album';
  }
};

// Get aspect ratio based on content type
const getAppleAspectRatio = (): string => {
  const contentType = getAppleContentType();

  switch (contentType) {
    case 'song':
    case 'episode':
    case 'podcast':
      return '16/7'; // Compact player ~175px height
    case 'album':
    case 'playlist':
      return '16/9'; // Standard player ~450px height
    default:
      return '16/9';
  }
};

const embedUrl = buildAppleEmbedUrl();
const contentType = getAppleContentType();
const finalAspectRatio = getAppleAspectRatio();

// Generate appropriate title
const finalTitle =
  title || `Apple ${contentType === 'episode' ? 'Podcast' : 'Music'} Embed`;

// Generate ARIA label for screen readers
const finalAriaLabel =
  ariaLabel ||
  `Apple ${contentType === 'episode' ? 'podcast' : 'music'} player${title ? `: ${title}` : ''}`;

// Host detection for debugging / conditional logic
let embedHost = '';
try {
  embedHost = new URL(embedUrl).hostname;
} catch {
  embedHost = '';
}

// Compute padding-top for aspect ratio containers (height/width * 100%)
let paddingTop = '56.25%';
try {
  const parts = finalAspectRatio.split('/');
  if (parts.length === 2) {
    const w = parseFloat(parts[0]) || 16;
    const h = parseFloat(parts[1]) || 9;
    paddingTop = `${(h / w) * 100}%`;
  }
} catch {
  paddingTop = '56.25%';
}

const uid = `apple-embed-${Math.random().toString(36).slice(2, 8)}`;
const baseHeight =
  contentType === 'song' ||
  contentType === 'episode' ||
  contentType === 'podcast'
    ? 175
    : 450;
const rootClasses = [
  'apple-embed',
  `apple-embed--variant-${variantKey}`,
  showLoading ? 'apple-embed--loading' : '',
  className,
]
  .filter(Boolean)
  .join(' ');
---

<div
  id={uid}
  class={rootClasses}
  role="region"
  aria-label={finalAriaLabel}
  data-apple-embed-id={uid}
  data-apple-embed-loading={showLoading ? 'true' : 'false'}
  data-auto-height={autoHeight ? 'true' : 'false'}
  data-base-height={baseHeight}
>
  {
    autoHeight ? (
      <div
        class="apple-embed__viewport apple-embed__viewport--fixed"
        data-apple-height-wrapper
        style={`height: ${baseHeight}px;`}
      >
        {showLoading && (
          <div data-apple-embed-overlay class="apple-embed__overlay">
            <LoadingSpinner
              size="lg"
              variant="primary"
              label="Loading content"
              showLabel={true}
              className="apple-embed__spinner"
            />
          </div>
        )}

        <iframe
          id={`${uid}-frame`}
          src={embedUrl}
          title={finalTitle}
          class="apple-embed__iframe"
          loading={showLoading ? 'lazy' : 'eager'}
          allow={
            props.allow ??
            'autoplay; encrypted-media; fullscreen; clipboard-write'
          }
          referrerpolicy={
            props.referrerPolicy ?? 'strict-origin-when-cross-origin'
          }
          aria-label={finalAriaLabel}
          aria-describedby={props.description ? `apple-embed-desc` : undefined}
          data-embed-host={embedHost}
          allowfullscreen={allowFullscreen}
          {...props}
        />

        {props.description && (
          <div id="apple-embed-desc" class="apple-embed__sr-only">
            {props.description}
          </div>
        )}
      </div>
    ) : (
      <div
        class="apple-embed__viewport"
        data-apple-height-wrapper
        style={`padding-top: ${paddingTop};`}
      >
        {showLoading && (
          <div class="apple-embed__overlay" data-apple-embed-overlay>
            <LoadingSpinner
              size="lg"
              variant="primary"
              label="Loading content"
              showLabel={true}
              className="apple-embed__spinner"
            />
          </div>
        )}

        <iframe
          id={`${uid}-frame`}
          src={embedUrl}
          title={finalTitle}
          class="apple-embed__iframe"
          loading={showLoading ? 'lazy' : 'eager'}
          allow={
            props.allow ??
            'autoplay; encrypted-media; fullscreen; clipboard-write'
          }
          referrerpolicy={
            props.referrerPolicy ?? 'strict-origin-when-cross-origin'
          }
          aria-label={finalAriaLabel}
          aria-describedby={props.description ? `apple-embed-desc` : undefined}
          data-embed-host={embedHost}
          allowfullscreen={allowFullscreen}
          {...props}
        />

        {props.description && (
          <div id="apple-embed-desc" class="apple-embed__sr-only">
            {props.description}
          </div>
        )}
      </div>
    )
  }

  <script type="module" is:inline>
    const initAppleEmbed = (container) => {
      if (!(container instanceof HTMLElement)) return;
      if (container.dataset.embedReady === 'true') return;
      const iframe = container.querySelector('.apple-embed__iframe');
      if (!(iframe instanceof HTMLIFrameElement)) return;
      const overlay = container.querySelector('[data-apple-embed-overlay]');
      const viewport = container.querySelector('[data-apple-height-wrapper]');
      const autoHeight = container.dataset.autoHeight === 'true';

      const hideOverlay = () => {
        overlay?.classList.add('apple-embed__overlay--hidden');
        container.classList.remove('apple-embed--loading');
        container.dataset.appleEmbedLoading = 'false';
      };

      const setHeight = (value) => {
        if (!autoHeight || !viewport || typeof value !== 'number') return;
        viewport.style.height = `${value}px`;
      };

      const handleLoad = () => {
        if (autoHeight) {
          try {
            const doc =
              iframe.contentDocument || iframe.contentWindow?.document;
            const h =
              doc?.documentElement?.scrollHeight || doc?.body?.scrollHeight;
            if (h) setHeight(h);
          } catch {
            /* cross-origin */
          }
        }
        hideOverlay();
      };

      iframe.addEventListener('load', handleLoad);

      const onMessage = (event) => {
        if (event.source !== iframe.contentWindow) return;
        const data = event.data || {};
        if (typeof data.height === 'number') setHeight(data.height);
        if (data.type === 'embed-ready') hideOverlay();
      };

      window.addEventListener('message', onMessage);
      const fallback = window.setTimeout(hideOverlay, 12000);

      const observer = new MutationObserver(() => {
        if (!document.body.contains(container)) {
          iframe.removeEventListener('load', handleLoad);
          window.removeEventListener('message', onMessage);
          window.clearTimeout(fallback);
          observer.disconnect();
        }
      });
      observer.observe(document.body, { childList: true, subtree: true });
      container.dataset.embedReady = 'true';
    };

    const hydrateEmbeds = () => {
      document
        .querySelectorAll('.apple-embed')
        .forEach((container) => initAppleEmbed(container));
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', hydrateEmbeds, {
        once: true,
      });
    } else {
      hydrateEmbeds();
    }

    document.addEventListener('astro:page-load', hydrateEmbeds);
  </script>
</div>

<style is:inline>
  .apple-embed {
    --apple-embed-bg: #0f172a;
    --apple-embed-border: #1e293b;
    --apple-embed-overlay: rgba(2, 6, 23, 0.7);
    --apple-embed-spinner: #e5e7eb;
    border-radius: 1.25rem;
    background: var(--apple-embed-bg);
    padding: clamp(0.5rem, 2vw, 1rem);
    box-shadow: 0 18px 35px rgba(15, 23, 42, 0.2);
    transition: box-shadow 0.2s ease;
  }

  .apple-embed--loading {
    box-shadow: 0 12px 25px rgba(15, 23, 42, 0.25);
  }

  .apple-embed__viewport {
    position: relative;
    width: 100%;
    border-radius: 1rem;
    overflow: hidden;
    border: 1px solid var(--apple-embed-border);
    background: #000;
  }

  .apple-embed__viewport--fixed {
    height: 100%;
  }

  .apple-embed__iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    background: transparent;
  }

  .apple-embed__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--apple-embed-overlay);
    transition: opacity 0.2s ease;
  }

  .apple-embed__overlay--hidden {
    opacity: 0;
    pointer-events: none;
  }

  .apple-embed__spinner {
    color: var(--apple-embed-spinner);
  }

  .apple-embed__sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .apple-embed--variant-minimal {
    --apple-embed-bg: transparent;
    --apple-embed-border: rgba(148, 163, 184, 0.3);
    box-shadow: none;
    padding: 0;
  }

  .apple-embed--variant-card {
    --apple-embed-bg: #ffffff;
    --apple-embed-border: #e2e8f0;
    --apple-embed-overlay: rgba(255, 255, 255, 0.8);
    --apple-embed-spinner: #0f172a;
  }

  :where(.dark) .apple-embed--variant-card {
    --apple-embed-bg: #111827;
    --apple-embed-border: #1f2937;
    --apple-embed-overlay: rgba(15, 23, 42, 0.75);
    --apple-embed-spinner: #f8fafc;
  }
</style>
