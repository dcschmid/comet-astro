---
/**
 * WeatherForecast – Minimal daily forecast snapshot (WCAG AAA)
 * Astro-only, BEM-based CSS, no overengineering.
 * Metrics (per day): Day label (Today/Tomorrow/Weekday), icon, condition text, high/low temp, precip %.
 * Optional live fetch via Open‑Meteo daily forecast.
 */
interface Props {
  latitude?: number;
  longitude?: number;
  location?: string;
  days?: number; // number of days to show (1-7)
  disableFetch?: boolean;
  refreshInterval?: number; // minutes; 0 = no auto refresh
  ariaLabel?: string;
  class?: string;
}

const props = Astro.props as Props;
const {
  latitude,
  longitude,
  location = 'Demo Location',
  days = 5,
  disableFetch = false,
  refreshInterval = 0,
  ariaLabel,
  class: className = '',
} = props;

const label = ariaLabel || `Daily forecast for ${location}`;
const baseClasses = ['weather-forecast', className].filter(Boolean).join(' ');

// Fallback demo data (simple predictable sequence)
const fallback = Array.from({ length: days }, (_, i) => ({
  code: [0, 1, 2, 61, 3, 95, 71][i % 7],
  tmax: 18 + i,
  tmin: 9 + i,
  precip: [10, 20, 40, 70, 15, 5, 30][i % 7],
}));

function mapWeather(code: number) {
  if ([0].includes(code))
    return ['Clear', '☀️', 'clear'];
  if ([1, 2, 3].includes(code)) return ['Partly Cloudy', '⛅', 'cloud'];
  if ([45, 48].includes(code)) return ['Fog', '🌫️', 'fog'];
  if ([51, 53, 55].includes(code)) return ['Drizzle', '🌦️', 'drizzle'];
  if ([61, 63, 65, 80, 81, 82].includes(code))
    return ['Rain', '🌧️', 'rain'];
  if ([66, 67].includes(code)) return ['Freezing Rain', '🧊', 'ice'];
  if ([71, 73, 75, 77, 85, 86].includes(code)) return ['Snow', '❄️', 'snow'];
  if ([95, 96, 99].includes(code)) return ['Storm', '⛈️', 'storm'];
  return ['Unknown', '❓', 'unknown'];
}

const initialMapped = fallback.map((d) => mapWeather(d.code));
---

<div
  class={baseClasses}
  role="region"
  aria-label={label}
  aria-busy={!disableFetch && latitude != null && longitude != null
    ? 'true'
    : 'false'}
  data-forecast
  data-lat={latitude}
  data-lon={longitude}
  data-disable-fetch={disableFetch}
  data-refresh={refreshInterval}
  data-days={days}
  data-state={!disableFetch && latitude != null && longitude != null
    ? 'loading'
    : 'static'}
>
  <header class="weather-forecast__header">
    <h2 class="weather-forecast__title">
      <span aria-hidden="true">📅</span>
      <span class="weather-forecast__location" data-location>{location}</span>
    </h2>
    <p class="weather-forecast__status" aria-live="polite" data-status>
      {
        !disableFetch && latitude != null && longitude != null
          ? 'Lade Vorhersage …'
          : 'Statische Demodaten'
      }
    </p>
  </header>
  <div class="weather-forecast__grid" data-days-wrapper>
    {
      fallback.map((d, i) => (
        <div
          class="weather-forecast__card"
          data-day-card
          data-idx={i}
          aria-label={`Forecast day ${i + 1}`}
        >
          <div class="weather-forecast__card-top">
            <div class="weather-forecast__day" data-day-label>
              <span
                class={`weather-forecast__dot weather-forecast__dot--${initialMapped[i][2]}`}
                aria-hidden="true"
                data-day-dot
              />
              <span class="weather-forecast__day-name" data-day-name>
                {i === 0
                  ? 'Today'
                  : i === 1
                    ? 'Tomorrow'
                    : new Date(
                        Date.now() + i * 24 * 3600 * 1000
                      ).toLocaleDateString([], { weekday: 'short' })}
              </span>
            </div>
            <span class="weather-forecast__icon" data-day-icon>
              {initialMapped[i][1]}
            </span>
          </div>
          <div class="weather-forecast__condition" data-day-cond>
            {initialMapped[i][0]}
          </div>
          <div class="weather-forecast__metrics">
            <span class="weather-forecast__metric" data-day-temp-high>
              H: {Math.round(d.tmax)}°C
            </span>
            <span class="weather-forecast__metric" data-day-temp-low>
              L: {Math.round(d.tmin)}°C
            </span>
            <span
              class="weather-forecast__metric weather-forecast__metric--precip"
              data-day-precip
            >
              {Math.round(d.precip)}%
            </span>
          </div>
        </div>
      ))
    }
  </div>
  <p class="weather-forecast__disclaimer" data-disclaimer>
    {
      !disableFetch && latitude != null && longitude != null
        ? `Live Daten (Open‑Meteo Daily). ${refreshInterval > 0 ? `Auto Refresh alle ${refreshInterval}m.` : ''} Fallback bei Fehler.`
        : 'Demodaten. latitude+longitude setzen für Live-Aktualisierung.'
    } AAA Kontrast eingehalten.
  </p>
  <footer class="weather-forecast__footer">
    <span class="weather-forecast__source">
      Quelle:
      <span class="weather-forecast__source-link">Open‑Meteo</span>
    </span>
    <span class="weather-forecast__refresh" data-refresh-indicator>
      {
        refreshInterval > 0 ? `Auto ${refreshInterval}m` : 'Kein Auto-Refresh'
      }
    </span>
  </footer>
</div>

<script>
  function mapWeather(code) {
    if ([0].includes(code)) return ['Clear', '☀️', 'clear'];
    if ([1, 2, 3].includes(code)) return ['Partly Cloudy', '⛅', 'cloud'];
    if ([45, 48].includes(code)) return ['Fog', '🌫️', 'fog'];
    if ([51, 53, 55].includes(code)) return ['Drizzle', '🌦️', 'drizzle'];
    if ([61, 63, 65, 80, 81, 82].includes(code))
      return ['Rain', '🌧️', 'rain'];
    if ([66, 67].includes(code)) return ['Freezing Rain', '🧊', 'ice'];
    if ([71, 73, 75, 77, 85, 86].includes(code)) return ['Snow', '❄️', 'snow'];
    if ([95, 96, 99].includes(code)) return ['Storm', '⛈️', 'storm'];
    return ['Unknown', '❓', 'unknown'];
  }
  function initForecast(el) {
    const disableFetch = el.dataset.disableFetch === 'true';
    const lat = el.dataset.lat ? parseFloat(el.dataset.lat) : undefined;
    const lon = el.dataset.lon ? parseFloat(el.dataset.lon) : undefined;
    const refresh = parseInt(el.dataset.refresh || '0');
    const days = Math.min(parseInt(el.dataset.days || '5'), 7);
    const statusEl = el.querySelector('[data-status]');
    const cards = Array.from(el.querySelectorAll('[data-day-card]'));
    const setState = (s) => {
      el.dataset.state = s;
      el.setAttribute('aria-busy', s === 'loading' ? 'true' : 'false');
    };
    async function fetchData() {
      if (disableFetch || lat == null || lon == null) {
        if (statusEl) statusEl.textContent = 'Fallback Werte aktiv';
        return;
      }
      setState('loading');
      if (statusEl) statusEl.textContent = 'Lade Vorhersage …';
      try {
        const params = new URLSearchParams({
          latitude: String(lat),
          longitude: String(lon),
          daily:
            'temperature_2m_max,temperature_2m_min,precipitation_probability_max,weather_code',
          timezone: 'auto',
        });
        const url = `https://api.open-meteo.com/v1/forecast?${params.toString()}`;
        const res = await fetch(url);
        if (!res.ok) throw 0;
        const data = await res.json();
        const d = data.daily || {};
        for (let i = 0; i < days; i++) {
          const card = cards[i];
          if (!card) continue;
          const code = d.weather_code?.[i];
          const tmax = d.temperature_2m_max?.[i];
          const tmin = d.temperature_2m_min?.[i];
          const precip = d.precipitation_probability_max?.[i];
          if (code != null) {
            const [cond, icon, token] = mapWeather(code);
            const dot = card.querySelector('[data-day-dot]');
            if (dot)
              dot.className = `weather-forecast__dot weather-forecast__dot--${token}`;
            const iconEl = card.querySelector('[data-day-icon]');
            if (iconEl) iconEl.textContent = icon;
            const condEl = card.querySelector('[data-day-cond]');
            if (condEl) condEl.textContent = cond;
          }
          if (tmax != null) {
            const elT = card.querySelector('[data-day-temp-high]');
            if (elT) elT.textContent = `H: ${Math.round(tmax)}°C`;
          }
          if (tmin != null) {
            const elT = card.querySelector('[data-day-temp-low]');
            if (elT) elT.textContent = `L: ${Math.round(tmin)}°C`;
          }
          if (precip != null) {
            const pEl = card.querySelector('[data-day-precip]');
            if (pEl) pEl.textContent = `${Math.round(precip)}%`;
          }
          const nameEl = card.querySelector('[data-day-name]');
          if (nameEl) {
            if (i === 0) nameEl.textContent = 'Today';
            else if (i === 1) nameEl.textContent = 'Tomorrow';
            else
              nameEl.textContent = new Date(
                d.time?.[i] || Date.now() + i * 86400000
              ).toLocaleDateString([], { weekday: 'short' });
          }
        }
        if (statusEl) statusEl.textContent = 'Live Daten geladen';
        setState('ready');
      } catch {
        if (statusEl) statusEl.textContent = 'Live Fehler (Fallback gezeigt)';
        setState('error');
      }
    }
    fetchData();
    if (refresh > 0 && !disableFetch && lat != null && lon != null) {
      setInterval(fetchData, refresh * 60 * 1000);
      const ind = el.querySelector('[data-refresh-indicator]');
      if (ind) ind.textContent = `Auto ${refresh}m`;
    }
  }
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('[data-forecast]').forEach(initForecast);
  });
</script>

<style is:inline>
  .weather-forecast {
    --wf-bg: #ffffff;
    --wf-text: #0f172a;
    --wf-muted: #475569;
    --wf-border: #e5e7eb;
    --wf-card-bg: #f8fafc;
    --wf-card-border: #e2e8f0;
    --wf-accent: #1d4ed8;
    --wf-radius: 1rem;
    --wf-gap: 1rem;

    display: flex;
    flex-direction: column;
    gap: var(--wf-gap);
    padding: clamp(1rem, 3vw, 1.5rem);
    background-color: var(--wf-bg);
    color: var(--wf-text);
    border: 1px solid var(--wf-border);
    border-radius: 1.25rem;
    box-shadow: 0 12px 30px rgba(15, 23, 42, 0.08);
  }

  .weather-forecast__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .weather-forecast__title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0;
    font-size: clamp(1.2rem, 3vw, 1.35rem);
    font-weight: 700;
    color: var(--wf-text);
  }

  .weather-forecast__location {
    display: inline-block;
    max-width: 20rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .weather-forecast__status {
    margin: 0;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--wf-muted);
  }

  .weather-forecast__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(12rem, 1fr));
    gap: 0.9rem;
  }

  .weather-forecast__card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 0.85rem 0.95rem;
    border: 1px solid var(--wf-card-border);
    border-radius: var(--wf-radius);
    background-color: var(--wf-card-bg);
  }

  .weather-forecast__card-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .weather-forecast__day {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--wf-text);
  }

  .weather-forecast__dot {
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 999px;
    background-color: var(--wf-muted);
  }

  .weather-forecast__dot--clear {
    background-color: #f59e0b;
  }

  .weather-forecast__dot--cloud {
    background-color: #6b7280;
  }

  .weather-forecast__dot--fog {
    background-color: #4b5563;
  }

  .weather-forecast__dot--drizzle {
    background-color: #0891b2;
  }

  .weather-forecast__dot--rain {
    background-color: #2563eb;
  }

  .weather-forecast__dot--ice {
    background-color: #6366f1;
  }

  .weather-forecast__dot--snow {
    background-color: #0ea5e9;
  }

  .weather-forecast__dot--storm {
    background-color: #dc2626;
  }

  .weather-forecast__dot--unknown {
    background-color: #94a3b8;
  }

  .weather-forecast__icon {
    font-size: 1.25rem;
    line-height: 1;
  }

  .weather-forecast__condition {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--wf-muted);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .weather-forecast__metrics {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    align-items: center;
  }

  .weather-forecast__metric {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--wf-text);
  }

  .weather-forecast__metric--precip {
    color: var(--wf-muted);
    font-weight: 600;
  }

  .weather-forecast__disclaimer {
    margin: 0;
    font-size: 0.78rem;
    color: var(--wf-muted);
  }

  .weather-forecast__footer {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-top: 0.5rem;
    border-top: 1px solid var(--wf-border);
    font-size: 0.78rem;
    color: var(--wf-muted);
    flex-wrap: wrap;
  }

  .weather-forecast__source-link {
    text-decoration: underline;
    color: var(--wf-text);
    font-weight: 700;
  }

  .weather-forecast__refresh {
    margin-left: auto;
    font-weight: 700;
    color: var(--wf-text);
  }

  :where(.dark) .weather-forecast {
    --wf-bg: #0f172a;
    --wf-text: #e5e7eb;
    --wf-muted: #cbd5e1;
    --wf-border: #1f2937;
    --wf-card-bg: rgba(30, 41, 59, 0.75);
    --wf-card-border: #334155;
    --wf-accent: #60a5fa;
    box-shadow: 0 16px 36px rgba(0, 0, 0, 0.35);
  }

  :where(.dark) .weather-forecast__source-link {
    color: var(--wf-text);
  }

  [data-forecast][data-state='loading'] .weather-forecast__card {
    position: relative;
    overflow: hidden;
  }

  [data-forecast][data-state='loading'] .weather-forecast__card::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: var(--wf-radius);
    background: linear-gradient(
      90deg,
      rgba(148, 163, 184, 0.15),
      rgba(148, 163, 184, 0.35),
      rgba(148, 163, 184, 0.15)
    );
    animation: forecast-pulse 1.4s ease-in-out infinite;
    opacity: 0.4;
    pointer-events: none;
  }

  @keyframes forecast-pulse {
    0%,
    100% {
      opacity: 0.35;
    }
    50% {
      opacity: 0.7;
    }
  }

  @media (max-width: 48rem) {
    .weather-forecast__header {
      flex-direction: column;
      align-items: flex-start;
    }

    .weather-forecast__location {
      max-width: 100%;
      white-space: normal;
    }

    .weather-forecast__refresh {
      margin-left: 0;
    }
  }

  @media (prefers-contrast: more) {
    .weather-forecast {
      border-width: 2px;
    }

    .weather-forecast__card {
      border-width: 2px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .weather-forecast,
    .weather-forecast * {
      transition: none !important;
      animation: none !important;
    }
  }
</style>
