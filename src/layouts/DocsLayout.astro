---
import BaseLayout from './BaseLayout.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
// Headline removed — header now shows a back-link instead of the page title.
import Prose from '../components/Prose.astro';
import { Astro } from 'astro';
import Container from '../components/Container.astro';

interface Props {
  title: string;
  description?: string;
  /** Optional SEO overrides forwarded to BaseLayout */
  seoTitle?: string;
  seoDescription?: string;
  /** Wrap content slot in <Prose> component for consistent typography */
  prose?: boolean;
  /** Paragraph size for description */
  descriptionSize?: 'xs' | 'sm' | 'md' | 'lg' | 'xl' | '2xl';
  /** Hide the default header (breadcrumbs, title, description) so a page can fully customize a hero section */
  hideHeader?: boolean;
  /** Show breadcrumbs even if header is shown (ignored when hideHeader=true) */
  // breadcrumbs removed — header contains a back-link now
}

const {
  title,
  description,
  seoTitle,
  seoDescription,
  prose = true,
  hideHeader = false,
} = Astro.props as Props;

const resolvedSeoTitle = seoTitle ? seoTitle : `${title} – Comet Astro`;
const resolvedSeoDescription = seoDescription ? seoDescription : description;
const resolvedContainerSize = 'lg';
---

<BaseLayout
  seoTitle={resolvedSeoTitle}
  seoDescription={resolvedSeoDescription}
  containerSize="lg"
  title={title}
>
  <div slot="header">
    {
      !hideHeader && (
        <header class="docs-layout__header">
          <Container
            size={resolvedContainerSize}
            className="docs-layout__header-inner"
          >
            <div className="docs-layout__back">
              <a
                href="/"
                class="docs-layout__back-link"
              >
                <svg
                  class="docs-layout__back-icon"
                  xmlns="http://www.w3.org/2000/svg"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <>
                    <path d="M19 12H6" />
                    <path d="M12 19L5 12 12 5" />
                  </>
                </svg>
                <span class="docs-layout__back-text">Back</span>
              </a>
            </div>
            <div className="docs-layout__toggle">
              <ThemeToggle />
            </div>
          </Container>
        </header>
      )
    }
  </div>
  <div slot="main">
    <div class="docs-layout">
      {
        prose ? (
          <Prose
            variant="default"
            size="md"
            maxWidth="lg"
            class="docs-layout__showcase"
          >
            <slot name="showcase" />
          </Prose>
        ) : (
          <div class="docs-layout__showcase">
            <slot name="showcase" />
          </div>
        )
      }
      {
        prose ? (
          <Prose
            variant="article"
            size="lg"
            maxWidth="xl"
            readingMode={true}
            class="docs-layout__content"
          >
            <slot />
          </Prose>
        ) : (
          <div class="docs-layout__content">
            <slot />
          </div>
        )
      }
    </div>
  </div>
</BaseLayout>

<style is:inline>
  .docs-layout {
    display: flex;
    flex-direction: column;
    gap: clamp(1.5rem, 3vw, 2rem);
    padding-bottom: 2rem;
  }

  .docs-layout__header {
    margin-bottom: 1.5rem;
  }

  .docs-layout__header-inner {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
    justify-content: space-between;
  }

  @media (min-width: 48rem) {
    .docs-layout__header-inner {
      flex-direction: row;
      gap: 1.5rem;
    }
  }

  .docs-layout__back {
    min-width: 0;
    text-align: center;
  }

  @media (min-width: 48rem) {
    .docs-layout__back {
      text-align: left;
    }
  }

  .docs-layout__back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.35rem 0.65rem;
    border-radius: 999px;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--bl-text, #0f172a);
    text-decoration: none;
    transition:
      background-color 0.2s ease,
      color 0.2s ease;
  }

  .docs-layout__back-link:hover {
    background-color: rgba(37, 99, 235, 0.12);
    color: #1d4ed8;
  }

  .docs-layout__back-icon {
    color: inherit;
  }

  .docs-layout__toggle {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .docs-layout__showcase {
    margin-bottom: 1.25rem;
  }

  .docs-layout__content {
    margin: 0;
  }

  :where(.dark) .docs-layout__back-link:hover {
    background-color: rgba(96, 165, 250, 0.18);
    color: #93c5fd;
  }

  @media (prefers-reduced-motion: reduce) {
    .docs-layout__back-link {
      transition: none !important;
    }
  }
</style>
